п»ҝ@using KLTN_Registration_System.Models.Entities
@model List<Registration>

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "QuГЎВәВЈn lГғВҪ Г„вҖҳГ„Ж’ng kГғВҪ Г„вҖҳГЎВ»ВҒ tГғВ i";

    var registrations = Model ?? new List<Registration>();
    var activePeriodName = ViewBag.ActivePeriodName as string ?? "Г„ВҗГЎВ»ВЈt hiГЎВ»вҖЎn tГЎВәВЎi";
    int pendingCount = ViewBag.PendingCount ?? registrations.Count(r => r.Status == "Pending");
    int approvedCount = ViewBag.ApprovedCount ?? registrations.Count(r => r.Status == "Approved");
    int rejectedCount = ViewBag.RejectedCount ?? registrations.Count(r => r.Status == "Rejected");
    int topicCount = ViewBag.TopicCount ?? registrations.Select(r => r.TopicId).Distinct().Count();
}

@section Styles {
    <link rel="stylesheet" href="~/css/topic/manage.css" asp-append-version="true" />
}

<div class="manage-shell">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <div class="page-kicker">@activePeriodName</div>
            <h1 class="page-title">QuГЎВәВЈn lГғВҪ Г„вҖҳГ„Ж’ng kГғВҪ Г„вҖҳГЎВ»ВҒ tГғВ i</h1>
            <p class="page-subtitle">Theo dГғВөi vГғВ  xГЎВ»Вӯ lГғВҪ sinh viГғВӘn Г„вҖҳГ„Ж’ng kГғВҪ vГғВ o cГғВЎc Г„вҖҳГЎВ»ВҒ tГғВ i bГЎВәВЎn phГЎВ»ВҘ trГғВЎch trong Г„вҖҳГЎВ»ВЈt hiГЎВ»вҖЎn tГЎВәВЎi.</p>
        </div>
        <a asp-controller="@(User.IsInRole("Admin") ? "Admin" : "Lecturer")"
           asp-action="Approval"
           class="action-btn action-approve action-main-approval">
            <i class="fa-regular fa-square-check"></i>
            Trang duyГЎВ»вҖЎt chГғВӯnh
        </a>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-label">TГЎВ»вҖўng Г„вҖҳГ„Ж’ng kГғВҪ</div>
            <div class="stat-value">@registrations.Count</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">ChГЎВ»Вқ duyГЎВ»вҖЎt</div>
            <div class="stat-value">@pendingCount</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Г„ВҗГғВЈ duyГЎВ»вҖЎt</div>
            <div class="stat-value">@approvedCount</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Г„ВҗГЎВ»ВҒ tГғВ i cГғВі Г„вҖҳГ„Ж’ng kГғВҪ</div>
            <div class="stat-value">@topicCount</div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="manage-alert success">
            <i class="fa-solid fa-circle-check"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="manage-alert error">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    <div class="registration-panel">
        <div class="panel-head">
            <h3>Danh sГғВЎch sinh viГғВӘn Г„вҖҳГ„Ж’ng kГғВҪ</h3>
            <span>@registrations.Count mГЎВ»ВҘc - @rejectedCount Г„вҖҳГғВЈ tГЎВ»В« chГЎВ»вҖҳi</span>
        </div>

        @if (!registrations.Any())
        {
            <div class="empty-state">
                <i class="fa-regular fa-folder-open"></i>
                <strong>ChГҶВ°a cГғВі sinh viГғВӘn Г„вҖҳГ„Ж’ng kГғВҪ</strong>
                <span>Khi sinh viГғВӘn gГЎВ»Вӯi Г„вҖҳГ„Ж’ng kГғВҪ vГғВ o Г„вҖҳГЎВ»ВҒ tГғВ i cГЎВ»В§a bГЎВәВЎn, danh sГғВЎch sГЎВәВҪ hiГЎВ»Ж’n thГЎВ»вҖ№ tГЎВәВЎi Г„вҖҳГғВўy.</span>
            </div>
        }
        else
        {
            <div class="registration-list">
                @foreach (var item in registrations)
                {
                    var statusClass = item.Status switch
                    {
                        "Pending" => "status-pending",
                        "Approved" => "status-approved",
                        "Rejected" => "status-rejected",
                        _ => "status-other"
                    };

                    var statusText = item.Status switch
                    {
                        "Pending" => "ChГЎВ»Вқ duyГЎВ»вҖЎt",
                        "Approved" => "Г„ВҗГғВЈ duyГЎВ»вҖЎt",
                        "Rejected" => "TГЎВ»В« chГЎВ»вҖҳi",
                        _ => item.Status
                    };

                    <div class="registration-row">
                        <div>
                            <h4 class="topic-title">@(item.Topic?.Title ?? "KhГғВҙng rГғВө Г„вҖҳГЎВ»ВҒ tГғВ i")</h4>
                            <div class="topic-meta">
                                <span><i class="fa-regular fa-calendar me-1"></i>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                @if (!string.IsNullOrWhiteSpace(item.Topic?.TopicCode))
                                {
                                    <span><i class="fa-solid fa-hashtag me-1"></i>@item.Topic.TopicCode</span>
                                }
                                @if (item.Topic != null)
                                {
                                    <span><i class="fa-solid fa-users me-1"></i>@item.Topic.CurrentStudents/@item.Topic.MaxStudents SV</span>
                                }
                            </div>
                        </div>

                        <div>
                            <div class="student-name">@(item.Student?.FullName ?? item.Student?.UserName ?? "KhГғВҙng rГғВө sinh viГғВӘn")</div>
                            <div class="student-meta">
                                <span>@(item.Student?.UserCode ?? "ChГҶВ°a cГғВі MSSV")</span>
                                <span>@(item.Student?.Email ?? "")</span>
                            </div>
                        </div>

                        <div>
                            <span class="status-pill @statusClass">@statusText</span>
                        </div>

                        <div class="action-stack">
                            @if (item.Status == "Pending")
                            {
                                <form asp-action="Approve" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnTo" value="Manage" />
                                    <button type="submit" class="action-btn action-approve">
                                        <i class="fa-solid fa-check"></i>
                                        DuyГЎВ»вҖЎt
                                    </button>
                                </form>

                                <button type="button" class="action-btn action-reject" data-toggle-reject="@item.Id">
                                    <i class="fa-solid fa-xmark"></i>
                                    TГЎВ»В« chГЎВ»вҖҳi
                                </button>

                                <form asp-action="Reject" asp-route-id="@item.Id" method="post" class="reject-box" id="reject-@item.Id">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnTo" value="Manage" />
                                    <textarea name="feedback" placeholder="NhГЎВәВӯp lГғВҪ do tГЎВ»В« chГЎВ»вҖҳi Г„вҖҳГЎВ»Ж’ sinh viГғВӘn biГЎВәВҝt cГЎВәВ§n chГЎВ»вҖ°nh gГғВ¬..."></textarea>
                                    <button type="submit" class="action-btn action-reject">
                                        GГЎВ»Вӯi tГЎВ»В« chГЎВ»вҖҳi
                                    </button>
                                </form>
                            }
                            else if (!string.IsNullOrWhiteSpace(item.Feedback))
                            {
                                <span class="text-muted small">LГғВҪ do: @item.Feedback</span>
                            }
                            else
                            {
                                <span class="text-muted small">KhГғВҙng cГғВІn thao tГғВЎc</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/topic/manage.js" asp-append-version="true"></script>
}

