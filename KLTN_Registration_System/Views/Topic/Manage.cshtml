@using KLTN_Registration_System.Models.Entities
@model List<Registration>

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Danh sách sinh viên đăng ký";
}

<h2>Danh sách sinh viên đăng ký</h2>

@if (TempData["Success"] != null)
{
    <div style="color:green">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div style="color:red">@TempData["Error"]</div>
}

<table border="1" cellpadding="10">
    <tr>
        <th>Đề tài</th>
        <th>Sinh viên</th>
        <th>Trạng thái</th>
        <th>Hành động</th>
    </tr>

    @foreach (var item in Model ?? new List<Registration>())
    {
        <tr>
            <td>@(item.Topic?.Title ?? "N/A")</td>
            <td>@(item.Student?.UserName ?? item.Student?.Email ?? "N/A")</td>
            <td>@item.Status</td>
            <td>
                @if (item.Status == "Pending")
                {
                    <form asp-action="Approve" asp-route-id="@item.Id" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit">Duyệt</button>
                    </form>
                    <form asp-action="Reject" asp-route-id="@item.Id" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit">Từ chối</button>
                    </form>
                }
            </td>
        </tr>
    }
</table>
