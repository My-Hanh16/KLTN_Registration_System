@using X.PagedList.Mvc.Core;
@using X.PagedList;
@using KLTN_Registration_System.Models.Entities
@model IPagedList<Topic>

@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Danh sách đề tài KLTN";
    var fullTopicIds = ViewBag.FullTopicIds as List<int> ?? new List<int>();
    bool canParticipate = ViewBag.CanParticipateInCurrentPeriod != false;
    bool hasCompletedThesis = ViewBag.StudentHasCompletedThesis == true;
    bool hasRegistered = ViewBag.HasRegistered == true;
    bool hasPendingProposal = ViewBag.HasPendingProposal == true;
    int registeredTopicId = ViewBag.RegisteredTopicId is int topicId ? topicId : 0;
    string participationMessage = ViewBag.StudentParticipationMessage as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/topic/index.css" asp-append-version="true" />
}

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="topic-page-title">
            Danh sách đề tài KLTN
        </h2>
        <div class="d-flex align-items-center gap-2">
            <span class="topic-total-count">@ViewBag.TotalAvailable</span>
            <span class="topic-total-label">đề tài đang khả dụng cho học kỳ này</span>
        </div>
    </div>
</div>

<!-- ALERTS -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm mb-3 topic-page-alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm mb-3 topic-page-alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
    </div>
}

@if (User.IsInRole("Student") && (!canParticipate || hasRegistered || hasPendingProposal))
{
    <div class="topic-guard-alert">
        <i class="fa-solid fa-circle-info"></i>
        <div>
            @if (!canParticipate)
            {
                <strong>@(hasCompletedThesis ? "Bạn đã hoàn thành khóa luận" : "Bạn chưa thể đăng ký trong đợt này")</strong>
                <span>@(!string.IsNullOrWhiteSpace(participationMessage) ? participationMessage : "Vui lòng liên hệ quản trị viên nếu thông tin đủ điều kiện của bạn chưa chính xác.")</span>
            }
            else if (hasRegistered)
            {
                <strong>Bạn đã có đăng ký đề tài trong đợt hiện tại</strong>
                <span>
                    Mỗi sinh viên chỉ được có một đề tài đang chờ duyệt hoặc đã duyệt.
                    <a asp-controller="Student" asp-action="MyRegistration">Xem đăng ký của tôi</a>
                    @if (registeredTopicId > 0)
                    {
                        <text> hoặc </text><a asp-action="Details" asp-route-id="@registeredTopicId">xem chi tiết đề tài</a>
                    }
                    .
                </span>
            }
            else if (hasPendingProposal)
            {
                <strong>Bạn đang có đề xuất đề tài chờ xử lý</strong>
                <span>Hãy chờ giảng viên/admin xử lý hoặc hủy đề xuất trước khi đăng ký đề tài từ danh sách chung. <a asp-controller="Student" asp-action="MyRegistration">Theo dõi tại Đăng ký của tôi</a>.</span>
            }
        </div>
    </div>
}

<!-- FILTER BAR -->
<form asp-action="Index" method="get" id="filterForm">

    <div class="filter-bar mb-4">

        <div class="filter-row">

            <!-- LEFT -->
            <div class="filter-left">

                <!-- Bộ môn -->
                <select name="majorId"
                        class="form-select"
                        onchange="this.form.submit()">

                    <option value="">BỘ MÔN: Tất cả</option>

                    @if (ViewBag.Majors != null)
                    {
                        @foreach (var m in (IEnumerable<KLTN_Registration_System.Models.Entities.Major>)ViewBag.Majors)
                        {
                            <option value="@m.Id"
                                    selected="@(Context.Request.Query["majorId"] == m.Id.ToString())">
                                @m.Name
                            </option>
                        }
                    }
                </select>

                <!-- Trạng thái -->
                <select name="status"
                        class="form-select"
                        onchange="this.form.submit()">

                    <option value="">TRẠNG THÁI: Tất cả</option>

                    <option value="available"
                            selected="@(Context.Request.Query["status"] == "available")">
                        Còn chỗ
                    </option>

                    <option value="full"
                            selected="@(Context.Request.Query["status"] == "full")">
                        Đã đầy
                    </option>

                </select>

                <!-- Level -->
                <!-- FILTER TAG -->
<div class="level-filter">

    <span class="filter-label">LOẠI:</span>

    <!-- LEVEL -->
    <input type="hidden"
           name="level"
           id="levelInput"
           value="@Context.Request.Query["level"]" />

    <button type="button"
            data-level-filter="Easy"
            class="filter-level-btn @(Context.Request.Query["level"] == "Easy" ? "active" : "")">
        Cơ bản
    </button>

    <button type="button"
            data-level-filter="Medium"
            class="filter-level-btn @(Context.Request.Query["level"] == "Medium" ? "active" : "")">
        Trung bình
    </button>

    <button type="button"
            data-level-filter="Hard"
            class="filter-level-btn @(Context.Request.Query["level"] == "Hard" ? "active" : "")">
        Nâng cao
    </button>

    <!-- TYPE -->
    <input type="hidden"
           name="type"
           id="typeInput"
           value="@Context.Request.Query["type"]" />

    <button type="button"
            data-type-filter="individual"
            class="filter-level-btn @(Context.Request.Query["type"] == "individual" ? "active" : "")">
        Cá nhân
    </button>

    <button type="button"
            data-type-filter="group"
            class="filter-level-btn @(Context.Request.Query["type"] == "group" ? "active" : "")">
        Đồ án nhóm
    </button>

</div>

            </div>

            <!-- RIGHT -->
            <a asp-action="Index" class="btn-clear-filter">
                <i class="fa-solid fa-filter-circle-xmark"></i>
                Xoá bộ lọc
            </a>

        </div>

    </div>

</form>

<!-- TOPIC LIST -->
<div class="topic-container">
    @if (!Model.Any())
    {
        <div class="topic-empty-state">
            <i class="fa-regular fa-folder-open"></i>
            <div>
                <h5>Không tìm thấy đề tài phù hợp</h5>
                <p>@(!canParticipate && !string.IsNullOrWhiteSpace(participationMessage)
                    ? participationMessage
                    : "Hãy kiểm tra lại bộ lọc hoặc liên hệ quản trị viên nếu khoa/chuyên ngành của bạn chưa được gán đúng.")</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            var current = item.Registrations?.Count(r => r.Status == "Approved") ?? 0;
            var pending = item.Registrations?.Count(r => r.Status == "Pending") ?? 0;
            var reserved = current + pending;
            var remainingSlots = Math.Max(0, item.MaxStudents - reserved);
            var isFull = fullTopicIds.Contains(item.Id) || reserved >= item.MaxStudents;
            var isNotOpen = !item.IsRegistrationOpen;
            var isExpired = DateTime.Now > item.Deadline;
            var isClosed = isExpired;
            var isGroupTopic = item.MaxStudents > 1;
            var hasEnoughSlotsForGroup = !isGroupTopic || remainingSlots >= 2;

            string levelText = "Cơ bản";
            string levelColorClass = "tag-basic";

            if (item.Level.ToString() == "Hard") {
                levelText = "Nâng cao";
                levelColorClass = "tag-advanced";
            }
            else if (item.Level.ToString() == "Medium") {
                levelText = "Trung bình";
                levelColorClass = "tag-medium";
            }

            <div class="topic-item @(isFull || isExpired ? "topic-full" : "")">
            <div class="topic-info">

                <!-- Hàng badge / bộ môn -->
                <div class="topic-meta-top">
                    <span class="label-department">
                        ● @(string.IsNullOrEmpty(item.DepartmentName) ? item.Major?.Name?.ToUpper() : item.DepartmentName.ToUpper())
                    </span>
                    <span class="badge-category @levelColorClass">@levelText.ToUpper()</span>
                    @if (isGroupTopic)
                    {
                        <span class="badge-type tag-group">Đồ án Nhóm</span>
                    }
                    else
                    {
                        <span class="badge-type tag-individual">Cá nhân</span>
                    }
                </div>

                <!-- Tiêu đề -->
                <h5>@item.Title</h5>

                <!-- Meta -->
                <div class="meta-data">
                    <div class="meta-item">
                        <i class="fa-solid fa-user-tie"></i>
                        <span>GVHD: <strong>@(!string.IsNullOrEmpty(item.Lecturer?.FullName) ? item.Lecturer.FullName : item.Lecturer?.Email)</strong></span>
                    </div>

                    <div class="meta-item">
                        <i class="fa-solid fa-users"></i>
                        @if (isFull)
                        {
                            <span class="text-full">Đã hết chỗ (<strong>@reserved/@item.MaxStudents</strong>)</span>
                        }
                        else
                        {
                            <span>Sĩ số: <strong>@current/@item.MaxStudents</strong></span>
                            @if (isNotOpen)
                            {
                                <span class="text-muted small ms-1">(Chưa mở đăng ký)</span>
                            }
                            @if (isGroupTopic)
                            {
                                <small class="text-muted ms-1">(Tối đa @item.MaxStudents)</small>
                            }
                            @if (isGroupTopic && !hasEnoughSlotsForGroup)
                            {
                                <span class="text-warning small ms-1">(không đủ chỗ cho nhóm mới)</span>
                            }
                            @if (pending > 0)
                            {
                                <span class="text-warning small ms-1">(@pending chờ duyệt)</span>
                            }
                        }
                    </div>
                </div>

            </div>

            <!-- Actions -->
            <div class="topic-actions">
                <a asp-action="Details" asp-route-id="@item.Id" class="link-detail">Xem chi tiết</a>

                @if (User.IsInRole("Student"))
                {
                    if (isFull)
                    {
                        <button class="btn-full" disabled title="Đề tài này đã đủ số lượng đăng ký/chờ duyệt">
                            <i class="fa-solid fa-lock me-1"></i> Đã đủ
                        </button>
                    }
                    else if (isClosed)
                    {
                        <button class="btn-full" disabled>Đã hết hạn</button>
                    }
                    else if (isNotOpen)
                    {
                        <button class="btn-full" disabled title="Admin chưa mở đăng ký cho đề tài này">
                            <i class="fa-solid fa-clock me-1"></i> Chưa mở
                        </button>
                    }
                    else if (ViewBag.HasRegistered == true)
                    {
                        <button class="btn-full" disabled title="Bạn đã có đăng ký trong đợt hiện tại">Đã đăng ký</button>
                    }
                    else if (hasPendingProposal)
                    {
                        <button class="btn-full" disabled title="Bạn đang có đề xuất đề tài chờ duyệt">
                            <i class="fa-solid fa-lightbulb me-1"></i> Đang đề xuất
                        </button>
                    }
                    else if (!canParticipate)
                    {
                        <button class="btn-full" disabled title="@participationMessage">
                            <i class="fa-solid fa-lock me-1"></i> @(hasCompletedThesis ? "Đã hoàn thành" : "Chưa đủ điều kiện")
                        </button>
                    }
                    else if (isGroupTopic && !hasEnoughSlotsForGroup)
                    {
                        <button class="btn-full" disabled title="Đề tài nhóm cần tối thiểu 2 sinh viên nhưng hiện chỉ còn @remainingSlots chỗ">
                            <i class="fa-solid fa-users-slash me-1"></i> Không đủ chỗ nhóm
                        </button>
                    }
                    else
                    {
                        if (isGroupTopic)
                        {
                            <button type="button"
                               class="btn-register btn-group-type js-open-group-register"
                               data-topic-id="@item.Id"
                               data-topic-title="@item.Title"
                               data-max-students="@item.MaxStudents"
                               data-current-members="@reserved"
                               data-remaining-slots="@remainingSlots">
                                <i class="fa-solid fa-users-plus"></i> Đăng ký nhóm
                            </button>
                        }
                        else
                        {
                            <form asp-action="Register" method="post" class="d-inline topic-register-form"
                                  data-topic-title="@item.Title">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="topicId" value="@item.Id" />
                                <button type="submit" class="btn-register">
                                    Đăng ký
                                </button>
                            </form>
                        }
                    }
                }
            </div>
        </div>
        }
    }
</div>

<!-- PAGINATION -->
@if (Model.PageCount > 1)
{
    <div class="d-flex justify-content-center mt-4">
        @Html.PagedListPager(Model, page => Url.Action("Index", new {
                page,
                majorId = Context.Request.Query["majorId"].ToString(),
                status = Context.Request.Query["status"].ToString(),
                level = Context.Request.Query["level"].ToString(),
                type = Context.Request.Query["type"].ToString(),
                search = Context.Request.Query["search"].ToString()
            }),
            new PagedListRenderOptions {
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" },
                UlElementClasses = new[] { "pagination shadow-sm" },
                MaximumPageNumbersToDisplay = 5,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always
            })
    </div>
}

<div id="groupRegisterModal" class="group-overlay" aria-hidden="true">
    <div class="group-modal" role="dialog" aria-modal="true" aria-labelledby="groupModalTitle">
        <div class="group-modal-head">
            <button type="button" class="group-modal-close js-close-group-modal" aria-label="Đóng">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="group-modal-badge">
                <i class="fa-solid fa-users"></i>
                Đồ án nhóm
            </div>
            <h3 id="groupModalTitle" class="group-modal-title">Đăng ký nhóm</h3>
            <p class="group-modal-sub">Nhập thông tin thành viên cùng thực hiện. Trưởng nhóm là tài khoản hiện tại.</p>
        </div>

        <form asp-action="SubmitGroupRegistration" method="post" id="groupRegisterForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="topicId" id="groupTopicId" />
            <input type="hidden" name="returnTo" value="Index" />

            <div class="group-modal-body">
                <div>
                    <div class="group-rule-title">Quy định nhóm</div>
                    <div class="group-rule-list">
                        <div class="group-rule">
                            <div class="group-rule-icon"><i class="fa-solid fa-user"></i></div>
                            <div>
                                <strong>Trưởng nhóm</strong>
                                <span>Chính là tài khoản bạn đang đăng nhập.</span>
                            </div>
                        </div>
                        <div class="group-rule">
                            <div class="group-rule-icon"><i class="fa-solid fa-users"></i></div>
                            <div>
                                <strong>Số lượng tối đa</strong>
                                <span id="groupRuleMax">Đề tài nhóm cần tối thiểu 2 sinh viên.</span>
                            </div>
                        </div>
                        <div class="group-rule">
                            <div class="group-rule-icon"><i class="fa-solid fa-chair"></i></div>
                            <div>
                                <strong>Chỗ còn lại</strong>
                                <span id="groupRuleSlots">Đang kiểm tra số chỗ còn lại.</span>
                            </div>
                        </div>
                    </div>
                    <div class="group-note">
                        <strong>Lưu ý:</strong> Sau khi gửi đăng ký, tất cả thành viên trong nhóm sẽ cùng nằm trong yêu cầu chờ giảng viên duyệt.
                    </div>
                </div>

                <div>
                    <div class="group-form-title">Thành viên nhóm</div>
                    <div class="group-leader-card">
                        <div class="group-avatar">SV</div>
                        <div>
                            <span>Trưởng nhóm</span>
                            <strong>@(User.Identity?.Name ?? "Bạn") (Hiện tại)</strong>
                        </div>
                        <i class="fa-solid fa-circle-check ms-auto text-success"></i>
                    </div>

                    <div id="groupMemberFields"></div>
                    <div id="groupClientError" class="group-client-error">
                        Đề tài nhóm bắt buộc phải nhập ít nhất 1 thành viên khác.
                    </div>

                    <div class="group-modal-actions">
                        <button type="button" class="group-btn cancel js-close-group-modal">Hủy bỏ</button>
                        <button type="submit" class="group-btn submit">
                            <i class="fa-solid fa-paper-plane me-1"></i>
                            Xác nhận đăng ký nhóm
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="registerConfirm" class="confirm-overlay" aria-hidden="true">
    <div class="confirm-box" role="dialog" aria-modal="true" aria-labelledby="registerConfirmTitle">
        <div class="confirm-head">
            <div class="confirm-icon">
                <i class="fa-solid fa-clipboard-check"></i>
            </div>
            <div>
                <h3 id="registerConfirmTitle" class="confirm-title">Xác nhận đăng ký đề tài</h3>
                <p class="confirm-message">Bạn có chắc muốn gửi yêu cầu đăng ký đề tài này không?</p>
                <div id="registerConfirmTopic" class="confirm-topic"></div>
            </div>
        </div>
        <div class="confirm-actions">
            <button type="button" class="confirm-btn cancel" id="cancelRegisterConfirm">Hủy</button>
            <button type="button" class="confirm-btn submit" id="submitRegisterConfirm">Xác nhận đăng ký</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/topic/index.js" asp-append-version="true"></script>
}

