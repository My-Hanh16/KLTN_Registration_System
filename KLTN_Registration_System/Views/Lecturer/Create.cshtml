@model KLTN_Registration_System.Models.Entities.Topic
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Tạo đề tài mới";
    bool noMajorAssigned = ViewBag.NoMajorAssigned == true;
    string activePeriodName = ViewBag.ActivePeriodName as string ?? Model.Semester ?? "";
}

<div class="max-w-4xl mx-auto">
    @* Breadcrumb *@
    <nav class="flex mb-6 text-sm font-medium text-slate-500">
        <a href="/Lecturer/ThesisManagement" class="hover:text-primary no-underline">Quản lý đề tài</a>
        <span class="mx-2">/</span>
        <span class="text-slate-900">Tạo mới</span>
    </nav>

    <div class="bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">
        <div class="bg-gradient-to-r from-primary to-blue-600 px-8 py-6 text-white">
            <h2 class="text-2xl font-bold font-headline">Thông tin đề tài mới</h2>
            <p class="opacity-80 text-sm">Điền đầy đủ các thông tin để sinh viên có thể tìm thấy và đăng ký.</p>
        </div>

        <form asp-action="CreateFromForm" method="post" class="p-8 space-y-6">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

            @if (TempData["Error"] != null)
            {
                <div class="p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm font-semibold">
                    @TempData["Error"]
                </div>
            }

            @if (noMajorAssigned)
            {
                <div class="p-4 rounded-xl bg-amber-50 border border-amber-200 text-amber-800 text-sm">
                    Bạn chưa được Admin phân công chuyên ngành nên chưa thể tạo đề tài.
                </div>
            }

            <div class="grid grid-cols-2 gap-6">
                @* Tên đề tài *@
                <div class="col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-2">Tên đề tài</label>
                    <input asp-for="Title" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" placeholder="Ví dụ: Hệ thống quản lý bãi xe thông minh..." required />
                    <span asp-validation-for="Title" class="text-red-500 text-xs mt-1"></span>
                </div>

                @* Chuyên ngành & Học kỳ *@
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Bộ môn / Chuyên ngành</label>
                    <select asp-for="MajorId" asp-items="ViewBag.MajorId" disabled="@noMajorAssigned" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-primary/20">
                        <option value="">-- Chọn chuyên ngành --</option>
                    </select>
                    <span asp-validation-for="MajorId" class="text-red-500 text-xs mt-1"></span>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Học kỳ hiện tại</label>
                    <input value="@activePeriodName" readonly class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-500 outline-none cursor-not-allowed" />
                    <p class="mt-1 text-xs text-slate-400">Đề tài sẽ được gắn tự động vào đợt đang mở.</p>
                </div>

                @* Số lượng sinh viên tối đa *@
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Số lượng SV tối đa</label>
                    <input asp-for="MaxStudents" type="number" min="1" max="3" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-primary/20" required />
                    <p class="mt-1 text-xs text-slate-400">Chọn 1 nếu là đề tài cá nhân, từ 2 trở lên nếu là đề tài nhóm.</p>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Mức độ</label>
                    <select asp-for="Level" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-primary/20">
                        <option value="Easy">Cơ bản</option>
                        <option value="Medium">Trung bình</option>
                        <option value="Hard">Nâng cao</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Phân loại</label>
                    <select asp-for="Category" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-primary/20">
                        <option value="">Tự động theo số lượng SV</option>
                        <option value="Cá nhân">Cá nhân</option>
                        <option value="Nhóm">Nhóm</option>
                        <option value="Ứng dụng">Ứng dụng</option>
                        <option value="Nghiên cứu">Nghiên cứu</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Hạn đăng ký</label>
                    <input asp-for="Deadline" type="datetime-local" value="@Model.Deadline.ToString("yyyy-MM-ddTHH:mm")" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-primary/20" />
                </div>

                @* Mô tả ngắn gọn *@
                <div class="col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-2">Mô tả đề tài</label>
                    <textarea asp-for="Description" rows="4" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-primary/20" placeholder="Yêu cầu kỹ thuật, mục tiêu đề tài..." required></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div class="col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-2">Ghi chú</label>
                    <textarea asp-for="Note" rows="2" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-primary/20" placeholder="Công nghệ nên biết, yêu cầu đầu vào, tài liệu tham khảo..."></textarea>
                </div>
            </div>

            <div class="pt-6 border-t border-slate-100 flex justify-end gap-4">
                <a href="/Lecturer/ThesisManagement" class="px-6 py-3 rounded-xl font-bold text-slate-600 hover:bg-slate-100 transition-all no-underline">Hủy bỏ</a>
                <button type="submit" disabled="@noMajorAssigned" class="bg-primary text-white px-8 py-3 rounded-xl font-bold hover:shadow-lg hover:scale-[1.02] active:scale-95 transition-all disabled:opacity-50 disabled:cursor-not-allowed">
                    Gửi Admin duyệt
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
