@model KLTN_Registration_System.Models.Entities.Topic
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Tạo đề tài mới";
    bool noMajorAssigned = ViewBag.NoMajorAssigned == true;
    string activePeriodName = ViewBag.ActivePeriodName as string ?? Model.Semester ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/lecturer/create.css" asp-append-version="true" />
}

<div class="lecturer-create-page">
    @* Breadcrumb *@
    <nav class="create-breadcrumb">
        <a href="/Lecturer/ThesisManagement">Quản lý đề tài</a>
        <span>/</span>
        <span>Tạo mới</span>
    </nav>

    <div class="create-card">
        <div class="create-card-header">
            <h2>Thông tin đề tài mới</h2>
            <p>Điền đầy đủ các thông tin để sinh viên có thể tìm thấy và đăng ký.</p>
        </div>

        <form asp-action="CreateFromForm" method="post" class="create-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            @if (TempData["Error"] != null)
            {
                <div class="create-alert create-alert-danger">
                    @TempData["Error"]
                </div>
            }

            @if (noMajorAssigned)
            {
                <div class="create-alert create-alert-warning">
                    Bạn chưa được Admin phân công chuyên ngành nên chưa thể tạo đề tài.
                </div>
            }

            <div class="create-grid">
                @* Tên đề tài *@
                <div class="form-group full-span">
                    <label>Tên đề tài</label>
                    <input asp-for="Title" class="form-control" placeholder="Ví dụ: Hệ thống quản lý bãi xe thông minh..." required />
                    <span asp-validation-for="Title" class="field-validation"></span>
                </div>

                @* Chuyên ngành & Học kỳ *@
                <div class="form-group">
                    <label>Bộ môn / Chuyên ngành</label>
                    <select asp-for="MajorId" asp-items="ViewBag.MajorId" disabled="@noMajorAssigned" class="form-control">
                        <option value="">-- Chọn chuyên ngành --</option>
                    </select>
                    <span asp-validation-for="MajorId" class="field-validation"></span>
                </div>
                <div class="form-group">
                    <label>Học kỳ hiện tại</label>
                    <input value="@activePeriodName" readonly class="form-control form-control-readonly" />
                    <p class="form-help">Đề tài sẽ được gắn tự động vào đợt đang mở.</p>
                </div>

                @* Số lượng sinh viên tối đa *@
                <div class="form-group">
                    <label>Số lượng SV tối đa</label>
                    <input asp-for="MaxStudents" type="number" min="1" max="3" class="form-control" required />
                    <p class="form-help">Chọn 1 nếu là đề tài cá nhân, từ 2 trở lên nếu là đề tài nhóm.</p>
                </div>

                <div class="form-group">
                    <label>Mức độ</label>
                    <select asp-for="Level" class="form-control">
                        <option value="Easy">Cơ bản</option>
                        <option value="Medium">Trung bình</option>
                        <option value="Hard">Nâng cao</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Phân loại</label>
                    <select asp-for="Category" class="form-control">
                        <option value="">Tự động theo số lượng SV</option>
                        <option value="Cá nhân">Cá nhân</option>
                        <option value="Nhóm">Nhóm</option>
                        <option value="Ứng dụng">Ứng dụng</option>
                        <option value="Nghiên cứu">Nghiên cứu</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Hạn đăng ký</label>
                    <input asp-for="Deadline" type="datetime-local" value="@Model.Deadline.ToString("yyyy-MM-ddTHH:mm")" class="form-control" />
                </div>

                @* Mô tả ngắn gọn *@
                <div class="form-group full-span">
                    <label>Mô tả đề tài</label>
                    <textarea asp-for="Description" rows="4" class="form-control" placeholder="Yêu cầu kỹ thuật, mục tiêu đề tài..." required></textarea>
                    <span asp-validation-for="Description" class="field-validation"></span>
                </div>

                <div class="form-group full-span">
                    <label>Ghi chú</label>
                    <textarea asp-for="Note" rows="2" class="form-control" placeholder="Công nghệ nên biết, yêu cầu đầu vào, tài liệu tham khảo..."></textarea>
                </div>
            </div>

            <div class="form-actions">
                <a href="/Lecturer/ThesisManagement" class="btn-cancel">Hủy bỏ</a>
                <button type="submit" disabled="@noMajorAssigned" class="btn-submit">
                    Gửi Admin duyệt
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
