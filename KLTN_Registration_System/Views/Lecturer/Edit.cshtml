@model KLTN_Registration_System.Models.Entities.Topic
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Sửa đề tài";
    string activePeriodName = ViewBag.ActivePeriodName as string ?? Model.Semester ?? "";
    int approvedCount = ViewBag.ApprovedCount ?? 0;
    int pendingCount = ViewBag.PendingCount ?? 0;
    int activeRegistrationCount = approvedCount + pendingCount;
    int minStudents = Math.Max(1, activeRegistrationCount);
}

@section Styles {
    <link rel="stylesheet" href="~/css/lecturer/edit.css" asp-append-version="true" />
}

<div class="lecturer-edit-page">

    <div class="edit-heading">
        <a asp-action="ThesisManagement" asp-controller="Lecturer"
           class="edit-back-btn">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
        </a>
        <div>
            <h1>Sửa đề tài</h1>
            <p>Chỉnh sửa thông tin - đề tài sẽ cần Admin duyệt lại</p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="edit-alert edit-alert-danger">
            <i class="fa-solid fa-triangle-exclamation"></i>
            @TempData["Error"]
        </div>
    }

    <div class="edit-card">
        <form asp-action="Edit" asp-controller="Lecturer" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="edit-stats-grid">
                <div class="edit-stat-card edit-stat-code">
                    <div class="edit-stat-label">Mã đề tài</div>
                    <div class="edit-stat-value edit-stat-code-value">@(Model.TopicCode ?? $"TOPIC-{Model.Id}")</div>
                </div>
                <div class="edit-stat-card edit-stat-approved">
                    <div class="edit-stat-label">Đã duyệt</div>
                    <div class="edit-stat-value">@approvedCount</div>
                </div>
                <div class="edit-stat-card edit-stat-pending">
                    <div class="edit-stat-label">Chờ duyệt</div>
                    <div class="edit-stat-value">@pendingCount</div>
                </div>
            </div>

            <div class="edit-form-grid">

                <div class="form-group">
                    <label asp-for="Title">
                        Tên đề tài <span>*</span>
                    </label>
                    <input asp-for="Title" required
                           class="form-control" />
                    <span asp-validation-for="Title" class="field-validation"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Description">
                        Mô tả đề tài <span>*</span>
                    </label>
                    <textarea asp-for="Description" rows="5" required
                              class="form-control"></textarea>
                    <span asp-validation-for="Description" class="field-validation"></span>
                </div>

                <div class="edit-two-cols">
                    <div class="form-group">
                        <label>Học kỳ hiện tại</label>
                        <input value="@activePeriodName" readonly
                               class="form-control form-control-readonly" />
                        <p class="form-help">Hệ thống tự gắn đề tài vào đợt đang mở, không sửa thủ công tại đây.</p>
                    </div>
                    <div class="form-group">
                        <label asp-for="MajorId">Chuyên ngành</label>
                        <select asp-for="MajorId" asp-items="ViewBag.MajorId"
                                class="form-control">
                            <option value="">-- Không chọn --</option>
                        </select>
                    </div>
                </div>

                <div class="edit-two-cols">
                    <div class="form-group">
                        <label asp-for="Level">Mức độ</label>
                        <select asp-for="Level"
                                class="form-control">
                            <option value="Easy">Cơ bản</option>
                            <option value="Medium">Trung bình</option>
                            <option value="Hard">Nâng cao</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label asp-for="MaxStudents">
                            Số sinh viên tối đa
                        </label>
                        <input asp-for="MaxStudents" type="number" min="@minStudents" max="5"
                               class="form-control" />
                        @if (activeRegistrationCount > 0)
                        {
                            <p class="form-help">Không thể nhỏ hơn @activeRegistrationCount sinh viên đang đăng ký/chờ duyệt.</p>
                        }
                    </div>
                </div>

                <div class="edit-two-cols">
                    <div class="form-group">
                        <label asp-for="Category">Phân loại</label>
                        <select asp-for="Category"
                                class="form-control">
                            <option value="Ứng dụng">Ứng dụng</option>
                            <option value="Nghiên cứu">Nghiên cứu</option>
                            <option value="Phân tích">Phân tích</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label asp-for="Deadline">
                            Hạn đăng ký
                        </label>
                        <input asp-for="Deadline" type="datetime-local"
                               value="@Model.Deadline.ToString("yyyy-MM-ddTHH:mm")"
                               class="form-control" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Note">Ghi chú</label>
                    <textarea asp-for="Note" rows="2"
                              class="form-control"
                              placeholder="Yêu cầu đặc biệt, công nghệ cần có..."></textarea>
                </div>

            </div>

            <div class="edit-actions">
                <button type="submit"
                        class="btn-save">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Lưu thay đổi
                </button>
                <a asp-action="ThesisManagement" asp-controller="Lecturer"
                   class="btn-cancel">
                    Hủy
                </a>
            </div>
        </form>
    </div>

    <div class="edit-alert edit-alert-warning edit-final-note">
        <i class="fa-solid fa-triangle-exclamation"></i>
        Sau khi sửa, đề tài sẽ chuyển về trạng thái <strong>Chờ duyệt</strong> và cần Admin phê duyệt lại trước khi sinh viên có thể đăng ký.
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
