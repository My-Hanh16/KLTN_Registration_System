@using KLTN_Registration_System.Controllers
@using KLTN_Registration_System.Models.Entities
@model IEnumerable<KLTN_Registration_System.Controllers.LecturerController.GroupedRegistration>
@{
    Layout = "_LayoutDashboard";
    string currentStatus = Context.Request.Query["status"].ToString();
    if (string.IsNullOrEmpty(currentStatus)) currentStatus = "Pending";
    var pendingProposals = ViewBag.PendingStudentProposals as List<Topic> ?? new List<Topic>();
    var lecturers = ViewBag.Lecturers as List<ApplicationUser> ?? new List<ApplicationUser>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/lecturer/approval.css" asp-append-version="true" />
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="page-title">Duyệt đăng ký đề tài</h2>
        <p class="page-sub">Xử lý các yêu cầu đăng ký thực hiện luận văn từ sinh viên.</p>
    </div>

    <div class="filter-tabs">
        <a href="?status=Pending"
           class="filter-tab @(currentStatus == "Pending" ? "active" : "")">
            Chờ duyệt
            @if ((int)(ViewBag.TotalPending ?? 0) > 0)
            {
                <span class="pending-count-badge">
                    @ViewBag.TotalPending
                </span>
            }
        </a>
        <a href="?status=Approved"
           class="filter-tab @(currentStatus == "Approved" ? "active" : "")">Đã duyệt</a>
        <a href="?status=Rejected"
           class="filter-tab @(currentStatus == "Rejected" ? "active" : "")">Đã từ chối</a>
    </div>
</div>

<!-- STATS CARDS -->
<div class="stats-grid">

    <div class="stat-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="stat-icon blue">
                <i class="fa-solid fa-clock-rotate-left"></i>
            </div>
            <span class="stat-badge blue">+@ViewBag.TotalPending mới</span>
        </div>
        <div class="stat-label">Yêu cầu chờ duyệt</div>
        <div class="stat-number">@ViewBag.TotalPending</div>
    </div>

    <div class="stat-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="stat-icon green">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <span class="stat-badge green">Tổng cộng</span>
        </div>
        <div class="stat-label">Đã phê duyệt</div>
        <div class="stat-number">@ViewBag.TotalApproved</div>
    </div>

    <div class="stat-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="stat-icon orange">
                <i class="fa-solid fa-users"></i>
            </div>
            <span class="stat-badge orange">Tỉ lệ @ViewBag.GroupPercent%</span>
        </div>
        <div class="stat-label">Sinh viên đã có nhóm</div>
        <div class="stat-number">@ViewBag.TotalStudentsGrouped</div>
    </div>

</div>

@if (pendingProposals.Any())
{
    <div class="table-card mb-4">
        <div class="table-header">
            <div>
                <h3 class="table-title">Đề xuất sinh viên chọn bạn hướng dẫn</h3>
                <div class="text-muted small">Đồng ý hướng dẫn, chuyển sang giảng viên khác, hoặc từ chối để sinh viên đề xuất đề tài mới trước hạn đăng ký.</div>
            </div>
            <span class="stat-badge blue">@pendingProposals.Count đề xuất</span>
        </div>

        <div class="table-scroll">
            <table class="approval-table">
                <thead>
                    <tr>
                        <th class="col-topic">Đề tài & sinh viên đề xuất</th>
                        <th class="text-center">Chuyên ngành</th>
                        <th class="text-center">Ngày gửi</th>
                        <th class="text-end th-actions">Quyết định</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var topic in pendingProposals)
                    {
                        <tr>
                            <td>
                                <div>
                                    <span class="topic-name">@topic.Title</span>
                                    <span class="type-badge individual">Sinh viên đề xuất</span>
                                </div>
                                <div class="student-chips">
                                    <div class="student-chip">
                                        <i class="fa-regular fa-user"></i>
                                        @(topic.Student?.FullName ?? topic.Student?.Email ?? "Sinh viên")
                                    </div>
                                </div>
                                <div class="text-muted small mt-2">@topic.Description</div>
                            </td>
                            <td class="text-center">
                                <span class="mssv-badge">@(topic.Major?.Name ?? topic.DepartmentName ?? "Chưa rõ")</span>
                            </td>
                            <td class="text-center">
                                <span class="date-text">@topic.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </td>
                            <td class="text-end td-actions">
                                <div class="d-flex justify-content-end align-items-center gap-2 flex-wrap">
                                    <form asp-action="ApproveStudentProposal" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="topicId" value="@topic.Id" />
                                        <button type="submit" class="btn-approve" title="Đồng ý hướng dẫn">
                                            <i class="fa-solid fa-check"></i>
                                        </button>
                                    </form>

                                    <form asp-action="ForwardStudentProposal" method="post" class="d-flex gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="topicId" value="@topic.Id" />
                                        <select name="assignLecturerId" class="modal-textarea"
                                                style="width:220px;min-height:38px;padding:8px 10px;" required>
                                            <option value="">Chuyển cho GV khác...</option>
                                            @foreach (var lecturer in lecturers)
                                            {
                                                <option value="@lecturer.Id">@lecturer.FullName</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn-approve" title="Phân công giảng viên khác">
                                            <i class="fa-solid fa-user-plus"></i>
                                        </button>
                                    </form>

                                    <form asp-action="RejectStudentProposal" method="post" class="d-flex gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="topicId" value="@topic.Id" />
                                        <input name="reason" class="modal-textarea" style="width:220px;min-height:38px;padding:8px 10px;"
                                               placeholder="Lý do từ chối, yêu cầu SV đổi đề tài..." />
                                        <button type="submit" class="btn-reject" title="Từ chối hướng dẫn">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- TABLE -->
<div class="table-card">

    <div class="table-header">
        <h3 class="table-title">
            Danh sách đăng ký
            @if (currentStatus == "Pending")
            {
                <span class="table-title-muted">— chờ xử lý</span>
            }
        </h3>
        <button class="btn-filter">
            <i class="fa-solid fa-filter"></i> Lọc dữ liệu
        </button>
    </div>

    <div class="table-scroll">
        <table class="approval-table">
            <thead>
                <tr>
                    <th class="col-topic">Đề tài & Người đăng ký</th>
                    <th class="text-center">MSSV</th>
                    <th class="text-center">Ngày đăng ký</th>
                    <th class="text-end th-actions">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <i class="fa-regular fa-folder-open"></i>
                                <p>Không có yêu cầu nào ở trạng thái này.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var group in Model)
                    {
                        <tr>
                            <!-- Đề tài & sinh viên -->
                            <td>
                                <div>
                                    <span class="topic-name">@group.TopicTitle</span>
                                    <span class="type-badge @(group.Students.Count > 1 ? "group" : "individual")">
                                        @(group.Students.Count > 1 ? "Nhóm" : "Cá nhân")
                                    </span>
                                </div>
                                <div class="student-chips">
                                    @foreach (var student in group.Students)
                                    {
                                        <div class="student-chip">
                                            <i class="fa-regular fa-user"></i>
                                            @student.FullName
                                        </div>
                                    }
                                </div>
                            </td>

                            <!-- MSSV -->
                            <td class="text-center">
                                <div class="d-flex flex-column align-items-center gap-1">
                                    @foreach (var student in group.Students)
                                    {
                                        <span class="mssv-badge">@student.UserCode</span>
                                    }
                            </div>
                        </td>

                        <!-- Ngày -->
                        <td class="text-center">
                            <span class="date-text">
                                @(group.CreatedAt != DateTime.MinValue
                                                            ? group.CreatedAt.ToString("dd/MM/yyyy")
                                                            : "N/A")
                        </span>
                    </td>

                            <!-- Thao tác -->
                            <td class="text-end td-actions">
                        @if (currentStatus == "Pending")
                                {
                                    <div class="d-flex justify-content-end align-items-center gap-2">

                                        <!-- Hidden IDs dùng chung cho cả 2 modal -->
                                        <div class="reg-ids-store" hidden>
                                            @foreach (var id in group.RegistrationIds)
                                            {
                                                <input type="hidden" class="reg-id" value="@id" />
                                            }
                                        </div>

                                        <button type="button"
                                                class="btn-approve"
                                                title="Duyệt đăng ký"
                                                data-approve-trigger>
                                            <i class="fa-solid fa-check"></i>
                                        </button>

                                        <button type="button"
                                                class="btn-reject"
                                                title="Từ chối đăng ký"
                                                data-reject-trigger data-topic="@group.TopicTitle">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <span class="resolved-badge @(currentStatus == "Approved" ? "approved" : "rejected")">
                                        @(currentStatus == "Approved" ? "Đã duyệt" : "Từ chối")
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL: DUYỆT -->
<div id="approveModal" class="modal-overlay" data-modal-overlay="approve">
    <div class="modal-box">

        <div class="d-flex align-items-center gap-3 mb-3">
            <div class="modal-icon approve">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <div>
                <p class="modal-title">Xác nhận duyệt đăng ký</p>
                <p class="modal-sub">Sinh viên sẽ được thêm vào đề tài này.</p>
            </div>
        </div>

        <div class="modal-info-box">
            Bạn có chắc muốn duyệt đăng ký này không? Hành động này không thể hoàn tác.
        </div>

        <form id="approveForm" asp-action="ApproveGroup" method="post">
            @Html.AntiForgeryToken()
            <div id="approveIdsContainer"></div>
            <div class="modal-actions">
                <button type="button" class="btn-modal-cancel" data-close-modal="approve">Hủy</button>
                <button type="submit" class="btn-modal-confirm approve">
                    <i class="fa-solid fa-check me-1"></i> Xác nhận duyệt
                </button>
            </div>
        </form>

    </div>
</div>

<!-- MODAL: TỪ CHỐI -->
<div id="rejectModal" class="modal-overlay" data-modal-overlay="reject">
    <div class="modal-box">

        <div class="d-flex align-items-center gap-3 mb-3">
            <div class="modal-icon reject">
                <i class="fa-solid fa-circle-xmark"></i>
            </div>
            <div>
                <p class="modal-title">Từ chối đăng ký nhóm</p>
                <p class="modal-sub modal-topic-name" id="rejectTopicName"></p>
            </div>
        </div>

        <form id="rejectForm" asp-action="RejectGroup" method="post">
            @Html.AntiForgeryToken()
            <div id="modalIdsContainer"></div>

            <label class="modal-label">
                Lý do từ chối
                <span>(để trống = mặc định)</span>
            </label>
            <textarea name="feedback" rows="3" class="modal-textarea"
                      placeholder="Ví dụ: Đề tài không phù hợp, sinh viên cần chọn lại..."></textarea>

            <div class="modal-actions">
                <button type="button" class="btn-modal-cancel" data-close-modal="reject">Hủy</button>
                <button type="submit" class="btn-modal-confirm reject">
                    <i class="fa-solid fa-xmark me-1"></i> Xác nhận từ chối
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <script src="~/js/lecturer/approval.js" asp-append-version="true"></script>
}

