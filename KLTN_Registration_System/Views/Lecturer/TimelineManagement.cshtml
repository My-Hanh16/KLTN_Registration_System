@model IEnumerable<KLTN_Registration_System.Models.Entities.Timeline>
@using KLTN_Registration_System.Models.Enums
@using KLTN_Registration_System.Controllers
@{
    Layout = "_LayoutDashboard";

    static string FormatReviewDeadline(DateTime value)
        => $"{value:HH:mm} ngày {value:dd/MM/yyyy}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/lecturer/timeline-management.css" asp-append-version="true" />
}

@{
    var allSubs = Model
        .SelectMany(t => t.TimelineSubmissions ?? new List<KLTN_Registration_System.Models.Entities.TimelineSubmission>())
        .ToList();

    int totalPending = allSubs.Count(s => s.Status == SubmissionStatus.Pending);
    int totalApproved = allSubs.Count(s => s.Status == SubmissionStatus.Approved);
    int totalRejected = allSubs.Count(s => s.Status == SubmissionStatus.Rejected);
    int totalTimelines = Model.Count();
    var activePeriod = ViewBag.ActivePeriod as KLTN_Registration_System.Models.Entities.RegistrationPeriod;
    string activePeriodName = activePeriod?.Name ?? "";
    var defenseEligibility = ViewBag.DefenseEligibility as List<LecturerController.DefenseEligibilityVM>
        ?? new List<LecturerController.DefenseEligibilityVM>();
    int defenseEligibleCount = defenseEligibility.Count(x => x.IsEligible);
    int nearDeadline = Model.Count(t =>
    {
        if (t.ReviewDeadline == null) return false;
        var diff = (t.ReviewDeadline.Value - DateTime.Now).TotalHours;
        return diff > 0 && diff <= 48;
    });
}

<div class="container-fluid px-0">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="page-title">Duyệt tiến độ sinh viên</h2>
            <p class="page-sub">
                Theo dõi, đánh giá và phê duyệt bài nộp trước thời hạn tổng hợp lên Admin
                @if (!string.IsNullOrWhiteSpace(activePeriodName))
                {
                    <span> trong đợt @activePeriodName</span>
                }
                .
            </p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="page-alert success">
            <i class="fa-solid fa-circle-check"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="page-alert error">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    <!-- STATS -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="stat-icon blue"><i class="fa-solid fa-layer-group"></i></div>
                <span class="stat-badge blue">Tổng</span>
            </div>
            <div class="stat-label">Mốc thời gian</div>
            <div class="stat-number">@totalTimelines</div>
        </div>

        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="stat-icon amber"><i class="fa-solid fa-hourglass-half"></i></div>
                <span class="stat-badge amber">Cần xử lý</span>
            </div>
            <div class="stat-label">Bài nộp chờ duyệt</div>
            <div class="stat-number">@totalPending</div>
        </div>

        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="stat-icon green"><i class="fa-solid fa-circle-check"></i></div>
                <span class="stat-badge green">Tổng</span>
            </div>
            <div class="stat-label">Đã phê duyệt</div>
            <div class="stat-number">@totalApproved</div>
        </div>

        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="stat-icon slate"><i class="fa-solid fa-ban"></i></div>
                <span class="stat-badge slate">Phản hồi</span>
            </div>
            <div class="stat-label">Bài đã từ chối</div>
            <div class="stat-number">@totalRejected</div>
        </div>

        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="stat-icon red"><i class="fa-solid fa-triangle-exclamation"></i></div>
                <span class="stat-badge red">Cảnh báo</span>
            </div>
            <div class="stat-label">Mốc sắp hết hạn duyệt</div>
            <div class="stat-number">@nearDeadline</div>
        </div>
    </div>

    <div class="defense-panel">
        <div class="defense-panel-head">
            <div>
                <div class="defense-title">Điều kiện báo cáo khóa luận</div>
                <p class="defense-sub">Sinh viên chỉ đủ điều kiện khi mọi mốc bắt buộc đã được duyệt.</p>
            </div>
            <span class="stat-badge @(defenseEligibleCount == defenseEligibility.Count && defenseEligibility.Any() ? "green" : "blue")">
                @defenseEligibleCount/@defenseEligibility.Count đủ điều kiện
            </span>
        </div>

        @if (!defenseEligibility.Any())
        {
            <div class="defense-empty">
                Chưa có sinh viên nào được duyệt vào đề tài của bạn trong đợt hiện tại.
            </div>
        }
        else
        {
            <div class="defense-list">
                @foreach (var item in defenseEligibility)
                {
                    int progress = item.RequiredCount > 0
                        ? Math.Min(100, item.ApprovedCount * 100 / item.RequiredCount)
                        : 0;

                    <div class="defense-item @(item.IsEligible ? "eligible" : "blocked")">
                        <div class="defense-student">
                            <div>
                                <div class="defense-name">@item.StudentName</div>
                                <div class="defense-code">@item.StudentCode</div>
                            </div>
                            <span class="defense-badge @(item.IsEligible ? "ok" : "no")">
                                @(item.IsEligible ? "Đủ điều kiện" : "Chưa đủ")
                            </span>
                        </div>

                        <div class="defense-topic">@item.TopicTitle</div>
                        <div class="defense-progress">
                            <div class="defense-progress-fill js-progress-fill" data-progress="@progress"></div>
                        </div>
                        <div class="defense-meta">
                            <span>Duyệt: @item.ApprovedCount/@item.RequiredCount</span>
                            <span>Chờ: @item.PendingCount</span>
                            <span>Từ chối: @item.RejectedCount</span>
                            <span>Thiếu: @item.MissingCount</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ══ TIMELINE SECTIONS ══ -->
    @foreach (var timeline in Model)
    {
        var submissions = timeline.TimelineSubmissions
        ?? new List<KLTN_Registration_System.Models.Entities.TimelineSubmission>();

        var groupedSubmissions = submissions
        .GroupBy(s => s.StudentId)
        .Select(g => new
        {
            Student = g.FirstOrDefault()?.Student,
            LatestSub = g.OrderByDescending(s => s.SubmittedAt).FirstOrDefault(),
            HistoryCount = g.Count()
        })
        .Where(x => x.Student != null && x.LatestSub != null)
        .ToList();

        int pendingCount = groupedSubmissions.Count(g => g.LatestSub!.Status == SubmissionStatus.Pending);

        /*
        * ReviewDeadline  — hạn giảng viên phải duyệt xong (cần thêm field này vào model Timeline)
        * SubmissionDeadline — hạn sinh viên nộp bài (đã có)
        * Nếu chưa có ReviewDeadline, fallback = SubmissionDeadline - 2 ngày
        */
        DateTime? reviewDeadline = timeline.ReviewDeadline
        ?? (timeline.SubmissionDeadline.HasValue
        ? timeline.SubmissionDeadline.Value.AddDays(-2)
        : (DateTime?)null);

        string deadlineStatus = "ok";
        string deadlineText = "";
        double hoursLeft = double.MaxValue;

        if (reviewDeadline.HasValue)
        {
            hoursLeft = (reviewDeadline.Value - DateTime.Now).TotalHours;
            if (hoursLeft < 0)
            {
                deadlineStatus = "passed";
                int daysOver = (int)Math.Abs(hoursLeft / 24);
                deadlineText = daysOver > 0
                ? $"Đã quá hạn {daysOver} ngày"
                : $"Quá hạn {(int)Math.Abs(hoursLeft)} giờ";
            }
            else if (hoursLeft <= 48)
            {
                deadlineStatus = "near";
                deadlineText = hoursLeft < 1
                ? "Còn dưới 1 giờ!"
                : hoursLeft < 24
                ? $"Còn {(int)hoursLeft} giờ {(int)((hoursLeft % 1) * 60)} phút"
                : $"Còn {(int)(hoursLeft / 24)} ngày {(int)(hoursLeft % 24)} giờ";
            }
            else
            {
                deadlineText = $"Còn {(int)(hoursLeft / 24)} ngày";
            }
        }

        bool isLocked = deadlineStatus == "passed";
        bool shouldOpenSection = pendingCount > 0 && !isLocked;

        var refDate = reviewDeadline ?? (submissions.Any()
        ? submissions.Max(s => s.SubmittedAt)
        : DateTime.Now);

        string sectionId = $"tl-body-{timeline.Id}";
        string btnId = $"tl-btn-{timeline.Id}";

        // Chuỗi JS-safe cho deadline
        string deadlineDisplay = reviewDeadline.HasValue
        ? FormatReviewDeadline(reviewDeadline.Value)
        : "";

        <div class="tl-section @(deadlineStatus == "near" ? "deadline-near" : deadlineStatus == "passed" ? "deadline-passed" : "")">

            <!-- HEADER -->
            <div class="tl-header js-toggle-section" data-body-id="@sectionId" data-button-id="@btnId">
                <div class="d-flex align-items-center gap-3 min-w-0">

                    <div class="tl-datebox @deadlineStatus">
                        <span class="month">Tháng @refDate.ToString("MM")</span>
                        <span class="day">@refDate.ToString("dd")</span>
                    </div>

                    <div class="min-w-0">
                        <div class="tl-meta-label">
                            <span class="dot"></span> MỐC THỜI GIAN
                        </div>
                        <div class="tl-title">@timeline.Title</div>
                        @if (!string.IsNullOrWhiteSpace(timeline.Description))
                        {
                            <div class="tl-desc">@timeline.Description</div>
                        }
                        @if (reviewDeadline.HasValue)
                        {
                            <div class="deadline-pill @deadlineStatus">
                                @if (deadlineStatus == "passed")
                                {
                                    <i class="fa-solid fa-lock deadline-icon"></i>
                                }
                                else if (deadlineStatus == "near")
                                {
                                    <i class="fa-solid fa-fire-flame-curved deadline-icon"></i>
                                }
                                else
                                {
                                    <i class="fa-regular fa-clock deadline-icon"></i>
                                }
                                Hạn duyệt: @reviewDeadline.Value.ToString("dd/MM/yyyy HH:mm") &mdash; @deadlineText
                            </div>
                        }
                    </div>
                </div>

                <!-- Toggle button -->
                <button id="@btnId" type="button" class="btn-toggle js-toggle-section @(shouldOpenSection ? "open" : "")"
                        data-body-id="@sectionId" data-button-id="@btnId">
                    @if (pendingCount > 0 && !isLocked)
                    {
                        <span class="pending-dot"></span>
                    }
                    <span>Danh sách nộp bài</span>
                    @if (groupedSubmissions.Any())
                    {
                        <span class="count-pill">@groupedSubmissions.Count</span>
                    }
                    <i class="fa-solid fa-chevron-down chevron"></i>
                </button>
            </div>

            <!-- BODY -->
            <div id="@sectionId" class="tl-body @(shouldOpenSection ? "open" : "")">

                @if (deadlineStatus == "near" && reviewDeadline.HasValue)
                {
                    <div class="deadline-banner near">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <div>
                            <strong>Sắp hết hạn duyệt!</strong> Bạn phải hoàn tất duyệt toàn bộ bài nộp trước
                            <strong>@deadlineDisplay</strong>
                            (@deadlineText). Sau thời điểm này hệ thống sẽ khóa và tự động tổng hợp kết quả lên Admin.
                        </div>
                    </div>
                }

                @if (deadlineStatus == "passed" && reviewDeadline.HasValue)
                {
                    <div class="deadline-banner passed">
                        <i class="fa-solid fa-lock"></i>
                        <div>
                            <strong>Đã hết hạn duyệt.</strong> Thời hạn kết thúc lúc
                            <strong>@deadlineDisplay</strong>.
                            Kết quả đã được tổng hợp và gửi lên Admin. Nếu cần điều chỉnh, hãy liên hệ Ban quản lý.
                        </div>
                    </div>
                }

                @if (!groupedSubmissions.Any())
                {
                    <div class="empty-state">
                        <i class="fa-regular fa-folder-open"></i>
                        <p>Chưa có sinh viên nào nộp bài cho mốc này.</p>
                    </div>
                }
                else
                {
                    @foreach (var group in groupedSubmissions)
                    {
                        var student = group.Student!;
                        var sub = group.LatestSub!;
                        string statusClass = sub.Status switch
                        {
                            SubmissionStatus.Approved => "approved",
                            SubmissionStatus.Rejected => "rejected",
                            _ => "pending"
                        };
                        string statusText = sub.Status switch
                        {
                            SubmissionStatus.Approved => "Đã duyệt",
                            SubmissionStatus.Rejected => "Từ chối",
                            _ => "Đang chờ"
                        };

                        var fullName = (student.FullName ?? "").Trim();

                        string initial = "?";

                        if (!string.IsNullOrWhiteSpace(fullName))
                        {
                            var lastWord = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault();

                            if (!string.IsNullOrWhiteSpace(lastWord))
                            {
                                initial = lastWord.Substring(0, 1).ToUpper();
                            }
                        }

                        <div class="student-row">
                            <!-- Left -->
                            <div class="d-flex align-items-center gap-3 min-w-0">
                                <div class="stu-avatar">@initial</div>
                                <div class="min-w-0">
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <span class="stu-name">@student.FullName</span>
                                        <span class="status-badge @statusClass">@statusText</span>
                                        @if (group.HistoryCount > 1)
                                        {
                                            <span class="history-tag" title="@student.FullName đã nộp @group.HistoryCount lần">
                                                +@(group.HistoryCount - 1) lần trước
                                            </span>
                                        }
                                    </div>
                                    <div class="stu-meta">Nộp lúc: @sub.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</div>

                                    @* Hiển thị lý do từ chối ngay trên giao diện *@
                                    @if (sub.Status == SubmissionStatus.Rejected
                                                            && !string.IsNullOrWhiteSpace(sub.LecturerComment))
                                    {
                                        <div class="reject-reason-row">
                                            <i class="fa-solid fa-comment-slash"></i>
                                            <span>@sub.LecturerComment</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Right -->
                            <div class="stu-actions">
                                @if (!string.IsNullOrWhiteSpace(sub.FilePath))
                                {
                                    <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = sub.Id })" target="_blank" class="btn-view-file">
                                        <i class="fa-solid fa-eye"></i> Xem file
                                    </a>
                                }

                                @if (sub.Status == SubmissionStatus.Pending)
                                {
                                    if (isLocked)
                                    {
                                        <span class="locked-tip">
                                            <i class="fa-solid fa-lock deadline-icon"></i> Đã khoá
                                        </span>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn-approve-sm js-open-approve" title="Duyệt bài nộp"
                                                data-submission-id="@sub.Id"
                                                data-student-name="@student.FullName"
                                                data-deadline-status="@deadlineStatus"
                                                data-deadline-time="@deadlineDisplay">
                                            <i class="fa-solid fa-check"></i>
                                        </button>

                                        <button type="button" class="btn-reject-sm js-open-reject" title="Từ chối bài nộp"
                                                data-submission-id="@sub.Id"
                                                data-student-name="@student.FullName">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    }
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

</div>

<!-- ════════════════════════════════
     MODAL: DUYỆT
════════════════════════════════ -->
<div id="approveModal" class="modal-overlay js-modal-overlay">
    <div class="modal-box">

        <div class="d-flex align-items-center gap-3 mb-3">
            <div class="modal-icon approve"><i class="fa-solid fa-circle-check"></i></div>
            <div>
                <p class="modal-title">Xác nhận duyệt bài nộp</p>
                <p class="modal-sub" id="approveStudentName"></p>
            </div>
        </div>

        <!-- Cảnh báo sắp hết hạn (chỉ hiện khi near) -->
        <div id="approveWarnBox" class="modal-warn is-hidden">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span id="approveWarnText"></span>
        </div>

        <div class="modal-info-box">
            Sau khi duyệt, bài nộp sẽ được <strong>ghi nhận hoàn thành</strong> mốc này và tổng hợp lên hệ thống chung.
            Hành động <strong>không thể hoàn tác</strong>.
        </div>

        <form id="approveForm" asp-action="ApproveSubmission" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="approveSubId" name="id" value="" />
            <div class="modal-actions">
                <button type="button" class="btn-modal-cancel js-close-approve">Hủy</button>
                <button type="submit" class="btn-modal-confirm approve">
                    <i class="fa-solid fa-check me-1"></i> Xác nhận duyệt
                </button>
            </div>
        </form>

    </div>
</div>

<!-- ════════════════════════════════
     MODAL: TỪ CHỐI — lý do bắt buộc
════════════════════════════════ -->
<div id="rejectModal" class="modal-overlay js-modal-overlay">
    <div class="modal-box">

        <div class="d-flex align-items-center gap-3 mb-3">
            <div class="modal-icon reject"><i class="fa-solid fa-circle-xmark"></i></div>
            <div>
                <p class="modal-title">Từ chối bài nộp</p>
                <p class="modal-sub" id="rejectStudentName"></p>
            </div>
        </div>

        <form id="rejectForm" asp-action="RejectSubmission" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="rejectSubId" name="id" value="" />

            <!-- Gợi ý nhanh -->
            <div class="modal-label modal-label-spaced">
                Lý do gợi ý <span class="opt">(click để điền nhanh)</span>
            </div>
            <div class="reason-chips">
                <span class="reason-chip" data-reason="Nội dung còn sơ sài, thiếu chi tiết — vui lòng bổ sung thêm.">Nội dung sơ sài</span>
                <span class="reason-chip" data-reason="Định dạng file không đúng yêu cầu, vui lòng nộp lại theo mẫu quy định.">Sai định dạng</span>
                <span class="reason-chip" data-reason="Thiếu chữ ký của giảng viên hướng dẫn.">Thiếu chữ ký GVHD</span>
                <span class="reason-chip" data-reason="Nội dung chưa khớp với đề cương đã đăng ký, cần chỉnh sửa lại.">Sai nội dung</span>
                <span class="reason-chip" data-reason="File bị lỗi hoặc không mở được, vui lòng tải lại.">File lỗi / không mở được</span>
                <span class="reason-chip" data-reason="Trình bày chưa đúng chuẩn, cần chỉnh sửa theo hướng dẫn của khoa.">Trình bày chưa chuẩn</span>
            </div>

            <!-- Textarea — bắt buộc tối thiểu 15 ký tự -->
            <label class="modal-label">
                Lý do từ chối <span class="required">*</span>
                <span class="opt">(sinh viên sẽ nhận được phản hồi này)</span>
            </label>
            <textarea id="rejectComment" name="comment" rows="4" class="modal-textarea"
                      placeholder="Mô tả rõ lý do từ chối để sinh viên biết cần chỉnh sửa điều gì...&#10;Ví dụ: Phần tổng quan tài liệu còn thiếu, cần bổ sung ít nhất 5 tài liệu tham khảo gần đây..."
                      maxlength="500"></textarea>
            <div class="d-flex justify-content-between align-items-center">
                <div id="rejectError" class="field-error">
                    <i class="fa-solid fa-circle-exclamation me-1"></i>
                    Vui lòng nhập lý do từ chối (ít nhất 15 ký tự) để sinh viên có thể chỉnh sửa.
                </div>
                <div id="charCount" class="char-count ms-auto">0 / 500</div>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-modal-cancel js-close-reject">Hủy</button>
                <button type="submit" class="btn-modal-confirm reject">
                    <i class="fa-solid fa-xmark me-1"></i> Gửi phản hồi từ chối
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <script src="~/js/lecturer/timeline-management.js" asp-append-version="true"></script>
}
