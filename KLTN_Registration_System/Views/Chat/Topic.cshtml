@* Views/Chat/Topic.cshtml *@
@using KLTN_Registration_System.Controllers
@model KLTN_Registration_System.Models.Entities.Topic

@{
    var messages = ViewBag.Messages as List<ChatMessageVM> ?? new();
    var currentUserId = ViewBag.CurrentUserId as string ?? "";
    var topicId = (int)ViewBag.TopicId;
    var topicTitle = ViewBag.TopicTitle as string ?? "";
    bool isLecturer = ViewBag.IsLecturer == true;

    Layout = isLecturer ? "_LayoutDashboard" : "_LayoutStudent";
    ViewData["Title"] = $"Chat — {topicTitle}";
}

@section Styles {
    <style>
        /* ═══════════════════════════════════════
               LAYOUT — Fix: không override body/html overflow
               để sidebar layout cha vẫn hoạt động bình thường
            ═══════════════════════════════════════ */
        .chat-page-wrap {
            height: calc(100vh - var(--topbar-h, 70px) - 32px);
            display: flex;
            flex-direction: column;
        }

        .chat-wrapper {
            display: flex;
            flex-direction: column;
            flex: 1;
            min-height: 0; /* Fix: quan trọng để flex child scroll đúng */
            background: #fff;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid #e8edf4;
            box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        }

        /* ═══════════════════════════════════════
               HEADER — Fix: bỏ gradient nặng, dùng style phù hợp layout
            ═══════════════════════════════════════ */
        .chat-header {
            padding: 14px 20px;
            background: #fff;
            border-bottom: 1px solid #e8edf4;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }

        .chat-header-back {
            width: 32px;
            height: 32px;
            border-radius: 9px;
            border: 1.5px solid #e8edf4;
            background: #f8fafc;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            text-decoration: none;
            font-size: 14px;
            flex-shrink: 0;
            transition: all .15s;
        }

            .chat-header-back:hover {
                background: #eef2ff;
                border-color: #c7d2fe;
                color: #4f46e5;
            }

        .chat-header-avatar {
            width: 38px;
            height: 38px;
            min-width: 38px;
            border-radius: 11px;
            background: linear-gradient(135deg, #4f46e5, #818cf8);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 15px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .chat-header-info {
            flex: 1;
            min-width: 0;
        }

        .chat-header-title {
            font-size: 14px;
            font-weight: 700;
            color: #1e293b;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.3;
            margin: 0;
        }

        .chat-header-sub {
            font-size: 11.5px;
            color: #94a3b8;
            font-weight: 500;
            margin-top: 1px;
        }

        .badge-role {
            font-size: 10px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 99px;
            letter-spacing: 0.4px;
            text-transform: uppercase;
            white-space: nowrap;
            flex-shrink: 0;
        }

            .badge-role.lecturer {
                background: #eef2ff;
                color: #4f46e5;
            }

            .badge-role.student {
                background: #f0fdf4;
                color: #16a34a;
            }

        /* ═══════════════════════════════════════
               MESSAGE AREA
            ═══════════════════════════════════════ */
        #chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px 24px;
            display: flex;
            flex-direction: column;
            gap: 14px; /* Fix: 18px → 14px gọn hơn */
            background: #f8fafc;
            scroll-behavior: smooth;
        }

            #chat-messages::-webkit-scrollbar {
                width: 5px;
            }

            #chat-messages::-webkit-scrollbar-thumb {
                background: #e2e8f0;
                border-radius: 99px;
            }

        /* ═══════════════════════════════════════
               MESSAGE ROW
            ═══════════════════════════════════════ */
        .msg-row {
            display: flex;
            align-items: flex-end;
            gap: 8px;
        }

            .msg-row.mine {
                flex-direction: row-reverse;
            }

        /* ═══════════════════════════════════════
               AVATAR — Fix: 40px → 34px, circle → rounded square
            ═══════════════════════════════════════ */
        .avatar {
            width: 32px;
            height: 32px;
            min-width: 32px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            flex-shrink: 0;
            color: #fff;
        }

            .avatar.lecturer {
                background: linear-gradient(135deg, #4f46e5, #818cf8);
            }

            .avatar.student {
                background: linear-gradient(135deg, #0891b2, #38bdf8);
            }

        /* ═══════════════════════════════════════
               BUBBLE
            ═══════════════════════════════════════ */
        .bubble-wrap {
            max-width: 68%;
        }

        .sender-name {
            font-size: 11.5px;
            color: #94a3b8;
            font-weight: 500;
            margin-bottom: 3px;
            padding: 0 4px;
        }

        .mine .sender-name {
            text-align: right;
        }

        .bubble {
            position: relative;
            padding: 10px 14px; /* Fix: 12px 16px → 10px 14px gọn hơn */
            border-radius: 14px; /* Fix: 20px → 14px đồng bộ với card khác */
            font-size: 13.5px;
            line-height: 1.6;
            word-break: break-word;
            transition: transform .15s;
        }

            .bubble.them {
                background: #fff;
                border: 1px solid #e8edf4;
                border-bottom-left-radius: 4px;
                color: #1e293b;
                box-shadow: 0 2px 6px rgba(0,0,0,0.04);
            }

            .bubble.mine {
                background: #4f46e5; /* Fix: gradient → flat color, nhất quán hơn */
                color: #fff;
                border-bottom-right-radius: 4px;
                box-shadow: 0 4px 12px rgba(79,70,229,0.22);
            }

            .bubble:hover {
                transform: translateY(-1px);
            }

        .bubble-time {
            font-size: 10.5px;
            color: #b0bec8;
            margin-top: 4px;
            padding: 0 4px;
            font-weight: 400;
        }

        .mine .bubble-time {
            text-align: right;
        }

        /* ═══════════════════════════════════════
               ATTACHMENT
            ═══════════════════════════════════════ */
        .attachment-link {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            margin-top: 8px;
            font-size: 12px;
            padding: 6px 10px;
            border-radius: 9px;
            text-decoration: none;
            transition: opacity .15s;
        }

        .bubble.them .attachment-link {
            background: #f1f5f9;
            color: #4f46e5;
            border: 1px solid #e2e8f0;
        }

        .bubble.mine .attachment-link {
            background: rgba(255,255,255,.15);
            color: #fff;
        }

        .attachment-link:hover {
            opacity: 0.8;
        }

        /* ═══════════════════════════════════════
               DELETE BUTTON — Fix: emoji 🗑 → FA icon
            ═══════════════════════════════════════ */
        .btn-del {
            position: absolute;
            top: 6px;
            right: 6px;
            opacity: 0;
            background: rgba(0,0,0,.12);
            border: none;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            cursor: pointer;
            transition: opacity .15s;
            font-size: 10px;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .bubble-wrap:hover .btn-del {
            opacity: 1;
        }

        /* ═══════════════════════════════════════
               DATE SEPARATOR
            ═══════════════════════════════════════ */
        .date-sep {
            text-align: center;
            font-size: 11px;
            color: #94a3b8;
            font-weight: 600;
            position: relative;
            margin: 4px 0;
        }

            .date-sep::before,
            .date-sep::after {
                content: '';
                position: absolute;
                top: 50%;
                width: 36%;
                height: 1px;
                background: #e8edf4;
            }

            .date-sep::before {
                left: 0;
            }

            .date-sep::after {
                right: 0;
            }

        /* ═══════════════════════════════════════
               TYPING INDICATOR
            ═══════════════════════════════════════ */
        #typing-indicator {
            font-size: 11.5px;
            color: #94a3b8;
            padding: 4px 24px;
            min-height: 20px;
            font-style: italic;
        }

        /* ═══════════════════════════════════════
               INPUT AREA
            ═══════════════════════════════════════ */
        .chat-input-area {
            padding: 12px 16px;
            background: #fff;
            border-top: 1px solid #e8edf4;
            flex-shrink: 0;
        }

        .input-row {
            display: flex;
            gap: 8px;
            align-items: flex-end;
        }

        #msg-input {
            flex: 1;
            resize: none;
            border: 1.5px solid #e8edf4;
            border-radius: 12px;
            padding: 10px 14px;
            font-size: 13.5px;
            outline: none;
            max-height: 120px;
            transition: border-color .2s, box-shadow .2s;
            font-family: inherit;
            background: #f8fafc;
            line-height: 1.5;
        }

            #msg-input:focus {
                border-color: #4f46e5;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(79,70,229,.08);
            }

            #msg-input::placeholder {
                color: #b0bec8;
            }

        .btn-send {
            height: 44px;
            padding: 0 20px;
            border: none;
            border-radius: 12px;
            background: #4f46e5;
            color: #fff;
            font-size: 13.5px;
            font-weight: 700;
            cursor: pointer;
            transition: background .15s, transform .15s;
            white-space: nowrap;
        }

            .btn-send:hover:not(:disabled) {
                background: #4338ca;
                transform: translateY(-1px);
            }

            .btn-send:disabled {
                opacity: .65;
                cursor: not-allowed;
            }

        .btn-attach {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border: 1.5px solid #e8edf4;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8fafc;
            cursor: pointer;
            font-size: 15px;
            color: #64748b;
            transition: all .15s;
            flex-shrink: 0;
        }

            .btn-attach:hover {
                background: #eef2ff;
                border-color: #c7d2fe;
                color: #4f46e5;
            }

        /* ═══════════════════════════════════════
               ATTACH PREVIEW
            ═══════════════════════════════════════ */
        .attach-preview {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12.5px;
            color: #334155;
            background: #f8fafc;
            border: 1px solid #e8edf4;
            border-radius: 10px;
            padding: 8px 12px;
            margin-bottom: 8px;
        }

            .attach-preview i {
                color: #4f46e5;
            }

            .attach-preview button {
                background: none;
                border: none;
                cursor: pointer;
                color: #94a3b8;
                font-size: 14px;
                margin-left: auto;
                line-height: 1;
                transition: color .15s;
            }

                .attach-preview button:hover {
                    color: #ef4444;
                }

        /* ═══════════════════════════════════════
               LOAD MORE
            ═══════════════════════════════════════ */
        #load-more-btn {
            margin: 0 auto 8px;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: #4f46e5;
            background: #eef2ff;
            border: 1px solid #c7d2fe;
            border-radius: 99px;
            padding: 6px 16px;
            cursor: pointer;
            transition: background .15s;
            font-weight: 600;
        }

            #load-more-btn:hover {
                background: #e0e7ff;
            }

        /* ═══════════════════════════════════════
               EMPTY STATE
            ═══════════════════════════════════════ */
        .chat-empty {
            text-align: center;
            color: #94a3b8;
            font-size: 13px;
            padding: 40px 0;
        }

            .chat-empty i {
                font-size: 32px;
                display: block;
                margin-bottom: 10px;
                opacity: 0.4;
            }

        /* ═══════════════════════════════════════
               MOBILE
            ═══════════════════════════════════════ */
        @@media (max-width: 768px) {
            .chat-page-wrap {
                height: calc(100vh - 60px);
            }

            .chat-wrapper {
                border-radius: 0;
            }

            #chat-messages {
                padding: 14px 16px;
            }
        }
    </style>
}

<div class="chat-page-wrap">
    <div class="chat-wrapper">

        <!-- HEADER -->
        <div class="chat-header">
            <a href="javascript:history.back()" class="chat-header-back" title="Quay lại">
                <i class="fa-solid fa-arrow-left"></i>
            </a>

            <div class="chat-header-avatar">
                @(topicTitle.Length > 0 ? topicTitle[0].ToString().ToUpper() : "T")
            </div>

            <div class="chat-header-info">
                <p class="chat-header-title">@topicTitle</p>
                <div class="chat-header-sub">Mã đề tài: @Model.TopicCode</div>
            </div>

            <span class="badge-role @(isLecturer ? "lecturer" : "student")">
                @(isLecturer ? "Giảng viên" : "Sinh viên")
            </span>
        </div>

        <!-- MESSAGES -->
        <div id="chat-messages">

            @if (!messages.Any())
            {
                <div class="chat-empty">
                    <i class="fa-regular fa-comments"></i>
                    Chưa có tin nhắn nào. Hãy bắt đầu cuộc trò chuyện!
                </div>
            }
            else
            {
                <button id="load-more-btn" data-first-id="@messages.First().Id">
                    <i class="fa-solid fa-chevron-up"></i> Tải thêm tin nhắn cũ
                </button>
            }

            @{
                string? lastDate = null;
            }

            @foreach (var msg in messages)
            {
                var dateStr = msg.CreatedAt.ToString("dd/MM/yyyy");

                if (dateStr != lastDate)
                {
                    <div class="date-sep">@dateStr</div>
                    lastDate = dateStr;
                }

                bool isMine = msg.SenderId == currentUserId;
                var avatarClass = msg.SenderRole == "Lecturer" ? "lecturer" : "student";
                var initial = msg.SenderName.Length > 0 ? msg.SenderName[0].ToString().ToUpper() : "?";

                <div class="msg-row @(isMine ? "mine" : "")" id="msg-@msg.Id">
                    <div class="avatar @avatarClass">@initial</div>

                    <div class="bubble-wrap">
                        <div class="sender-name">@msg.SenderName</div>

                        <div class="bubble @(isMine ? "mine" : "them")">
                            @if (!string.IsNullOrEmpty(msg.Content))
                            {
                                <span>@msg.Content</span>
                            }

                            @if (!string.IsNullOrEmpty(msg.AttachmentUrl))
                            {
                                <div>
                                    <a class="attachment-link"
                                       href="@Url.Action("DownloadAttachment", "Chat", new { messageId = msg.Id })"
                                       target="_blank"
                                       rel="noopener noreferrer">
                                        <i class="fa-solid fa-paperclip"></i>
                                        @(msg.AttachmentName ?? "File đính kèm")
                                    </a>
                                </div>
                            }

                            @if (isMine)
                            {
                                <button class="btn-del" onclick="deleteMsg(@msg.Id)" title="Xóa tin nhắn">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            }
                        </div>

                        <div class="bubble-time">@msg.CreatedAt.ToString("HH:mm")</div>
                    </div>
                </div>
            }
        </div>

        <!-- TYPING -->
        <div id="typing-indicator"></div>

        <!-- INPUT AREA -->
        <div class="chat-input-area">
            @Html.AntiForgeryToken()

            <div id="attach-preview" class="attach-preview" style="display:none;">
                <i class="fa-solid fa-paperclip"></i>
                <span id="attach-name"></span>
                <button onclick="clearAttach()" title="Xóa file">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="input-row">
                <label class="btn-attach" title="Đính kèm file">
                    <i class="fa-solid fa-paperclip"></i>
                    <input type="file"
                           id="file-input"
                           style="display:none;"
                           accept=".pdf,.doc,.docx,.png,.jpg,.jpeg,.zip,.rar,.xlsx"
                           onchange="handleFileSelect(this)">
                </label>

                <textarea id="msg-input"
                          rows="1"
                          placeholder="Nhập tin nhắn..."
                          onkeydown="handleKey(event)"
                          oninput="autoResize(this);sendTyping()"></textarea>

                <button class="btn-send" id="btn-send" onclick="sendMessage()">
                    <i class="fa-solid fa-paper-plane me-1"></i> Gửi
                </button>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        const TOPIC_ID    = @topicId;
        const CURRENT_USER = "@currentUserId";

        let pendingFile = null;
        let typingTimer = null;
        let isTyping    = false;
        let sending     = false;

        // SignalR connection
        const conn = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/chat")
            .withAutomaticReconnect()
            .build();

        conn.on("ReceiveMessage", function (msg) {
            if (!msg || (msg.topicId && msg.topicId != TOPIC_ID)) return;
            appendMessage(msg);
            scrollToBottom();
        });

        conn.on("MessageDeleted", function (id) {
            document.getElementById("msg-" + id)?.remove();
        });

        conn.on("UserTyping", function (name) {
            const el = document.getElementById("typing-indicator");
            el.textContent = (name || "Ai đó") + " đang gõ...";
            clearTimeout(window._typingClear);
            window._typingClear = setTimeout(() => el.textContent = "", 2000);
        });

        conn.onreconnected(async () => {
            await conn.invoke("JoinTopicRoom", TOPIC_ID);
        });

        async function startConn() {
            try {
                await conn.start();
                await conn.invoke("JoinTopicRoom", TOPIC_ID);
            } catch {
                setTimeout(startConn, 3000);
            }
        }

        startConn();

        // Send message
        async function sendMessage() {
            if (sending) return;

            const input   = document.getElementById("msg-input");
            const content = (input.value || "").trim();
            if (!content && !pendingFile) return;

            sending = true;
            const btn = document.getElementById("btn-send");
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i> Đang gửi...';

            try {
                await conn.invoke(
                    "SendMessage",
                    TOPIC_ID,
                    content,
                    pendingFile?.url ?? null,
                    pendingFile?.name ?? null
                );
                input.value = "";
                input.style.height = "";
                clearAttach();
            } catch {
                alert("Gửi thất bại. Vui lòng thử lại.");
            } finally {
                sending = false;
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-paper-plane me-1"></i> Gửi';
                input.focus();
            }
        }

        async function deleteMsg(id) {
            if (!confirm("Xóa tin nhắn này?")) return;
            await conn.invoke("DeleteMessage", id);
        }

        function sendTyping() {
            if (isTyping) return;
            isTyping = true;
            conn.invoke("Typing", TOPIC_ID).catch(() => {});
            clearTimeout(typingTimer);
            typingTimer = setTimeout(() => isTyping = false, 1500);
        }

        // Append new message to DOM
        function appendMessage(msg) {
            if (!msg) return;

            const isMine  = msg.senderId === CURRENT_USER;
            const initial = msg.senderName ? msg.senderName[0].toUpperCase() : "?";
            const avClass = msg.senderRole === "Lecturer" ? "lecturer" : "student";

            const attachHtml = msg.attachmentUrl
                ? `<div>
                    <a class="attachment-link" href="${escAttr(msg.attachmentUrl)}" target="_blank" rel="noopener noreferrer">
                        <i class="fa-solid fa-paperclip"></i> ${escHtml(msg.attachmentName || "File đính kèm")}
                    </a>
                   </div>`
                : "";

            const delBtn = isMine
                ? `<button class="btn-del" onclick="deleteMsg(${msg.id})" title="Xóa">
                    <i class="fa-solid fa-xmark"></i>
                   </button>`
                : "";

            const row = document.createElement("div");
            row.className = "msg-row" + (isMine ? " mine" : "");
            row.id = "msg-" + msg.id;
            row.innerHTML = `
                <div class="avatar ${avClass}">${initial}</div>
                <div class="bubble-wrap">
                    <div class="sender-name">${escHtml(msg.senderName || "")}</div>
                    <div class="bubble ${isMine ? "mine" : "them"}">
                        ${msg.content ? `<span>${escHtml(msg.content)}</span>` : ""}
                        ${attachHtml}
                        ${delBtn}
                    </div>
                    <div class="bubble-time">${msg.createdAtShort || ""}</div>
                </div>`;

            document.getElementById("chat-messages").appendChild(row);
        }

        // Load more
        document.getElementById("load-more-btn")?.addEventListener("click", async function () {
            const btn     = this;
            const firstId = parseInt(btn.dataset.firstId || "0");

            btn.disabled  = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang tải...';

            const res  = await fetch(`/Chat/LoadMore?topicId=${TOPIC_ID}&beforeId=${firstId}`);
            const msgs = await res.json();

            if (!msgs || msgs.length === 0) {
                btn.remove();
                return;
            }

            const container = document.getElementById("chat-messages");
            const oldHeight = container.scrollHeight;

            msgs.forEach(msg => {
                const isMine = msg.senderId === CURRENT_USER;
                const row = document.createElement("div");
                row.className = "msg-row" + (isMine ? " mine" : "");
                row.id = "msg-" + msg.id;
                row.innerHTML = `
                    <div class="avatar ${msg.senderRole === "Lecturer" ? "lecturer" : "student"}">
                        ${(msg.senderName || "?")[0]}
                    </div>
                    <div class="bubble-wrap">
                        <div class="sender-name">${escHtml(msg.senderName || "")}</div>
                        <div class="bubble ${isMine ? "mine" : "them"}">
                            ${msg.content ? `<span>${escHtml(msg.content)}</span>` : ""}
                            ${msg.attachmentUrl ? `<div>
                                <a class="attachment-link" href="${escAttr(msg.attachmentUrl)}" target="_blank" rel="noopener noreferrer">
                                    <i class="fa-solid fa-paperclip"></i> ${escHtml(msg.attachmentName || "File đính kèm")}
                                </a>
                            </div>` : ""}
                        </div>
                        <div class="bubble-time">${msg.createdAtFmt || ""}</div>
                    </div>`;
                btn.insertAdjacentElement("afterend", row);
            });

            btn.dataset.firstId = msgs[0].id;
            container.scrollTop = container.scrollHeight - oldHeight;
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-chevron-up"></i> Tải thêm tin nhắn cũ';
        });

        // File upload
        async function handleFileSelect(input) {
            const file = input.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append("file", file);
            formData.append("topicId", TOPIC_ID);

            document.getElementById("attach-preview").style.display = "flex";
            document.getElementById("attach-name").textContent = "Đang tải lên...";

            const res  = await fetch("/Chat/UploadFile", {
                method: "POST",
                headers: {
                    "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ""
                },
                body: formData
            });
            let data = {};
            try {
                data = await res.json();
            } catch {
                data = { error: "Không thể tải file lên. Vui lòng thử lại." };
            }

            if (!res.ok || data.error) {
                alert(data.error || "Không thể tải file lên. Vui lòng thử lại.");
                clearAttach();
                return;
            }

            pendingFile = { url: data.url, name: data.name };
            document.getElementById("attach-name").textContent = data.name;
        }

        function clearAttach() {
            pendingFile = null;
            document.getElementById("attach-preview").style.display = "none";
            document.getElementById("file-input").value = "";
        }

        function handleKey(e) {
            if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        }

        function autoResize(el) {
            el.style.height = "";
            el.style.height = Math.min(el.scrollHeight, 120) + "px";
        }

        function scrollToBottom() {
            const el = document.getElementById("chat-messages");
            el.scrollTop = el.scrollHeight;
        }

        function escHtml(str) {
            if (!str) return "";
            return str
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");
        }

        function escAttr(str) {
            return escHtml(str).replace(/"/g, "&quot;");
        }

        scrollToBottom();
    </script>
}
