@model List<KLTN_Registration_System.Models.Entities.Topic>
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Trao đổi sinh viên";

    var unreadMap = ViewBag.UnreadMap as Dictionary<int, int>;
    int totalUnread = unreadMap?.Values.Sum() ?? 0;
}

@section Styles {
<style>
    /* ══════════════════════════════════════
       HEADER
    ══════════════════════════════════════ */
    .page-title {
        font-size: 20px;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .page-sub {
        font-size: 13.5px;
        color: #94a3b8;
        margin: 0;
    }

    /* ══════════════════════════════════════
       SEARCH
    ══════════════════════════════════════ */
    .chat-search {
        position: relative;
        width: 280px;
    }

    .chat-search i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 13px;
        pointer-events: none;
    }

    .chat-search input {
        width: 100%;
        height: 40px;
        border: 1.5px solid #e8edf4;
        border-radius: 10px;
        padding: 0 14px 0 38px;
        font-size: 13.5px;
        font-family: 'Inter', sans-serif;
        background: #f8fafc;
        color: #1e293b;
        outline: none;
        transition: border-color .15s, box-shadow .15s;
    }

    .chat-search input:focus {
        border-color: #4f46e5;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(79,70,229,.08);
    }

    .chat-search input::placeholder { color: #b0bec8; }

    /* ══════════════════════════════════════
       TOPIC GRID
    ══════════════════════════════════════ */
    .topic-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
    }

    @@media (max-width: 1280px) { .topic-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 768px)  { .topic-grid { grid-template-columns: 1fr; } }

    /* ══════════════════════════════════════
       TOPIC CARD
    ══════════════════════════════════════ */
    .topic-card {
        background: #fff;
        border-radius: 14px;
        padding: 18px 20px;
        border: 1px solid #e8edf4;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        transition: box-shadow .2s, border-color .2s, transform .2s;
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .topic-card:hover {
        transform: translateY(-2px);
        border-color: #c7d2fe;
        box-shadow: 0 8px 24px rgba(79,70,229,.08);
    }

    /* Unread badge */
    .unread-dot {
        position: absolute;
        top: 14px;
        right: 14px;
        min-width: 20px;
        height: 20px;
        border-radius: 99px;
        background: #ef4444;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        padding: 0 5px;
        line-height: 1;
    }

    /* Card header */
    .card-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    /* Topic icon — đồng bộ icon-box-sm style layout */
    .topic-icon {
        width: 42px;
        height: 42px;
        min-width: 42px;
        border-radius: 12px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        flex-shrink: 0;
    }

    /* Status badge — phản ánh trạng thái thực */
    .topic-status {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 10px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 99px;
        letter-spacing: 0.3px;
        white-space: nowrap;
    }

    .status-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
        opacity: 0.8;
    }

    .s-active   { background: #dcfce7; color: #15803d; }
    .s-pending  { background: #fef3c7; color: #b45309; }
    .s-full     { background: #fff7ed; color: #ea580c; }
    .s-closed   { background: #f1f5f9; color: #64748b; }

    /* Topic name */
    .topic-name {
        font-size: 14px;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin: 0;
    }

    /* Meta chips */
    .topic-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .meta-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f8fafc;
        border: 1px solid #e8edf4;
        border-radius: 7px;
        padding: 4px 10px;
        font-size: 11.5px;
        font-weight: 600;
        color: #475569;
    }

    .meta-chip i { font-size: 10px; color: #94a3b8; }

    /* Description */
    .topic-desc {
        font-size: 12.5px;
        color: #94a3b8;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin: 0;
        flex: 1;
    }

    /* Footer */
    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding-top: 12px;
        border-top: 1px solid #f1f5f9;
    }

    /* Student info */
    .student-info {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
    }

    /* Fix: rounded-square thay vì tròn */
    .student-avatar {
        width: 32px;
        height: 32px;
        min-width: 32px;
        border-radius: 9px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .student-name {
        font-size: 12.5px;
        font-weight: 600;
        color: #1e293b;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 130px;
    }

    .student-role {
        font-size: 10.5px;
        color: #94a3b8;
        font-weight: 400;
    }

    /* Fix: nhiều sinh viên (nhóm) */
    .student-count {
        font-size: 11px;
        font-weight: 600;
        color: #7c3aed;
        background: #f5f3ff;
        border-radius: 99px;
        padding: 2px 8px;
        margin-left: 4px;
    }

    /* Btn chat — flat color thay gradient */
    .btn-chat {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 10px;
        background: #4f46e5;
        color: #fff;
        text-decoration: none;
        font-size: 12.5px;
        font-weight: 700;
        white-space: nowrap;
        flex-shrink: 0;
        transition: background .15s, transform .15s;
        box-shadow: 0 4px 10px rgba(79,70,229,.2);
    }

    .btn-chat:hover { background: #4338ca; color: #fff; transform: translateY(-1px); }

    .btn-chat.has-unread {
        background: #ef4444;
        box-shadow: 0 4px 10px rgba(239,68,68,.2);
    }

    .btn-chat.has-unread:hover { background: #dc2626; }

    /* ══════════════════════════════════════
       EMPTY STATE
    ══════════════════════════════════════ */
    .empty-state {
        background: #fff;
        border: 1px dashed #e2e8f0;
        border-radius: 14px;
        padding: 56px 24px;
        text-align: center;
    }

    .empty-state i {
        font-size: 36px;
        color: #cbd5e1;
        display: block;
        margin-bottom: 12px;
    }

    .empty-state h3 {
        font-size: 15px;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 6px;
    }

    .empty-state p {
        font-size: 13px;
        color: #94a3b8;
        margin: 0;
    }

    .hidden-by-search {
        display: none !important;
    }
</style>
}

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4 gap-3 flex-wrap">
    <div>
        <h2 class="page-title">
            Trao đổi sinh viên
            @if (totalUnread > 0)
            {
                <span style="background:#ef4444;color:#fff;font-size:10px;font-weight:700;
                             border-radius:99px;padding:2px 9px;letter-spacing:0.3px;">
                    @totalUnread chưa đọc
                </span>
            }
        </h2>
        <p class="page-sub">Chỉ hiển thị các đề tài đã có sinh viên được duyệt trong đợt hiện tại.</p>
    </div>

    <div class="chat-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="searchBox" placeholder="Tìm đề tài, mã đề tài, sinh viên..." />
    </div>
</div>

<!-- TOPIC GRID -->
@if (Model != null && Model.Any())
{
    <div class="topic-grid" id="topicGrid">

        @foreach (var item in Model)
        {
            int unread = unreadMap != null && unreadMap.ContainsKey(item.Id)
                ? unreadMap[item.Id] : 0;

            // Fix: lấy tất cả sinh viên approved, không chỉ 1
            var approvedStudents = item.Registrations?
                .Where(r => r.Status == "Approved")
                .Select(r => r.Student)
                .Where(s => s != null)
                .ToList() ?? new();

            var firstStudent = approvedStudents.FirstOrDefault();
            string studentName = firstStudent?.FullName ?? "Chưa có sinh viên";
            string initial     = !string.IsNullOrWhiteSpace(studentName)
                ? studentName[0].ToString().ToUpper() : "?";

            string sClass = unread > 0 ? "s-pending" : "s-active";
            string sText = unread > 0 ? "Có tin mới" : "Đang hướng dẫn";

            <div class="topic-card topic-item">

                @if (unread > 0)
                {
                    <div class="unread-dot">@unread</div>
                }

                <!-- Header -->
                <div class="card-header-row">
                    <div class="topic-icon">
                        <i class="fa-regular fa-comments"></i>
                    </div>
                    <span class="topic-status @sClass">
                        <span class="status-dot"></span>
                        @sText
                    </span>
                </div>

                <!-- Title -->
                <p class="topic-name">@item.Title</p>

                <!-- Meta -->
                <div class="topic-meta">
                    @if (!string.IsNullOrEmpty(item.TopicCode))
                    {
                        <span class="meta-chip">
                            <i class="fa-solid fa-hashtag"></i>
                            @item.TopicCode
                        </span>
                    }
                    <span class="meta-chip">
                        <i class="fa-solid fa-graduation-cap"></i>
                        KLTN
                    </span>
                    @if (approvedStudents.Count > 0)
                    {
                        <span class="meta-chip">
                            <i class="fa-solid fa-users"></i>
                            @approvedStudents.Count SV
                        </span>
                    }
                </div>

                <!-- Description -->
                <p class="topic-desc">
                    @(string.IsNullOrWhiteSpace(item.Description)
                        ? "Trao đổi tiến độ, tài liệu và hướng dẫn thực hiện đề tài."
                        : item.Description)
                </p>

                <!-- Footer -->
                <div class="card-footer">
                    <div class="student-info">
                        <div class="student-avatar">@initial</div>
                        <div>
                            <div class="student-name">
                                @studentName
                                @if (approvedStudents.Count > 1)
                                {
                                    <span class="student-count">+@(approvedStudents.Count - 1)</span>
                                }
                            </div>
                            <div class="student-role">Sinh viên thực hiện</div>
                        </div>
                    </div>

                    <a asp-action="Topic"
                       asp-route-topicId="@item.Id"
                       class="btn-chat @(unread > 0 ? "has-unread" : "")">
                        <i class="fa-regular fa-comment-dots"></i>
                        @(unread > 0 ? $"{unread} tin mới" : "Vào chat")
                    </a>
                </div>

            </div>
        }

    </div>
    <div class="empty-state hidden-by-search" id="noSearchResult">
        <i class="fa-solid fa-magnifying-glass"></i>
        <h3>Không tìm thấy hội thoại phù hợp</h3>
        <p>Thử tìm bằng tên đề tài, mã đề tài hoặc tên sinh viên.</p>
    </div>
}
else
{
    <div class="empty-state">
        <i class="fa-regular fa-comments"></i>
        <h3>Chưa có hội thoại hướng dẫn</h3>
        <p>Đề tài sẽ xuất hiện khi sinh viên được duyệt chính thức vào đề tài của bạn.</p>
    </div>
}

@section Scripts {
<script>
    document.getElementById('searchBox')?.addEventListener('input', function () {
        const kw = this.value.toLowerCase().trim();
        let visibleCount = 0;

        document.querySelectorAll('.topic-item').forEach(card => {
            const matched = card.innerText.toLowerCase().includes(kw);
            card.classList.toggle('hidden-by-search', !matched);
            if (matched) visibleCount++;
        });

        document.getElementById('noSearchResult')?.classList.toggle('hidden-by-search', visibleCount > 0);
    });
</script>
}
