@model List<KLTN_Registration_System.Models.Entities.Topic>
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Trao đổi sinh viên";

    var unreadMap = ViewBag.UnreadMap as Dictionary<int, int>;
    int totalUnread = unreadMap?.Values.Sum() ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/chat/lecturer-topics.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-center mb-4 gap-3 flex-wrap">
    <div>
        <h2 class="page-title">
            Trao đổi sinh viên
            @if (totalUnread > 0)
            {
                <span class="page-unread-badge">
                    @totalUnread chưa đọc
                </span>
            }
        </h2>
        <p class="page-sub">Chỉ hiển thị các đề tài đã có sinh viên được duyệt trong đợt hiện tại.</p>
    </div>

    <div class="chat-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="searchBox" placeholder="Tìm đề tài, mã đề tài, sinh viên..." />
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="topic-grid" id="topicGrid">

        @foreach (var item in Model)
        {
            int unread = unreadMap != null && unreadMap.ContainsKey(item.Id)
                ? unreadMap[item.Id] : 0;

            var approvedStudents = item.Registrations?
                .Where(r => r.Status == "Approved")
                .Select(r => r.Student)
                .Where(s => s != null)
                .ToList() ?? new();

            var firstStudent = approvedStudents.FirstOrDefault();
            string studentName = firstStudent?.FullName ?? "Chưa có sinh viên";
            string initial     = !string.IsNullOrWhiteSpace(studentName)
                ? studentName[0].ToString().ToUpper() : "?";

            string sClass = unread > 0 ? "s-pending" : "s-active";
            string sText = unread > 0 ? "Có tin mới" : "Đang hướng dẫn";

            <div class="topic-card topic-item">

                @if (unread > 0)
                {
                    <div class="unread-dot">@unread</div>
                }

                <!-- Header -->
                <div class="card-header-row">
                    <div class="topic-icon">
                        <i class="fa-regular fa-comments"></i>
                    </div>
                    <span class="topic-status @sClass">
                        <span class="status-dot"></span>
                        @sText
                    </span>
                </div>

                <!-- Title -->
                <p class="topic-name">@item.Title</p>

                <!-- Meta -->
                <div class="topic-meta">
                    @if (!string.IsNullOrEmpty(item.TopicCode))
                    {
                        <span class="meta-chip">
                            <i class="fa-solid fa-hashtag"></i>
                            @item.TopicCode
                        </span>
                    }
                    <span class="meta-chip">
                        <i class="fa-solid fa-graduation-cap"></i>
                        KLTN
                    </span>
                    @if (approvedStudents.Count > 0)
                    {
                        <span class="meta-chip">
                            <i class="fa-solid fa-users"></i>
                            @approvedStudents.Count SV
                        </span>
                    }
                </div>

                <!-- Description -->
                <p class="topic-desc">
                    @(string.IsNullOrWhiteSpace(item.Description)
                        ? "Trao đổi tiến độ, tài liệu và hướng dẫn thực hiện đề tài."
                        : item.Description)
                </p>

                <!-- Footer -->
                <div class="card-footer">
                    <div class="student-info">
                        <div class="student-avatar">@initial</div>
                        <div>
                            <div class="student-name">
                                @studentName
                                @if (approvedStudents.Count > 1)
                                {
                                    <span class="student-count">+@(approvedStudents.Count - 1)</span>
                                }
                            </div>
                            <div class="student-role">Sinh viên thực hiện</div>
                        </div>
                    </div>

                    <a asp-action="Topic"
                       asp-route-topicId="@item.Id"
                       class="btn-chat @(unread > 0 ? "has-unread" : "")">
                        <i class="fa-regular fa-comment-dots"></i>
                        @(unread > 0 ? $"{unread} tin mới" : "Vào chat")
                    </a>
                </div>

            </div>
        }

    </div>
    <div class="empty-state hidden-by-search" id="noSearchResult">
        <i class="fa-solid fa-magnifying-glass"></i>
        <h3>Không tìm thấy hội thoại phù hợp</h3>
        <p>Thử tìm bằng tên đề tài, mã đề tài hoặc tên sinh viên.</p>
    </div>
}
else
{
    <div class="empty-state">
        <i class="fa-regular fa-comments"></i>
        <h3>Chưa có hội thoại hướng dẫn</h3>
        <p>Đề tài sẽ xuất hiện khi sinh viên được duyệt chính thức vào đề tài của bạn.</p>
    </div>
}

@section Scripts {
    <script src="~/js/chat/lecturer-topics.js" asp-append-version="true"></script>
}
