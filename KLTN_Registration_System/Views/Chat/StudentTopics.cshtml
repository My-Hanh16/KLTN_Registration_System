@model List<KLTN_Registration_System.Models.Entities.Topic>

@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Trao đổi với GVHD";

    var topics = Model ?? new List<KLTN_Registration_System.Models.Entities.Topic>();
    var unreadMap = ViewBag.UnreadMap as Dictionary<int, int> ?? new Dictionary<int, int>();
    int totalUnread = unreadMap.Values.Sum();
}

@section Styles {
<style>
    .chat-page {
        max-width: 1080px;
        margin: 0 auto;
    }

    .chat-header {
        align-items: flex-start;
        display: flex;
        gap: 16px;
        justify-content: space-between;
        margin-bottom: 22px;
    }

    .chat-title {
        color: #0f172a;
        font-size: 24px;
        font-weight: 800;
        margin: 0 0 6px;
    }

    .chat-sub {
        color: #64748b;
        font-size: 14px;
        margin: 0;
    }

    .chat-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .soft-btn {
        align-items: center;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        color: #475569;
        display: inline-flex;
        font-size: 13px;
        font-weight: 800;
        gap: 8px;
        min-height: 40px;
        padding: 9px 14px;
        text-decoration: none;
    }

    .soft-btn:hover {
        background: #eef2ff;
        border-color: #c7d2fe;
        color: #4f46e5;
    }

    .chat-search {
        margin-bottom: 18px;
        position: relative;
    }

    .chat-search i {
        color: #94a3b8;
        left: 16px;
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
    }

    .chat-search input {
        background: #fff;
        border: 1.5px solid #e2e8f0;
        border-radius: 14px;
        color: #0f172a;
        font-size: 14px;
        height: 46px;
        outline: none;
        padding: 0 14px 0 44px;
        width: 100%;
    }

    .chat-search input:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, .1);
    }

    .topic-grid {
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .topic-card {
        background: #fff;
        border: 1px solid #e8edf4;
        border-radius: 18px;
        box-shadow: 0 8px 26px rgba(15, 23, 42, .05);
        display: grid;
        gap: 14px;
        padding: 20px;
        position: relative;
    }

    .topic-card.has-unread {
        border-color: #fecaca;
        box-shadow: 0 8px 26px rgba(239, 68, 68, .08);
    }

    .topic-top {
        align-items: flex-start;
        display: flex;
        gap: 12px;
        justify-content: space-between;
    }

    .topic-title {
        color: #0f172a;
        font-size: 16px;
        font-weight: 800;
        line-height: 1.45;
        margin: 0;
    }

    .unread-pill {
        background: #ef4444;
        border-radius: 999px;
        color: #fff;
        flex-shrink: 0;
        font-size: 11px;
        font-weight: 800;
        padding: 5px 9px;
    }

    .topic-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .meta-chip {
        align-items: center;
        background: #f8fafc;
        border: 1px solid #e8edf4;
        border-radius: 9px;
        color: #475569;
        display: inline-flex;
        font-size: 12px;
        font-weight: 700;
        gap: 6px;
        padding: 6px 10px;
    }

    .meta-chip i {
        color: #94a3b8;
        font-size: 11px;
    }

    .topic-desc {
        color: #64748b;
        display: -webkit-box;
        font-size: 13px;
        line-height: 1.55;
        margin: 0;
        overflow: hidden;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
    }

    .topic-footer {
        align-items: center;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding-top: 14px;
    }

    .lecturer-box {
        align-items: center;
        display: flex;
        gap: 9px;
        min-width: 0;
    }

    .lecturer-avatar {
        align-items: center;
        background: #ecfeff;
        border-radius: 10px;
        color: #0891b2;
        display: inline-flex;
        flex-shrink: 0;
        font-size: 12px;
        font-weight: 800;
        height: 34px;
        justify-content: center;
        width: 34px;
    }

    .lecturer-name {
        color: #0f172a;
        font-size: 13px;
        font-weight: 800;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .lecturer-role {
        color: #94a3b8;
        font-size: 11px;
        font-weight: 600;
    }

    .chat-btn {
        align-items: center;
        background: #4f46e5;
        border-radius: 12px;
        color: #fff;
        display: inline-flex;
        flex-shrink: 0;
        font-size: 13px;
        font-weight: 800;
        gap: 8px;
        min-height: 40px;
        padding: 9px 14px;
        text-decoration: none;
    }

    .chat-btn:hover {
        background: #4338ca;
        color: #fff;
    }

    .chat-btn.has-unread {
        background: #ef4444;
    }

    .chat-btn.has-unread:hover {
        background: #dc2626;
    }

    .empty-state {
        background: #fff;
        border: 1px dashed #dbe4f0;
        border-radius: 18px;
        padding: 56px 24px;
        text-align: center;
    }

    .empty-state i {
        color: #cbd5e1;
        display: block;
        font-size: 40px;
        margin-bottom: 14px;
    }

    .empty-state h3 {
        color: #0f172a;
        font-size: 17px;
        font-weight: 800;
        margin: 0 0 6px;
    }

    .empty-state p {
        color: #64748b;
        font-size: 13.5px;
        margin: 0 0 18px;
    }

    .hidden-by-search {
        display: none !important;
    }

    @@media (max-width: 820px) {
        .topic-grid {
            grid-template-columns: 1fr;
        }

        .chat-header {
            flex-direction: column;
        }
    }

    @@media (max-width: 560px) {
        .topic-footer {
            align-items: stretch;
            flex-direction: column;
        }

        .chat-btn,
        .soft-btn {
            justify-content: center;
            width: 100%;
        }
    }
</style>
}

<div class="chat-page">
    <div class="chat-header">
        <div>
            <h1 class="chat-title">Trao đổi với GVHD</h1>
            <p class="chat-sub">
                Theo dõi hội thoại theo đề tài đã được duyệt.
                @if (totalUnread > 0)
                {
                    <strong class="text-danger">@totalUnread tin chưa đọc</strong>
                }
            </p>
        </div>

        <div class="chat-actions">
            <a asp-controller="Student" asp-action="MyRegistration" class="soft-btn">
                <i class="fa-regular fa-square-check"></i>
                Đăng ký của tôi
            </a>
            <a asp-controller="Student" asp-action="Timeline" class="soft-btn">
                <i class="fa-solid fa-timeline"></i>
                Timeline
            </a>
        </div>
    </div>

    @if (!topics.Any())
    {
        <div class="empty-state">
            <i class="fa-regular fa-comments"></i>
            <h3>Chưa có phòng chat</h3>
            <p>Phòng chat sẽ xuất hiện sau khi đăng ký đề tài của bạn được duyệt chính thức.</p>
            <a asp-controller="Student" asp-action="MyRegistration" class="soft-btn">
                Kiểm tra đăng ký
            </a>
        </div>
    }
    else
    {
        <div class="chat-search">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="chatSearch" placeholder="Tìm theo tên đề tài, mã đề tài hoặc giảng viên..." />
        </div>

        <div class="topic-grid" id="topicGrid">
            @foreach (var topic in topics)
            {
                var unread = unreadMap.TryGetValue(topic.Id, out var count) ? count : 0;
                var lecturerName = topic.Lecturer?.FullName ?? topic.Lecturer?.UserName ?? "Giảng viên hướng dẫn";
                var lecturerInitial = !string.IsNullOrWhiteSpace(lecturerName) ? lecturerName.Trim()[0].ToString().ToUpper() : "GV";

                <article class="topic-card topic-item @(unread > 0 ? "has-unread" : "")">
                    <div class="topic-top">
                        <h2 class="topic-title">@topic.Title</h2>
                        @if (unread > 0)
                        {
                            <span class="unread-pill">@unread mới</span>
                        }
                    </div>

                    <div class="topic-meta">
                        @if (!string.IsNullOrWhiteSpace(topic.TopicCode))
                        {
                            <span class="meta-chip">
                                <i class="fa-solid fa-hashtag"></i>
                                @topic.TopicCode
                            </span>
                        }
                        <span class="meta-chip">
                            <i class="fa-solid fa-circle-check"></i>
                            Đã duyệt
                        </span>
                        @if (!string.IsNullOrWhiteSpace(topic.DepartmentName ?? topic.Major?.Name))
                        {
                            <span class="meta-chip">
                                <i class="fa-solid fa-book"></i>
                                @(topic.DepartmentName ?? topic.Major?.Name)
                            </span>
                        }
                    </div>

                    <p class="topic-desc">
                        @(string.IsNullOrWhiteSpace(topic.Description)
                            ? "Trao đổi tiến độ, tài liệu và phản hồi liên quan đến đề tài."
                            : topic.Description)
                    </p>

                    <div class="topic-footer">
                        <div class="lecturer-box">
                            <div class="lecturer-avatar">@lecturerInitial</div>
                            <div style="min-width:0;">
                                <div class="lecturer-name">@lecturerName</div>
                                <div class="lecturer-role">Giảng viên hướng dẫn</div>
                            </div>
                        </div>

                        <a asp-controller="Chat"
                           asp-action="Topic"
                           asp-route-topicId="@topic.Id"
                           class="chat-btn @(unread > 0 ? "has-unread" : "")">
                            <i class="fa-regular fa-comment-dots"></i>
                            @(unread > 0 ? "Xem tin mới" : "Vào chat")
                        </a>
                    </div>
                </article>
            }
        </div>

        <div class="empty-state hidden-by-search" id="noSearchResult">
            <i class="fa-solid fa-magnifying-glass"></i>
            <h3>Không tìm thấy phòng chat</h3>
            <p>Thử tìm bằng tên đề tài, mã đề tài hoặc tên giảng viên.</p>
        </div>
    }
</div>

@section Scripts {
<script>
    document.getElementById('chatSearch')?.addEventListener('input', function () {
        const keyword = this.value.toLowerCase().trim();
        let visibleCount = 0;

        document.querySelectorAll('.topic-item').forEach((card) => {
            const matched = card.innerText.toLowerCase().includes(keyword);
            card.classList.toggle('hidden-by-search', !matched);
            if (matched) visibleCount++;
        });

        document.getElementById('noSearchResult')?.classList.toggle('hidden-by-search', visibleCount > 0);
    });
</script>
}
