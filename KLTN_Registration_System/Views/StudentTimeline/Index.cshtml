@model IEnumerable<KLTN_Registration_System.Models.Entities.Timeline>

@using KLTN_Registration_System.Models.Entities
@using KLTN_Registration_System.Models.Enums

@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Timeline";

    var timelines = Model?.ToList() ?? new List<Timeline>();
    var submissions =
        ViewBag.Submissions as List<TimelineSubmission> ?? new List<TimelineSubmission>();
    bool hasApprovedTopic = ViewBag.HasApprovedTopic == true;
    bool hasCompletedThesis = ViewBag.HasCompletedThesis == true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/student-timeline/index.css" asp-append-version="true" />
}

<div class="student-timeline-page">
    @if (TempData["Success"] != null)
    {
        <div class="st-alert st-alert-success">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="st-alert st-alert-danger">
            @TempData["Error"]
        </div>
    }

    <h2 class="st-page-title">
        Timeline & Báo cáo tiến độ
    </h2>

    @if (!hasApprovedTopic)
    {
        <div class="st-alert st-alert-warning">
            <i class="fa-solid fa-circle-info"></i>
            Bạn cần có đề tài đã được duyệt trước khi nộp báo cáo tiến độ.
        </div>
    }
    @if (hasCompletedThesis)
    {
        <div class="st-alert st-alert-success">
            <i class="fa-solid fa-circle-check"></i>
            Bạn đã hoàn thành khóa luận. Timeline chỉ còn dùng để xem lại lịch sử nộp bài.
        </div>
    }

    @if (!timelines.Any())
    {
        <div class="st-empty-state">
            <i class="fa-regular fa-calendar-xmark"></i>
            <p>Hiện chưa có mốc timeline nào đang hoạt động.</p>
        </div>
    }

    @foreach (var item in timelines)
    {
        var submission = submissions
        .Where(x => x.TimelineId == item.Id)
        .OrderByDescending(x => x.SubmittedAt)
        .FirstOrDefault();
        var isRejectedResubmission = submission?.Status == SubmissionStatus.Rejected;
        var isNotOpenYet = item.Date > DateTime.Now;
        var isExpired = item.SubmissionDeadline.HasValue && DateTime.Now > item.SubmissionDeadline.Value;
        var canSubmit = hasApprovedTopic
            && !hasCompletedThesis
            && item.IsActive
            && item.AllowSubmission
            && (!isNotOpenYet || isRejectedResubmission)
            && (!isExpired || isRejectedResubmission)
            && (submission == null || submission.Status == SubmissionStatus.Rejected);

        <div class="st-card">

            <!-- HEADER -->
            <div class="st-card-header">

                <div>
                    <h3 class="st-card-title">
                        @item.Title
                    </h3>

                    <p class="st-card-description">
                        @item.Description
                    </p>
                </div>

                <div class="st-date-box">
                    <div class="st-date-main">
                        @item.Date.ToString("dd/MM/yyyy")
                    </div>
                    @if (item.SubmissionDeadline.HasValue)
                    {
                        <div class="st-date-sub">
                            Hạn nộp: @item.SubmissionDeadline.Value.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    }
                </div>

            </div>

            <!-- TRẠNG THÁI NỘP -->
            @if (submission != null)
            {
                <div class="st-submission-box">

                    <div class="st-submission-header">

                        <div>
                            <div class="st-submission-title">
                                Đã nộp báo cáo
                            </div>

                            <div class="st-submission-time">
                                @submission.SubmittedAt.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>

                        <div>
                            @if (submission.Status.ToString() == "Pending")
                            {
                                <span class="st-status st-status-pending">
                                    Chờ duyệt
                                </span>
                            }
                            else if (submission.Status.ToString() == "Approved")
                            {
                                <span class="st-status st-status-approved">
                                    Đã duyệt
                                </span>
                            }
                            else if (submission.Status.ToString() == "Rejected")
                            {
                                <span class="st-status st-status-rejected">
                                    Từ chối
                                </span>
                            }
                            else
                            {
                                <span class="st-status st-status-default">
                                    @submission.Status
                                </span>
                            }
                        </div>

                    </div>

                    <!-- COMMENT -->
                    @if (!string.IsNullOrEmpty(submission.Comment))
                    {
                        <div class="st-comment-box">

                            <div class="st-comment-title">
                                Nhận xét giảng viên
                            </div>

                            <div class="st-comment-content">
                                @submission.Comment
                            </div>

                        </div>
                    }

                    <!-- SCORE -->
                    @if (submission.Score != null)
                    {
                        <div class="st-score">
                            <span class="st-score-label">
                                Điểm:
                            </span>

                            <span class="st-score-value">
                                @submission.Score
                            </span>
                        </div>
                    }

                </div>
            }

            <!-- FORM NỘP -->
            @if (canSubmit)
            {
                <form method="post"
                      asp-action="Submit"
                      enctype="multipart/form-data"
                      class="st-submit-form">
                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="timelineId"
                           value="@item.Id" />

                    <textarea name="content"
                          class="st-textarea"
                          rows="4"
                          placeholder="Nhập báo cáo tiến độ...">@submission?.ProgressDescription</textarea>

                    <input type="file"
                           name="file"
                           accept=".pdf,.doc,.docx,.ppt,.pptx,.zip,.rar,.txt"
                           class="st-file-input"
                           required />

                    <button type="submit"
                            class="st-submit-button">
                        @(submission == null ? "Nộp báo cáo" : "Nộp lại phiên bản mới")
                    </button>

                </form>
            }
            else if (!hasApprovedTopic)
            {
                <div class="st-alert st-alert-warning st-card-alert">
                    Bạn chưa có đề tài đã được duyệt nên chưa thể nộp báo cáo cho mốc này.
                </div>
            }
            else if (hasCompletedThesis)
            {
                <div class="st-alert st-alert-success st-card-alert">
                    Bạn đã hoàn thành khóa luận nên không cần nộp thêm ở mốc này.
                </div>
            }
            else if (!item.AllowSubmission)
            {
                <div class="st-alert st-alert-muted st-card-alert">
                    Mốc này chưa mở chức năng nộp bài.
                </div>
            }
            else if (isNotOpenYet && !isRejectedResubmission)
            {
                <div class="st-alert st-alert-muted st-card-alert">
                    Chưa đến thời gian mở nộp bài.
                </div>
            }
            else if (isExpired && !isRejectedResubmission)
            {
                <div class="st-alert st-alert-danger st-card-alert">
                    Đã quá hạn nộp bài.
                </div>
            }
            else if (isRejectedResubmission)
            {
                <div class="st-alert st-alert-danger st-card-alert">
                    Bài nộp đã bị từ chối. Bạn cần nộp lại bản mới để giảng viên xem xét.
                </div>
            }

            <!-- LỊCH SỬ VERSION -->
            @if (submission?.Versions != null &&
                    submission.Versions.Any())
            {
                <div class="st-version-section">

                    <h4 class="st-section-title">
                        Lịch sử phiên bản
                    </h4>

                    <div class="st-table-wrap">

                        <table class="st-version-table">

                            <thead>
                                <tr>
                                    <th>
                                        Version
                                    </th>

                                    <th>
                                        File
                                    </th>

                                    <th>
                                        Ngày upload
                                    </th>
                                </tr>
                            </thead>

                            <tbody>

                                @{
                                    var latestVersion = submission.Versions.Max(x => x.VersionNumber);
                                }

                                @foreach (var v in submission.Versions
                                                        .OrderByDescending(x => x.VersionNumber))
                                {
                                    <tr>

                                        <td class="st-version-number">

                                            v@v.VersionNumber

                                            @if (v.VersionNumber == latestVersion)
                                            {
                                                <span class="st-latest-badge">
                                                    Latest
                                                </span>
                                            }

                                        </td>

                                        <td>

                                            @if (!string.IsNullOrWhiteSpace(v.FilePath))
                                            {
                                                <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = v.TimelineSubmissionId, versionId = v.Id })"
                                                   target="_blank"
                                                   class="st-file-link">
                                                    @(string.IsNullOrWhiteSpace(v.FileName) ? $"Phiên bản {v.VersionNumber}" : v.FileName)
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="st-no-file">Không có file</span>
                                            }

                                        </td>

                                        <td class="st-upload-time">

                                            @v.UploadedAt.ToString("dd/MM/yyyy HH:mm")

                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>
            }

        </div>
    }

</div>
