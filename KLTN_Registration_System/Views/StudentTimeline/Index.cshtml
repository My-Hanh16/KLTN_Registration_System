@model IEnumerable<KLTN_Registration_System.Models.Entities.Timeline>

@using KLTN_Registration_System.Models.Entities
@using KLTN_Registration_System.Models.Enums

@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Timeline";

    var submissions =
        ViewBag.Submissions as List<TimelineSubmission> ?? new List<TimelineSubmission>();
}

<div class="space-y-6">
    @if (TempData["Success"] != null)
    {
        <div class="p-4 rounded-xl bg-green-50 border border-green-200 text-green-700 font-semibold">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 font-semibold">
            @TempData["Error"]
        </div>
    }

    <h2 class="text-3xl font-bold">
        Timeline & Báo cáo tiến độ
    </h2>

    @foreach (var item in Model)
    {
        var submission = submissions
        .FirstOrDefault(x => x.TimelineId == item.Id);
        var canSubmit = item.IsActive
            && item.AllowSubmission
            && (!item.SubmissionDeadline.HasValue || DateTime.Now <= item.SubmissionDeadline.Value)
            && (submission == null || submission.Status == SubmissionStatus.Rejected);

        <div class="bg-white rounded-2xl p-6 shadow">

            <!-- HEADER -->
            <div class="flex justify-between items-center">

                <div>
                    <h3 class="text-xl font-bold">
                        @item.Title
                    </h3>

                    <p class="text-gray-500">
                        @item.Description
                    </p>
                </div>

                <div class="text-right">
                    <div class="font-bold text-blue-600">
                        @item.Date.ToString("dd/MM/yyyy")
                    </div>
                    @if (item.SubmissionDeadline.HasValue)
                    {
                        <div class="text-sm text-gray-500">
                            Hạn nộp: @item.SubmissionDeadline.Value.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    }
                </div>

            </div>

            <!-- TRẠNG THÁI NỘP -->
            @if (submission != null)
            {
                <div class="mt-4 p-4 rounded-xl bg-gray-50 border">

                    <div class="flex justify-between items-center">

                        <div>
                            <div class="font-semibold text-green-600">
                                Đã nộp báo cáo
                            </div>

                            <div class="text-sm text-gray-500">
                                @submission.SubmittedAt
                                .ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>

                        <div>
                            @if (submission.Status.ToString() == "Pending")
                            {
                                <span class="px-3 py-1 rounded-full text-sm bg-yellow-100 text-yellow-700">
                                    Chờ duyệt
                                </span>
                            }
                            else if (submission.Status.ToString() == "Approved")
                            {
                                <span class="px-3 py-1 rounded-full text-sm bg-green-100 text-green-700">
                                    Đã duyệt
                                </span>
                            }
                            else if (submission.Status.ToString() == "Rejected")
                            {
                                <span class="px-3 py-1 rounded-full text-sm bg-red-100 text-red-700">
                                    Từ chối
                                </span>
                            }
                            else
                            {
                                <span class="px-3 py-1 rounded-full text-sm bg-gray-100 text-gray-700">
                                    @submission.Status
                                </span>
                            }
                        </div>

                    </div>

                    <!-- COMMENT -->
                    @if (!string.IsNullOrEmpty(submission.Comment))
                    {
                        <div class="mt-4 p-3 bg-white rounded-xl border">

                            <div class="font-semibold mb-1">
                                Nhận xét giảng viên
                            </div>

                            <div class="text-gray-700">
                                @submission.Comment
                            </div>

                        </div>
                    }

                    <!-- SCORE -->
                    @if (submission.Score != null)
                    {
                        <div class="mt-3">
                            <span class="font-semibold">
                                Điểm:
                            </span>

                            <span class="text-blue-600 font-bold">
                                @submission.Score
                            </span>
                        </div>
                    }

                </div>
            }

            <!-- FORM NỘP -->
            @if (canSubmit)
            {
                <form method="post"
                      asp-action="Submit"
                      enctype="multipart/form-data"
                      class="mt-6 space-y-4">
                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="timelineId"
                           value="@item.Id" />

                    <textarea name="content"
                          class="w-full border rounded-xl p-3"
                          rows="4"
                          placeholder="Nhập báo cáo tiến độ...">@submission?.ProgressDescription</textarea>

                    <input type="file"
                           name="file"
                           accept=".pdf,.doc,.docx,.ppt,.pptx,.zip,.rar,.txt"
                           class="w-full border rounded-xl p-2"
                           required />

                    <button type="submit"
                            class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-xl transition">
                        @(submission == null ? "Nộp báo cáo" : "Nộp lại phiên bản mới")
                    </button>

                </form>
            }
            else if (!item.AllowSubmission)
            {
                <div class="mt-6 p-4 rounded-xl bg-gray-50 border text-gray-500">
                    Mốc này chưa mở chức năng nộp bài.
                </div>
            }
            else if (item.SubmissionDeadline.HasValue && DateTime.Now > item.SubmissionDeadline.Value)
            {
                <div class="mt-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-600">
                    Đã quá hạn nộp bài.
                </div>
            }

            <!-- LỊCH SỬ VERSION -->
            @if (submission?.Versions != null &&
                    submission.Versions.Any())
            {
                <div class="mt-6">

                    <h4 class="font-bold text-lg mb-3">
                        Lịch sử phiên bản
                    </h4>

                    <div class="overflow-x-auto">

                        <table class="w-full border rounded-xl overflow-hidden">

                            <thead class="bg-gray-100">
                                <tr>
                                    <th class="p-3 text-left">
                                        Version
                                    </th>

                                    <th class="p-3 text-left">
                                        File
                                    </th>

                                    <th class="p-3 text-left">
                                        Ngày upload
                                    </th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var v in submission.Versions
                                                        .OrderByDescending(x => x.VersionNumber))
                                {
                                    <tr class="border-t hover:bg-gray-50">

                                        <td class="p-3 font-semibold">

                                            v@v.VersionNumber

                                            @if (v.VersionNumber ==
                                                                            submission.Versions.Max(x => x.VersionNumber))
                                            {
                                                <span class="ml-2 px-2 py-1 text-xs rounded-full bg-green-100 text-green-700">
                                                    Latest
                                                </span>
                                            }

                                        </td>

                                        <td class="p-3">

                                            <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = v.TimelineSubmissionId, versionId = v.Id })"
                                               target="_blank"
                                               class="text-blue-600 hover:underline">

                                                @v.FileName

                                            </a>

                                        </td>

                                        <td class="p-3 text-gray-600">

                                            @v.UploadedAt
                                            .ToString("dd/MM/yyyy HH:mm")

                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>
            }

        </div>
    }

</div>
