@using KLTN_Registration_System.Models.Entities
@model IEnumerable<Topic>

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Quản lý kho đề tài";

    bool isAdmin   = User.IsInRole("Admin");
    string createUrl = isAdmin ? "/Admin/Create" : "/Lecturer/Create";
    int totalTopics = ViewBag.TotalTopics ?? Model.Count();
    int openTopics = ViewBag.OpenTopics ?? Model.Count(t => t.IsApproved && t.IsRegistrationOpen);
    int fullTopics = ViewBag.FullTopics ?? Model.Count(t => t.Status == TopicStatus.Full || (t.IsApproved && !t.IsRegistrationOpen && !string.IsNullOrWhiteSpace(t.CreatedByStudentId)));
    int closedTopics = ViewBag.ClosedTopics ?? Model.Count(t => t.Status == TopicStatus.Closed || t.Status == TopicStatus.Full || (t.IsApproved && !t.IsRegistrationOpen && !string.IsNullOrWhiteSpace(t.CreatedByStudentId)));
    int readyTopics = ViewBag.ReadyTopics ?? Model.Count(t => t.IsApproved && !t.IsRegistrationOpen && t.Status == TopicStatus.Available);
    var activePeriod = ViewBag.ActivePeriod as RegistrationPeriod;
    var selectedPeriod = ViewBag.SelectedPeriod as RegistrationPeriod ?? activePeriod;
    var periods = ViewBag.RegistrationPeriods as IEnumerable<RegistrationPeriod> ?? Enumerable.Empty<RegistrationPeriod>();
    int? selectedPeriodId = ViewBag.SelectedPeriodId as int?;
    bool isViewingOldPeriod = ViewBag.IsViewingOldPeriod == true;
    bool adminReadOnlyOldPeriod = isAdmin && isViewingOldPeriod;
    string periodText = selectedPeriod?.Name ?? activePeriod?.Name ?? "đợt hiện tại";
}

@section Styles {
    <link rel="stylesheet" href="~/css/shared/topic-list.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="page-title">Quản lý kho đề tài</h2>
        <p class="page-sub">@(isAdmin ? "Biên soạn và theo dõi tiến độ các đề tài luận văn trong kỳ học này." : $"Theo dõi đề tài trong {periodText}; có thể xem lại đợt cũ để tránh trùng và sao chép dùng lại.")</p>
    </div>

    <div class="d-flex align-items-center gap-2 flex-wrap">

        @if (!adminReadOnlyOldPeriod)
        {
            <form asp-action="ImportTopics" method="post" enctype="multipart/form-data" id="importExcelForm" style="display:none;">
                @Html.AntiForgeryToken()
                <input type="file" name="file" id="excelInput" accept=".xlsx,.xls" onchange="handleFileSelect()">
            </form>

            <button type="button" id="importBtn" class="btn-header" onclick="document.getElementById('excelInput').click()">
                <i class="fa-solid fa-file-import"></i> Nhập Excel
            </button>
        }

        @if (isAdmin)
        {
            <a href="/Admin/ExportRegistrations?status=Approved" class="btn-header green">
                <i class="fa-solid fa-circle-check"></i> Xuất SV đã duyệt
            </a>
            <a href="/Admin/ExportRegistrations?status=Pending" class="btn-header amber">
                <i class="fa-solid fa-clock"></i> Xuất chờ duyệt
            </a>
            <a href="/Admin/ExportRegistrations" class="btn-header" title="Xuất tất cả">
                <i class="fa-solid fa-download"></i>
            </a>
        }

        @if (!adminReadOnlyOldPeriod)
        {
            <button type="button" class="btn-header primary" onclick="openCreateModal()">
                <i class="fa-solid fa-plus"></i> Tạo đề tài
            </button>
        }
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Tổng đề tài</div>
        <div class="stat-number">@totalTopics</div>
    </div>
    <div class="stat-card blue-accent">
        <div class="stat-label blue">Đang tuyển</div>
        <div class="stat-number">@openTopics</div>
    </div>
    <div class="stat-card orange-accent">
        <div class="stat-label orange">Đã đủ SV</div>
        <div class="stat-number">@fullTopics</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Sẵn sàng / Đã đóng</div>
        <div class="stat-number">@readyTopics / @closedTopics</div>
    </div>
</div>

<div class="filter-box">
    <form id="filterForm" method="get">
        <div class="d-flex align-items-end gap-4 flex-wrap">

            @if (periods.Any())
            {
                <div>
                    <span class="filter-label">Đợt đề tài</span>
                    <select name="periodId" class="filter-select" onchange="this.form.submit()">
                        @foreach (var period in periods)
                        {
                            <option value="@period.Id" selected="@(selectedPeriodId == period.Id)">
                                @(period.IsActive ? "Đợt hiện tại - " : "")@period.Name
                            </option>
                        }
                    </select>
                </div>
            }

            <div>
                <span class="filter-label">Bộ môn</span>
                <select name="majorId" class="filter-select" onchange="this.form.submit()">
                    <option value="">Tất cả bộ môn</option>
                    @if (ViewBag.Majors != null)
                    {
                        foreach (var major in ViewBag.Majors)
                        {
                            <option value="@major.Id"
                                    selected="@(Context.Request.Query["majorId"] == major.Id.ToString())">
                                @major.Name
                            </option>
                        }
                    }
                </select>
            </div>

            <div>
                <span class="filter-label">Trạng thái</span>
                <input type="hidden" name="status" id="statusInput" value="@Context.Request.Query["status"]" />
                <div class="filter-chips">
                    @{
                        var currentStatus = Context.Request.Query["status"].ToString();
                    }
                    <button type="button" onclick="filterByStatus('')"
                            class="filter-chip @(string.IsNullOrEmpty(currentStatus) ? "active" : "")">Tất cả</button>
                    <button type="button" onclick="filterByStatus('Available')"
                            class="filter-chip @(currentStatus == "Available" ? "active" : "")">Đang tuyển</button>
                    <button type="button" onclick="filterByStatus('Full')"
                            class="filter-chip @(currentStatus == "Full" ? "active" : "")">Đã đủ</button>
                    <button type="button" onclick="filterByStatus('Pending')"
                            class="filter-chip @(currentStatus == "Pending" ? "active" : "")">Chờ duyệt</button>
                    <button type="button" onclick="filterByStatus('Closed')"
                            class="filter-chip @(currentStatus == "Closed" ? "active" : "")">Đã đóng</button>
                </div>
            </div>

        </div>
    </form>
</div>

@if (isAdmin && !adminReadOnlyOldPeriod)
{
    <div class="bulk-toolbar">
        <label class="bulk-label">
            <input type="checkbox" id="selectAllPending" style="width:15px;height:15px;accent-color:#4f46e5;cursor:pointer;" />
            Chọn tất cả
        </label>
        <button type="button" class="btn-bulk approve" onclick="bulkApprove()">
            <i class="fa-solid fa-check"></i> Duyệt đã chọn
        </button>
        <button type="button" class="btn-bulk reject" onclick="bulkReject()">
            <i class="fa-solid fa-xmark"></i> Từ chối đã chọn
        </button>
    </div>
}

<div class="topics-grid">
    @foreach (var item in Model)
    {
        bool isPrivateApprovedProposal = item.IsApproved
            && !item.IsRegistrationOpen
            && !string.IsNullOrWhiteSpace(item.CreatedByStudentId);

        string sClass = isPrivateApprovedProposal ? "s-full"
                      : item.Status == TopicStatus.Available && item.IsRegistrationOpen ? "s-available"
                      : item.Status == TopicStatus.Available && !item.IsRegistrationOpen ? "s-pending"
                      : item.Status == TopicStatus.Pending   ? "s-pending"
                      : item.Status == TopicStatus.Full      ? "s-full"
                      : "s-closed";

        string sText  = isPrivateApprovedProposal ? "Đã đủ SV"
                      : item.Status == TopicStatus.Available && item.IsRegistrationOpen ? "Đang tuyển"
                      : item.Status == TopicStatus.Available && !item.IsRegistrationOpen ? "Sẵn sàng"
                      : item.Status == TopicStatus.Pending   ? "Chờ duyệt"
                      : item.Status == TopicStatus.Full      ? "Đã đủ SV"
                      : "Đã đóng";

        bool isPending = item.Status == TopicStatus.Pending;
        int approvedCount = item.Registrations?.Count(r => r.Status == "Approved") ?? 0;
        bool isLockedForEditDelete = item.Status == TopicStatus.Closed
            || item.Status == TopicStatus.Full
            || (item.MaxStudents > 0 && approvedCount >= item.MaxStudents);

        <div class="topic-card">

            @if (isPending && isAdmin && !adminReadOnlyOldPeriod)
            {
                <div class="bulk-check-wrap">
                    <input type="checkbox" class="pending-checkbox" value="@item.Id" />
                </div>
            }

            <div class="d-flex justify-content-between align-items-start @(isPending && isAdmin && !adminReadOnlyOldPeriod ? "ps-4" : "")">
                <div>
                    @if (isAdmin)
                    {
                        <div class="lecturer-tag mb-1">
                            <i class="fa-solid fa-user-tie"></i>
                            @(item.Lecturer?.FullName ?? "Chưa phân công")
                        </div>
                    }
                </div>
                <span class="topic-status @sClass">
                    <span class="status-dot"></span>
                    @sText
                </span>
            </div>

            <div>
                <p class="topic-title">@item.Title</p>
                <p class="topic-code">Mã: <span>@item.TopicCode</span></p>
            </div>

            <div class="topic-info-box">
                <div>
                    <div class="info-label">Số lượng SV</div>
                    <div class="info-value">
                        @(item.Registrations?.Count(r => r.Status == "Approved") ?? 0) / @item.MaxStudents
                    </div>
                </div>
                <div class="info-divider"></div>
                <div class="registration-state flex-grow-1">
                    <span class="registration-label">Đăng ký:</span>
                    <span class="registration-pill @(item.IsRegistrationOpen ? "open" : "locked")">
                        <i class="fa-solid @(item.IsRegistrationOpen ? "fa-unlock" : "fa-lock")"></i>
                        @(item.IsRegistrationOpen ? "Đang mở" : isPrivateApprovedProposal || item.Status == TopicStatus.Closed ? "Đã đóng" : "Chưa mở")
                    </span>
                </div>
            </div>

            <div class="card-actions">

                @if (isPending && isAdmin && !adminReadOnlyOldPeriod)
                {
                    <div class="action-row">
                        <form asp-action="ApproveTopic" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn-card-action approve w-100">
                                <i class="fa-solid fa-check"></i> Duyệt
                            </button>
                        </form>
                        <form asp-action="RejectTopic" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn-card-action reject-btn w-100">
                                <i class="fa-solid fa-xmark"></i> Từ chối
                            </button>
                        </form>
                    </div>
                }

                @if (isAdmin || !isViewingOldPeriod)
                {
                    <div class="action-row">
                        <a asp-controller="@(isAdmin ? "Admin" : "Lecturer")"
                           asp-action="TopicRegistrations"
                           asp-route-id="@item.Id"
                           class="btn-card-action">
                            <i class="fa-solid fa-users"></i>
                            Danh sách @(item.CurrentStudents > 0 ? $"({item.CurrentStudents})" : "")
                        </a>
                        <a asp-controller="Timeline"
                           asp-action="Index"
                           asp-route-topicId="@item.Id"
                           class="btn-card-action">
                            <i class="fa-solid fa-timeline"></i> Tiến độ
                        </a>
                    </div>
                }

                @if (!isAdmin && isViewingOldPeriod)
                {
                    <form asp-controller="Lecturer"
                          asp-action="CopyTopicToActivePeriod"
                          method="post"
                          class="m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="hidden" name="periodId" value="@selectedPeriodId" />
                        <input type="hidden" name="status" value="@Context.Request.Query["status"]" />
                        <input type="hidden" name="majorId" value="@Context.Request.Query["majorId"]" />
                        <button type="submit"
                                class="btn-card-action approve w-100"
                                data-confirm-copy="Sao chép đề tài này sang đợt hiện tại?">
                            <i class="fa-solid fa-copy"></i> Sao chép sang đợt hiện tại
                        </button>
                    </form>
                }

                @if (isAdmin)
                {
                    @if (adminReadOnlyOldPeriod)
                    {
                        <button type="button" class="btn-card-action locked-action w-100" disabled>
                            <i class="fa-solid fa-lock"></i> Đề tài đợt cũ, admin chỉ được xem
                        </button>
                    }
                    else if (isLockedForEditDelete)
                    {
                        <button type="button" class="btn-card-action locked-action w-100" disabled>
                            <i class="fa-solid fa-lock"></i> Đề tài đã đóng/đủ SV, không thể sửa/xóa
                        </button>
                    }
                    else
                    {
                        <div class="action-row">
                            <button type="button"
                               class="btn-card-action"
                               data-edit-topic
                               data-id="@item.Id"
                               data-title="@item.Title"
                               data-description="@item.Description"
                               data-lecturer-id="@item.LecturerId"
                               data-major-id="@item.MajorId"
                               data-level="@item.Level"
                               data-max-students="@item.MaxStudents"
                               data-status="@item.Status"
                               data-deadline="@item.Deadline.ToString("yyyy-MM-ddTHH:mm")"
                               data-category="@item.Category"
                               data-is-approved="@item.IsApproved.ToString().ToLowerInvariant()"
                               data-is-registration-open="@item.IsRegistrationOpen.ToString().ToLowerInvariant()"
                               data-note="@item.Note">
                                <i class="fa-solid fa-pen"></i> Sửa
                            </button>
                            <form asp-action="DeleteTopic" method="post"
                                  onsubmit="confirmDelete(event, this)" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn-card-action danger w-100">
                                    <i class="fa-solid fa-trash"></i> Xóa
                                </button>
                            </form>
                        </div>
                    }
                }

            </div>
        </div>
    }
</div>

<!-- PAGINATION -->
@if (ViewBag.TotalPages > 1)
{
    <div class="pagination-wrap">
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <a href="?page=@i&status=@Context.Request.Query["status"]&majorId=@Context.Request.Query["majorId"]&periodId=@Context.Request.Query["periodId"]"
               class="page-btn @(i == ViewBag.CurrentPage ? "active" : "")">@i</a>
        }
    </div>
}

@if (isAdmin)
{
    <!-- MODAL SỬA ĐỀ TÀI -->
    <div id="editModal" class="modal-overlay" onclick="if(event.target===this)closeEditModal()">
        <div class="modal-box" onclick="event.stopPropagation()">

            <div class="modal-head">
                <div>
                    <p class="modal-head-title">Sửa đề tài</p>
                    <p class="modal-head-sub">Cập nhật thông tin đề tài ngay trên danh sách</p>
                </div>
                <button type="button" class="modal-close" onclick="closeEditModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <form id="editTopicForm" onsubmit="submitEditTopic(event)">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" />

                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Tên đề tài <span style="color:#ef4444;">*</span></label>
                        <input name="Title" required class="form-control-custom" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mô tả <span style="color:#ef4444;">*</span></label>
                        <textarea name="Description" rows="3" required class="form-control-custom"></textarea>
                    </div>

                    <div class="form-grid-2">
                        <div class="form-group">
                            <label class="form-label">Giảng viên hướng dẫn</label>
                            <select name="LecturerId" class="form-control-custom">
                                <option value="">-- Chưa phân công --</option>
                                @if (ViewBag.Lecturers != null)
                                {
                                    foreach (var lec in ViewBag.Lecturers)
                                    {
                                        <option value="@lec.Id">@lec.FullName</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Chuyên ngành</label>
                            <select name="MajorId" class="form-control-custom">
                                <option value="">-- Không chọn --</option>
                                @if (ViewBag.Majors != null)
                                {
                                    foreach (var major in ViewBag.Majors)
                                    {
                                        <option value="@major.Id">@major.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Mức độ</label>
                            <select name="Level" class="form-control-custom">
                                <option value="Easy">Cơ bản</option>
                                <option value="Medium">Trung bình</option>
                                <option value="Hard">Nâng cao</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Tối đa SV</label>
                            <input type="number" name="MaxStudents" min="1" max="10" class="form-control-custom" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Trạng thái</label>
                            <select name="Status" class="form-control-custom">
                                <option value="Available">Còn chỗ</option>
                                <option value="Full">Đã đầy</option>
                                <option value="Closed">Đóng</option>
                                <option value="Pending">Chờ duyệt</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Hạn đăng ký</label>
                            <input type="datetime-local" name="Deadline" class="form-control-custom" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Phân loại</label>
                            <select name="Category" class="form-control-custom">
                                <option value="Ứng dụng">Ứng dụng</option>
                                <option value="Nghiên cứu">Nghiên cứu</option>
                                <option value="Phân tích">Phân tích</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Tùy chọn</label>
                            <label class="student-chip" style="width:100%;justify-content:flex-start;">
                                <input type="checkbox" name="IsApproved" value="true" style="accent-color:#4f46e5;" />
                                Đã phê duyệt
                            </label>
                            <label class="student-chip" style="width:100%;justify-content:flex-start;margin-top:8px;">
                                <input type="checkbox" name="IsRegistrationOpen" value="true" style="accent-color:#4f46e5;" />
                                Mở đăng ký
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Ghi chú</label>
                        <textarea name="Note" rows="2" class="form-control-custom"></textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-modal-cancel" onclick="closeEditModal()">Hủy</button>
                    <button type="submit" class="btn-modal-submit" id="submitEditBtn">
                        <i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi
                    </button>
                </div>
            </form>

        </div>
    </div>
}

<!-- MODAL TẠO ĐỀ TÀI -->
<div id="createModal" class="modal-overlay" onclick="if(event.target===this)closeCreateModal()">
    <div class="modal-box" onclick="event.stopPropagation()">

        <div class="modal-head">
            <div>
                <p class="modal-head-title">Tạo đề tài mới</p>
                <p class="modal-head-sub">Thêm đề tài nghiên cứu vào hệ thống</p>
            </div>
            <button type="button" class="modal-close" onclick="closeCreateModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form id="createTopicForm" onsubmit="submitCreateTopic(event)">
            @Html.AntiForgeryToken()

            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Tên đề tài <span style="color:#ef4444;">*</span></label>
                    <input name="Title" required placeholder="Nhập tên đề tài..."
                           class="form-control-custom" />
                </div>

                <div class="form-group">
                    <label class="form-label">Mô tả</label>
                    <textarea name="Description" rows="3"
                              placeholder="Mô tả chi tiết đề tài..."
                              class="form-control-custom"></textarea>
                </div>

                <div class="form-grid-2">
                    <div class="form-group">
                        <label class="form-label">Bộ môn</label>
                        <select name="MajorId" class="form-control-custom">
                            @if (ViewBag.Majors != null)
                            {
                                foreach (var major in ViewBag.Majors)
                                {
                                    <option value="@major.Id">@major.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Độ khó</label>
                        <select name="Level" class="form-control-custom">
                            <option value="Easy">Dễ</option>
                            <option value="Medium">Trung bình</option>
                            <option value="Hard">Khó</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Số lượng SV tối đa</label>
                        <input type="number" name="MaxStudents" min="1" value="1"
                               class="form-control-custom" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Hạn đăng ký</label>
                        <input type="date" name="Deadline" class="form-control-custom" />
                    </div>
                </div>

                @if (isAdmin)
                {
                    <div class="form-group">
                        <label class="form-label">Giảng viên hướng dẫn</label>
                        <select name="LecturerId" class="form-control-custom">
                            <option value="">-- Chọn giảng viên --</option>
                            @if (ViewBag.Lecturers != null)
                            {
                                foreach (var lec in ViewBag.Lecturers)
                                {
                                    <option value="@lec.Id">@lec.FullName</option>
                                }
                            }
                        </select>
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-modal-cancel" onclick="closeCreateModal()">Hủy</button>
                <button type="submit" class="btn-modal-submit" id="submitCreateBtn">
                    <i class="fa-solid fa-plus"></i> Tạo đề tài
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div id="topic-list-config"
     data-create-url="@createUrl"
     data-edit-url="/Admin/EditTopic"
     data-is-admin="@(isAdmin.ToString().ToLowerInvariant())"
     hidden></div>
<script src="~/js/shared/topic-list.js" asp-append-version="true"></script>

@if (TempData["Success"] != null)
{
    <div id="tempdata-msg"
         data-msg="@TempData["Success"]"
         data-type="success"
         style="display:none;"></div>
}
@if (TempData["Error"] != null)
{
    <div id="tempdata-msg"
         data-msg="@TempData["Error"]"
         data-type="error"
         style="display:none;"></div>
}
}

