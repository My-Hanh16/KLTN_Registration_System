@{
    var controller = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";

    string IsActive(string targetController, string? targetAction = null)
    {
        var controllerMatches = string.Equals(controller, targetController, StringComparison.OrdinalIgnoreCase);
        var actionMatches = string.IsNullOrWhiteSpace(targetAction)
            || string.Equals(action, targetAction, StringComparison.OrdinalIgnoreCase);

        return controllerMatches && actionMatches ? "active" : "";
    }

    string dashboardController = User.IsInRole("Admin")
        ? "Admin"
        : User.IsInRole("Lecturer")
            ? "Lecturer"
            : "Student";
    string dashboardAction = User.IsInRole("Student") ? "Home" : "Index";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KLTN Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KLTN_Registration_System.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-graduation-cap me-2"></i>KLTN PORTAL
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Mở menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark @IsActive("Home", "Index")"
                               asp-controller="Home"
                               asp-action="Index">Trang chủ</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark @IsActive(dashboardController, dashboardAction)"
                                   asp-controller="@dashboardController"
                                   asp-action="@dashboardAction">Bảng điều khiển</a>
                            </li>

                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark @IsActive("Student", "MyRegistration")"
                                       asp-controller="Student"
                                       asp-action="MyRegistration">Đăng ký của tôi</a>
                                </li>
                            }
                        }

                        <li class="nav-item">
                            <a class="nav-link text-dark @IsActive("Topic", "Index")"
                               asp-controller="Topic"
                               asp-action="Index">Danh sách đề tài</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="nav-link text-dark">
                                    <i class="fa-regular fa-circle-user me-1 text-primary"></i>
                                    Xin chào <strong>@User.Identity.Name</strong>
                                </span>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="nav-link btn btn-link p-0 text-secondary ms-3">
                                        <i class="fa-solid fa-right-from-bracket me-1"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-primary px-4 border-0"
                                   asp-controller="Account"
                                   asp-action="Login">Đăng nhập</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["Success"] != null)
            {
                <div class="portal-alert portal-alert-success">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>@TempData["Success"]</span>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="portal-alert portal-alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@TempData["Error"]</span>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light">
        <div class="container text-center py-3">
            &copy; 2026 - <strong>KLTN Portal</strong> - Hệ thống đăng ký khóa luận tốt nghiệp
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
