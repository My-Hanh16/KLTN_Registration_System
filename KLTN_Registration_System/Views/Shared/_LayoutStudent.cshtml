@using Microsoft.AspNetCore.Identity
@using KLTN_Registration_System.Models.Entities
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KLTN Portal</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <link rel="stylesheet" href="~/css/student/student-layout.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body>

    @{
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
        var action = ViewContext.RouteData.Values["action"]?.ToString();
        var currentUser = await UserManager.GetUserAsync(User);
        var unread = (int)(ViewBag.UnreadCount ?? 0);
        var studentCode = !string.IsNullOrWhiteSpace(currentUser?.UserCode)
            ? currentUser.UserCode
            : "STUDENT";

        string initials = "SV";
        if (!string.IsNullOrEmpty(currentUser?.FullName))
        {
            var parts = currentUser.FullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            initials = parts.Length >= 2
            ? $"{parts[^2][0]}{parts[^1][0]}".ToUpper()
            : currentUser.FullName[0].ToString().ToUpper();
        }
        else if (!string.IsNullOrEmpty(currentUser?.Email))
        {
            initials = currentUser.Email[0].ToString().ToUpper();
        }
    }

    <div class="sidebar-backdrop" data-close-sidebar></div>

    <!-- ═══════════════ SIDEBAR ═══════════════ -->
    <nav class="sidebar">

        <div class="sidebar-brand">
            <h4>KLTN PORTAL</h4>
            <small>Student Dashboard</small>
        </div>

        <div class="sidebar-nav">

            <div class="menu-section">Danh mục chính</div>

            <a asp-controller="Student" asp-action="Home"
               class="menu-item @(ctrl == "Student" && action == "Home" ? "active" : "")">
                <i class="fa-solid fa-border-all"></i>
                <span>Tổng quan</span>
            </a>

            <a asp-controller="Topic" asp-action="Index"
               class="menu-item @(ctrl == "Topic" && action == "Index" ? "active" : "")">
                <i class="fa-regular fa-folder-open"></i>
                <span>Danh sách đề tài</span>
            </a>

            <a asp-controller="Student" asp-action="MyRegistration"
               class="menu-item @(action == "MyRegistration" ? "active" : "")">
                <i class="fa-regular fa-square-check"></i>
                <span>Đăng ký của tôi</span>
            </a>

            <div class="menu-section">Quản lý khóa luận</div>

            <a asp-controller="Student" asp-action="Timeline"
               class="menu-item @(action == "Timeline" ? "active" : "")">
                <span class="material-symbols-outlined">timeline</span>
                <span>Timeline</span>
            </a>

            @if (currentUser?.HasCompletedThesis == true)
            {
                <span class="menu-item" title="Bạn đã hoàn thành KLTN nên không thể đề xuất ở đợt sau.">
                    <i class="fa-solid fa-lock"></i>
                    <span>Đề xuất đề tài</span>
                </span>
            }
            else
            {
                <a asp-controller="Student" asp-action="ProposeTopic"
                   class="menu-item @(action == "ProposeTopic" ? "active" : "")">
                    <i class="fa-regular fa-lightbulb"></i>
                    <span>Đề xuất đề tài</span>
                </a>
            }

            @{
                var activeTopicId = ViewBag.ActiveTopicId as int?;
            }
            @if (activeTopicId != null)
            {
                <a asp-controller="Chat" asp-action="Topic" asp-route-topicId="@activeTopicId"
                   class="menu-item @(ctrl == "Chat" ? "active" : "")">
                    <i class="fa-regular fa-comments"></i>
                    <span>Trao đổi GVHD</span>
                </a>
            }

            <div class="menu-section">Cá nhân & hệ thống</div>

            <a asp-controller="Student" asp-action="Notifications"
               class="menu-item @(action == "Notifications" ? "active" : "")">
                <i class="fa-regular fa-bell"></i>
                <span>Thông báo</span>
                <span class="menu-badge @(unread > 0 ? "" : "is-hidden")"
                      data-notif-badge>@(unread > 9 ? "9+" : unread.ToString())</span>
            </a>

            <a asp-controller="Student" asp-action="Profile"
               class="menu-item @(action == "Profile" ? "active" : "")">
                <i class="fa-regular fa-user"></i>
                <span>Hồ sơ cá nhân</span>
            </a>

        </div>

        <div class="sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="menu-item logout-btn">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i>
                    <span>Đăng xuất</span>
                </button>
            </form>
        </div>

    </nav>

    <!-- ═══════════════ MAIN ═══════════════ -->
    <div class="main-wrapper">

        <!-- TOPBAR -->
        <header class="topbar">
            <button type="button" class="mobile-menu-btn" id="studentMenuBtn" aria-label="Mở menu">
                <i class="fa-solid fa-bars"></i>
            </button>

            <div class="search-wrap">
                <form asp-controller="Topic" asp-action="Index" method="get">
                    <input type="text" name="search"
                           value="@Context.Request.Query["search"]"
                           placeholder="Tìm kiếm đề tài, giảng viên..." />
                </form>
            </div>

            <div class="topbar-right">

                <!-- Thông báo -->
                <a asp-controller="Student" asp-action="Notifications"
                   class="topbar-icon-btn" title="Thông báo">
                    <i class="fa-regular fa-bell"></i>
                    <span class="notif-dot @(unread > 0 ? "" : "is-hidden")"
                          data-notif-badge>@(unread > 9 ? "9+" : unread.ToString())</span>
                </a>

                <div class="topbar-divider"></div>

                <!-- User chip -->
                <a asp-controller="Student" asp-action="Profile" class="user-chip text-decoration-none">
                    <div class="user-avatar">@initials</div>
                    <div class="user-info-text">
                        <div class="u-name">
                            @(currentUser?.FullName ?? currentUser?.UserName ?? "Student")
                        </div>
                        <div class="u-role">@studentCode • STUDENT</div>
                    </div>
                </a>

            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="page-content">
            @RenderBody()
        </main>

    </div>

    <!-- ═══════════════ TOAST ═══════════════ -->
    <div class="toast-wrap" id="toastWrap">

        @if (TempData["Success"] != null)
        {
            <div class="toast-item success" id="toastSuccess">
                <div class="toast-icon"><i class="fa-solid fa-circle-check"></i></div>
                <div class="toast-body">
                    <div class="t-title">Thành công</div>
                    <div class="t-msg">@TempData["Success"]</div>
                </div>
                <button class="toast-close" data-toast-close="toastSuccess">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="toast-item error" id="toastError">
                <div class="toast-icon"><i class="fa-solid fa-circle-exclamation"></i></div>
                <div class="toast-body">
                    <div class="t-title">Có lỗi xảy ra</div>
                    <div class="t-msg">@TempData["Error"]</div>
                </div>
                <button class="toast-close" data-toast-close="toastError">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }

    </div>

    <script src="~/js/student/student-layout.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
    @if (User.Identity?.IsAuthenticated == true)
    {
        <partial name="_NotificationSignalR" />
    }

</body>
</html>

