@using Microsoft.AspNetCore.Identity
@using KLTN_Registration_System.Models.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    string? adminSelectedSemester = ViewBag.AdminSelectedSemester as string;
    string? adminSelectedYear = ViewBag.AdminSelectedYear as string;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KLTN Portal</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <script src="~/js/shared/layout-dashboard-tailwind.js" asp-append-version="true"></script>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="~/css/shared/layout-dashboard.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body>

    @{
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
        var action = ViewContext.RouteData.Values["action"]?.ToString();
        var currentUser = await UserManager.GetUserAsync(User);

        // Initials
        string initials = "AD";
        if (!string.IsNullOrEmpty(currentUser?.FullName))
        {
            var parts = currentUser.FullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            initials = parts.Length >= 2
            ? $"{parts[^2][0]}{parts[^1][0]}".ToUpper()
            : currentUser.FullName[0].ToString().ToUpper();
        }
        else if (!string.IsNullOrEmpty(currentUser?.Email))
        {
            initials = currentUser.Email[0].ToString().ToUpper();
        }

        string displayName = currentUser?.FullName ?? currentUser?.UserName ?? User.Identity?.Name ?? "Người dùng";
        // Fix: bỏ lặp nghĩa "LECTURER • Giảng viên" → chọn 1 cách hiển thị
        bool isAdmin = User.IsInRole("Admin");
        string roleLabel = isAdmin ? "Quản trị viên" : "Giảng viên";
        string avatarClass = isAdmin ? "admin" : "lecturer";

        // Fix: helper active dùng tag helpers thay vì href hardcode
        Func<string, string, string> IsActive = (c, a) =>
        string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) &&
        string.Equals(action, a, StringComparison.OrdinalIgnoreCase)
        ? "menu-item active" : "menu-item";

        Func<string, string> IsActiveCtrl = (c) =>
        string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase)
        ? "menu-item active" : "menu-item";
    }

    <div class="sidebar-backdrop" data-close-sidebar></div>

    <!-- SIDEBAR -->
    <nav class="sidebar">

        <div class="sidebar-brand">
            <h4>KLTN PORTAL</h4>
            <small>@(isAdmin ? "Admin Dashboard" : "Lecturer Dashboard")</small>
        </div>

        <div class="sidebar-nav">

            @if (isAdmin)
            {
                <div class="menu-section">Tổng quan</div>

                <a asp-controller="Admin" asp-action="Statistics"
                   asp-route-semester="@adminSelectedSemester"
                   asp-route-year="@adminSelectedYear"
                   class="@IsActive("Admin", "Statistics")">
                    <i class="fa-solid fa-chart-pie"></i>
                    <span>Thống kê hệ thống</span>
                </a>

                <div class="menu-section">Quản lý</div>

                <a asp-controller="Admin" asp-action="StudentManagement"
                   asp-route-semester="@adminSelectedSemester"
                   asp-route-year="@adminSelectedYear"
                   class="@IsActive("Admin", "StudentManagement")">
                    <i class="fa-solid fa-user-graduate"></i>
                    <span>Sinh viên</span>
                </a>

                <a asp-controller="Admin" asp-action="LecturerManagement"
                   class="@IsActive("Admin", "LecturerManagement")">
                    <i class="fa-solid fa-chalkboard-user"></i>
                    <span>Giảng viên</span>
                </a>

                <a asp-controller="Admin" asp-action="ManageTopics"
                   asp-route-semester="@adminSelectedSemester"
                   asp-route-year="@adminSelectedYear"
                   class="@IsActive("Admin", "ManageTopics")">
                    <i class="fa-regular fa-file-lines"></i>
                    <span>Đề tài</span>
                </a>

                <a asp-controller="Admin" asp-action="StudentProposals"
                   class="@IsActive("Admin", "StudentProposals")">
                    <i class="fa-regular fa-lightbulb"></i>
                    <span>Đề xuất từ sinh viên</span>
                </a>

                <a asp-controller="Admin" asp-action="Approval"
                   asp-route-semester="@adminSelectedSemester"
                   asp-route-year="@adminSelectedYear"
                   class="@IsActive("Admin", "Approval")">
                    <i class="fa-regular fa-square-check"></i>
                    <span>Duyệt đăng ký</span>
                </a>

                <div class="menu-section">Tiến độ</div>

                <a asp-controller="Timeline" asp-action="Index"
                   asp-route-semester="@adminSelectedSemester"
                   asp-route-year="@adminSelectedYear"
                   class="@IsActive("Timeline", "Index")">
                    <span class="material-symbols-outlined">calendar_month</span>
                    <span>Timeline</span>
                </a>

                <a asp-controller="Timeline" asp-action="ApprovedSubmissions"
                   asp-route-semester="@adminSelectedSemester"
                   asp-route-year="@adminSelectedYear"
                   class="@IsActive("Timeline", "ApprovedSubmissions")">
                    <span class="material-symbols-outlined">task_alt</span>
                    <span>Bài đã duyệt</span>
                </a>

                <a asp-controller="Timeline" asp-action="PendingAfterDeadline"
                   asp-route-semester="@adminSelectedSemester"
                   asp-route-year="@adminSelectedYear"
                   class="@IsActive("Timeline", "PendingAfterDeadline")">
                    <span class="material-symbols-outlined">running_with_errors</span>
                    <span>Quá hạn duyệt</span>
                </a>

                <a asp-controller="Timeline" asp-action="DefenseEligibility"
                   asp-route-semester="@adminSelectedSemester"
                   asp-route-year="@adminSelectedYear"
                   class="@IsActive("Timeline", "DefenseEligibility")">
                    <span class="material-symbols-outlined">verified</span>
                    <span>Điều kiện báo cáo</span>
                </a>

                <a asp-controller="Timeline" asp-action="DefenseResults"
                   asp-route-semester="@adminSelectedSemester"
                   asp-route-year="@adminSelectedYear"
                   class="@IsActive("Timeline", "DefenseResults")">
                    <span class="material-symbols-outlined">workspace_premium</span>
                    <span>Kết quả báo cáo</span>
                </a>

                <div class="menu-section">Hệ thống</div>

                <a asp-controller="Broadcast" asp-action="Index"
                   asp-route-semester="@adminSelectedSemester"
                   asp-route-year="@adminSelectedYear"
                   class="@IsActive("Broadcast", "Index")">
                    <i class="fa-solid fa-bullhorn"></i>
                    <span>Gửi thông báo</span>
                </a>

                <a asp-controller="Admin" asp-action="Settings"
                   class="@IsActive("Admin", "Settings")">
                    <i class="fa-solid fa-gear"></i>
                    <span>Cài đặt</span>
                </a>
            }
            else
            {
                <div class="menu-section">Tổng quan</div>

                <a asp-controller="Lecturer" asp-action="Index"
                   class="@IsActive("Lecturer", "Index")">
                    <i class="fa-solid fa-border-all"></i>
                    <span>Bảng điều khiển</span>
                </a>

                <div class="menu-section">Quản lý</div>

                <a asp-controller="Lecturer" asp-action="Approval"
                   class="@IsActive("Lecturer", "Approval")">
                    <i class="fa-regular fa-square-check"></i>
                    <span>Duyệt đăng ký</span>
                </a>

                <a asp-controller="Lecturer" asp-action="ThesisManagement"
                   class="@IsActive("Lecturer", "ThesisManagement")">
                    <i class="fa-regular fa-file-lines"></i>
                    <span>Quản lý đề tài</span>
                </a>

                <a asp-controller="Lecturer" asp-action="GuidedTopics"
                   class="@IsActive("Lecturer", "GuidedTopics")">
                    <i class="fa-solid fa-user-graduate"></i>
                    <span>Đề tài hướng dẫn</span>
                </a>

                <a asp-controller="Chat" asp-action="Index"
                   class="@IsActiveCtrl("Chat")">
                    <i class="fa-regular fa-comments"></i>
                    <span>Trao đổi sinh viên</span>
                </a>

                <div class="menu-section">Tiến độ</div>

                <a asp-controller="Lecturer" asp-action="TimelineManagement"
                   class="@IsActive("Lecturer", "TimelineManagement")">
                    <span class="material-symbols-outlined">assignment_turned_in</span>
                    <span>Timeline KLTN</span>
                </a>

                <div class="menu-section">Cá nhân</div>

                <a asp-controller="Lecturer" asp-action="Profile"
                   class="@IsActive("Lecturer", "Profile")">
                    <i class="fa-regular fa-user"></i>
                    <span>Hồ sơ cá nhân</span>
                </a>

                <a asp-controller="Account" asp-action="ChangePassword"
                   class="@IsActive("Account", "ChangePassword")">
                    <i class="fa-solid fa-lock"></i>
                    <span>Đổi mật khẩu</span>
                </a>
            }

        </div>

        <div class="sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="menu-item logout-btn">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i>
                    <span>Đăng xuất</span>
                </button>
            </form>
        </div>

    </nav>

    <!-- MAIN -->
    <div class="main-wrapper">

        <!-- TOPBAR -->
        <header class="topbar">
            <button type="button" class="mobile-menu-btn" id="dashboardMenuBtn" aria-label="Mở menu">
                <i class="fa-solid fa-bars"></i>
            </button>

            <div class="search-wrap">
                <form method="get"
                      asp-controller="@(isAdmin ? "Admin" : "Lecturer")"
                      asp-action="@(isAdmin ? "ManageTopics" : "ThesisManagement")">
                    <input type="text" name="search"
                           value="@Context.Request.Query["search"]"
                           placeholder="Tìm kiếm sinh viên, đề tài..." />
                </form>
            </div>

            <div class="topbar-right">

                @if (isAdmin)
                {
                    <a asp-controller="Broadcast" asp-action="Index"
                       class="topbar-icon-btn" title="Gửi thông báo">
                        <i class="fa-solid fa-bullhorn"></i>
                    </a>
                }

                <a asp-controller="@(isAdmin ? "Admin" : "Lecturer")"
                   asp-action="@(isAdmin ? "Settings" : "Profile")"
                   class="topbar-icon-btn" title="@(isAdmin ? "Cài đặt" : "Hồ sơ")">
                    <i class="fa-solid fa-@(isAdmin ? "gear" : "user")"></i>
                </a>

                <div class="topbar-divider"></div>

                <a asp-controller="@(isAdmin ? "Admin" : "Lecturer")"
                   asp-action="@(isAdmin ? "Settings" : "Profile")"
                   class="user-chip text-decoration-none">
                    <div class="user-avatar @avatarClass">@initials</div>
                    <div class="user-info-text">
                        <div class="u-name">
                            @(displayName.Length > 20 ? displayName[..20] + "…" : displayName)
                        </div>
                        <!-- Fix: bỏ lặp nghĩa, chỉ hiện role label -->
                        <div class="u-role">@roleLabel</div>
                    </div>
                </a>

            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="page-content">

            @if (TempData["ResetSuccess"] != null)
            {
                <div class="reset-banner">
                    <div class="reset-banner-title">@TempData["ResetSuccess"]</div>
                    @if (TempData["TempPassword"] != null)
                    {
                        <div class="reset-banner-pwd">
                            Mật khẩu mới: @TempData["TempPassword"]
                        </div>
                    }
                </div>
            }

            @RenderBody()

        </main>

    </div>

    <!-- TOAST -->
    <div class="toast-wrap" id="toastWrap">

        @if (TempData["Success"] != null)
        {
            <div class="toast-item success" id="toastSuccess">
                <div class="toast-icon"><i class="fa-solid fa-circle-check"></i></div>
                <div class="toast-body">
                    <div class="t-title">Thành công</div>
                    <div class="t-msg">@TempData["Success"]</div>
                </div>
                <button class="toast-close js-toast-close" data-toast-id="toastSuccess">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="toast-item error" id="toastError">
                <div class="toast-icon"><i class="fa-solid fa-circle-exclamation"></i></div>
                <div class="toast-body">
                    <div class="t-title">Có lỗi xảy ra</div>
                    <div class="t-msg">@TempData["Error"]</div>
                </div>
                <button class="toast-close js-toast-close" data-toast-id="toastError">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }

    </div>
    <script src="~/js/shared/layout-dashboard.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
    @if (User.Identity?.IsAuthenticated == true)
    {
        <partial name="_NotificationSignalR" />
    }

</body>
</html>
