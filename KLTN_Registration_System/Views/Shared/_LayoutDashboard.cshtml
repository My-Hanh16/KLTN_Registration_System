@using Microsoft.AspNetCore.Identity
@using KLTN_Registration_System.Models.Entities
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KLTN Portal</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @* Tailwind config: đồng bộ màu với _LayoutStudent *@
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary":                  "#4f46e5",
                        "primary-container":        "#6366f1",
                        "on-primary":               "#ffffff",
                        "background":               "#f5f7fb",
                        "surface":                  "#f5f7fb",
                        "on-surface":               "#0f172a",
                        "on-surface-variant":       "#475569",
                        "surface-container":        "#eceef0",
                        "surface-container-low":    "#f2f4f6",
                        "surface-container-lowest": "#ffffff",
                        "outline-variant":          "#e2e8f0",
                        "error":                    "#dc2626",
                    },
                    fontFamily: {
                        headline: ["Inter"],
                        body:     ["Inter"],
                    }
                }
            }
        }
    </script>

    <style>
        /* ── CSS vars: đồng bộ với _LayoutStudent ── */
        :root {
            --primary-blue: #4f46e5;
            --primary-light: #eef2ff;
            --bg-light: #f5f7fb;
            --sidebar-w: 250px;
            --topbar-h: 70px;
            --border-color: #e8edf4;
        }

        * {
            box-sizing: border-box;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-flex;
            vertical-align: middle;
            text-transform: none !important;
            font-size: 18px !important;
            line-height: 1;
        }

        html, body {
            margin: 0;
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: var(--bg-light);
            color: #1e293b;
            overflow-x: hidden;
            height: 100%;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ══════════════════════════════════════
                   SIDEBAR
                ══════════════════════════════════════ */
        .sidebar {
            width: var(--sidebar-w);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: #fff;
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            box-shadow: 2px 0 12px rgba(0,0,0,0.04);
        }

        .sidebar-brand {
            padding: 22px 22px 18px;
            border-bottom: 1px solid #f1f3f9;
        }

            .sidebar-brand h4 {
                font-size: 18px;
                font-weight: 800;
                color: var(--primary-blue);
                margin: 0 0 2px;
                letter-spacing: -0.5px;
                line-height: 1.3;
            }

            .sidebar-brand small {
                color: #94a3b8;
                font-size: 11px;
                font-weight: 500;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 8px 10px;
            scrollbar-width: none;
        }

            .sidebar-nav::-webkit-scrollbar {
                display: none;
            }

        .menu-section {
            margin: 18px 0 5px 10px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            color: #b0bac8;
            text-transform: uppercase;
        }

        .menu-item {
            position: relative;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            margin: 2px 0;
            border-radius: 12px;
            text-decoration: none !important;
            color: #64748b;
            font-size: 13.5px;
            font-weight: 500;
            transition: all .18s ease;
            cursor: pointer;
            background: transparent;
            border: none;
            width: 100%;
            text-align: left;
            line-height: 1.4;
        }

            .menu-item i {
                width: 18px;
                min-width: 18px;
                font-size: 14px;
                text-align: center;
                flex-shrink: 0;
                line-height: 1;
            }

            .menu-item .material-symbols-outlined {
                width: 18px;
                min-width: 18px;
                flex-shrink: 0;
            }

            .menu-item:hover {
                background: var(--primary-light);
                color: var(--primary-blue);
            }

            .menu-item.active {
                background: var(--primary-light);
                color: var(--primary-blue);
                font-weight: 700;
            }

                .menu-item.active::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 50%;
                    transform: translateY(-50%);
                    width: 3px;
                    height: 60%;
                    background: var(--primary-blue);
                    border-radius: 0 3px 3px 0;
                }

        .menu-badge {
            margin-left: auto;
            background: #ef4444;
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            min-width: 18px;
            height: 18px;
            border-radius: 99px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            line-height: 1;
        }

        .sidebar-footer {
            border-top: 1px solid #f1f3f9;
            padding: 10px 10px 14px;
        }

        .logout-btn {
            color: #ef4444 !important;
        }

            .logout-btn:hover {
                background: #fff5f5 !important;
                color: #dc2626 !important;
            }

        /* ══════════════════════════════════════
                   MAIN
                ══════════════════════════════════════ */
        .main-wrapper {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ══════════════════════════════════════
                   TOPBAR — đồng bộ với _LayoutStudent
                ══════════════════════════════════════ */
        .topbar {
            height: var(--topbar-h);
            background: #fff;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            position: sticky;
            top: 0;
            z-index: 900;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            gap: 16px;
        }

        .search-wrap {
            flex: 1;
            max-width: 480px;
        }

            .search-wrap form {
                position: relative;
            }

                .search-wrap form::before {
                    content: "\f002";
                    font-family: "Font Awesome 6 Free";
                    font-weight: 900;
                    position: absolute;
                    left: 16px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #94a3b8;
                    font-size: 13px;
                    pointer-events: none;
                }

            .search-wrap input {
                width: 100%;
                height: 42px;
                border-radius: 12px;
                border: 1.5px solid var(--border-color);
                padding: 0 16px 0 42px;
                background: #f8fafc;
                font-size: 13.5px;
                font-family: 'Inter', sans-serif;
                font-weight: 400;
                color: #1e293b;
                transition: all .2s;
            }

                .search-wrap input:focus {
                    outline: none;
                    border-color: var(--primary-blue);
                    background: #fff;
                    box-shadow: 0 0 0 3px rgba(79,70,229,.1);
                }

                .search-wrap input::placeholder {
                    color: #94a3b8;
                    font-weight: 400;
                }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-icon-btn {
            position: relative;
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: #f8fafc;
            border: 1.5px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            transition: all .2s;
            text-decoration: none;
            cursor: pointer;
        }

            .topbar-icon-btn:hover {
                background: var(--primary-light);
                border-color: var(--primary-blue);
                color: var(--primary-blue);
            }

            .topbar-icon-btn i {
                font-size: 15px;
                line-height: 1;
            }

        .topbar-divider {
            width: 1px;
            height: 28px;
            background: var(--border-color);
            margin: 0 4px;
        }

        /* Fix: user-chip đồng bộ _LayoutStudent */
        .user-chip {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 5px 12px 5px 6px;
            border-radius: 12px;
            border: 1.5px solid var(--border-color);
            background: #f8fafc;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
        }

            .user-chip:hover {
                border-color: var(--primary-blue);
                background: var(--primary-light);
            }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 9px;
            background: linear-gradient(135deg, #4f46e5, #818cf8);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            flex-shrink: 0;
            line-height: 1;
        }

            /* Fix: admin/lecturer dùng màu avatar khác để phân biệt với student */
            .user-avatar.admin {
                background: linear-gradient(135deg, #dc2626, #ef4444);
            }

            .user-avatar.lecturer {
                background: linear-gradient(135deg, #0891b2, #38bdf8);
            }

        .user-info-text .u-name {
            font-size: 13px;
            font-weight: 600;
            color: #1e293b;
            line-height: 1.3;
            white-space: nowrap;
        }

        .user-info-text .u-role {
            font-size: 11px;
            color: #94a3b8;
            font-weight: 500;
            line-height: 1.3;
        }

        /* ══════════════════════════════════════
                   PAGE CONTENT
                ══════════════════════════════════════ */
        .page-content {
            flex: 1;
            padding: 28px;
        }

        /* ══════════════════════════════════════
                   RESET PASSWORD BANNER
                ══════════════════════════════════════ */
        .reset-banner {
            background: #eef2ff;
            border: 1px solid #c7d2fe;
            border-radius: 12px;
            padding: 14px 18px;
            margin-bottom: 20px;
        }

        .reset-banner-title {
            font-size: 13.5px;
            font-weight: 700;
            color: #3730a3;
        }

        .reset-banner-pwd {
            font-size: 18px;
            font-weight: 800;
            color: var(--primary-blue);
            margin-top: 6px;
            letter-spacing: 0.5px;
        }

        /* ══════════════════════════════════════
                   TOAST — đồng bộ với _LayoutStudent
                ══════════════════════════════════════ */
        .toast-wrap {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 99999;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .toast-item {
            min-width: 300px;
            max-width: 380px;
            background: #fff;
            border-radius: 14px;
            padding: 14px 16px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            box-shadow: 0 8px 28px rgba(0,0,0,0.12);
            transform: translateX(120%);
            opacity: 0;
            transition: all .35s cubic-bezier(.175,.885,.32,1.275);
        }

            .toast-item.show {
                transform: translateX(0);
                opacity: 1;
            }

            .toast-item.success {
                border-left: 4px solid #22c55e;
            }

            .toast-item.error {
                border-left: 4px solid #ef4444;
            }

        .toast-icon {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            flex-shrink: 0;
            line-height: 1;
        }

        .toast-item.success .toast-icon {
            background: #dcfce7;
            color: #16a34a;
        }

        .toast-item.error .toast-icon {
            background: #fee2e2;
            color: #dc2626;
        }

        .toast-body {
            flex: 1;
        }

            .toast-body .t-title {
                font-size: 13.5px;
                font-weight: 700;
                color: #111827;
                margin-bottom: 2px;
                line-height: 1.4;
            }

            .toast-body .t-msg {
                font-size: 12.5px;
                color: #6b7280;
                line-height: 1.5;
            }

        .toast-close {
            background: none;
            border: none;
            color: #9ca3af;
            cursor: pointer;
            font-size: 13px;
            padding: 0;
            line-height: 1;
        }

            .toast-close:hover {
                color: #374151;
            }

        /* ══════════════════════════════════════
                   COLLAPSE / ACCORDION
                ══════════════════════════════════════ */
        .collapse:not(.show) {
            display: none !important;
        }

        .collapse.show {
            display: block !important;
            height: auto !important;
        }

        .collapsing {
            position: relative;
            height: 0;
            overflow: hidden;
            transition: height .35s ease;
        }

        .accordion-button::after {
            margin-left: auto;
        }

        .accordion-button:focus {
            box-shadow: none !important;
        }

        .accordion-button:not(.collapsed) {
            background: #eef4ff;
            color: var(--primary-blue);
        }

        /* ══════════════════════════════════════
                   DASHBOARD BANNER — chuẩn hoá gradient
                ══════════════════════════════════════ */
        .dashboard-banner {
            background: linear-gradient(135deg, #4f46e5 0%, #6366f1 60%, #818cf8 100%);
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>

    @{
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
        var action = ViewContext.RouteData.Values["action"]?.ToString();
        var currentUser = await UserManager.GetUserAsync(User);

        // Initials
        string initials = "AD";
        if (!string.IsNullOrEmpty(currentUser?.FullName))
        {
            var parts = currentUser.FullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            initials = parts.Length >= 2
            ? $"{parts[^2][0]}{parts[^1][0]}".ToUpper()
            : currentUser.FullName[0].ToString().ToUpper();
        }
        else if (!string.IsNullOrEmpty(currentUser?.Email))
        {
            initials = currentUser.Email[0].ToString().ToUpper();
        }

        string displayName = currentUser?.FullName ?? currentUser?.UserName ?? User.Identity?.Name ?? "Người dùng";
        // Fix: bỏ lặp nghĩa "LECTURER • Giảng viên" → chọn 1 cách hiển thị
        bool isAdmin = User.IsInRole("Admin");
        string roleLabel = isAdmin ? "Quản trị viên" : "Giảng viên";
        string avatarClass = isAdmin ? "admin" : "lecturer";

        // Fix: helper active dùng tag helpers thay vì href hardcode
        Func<string, string, string> IsActive = (c, a) =>
        string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) &&
        string.Equals(action, a, StringComparison.OrdinalIgnoreCase)
        ? "menu-item active" : "menu-item";

        Func<string, string> IsActiveCtrl = (c) =>
        string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase)
        ? "menu-item active" : "menu-item";
    }

    <!-- SIDEBAR -->
    <nav class="sidebar">

        <div class="sidebar-brand">
            <h4>KLTN PORTAL</h4>
            <small>@(isAdmin ? "Admin Dashboard" : "Lecturer Dashboard")</small>
        </div>

        <div class="sidebar-nav">

            @if (isAdmin)
            {
                <div class="menu-section">Tổng quan</div>

                <a asp-controller="Admin" asp-action="Statistics"
                   class="@IsActive("Admin", "Statistics")">
                    <i class="fa-solid fa-chart-pie"></i>
                    <span>Thống kê hệ thống</span>
                </a>

                <div class="menu-section">Quản lý</div>

                <a asp-controller="Admin" asp-action="StudentManagement"
                   class="@IsActive("Admin", "StudentManagement")">
                    <i class="fa-solid fa-user-graduate"></i>
                    <span>Sinh viên</span>
                </a>

                <a asp-controller="Admin" asp-action="LecturerManagement"
                   class="@IsActive("Admin", "LecturerManagement")">
                    <i class="fa-solid fa-chalkboard-user"></i>
                    <span>Giảng viên</span>
                </a>

                <a asp-controller="Admin" asp-action="ManageTopics"
                   class="@IsActive("Admin", "ManageTopics")">
                    <i class="fa-regular fa-file-lines"></i>
                    <span>Đề tài</span>
                </a>

                <a asp-controller="Admin" asp-action="Approval"
                   class="@IsActive("Admin", "Approval")">
                    <i class="fa-regular fa-square-check"></i>
                    <span>Duyệt đăng ký</span>
                </a>

                <div class="menu-section">Tiến độ</div>

                <a asp-controller="Timeline" asp-action="Index"
                   class="@IsActive("Timeline", "Index")">
                    <span class="material-symbols-outlined">calendar_month</span>
                    <span>Timeline</span>
                </a>

                <a asp-controller="Timeline" asp-action="ApprovedSubmissions"
                   class="@IsActive("Timeline", "ApprovedSubmissions")">
                    <span class="material-symbols-outlined">task_alt</span>
                    <span>Bài đã duyệt</span>
                </a>

                <a asp-controller="Timeline" asp-action="PendingAfterDeadline"
                   class="@IsActive("Timeline", "PendingAfterDeadline")">
                    <span class="material-symbols-outlined">running_with_errors</span>
                    <span>Quá hạn duyệt</span>
                </a>

                <div class="menu-section">Hệ thống</div>

                <a asp-controller="Broadcast" asp-action="Index"
                   class="@IsActive("Broadcast", "Index")">
                    <i class="fa-solid fa-bullhorn"></i>
                    <span>Gửi thông báo</span>
                </a>

                <a asp-controller="Admin" asp-action="Settings"
                   class="@IsActive("Admin", "Settings")">
                    <i class="fa-solid fa-gear"></i>
                    <span>Cài đặt</span>
                </a>
            }
            else
            {
                <div class="menu-section">Tổng quan</div>

                <a asp-controller="Lecturer" asp-action="Index"
                   class="@IsActive("Lecturer", "Index")">
                    <i class="fa-solid fa-border-all"></i>
                    <span>Bảng điều khiển</span>
                </a>

                <div class="menu-section">Quản lý</div>

                <a asp-controller="Lecturer" asp-action="Approval"
                   class="@IsActive("Lecturer", "Approval")">
                    <i class="fa-regular fa-square-check"></i>
                    <span>Duyệt đăng ký</span>
                </a>

                <a asp-controller="Lecturer" asp-action="ThesisManagement"
                   class="@IsActive("Lecturer", "ThesisManagement")">
                    <i class="fa-regular fa-file-lines"></i>
                    <span>Quản lý đề tài</span>
                </a>

                <a asp-controller="Chat" asp-action="Index"
                   class="@IsActiveCtrl("Chat")">
                    <i class="fa-regular fa-comments"></i>
                    <span>Trao đổi sinh viên</span>
                </a>

                <div class="menu-section">Tiến độ</div>

                <a asp-controller="Lecturer" asp-action="TimelineManagement"
                   class="@IsActive("Lecturer", "TimelineManagement")">
                    <span class="material-symbols-outlined">assignment_turned_in</span>
                    <span>Timeline KLTN</span>
                </a>

                <div class="menu-section">Cá nhân</div>

                <a asp-controller="Lecturer" asp-action="Profile"
                   class="@IsActive("Lecturer", "Profile")">
                    <i class="fa-regular fa-user"></i>
                    <span>Hồ sơ cá nhân</span>
                </a>

                <a asp-controller="Account" asp-action="ChangePassword"
                   class="@IsActive("Account", "ChangePassword")">
                    <i class="fa-solid fa-lock"></i>
                    <span>Đổi mật khẩu</span>
                </a>
            }

        </div>

        <div class="sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="menu-item logout-btn">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i>
                    <span>Đăng xuất</span>
                </button>
            </form>
        </div>

    </nav>

    <!-- MAIN -->
    <div class="main-wrapper">

        <!-- TOPBAR -->
        <header class="topbar">

            <div class="search-wrap">
                <form method="get"
                      asp-controller="@(isAdmin ? "Admin" : "Lecturer")"
                      asp-action="@(isAdmin ? "ManageTopics" : "ThesisManagement")">
                    <input type="text" name="search"
                           value="@Context.Request.Query["search"]"
                           placeholder="Tìm kiếm sinh viên, đề tài..." />
                </form>
            </div>

            <div class="topbar-right">

                @if (isAdmin)
                {
                    <a asp-controller="Broadcast" asp-action="Index"
                       class="topbar-icon-btn" title="Gửi thông báo">
                        <i class="fa-solid fa-bullhorn"></i>
                    </a>
                }

                <a asp-controller="@(isAdmin ? "Admin" : "Lecturer")"
                   asp-action="@(isAdmin ? "Settings" : "Profile")"
                   class="topbar-icon-btn" title="@(isAdmin ? "Cài đặt" : "Hồ sơ")">
                    <i class="fa-solid fa-@(isAdmin ? "gear" : "user")"></i>
                </a>

                <div class="topbar-divider"></div>

                <a asp-controller="@(isAdmin ? "Admin" : "Lecturer")"
                   asp-action="@(isAdmin ? "Settings" : "Profile")"
                   class="user-chip text-decoration-none">
                    <div class="user-avatar @avatarClass">@initials</div>
                    <div class="user-info-text">
                        <div class="u-name">
                            @(displayName.Length > 20 ? displayName[..20] + "…" : displayName)
                        </div>
                        <!-- Fix: bỏ lặp nghĩa, chỉ hiện role label -->
                        <div class="u-role">@roleLabel</div>
                    </div>
                </a>

            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="page-content">

            @if (TempData["ResetSuccess"] != null)
            {
                <div class="reset-banner">
                    <div class="reset-banner-title">@TempData["ResetSuccess"]</div>
                    @if (TempData["TempPassword"] != null)
                    {
                        <div class="reset-banner-pwd">
                            Mật khẩu mới: @TempData["TempPassword"]
                        </div>
                    }
                </div>
            }

            @RenderBody()

        </main>

    </div>

    <!-- TOAST -->
    <div class="toast-wrap" id="toastWrap">

        @if (TempData["Success"] != null)
        {
            <div class="toast-item success" id="toastSuccess">
                <div class="toast-icon"><i class="fa-solid fa-circle-check"></i></div>
                <div class="toast-body">
                    <div class="t-title">Thành công</div>
                    <div class="t-msg">@TempData["Success"]</div>
                </div>
                <button class="toast-close" onclick="removeToast('toastSuccess')">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="toast-item error" id="toastError">
                <div class="toast-icon"><i class="fa-solid fa-circle-exclamation"></i></div>
                <div class="toast-body">
                    <div class="t-title">Có lỗi xảy ra</div>
                    <div class="t-msg">@TempData["Error"]</div>
                </div>
                <button class="toast-close" onclick="removeToast('toastError')">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.toast-item').forEach(t => {
                requestAnimationFrame(() => t.classList.add('show'));
                setTimeout(() => removeToast(t.id), 4500);
            });
        });

        function removeToast(id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.classList.remove('show');
            setTimeout(() => el.remove(), 350);
        }

        // Dùng cho các view cũ gọi showToast()
        function showToast(message, type = 'success') {
            const wrap = document.getElementById('toastWrap');
            const id   = 'toast_' + Date.now();
            const isErr = type === 'error';
            wrap.insertAdjacentHTML('beforeend', `
                <div class="toast-item ${isErr ? 'error' : 'success'}" id="${id}">
                    <div class="toast-icon">
                        <i class="fa-solid ${isErr ? 'fa-circle-exclamation' : 'fa-circle-check'}"></i>
                    </div>
                    <div class="toast-body">
                        <div class="t-title">${isErr ? 'Có lỗi xảy ra' : 'Thành công'}</div>
                        <div class="t-msg">${message}</div>
                    </div>
                    <button class="toast-close" onclick="removeToast('${id}')">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>`);
            const el = document.getElementById(id);
            requestAnimationFrame(() => el?.classList.add('show'));
            setTimeout(() => removeToast(id), 4000);
        }
    </script>

    @RenderSection("Scripts", required: false)
    <partial name="_NotificationSignalR" />

</body>
</html>
