@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=Sora:wght@700;800&display=swap" rel="stylesheet" />

<style>
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html, body {
        height: 100%;
        font-family: 'Be Vietnam Pro', sans-serif;
        -webkit-font-smoothing: antialiased;
        background: #05091a;
        color: #fff;
    }

    /* ════════════════════════════════
       NAVBAR
    ════════════════════════════════ */
    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 200;
        height: 62px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 52px;
        background: rgba(5, 9, 26, 0.55);
        backdrop-filter: blur(20px) saturate(1.4);
        -webkit-backdrop-filter: blur(20px) saturate(1.4);
        border-bottom: 1px solid rgba(255,255,255,.07);
    }

    .nav-logo {
        font-family: 'Sora', sans-serif;
        font-size: 17px;
        font-weight: 800;
        color: #fff;
        text-decoration: none;
        letter-spacing: -.2px;
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 34px;
        list-style: none;
    }

        .nav-links a {
            font-size: 13.5px;
            font-weight: 500;
            color: rgba(255,255,255,.55);
            text-decoration: none;
            transition: color .15s;
        }

            .nav-links a.active {
                color: #60a5fa;
                font-weight: 600;
            }

            .nav-links a:hover {
                color: #fff;
            }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .nav-icon {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,.65);
        font-size: 14px;
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
    }

        .nav-icon:hover {
            background: rgba(255,255,255,.15);
            color: #fff;
        }

    .btn-portal-login {
        padding: 8px 22px;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 9px;
        font-family: 'Be Vietnam Pro', sans-serif;
        font-size: 13.5px;
        font-weight: 700;
        cursor: pointer;
        transition: background .15s;
        text-decoration: none;
        display: inline-block;
        letter-spacing: .2px;
    }

        .btn-portal-login:hover {
            background: #1d4ed8;
        }

    /* ════════════════════════════════
       HERO — full viewport, real photo bg
    ════════════════════════════════ */
    .hero-wrap {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* Real university corridor photo via Unsplash */
    .hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        background-image: url('https://images.unsplash.com/photo-1541829070764-84a7d30dd3f3?w=1600&q=80&auto=format&fit=crop');
        background-size: cover;
        background-position: center 30%;
        background-repeat: no-repeat;
    }

        /* Dark overlay — tái hiện đúng màu tối trong ảnh tham chiếu */
        .hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient( 108deg, rgba(4, 8, 28, 0.91) 0%, rgba(6, 14, 42, 0.85) 35%, rgba(10, 25, 65, 0.70) 58%, rgba(18, 40, 100, 0.55) 80%, rgba(30, 60, 140, 0.45) 100% );
        }

    /* Extra blue-purple glow on right half */
    .hero-glow {
        position: absolute;
        z-index: 1;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(79,100,220,.22) 0%, transparent 70%);
        right: -100px;
        bottom: -100px;
        pointer-events: none;
    }

    /* ── Hero body ── */
    .hero-body {
        position: relative;
        z-index: 10;
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 440px;
        gap: 60px;
        align-items: center;
        padding: 100px 72px 80px;
        max-width: 1280px;
        width: 100%;
        margin: 0 auto;
    }

    /* ── Left ── */
    .hero-left {
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.18);
        padding: 5px 16px 5px 10px;
        border-radius: 99px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: rgba(255,255,255,.88);
        margin-bottom: 26px;
        width: fit-content;
        animation: fadeUp .5s ease both .1s;
    }

    .badge-icon {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: rgba(96,165,250,.25);
        border: 1px solid rgba(96,165,250,.45);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        color: #93c5fd;
    }

    .hero-title {
        font-family: 'Sora', sans-serif;
        font-size: clamp(38px, 4.5vw, 58px);
        font-weight: 800;
        line-height: 1.12;
        letter-spacing: -1.5px;
        color: #fff;
        margin-bottom: 20px;
        animation: fadeUp .55s ease both .2s;
    }

        .hero-title .hi {
            color: #60a5fa;
        }

    .hero-desc {
        font-size: 14.5px;
        line-height: 1.78;
        color: rgba(255,255,255,.55);
        max-width: 440px;
        margin-bottom: 52px;
        animation: fadeUp .55s ease both .3s;
    }

    /* Stats */
    .hero-stats {
        display: flex;
        gap: 44px;
        animation: fadeUp .55s ease both .4s;
    }

    .stat-num {
        font-family: 'Sora', sans-serif;
        font-size: 30px;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 5px;
        color: #fff;
    }

    .stat-lbl {
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: rgba(255,255,255,.38);
    }

    /* ── Right: form card ── */
    .form-card {
        background: rgba(8, 16, 50, 0.68);
        border: 1px solid rgba(255,255,255,.11);
        border-radius: 22px;
        padding: 38px 36px 36px;
        backdrop-filter: blur(32px) saturate(1.2);
        -webkit-backdrop-filter: blur(32px) saturate(1.2);
        box-shadow: 0 40px 100px rgba(0,0,0,.55), 0 0 0 1px rgba(255,255,255,.05) inset, 0 1px 0 rgba(255,255,255,.1) inset;
        animation: fadeUp .6s ease both .22s;
    }

    .card-title {
        font-family: 'Sora', sans-serif;
        font-size: 26px;
        font-weight: 800;
        color: #fff;
        text-align: center;
        letter-spacing: -.4px;
        margin-bottom: 5px;
    }

    .card-sub {
        font-size: 13.5px;
        color: rgba(255,255,255,.4);
        text-align: center;
        margin-bottom: 26px;
    }

    /* Error alert */
    .alert-error {
        background: rgba(239,68,68,.12);
        border: 1px solid rgba(239,68,68,.28);
        border-radius: 10px;
        padding: 11px 14px;
        margin-bottom: 18px;
        display: flex;
        align-items: flex-start;
        gap: 9px;
        font-size: 13px;
        color: #fca5a5;
    }

        .alert-error i {
            flex-shrink: 0;
            margin-top: 1px;
        }

    /* Field */
    .field {
        margin-bottom: 16px;
    }

    .field-label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: rgba(255,255,255,.75);
        margin-bottom: 7px;
    }

    .field-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 7px;
    }

    .forgot-link {
        font-size: 12.5px;
        font-weight: 600;
        color: #60a5fa;
        text-decoration: none;
        transition: color .15s;
    }

        .forgot-link:hover {
            color: #93c5fd;
        }

    .field-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .field-icon {
        position: absolute;
        left: 14px;
        z-index: 1;
        color: #60a5fa;
        font-size: 14px;
        pointer-events: none;
        text-shadow: 0 0 10px rgba(96,165,250,.35);
    }

    .field-wrap input {
        width: 100%;
        height: 48px;
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.13);
        border-radius: 11px;
        padding: 0 44px;
        font-size: 14px;
        font-family: 'Be Vietnam Pro', sans-serif;
        color: #fff;
        outline: none;
        transition: border-color .15s, background .15s, box-shadow .15s;
    }

        .field-wrap input::placeholder {
            color: rgba(255,255,255,.22);
        }

        .field-wrap input:focus {
            border-color: rgba(96,165,250,.6);
            background: rgba(255,255,255,.1);
            box-shadow: 0 0 0 3px rgba(59,130,246,.18);
        }

        .field-wrap input.is-error {
            border-color: rgba(239,68,68,.6);
            box-shadow: 0 0 0 3px rgba(239,68,68,.14);
        }

    .field-error {
        font-size: 12px;
        color: #fca5a5;
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .eye-btn {
        position: absolute;
        right: 13px;
        z-index: 1;
        background: none;
        border: none;
        cursor: pointer;
        color: #60a5fa;
        font-size: 14px;
        padding: 0;
        transition: color .15s;
    }

        .eye-btn:hover {
            color: rgba(255,255,255,.75);
        }

    /* Remember */
    .remember-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
        margin-top: 2px;
    }

    .login-options {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 12px;
        margin-bottom: 20px;
    }

        .login-options .remember-row {
            margin: 0;
        }

        .remember-row input[type=checkbox] {
            width: 16px;
            height: 16px;
            accent-color: #3b82f6;
            cursor: pointer;
        }

    .remember-label {
        font-size: 13px;
        color: rgba(255,255,255,.5);
        cursor: pointer;
        user-select: none;
    }

    /* Submit */
    .btn-submit {
        width: 100%;
        height: 50px;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 13.5px;
        font-weight: 800;
        font-family: 'Be Vietnam Pro', sans-serif;
        letter-spacing: 1.8px;
        text-transform: uppercase;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all .18s;
        box-shadow: 0 6px 28px rgba(37,99,235,.45);
        margin-bottom: 22px;
    }

        .btn-submit:hover {
            background: #1d4ed8;
            box-shadow: 0 10px 36px rgba(37,99,235,.55);
            transform: translateY(-1px);
        }

        .btn-submit:active {
            transform: none;
        }

        .btn-submit:disabled {
            background: rgba(255,255,255,.08);
            color: rgba(255,255,255,.25);
            box-shadow: none;
            cursor: not-allowed;
            transform: none;
        }

        .btn-submit .spinner {
            width: 17px;
            height: 17px;
            border-radius: 50%;
            border: 2.5px solid rgba(255,255,255,.3);
            border-top-color: #fff;
            animation: spin .7s linear infinite;
            display: none;
        }

    @@keyframes spin {
        to

    {
        transform: rotate(360deg);
    }

    }

    /* Role divider */
    .role-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

        .role-divider::before,
        .role-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255,255,255,.1);
        }

    .role-text {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: rgba(255,255,255,.28);
        white-space: nowrap;
    }

    /* Role chips */
    .role-chips {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .role-chip {
        padding: 13px 8px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 7px;
        cursor: pointer;
        transition: all .15s;
        text-align: center;
    }

        .role-chip:hover {
            background: rgba(59,130,246,.18);
            border-color: rgba(96,165,250,.4);
            transform: translateY(-2px);
        }

    .role-chip-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: rgba(255,255,255,.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        color: rgba(255,255,255,.75);
    }

    .role-chip-label {
        font-size: 12px;
        font-weight: 600;
        color: rgba(255,255,255,.55);
    }

    /* ════════════════════════════════
       FOOTER
    ════════════════════════════════ */
    .site-footer {
        position: relative;
        z-index: 10;
        background: #05091a;
        border-top: 1px solid rgba(255,255,255,.06);
        padding: 32px 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 32px;
    }

    .footer-brand {
        font-family: 'Sora', sans-serif;
        font-size: 17px;
        font-weight: 800;
        color: #fff;
        margin-bottom: 6px;
    }

    .footer-copy {
        font-size: 12px;
        color: rgba(255,255,255,.3);
        line-height: 1.65;
    }

    .footer-links {
        display: flex;
        gap: 28px;
        flex-wrap: wrap;
    }

        .footer-links a {
            font-size: 12.5px;
            font-weight: 500;
            color: rgba(255,255,255,.35);
            text-decoration: none;
            transition: color .15s;
            white-space: nowrap;
        }

            .footer-links a:hover {
                color: rgba(255,255,255,.8);
            }

    /* ════════════════════════════════
       ANIMATIONS
    ════════════════════════════════ */
    @@keyframes fadeUp {
        from

    {
        opacity: 0;
        transform: translateY(22px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* ════════════════════════════════
       RESPONSIVE
    ════════════════════════════════ */
    @@media (max-width: 960px) {
        .hero-body

    {
        grid-template-columns: 1fr;
        padding: 100px 28px 60px;
    }

    .form-card {
        max-width: 460px;
        margin: 0 auto;
    }

    .navbar {
        padding: 0 24px;
    }

    .nav-links {
        display: none;
    }

    .site-footer {
        flex-direction: column;
        padding: 28px 24px;
    }

    }
</style>

<!-- ════ NAVBAR ════ -->
<nav class="navbar">
    <a href="/" class="nav-logo">KLTN Portal</a>

    <ul class="nav-links">
        <li><a href="/" class="active">Home</a></li>
        <li><a href="#">Guidelines</a></li>
        <li><a href="#">Thesis Archive</a></li>
        <li><a href="#">Help Center</a></li>
    </ul>

    <div class="nav-right">
        <a href="#" class="nav-icon"><i class="fa-solid fa-globe"></i></a>
        <a href="#" class="nav-icon"><i class="fa-regular fa-bell"></i></a>
        <a href="#" class="btn-portal-login">Portal Login</a>
    </div>
</nav>

<!-- ════ HERO ════ -->
<div class="hero-wrap">
    <div class="hero-bg"></div>
    <div class="hero-glow"></div>

    <div class="hero-body">

        <!-- LEFT -->
        <div class="hero-left">
            <div class="hero-badge">
                <div class="badge-icon"><i class="fa-solid fa-check"></i></div>
                Hệ thống quản lý chính thức
            </div>

            <h1 class="hero-title">
                Khai phá tri thức<br>
                Kiến tạo <span class="hi">tương<br>lai</span>
            </h1>

            <p class="hero-desc">
                Nền tảng quản lý khóa luận tốt nghiệp thông minh dành cho
                giảng viên và sinh viên, thúc đẩy sự sáng tạo và chuẩn hóa
                quy trình nghiên cứu khoa học.
            </p>

            <div class="hero-stats">
                <div>
                    <div class="stat-num">25k+</div>
                    <div class="stat-lbl">Sinh viên</div>
                </div>
                <div>
                    <div class="stat-num">1.2k+</div>
                    <div class="stat-lbl">Giảng viên</div>
                </div>
                <div>
                    <div class="stat-num">500+</div>
                    <div class="stat-lbl">Đối tác</div>
                </div>
            </div>
        </div>

        <!-- RIGHT: FORM CARD -->
        <div class="form-card">
            <div class="card-title">Đăng nhập</div>
            <div class="card-sub">Chào mừng trở lại với hệ thống KLTN</div>

            @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0)
                        && ViewData.ModelState["username"]?.Errors.Count == 0
                        && ViewData.ModelState["password"]?.Errors.Count == 0)
            {
                <div class="alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>Thông tin đăng nhập không chính xác. Vui lòng kiểm tra lại.</span>
                </div>
            }

            <form method="post" id="loginForm" novalidate>
                @Html.AntiForgeryToken()

                <!-- Username -->
                <div class="field">
                    <label class="field-label" for="username">Tên đăng nhập / Email</label>
                    <div class="field-wrap">
                        <i class="fa-regular fa-envelope field-icon"></i>
                        <input type="text" id="username" name="username"
                               value="@(ViewData["username"] ?? "")"
                               placeholder="username@university.edu.vn"
                               class="@(ViewData.ModelState["username"]?.Errors.Count > 0 ? "is-error" : "")"
                               autocomplete="username" autofocus />
                    </div>
                    @if (ViewData.ModelState["username"]?.Errors.Count > 0)
                    {
                        <div class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            @ViewData.ModelState["username"]!.Errors[0].ErrorMessage
                        </div>
                    }
                </div>

                <!-- Password -->
                <div class="field">
                    <label class="field-label" for="password">Mật khẩu</label>

                    <div class="field-wrap">
                        <i class="fa-solid fa-lock field-icon"></i>

                        <input type="password" id="password" name="password"
                               placeholder="••••••••••"
                               class="@(ViewData.ModelState["password"]?.Errors.Count > 0 ? "is-error" : "")"
                               autocomplete="current-password" />

                        <button type="button" class="eye-btn" onclick="togglePwd()" tabindex="-1">
                            <i id="eyeIcon" class="fa-regular fa-eye"></i>
                        </button>
                    </div>

                    @if (ViewData.ModelState["password"]?.Errors.Count > 0)
                    {
                        <div class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            @ViewData.ModelState["password"]!.Errors[0].ErrorMessage
                        </div>
                    }

                    <!-- Remember + Forgot -->
                    <div class="login-options">
                        <div class="remember-row">
                            <input type="checkbox" id="rememberMe" name="rememberMe" />
                            <label class="remember-label" for="rememberMe">Ghi nhớ đăng nhập</label>
                        </div>

                        <a href="#" class="forgot-link">Quên mật khẩu?</a>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-submit" id="submitBtn">
                    <div class="spinner" id="spinner"></div>
                    <span id="submitText">Đăng nhập</span>
                </button>

                <!-- Role chips -->
                <div class="role-divider">
                    <span class="role-text">Truy cập theo vai trò</span>
                </div>

                <div class="role-chips">
                    <div class="role-chip" onclick="fillRole('admin')">
                        <div class="role-chip-icon"><i class="fa-solid fa-shield-halved"></i></div>
                        <span class="role-chip-label">Quản trị</span>
                    </div>
                    <div class="role-chip" onclick="fillRole('lecturer')">
                        <div class="role-chip-icon"><i class="fa-solid fa-chalkboard-user"></i></div>
                        <span class="role-chip-label">Giảng viên</span>
                    </div>
                    <div class="role-chip" onclick="fillRole('student')">
                        <div class="role-chip-icon"><i class="fa-solid fa-graduation-cap"></i></div>
                        <span class="role-chip-label">Sinh viên</span>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- ════ FOOTER ════ -->
<footer class="site-footer">
    <div>
        <div class="footer-brand">KLTN Portal</div>
        <div class="footer-copy">
            © @DateTime.Now.Year Thesis Management System – Office of Academic Affairs.<br>
            Excellence in Research and Innovation.
        </div>
    </div>
    <div class="footer-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">University Directory</a>
        <a href="#">Technical Support</a>
    </div>
</footer>

<script>
    function togglePwd() {
        const inp  = document.getElementById('password');
        const icon = document.getElementById('eyeIcon');
        inp.type === 'password'
            ? (inp.type = 'text',    icon.classList.replace('fa-eye','fa-eye-slash'))
            : (inp.type = 'password', icon.classList.replace('fa-eye-slash','fa-eye'));
    }

    document.getElementById('loginForm').addEventListener('submit', function () {
        const u = document.getElementById('username').value.trim();
        const p = document.getElementById('password').value;
        if (!u || !p) return;
        const btn  = document.getElementById('submitBtn');
        const spin = document.getElementById('spinner');
        const txt  = document.getElementById('submitText');
        btn.disabled = true;
        spin.style.display = 'block';
        txt.textContent = 'Đang đăng nhập...';
    });

    const accounts = {
        admin:    { user: 'admin@gmail.com',           pass: 'Admin@123'    },
        lecturer: { user: 'GV001@uni.edu.vn',          pass: 'Lecturer@123' },
        student:  { user: 'SV2024001@student.edu.vn',  pass: 'Student@123'  },
    };

    function fillRole(r) {
        const a = accounts[r];
        if (!a) return;
        document.getElementById('username').value = a.user;
        document.getElementById('password').value = a.pass;
    }
</script>
