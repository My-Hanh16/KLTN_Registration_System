@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=Sora:wght@700;800&display=swap" rel="stylesheet" />

<link rel="stylesheet" href="~/css/account/login.css" asp-append-version="true" />

<!-- ════ NAVBAR ════ -->
<nav class="navbar">
    <a href="/" class="nav-logo">KLTN Portal</a>

    <ul class="nav-links">
        <li><a href="/" class="active">Home</a></li>
        <li><a href="#">Guidelines</a></li>
        <li><a href="#">Thesis Archive</a></li>
        <li><a href="#">Help Center</a></li>
    </ul>

    <div class="nav-right">
        <a href="#" class="nav-icon"><i class="fa-solid fa-globe"></i></a>
        <a href="#" class="nav-icon"><i class="fa-regular fa-bell"></i></a>
        <a href="#" class="btn-portal-login">Portal Login</a>
    </div>
</nav>

<!-- ════ HERO ════ -->
<div class="hero-wrap">
    <div class="hero-bg"></div>
    <div class="hero-glow"></div>

    <div class="hero-body">

        <!-- LEFT -->
        <div class="hero-left">
            <div class="hero-badge">
                <div class="badge-icon"><i class="fa-solid fa-check"></i></div>
                Hệ thống quản lý chính thức
            </div>

            <h1 class="hero-title">
                Khai phá tri thức<br>
                Kiến tạo <span class="hi">tương<br>lai</span>
            </h1>

            <p class="hero-desc">
                Nền tảng quản lý khóa luận tốt nghiệp thông minh dành cho
                giảng viên và sinh viên, thúc đẩy sự sáng tạo và chuẩn hóa
                quy trình nghiên cứu khoa học.
            </p>

            <div class="hero-stats">
                <div>
                    <div class="stat-num">25k+</div>
                    <div class="stat-lbl">Sinh viên</div>
                </div>
                <div>
                    <div class="stat-num">1.2k+</div>
                    <div class="stat-lbl">Giảng viên</div>
                </div>
                <div>
                    <div class="stat-num">500+</div>
                    <div class="stat-lbl">Đối tác</div>
                </div>
            </div>
        </div>

        <!-- RIGHT: FORM CARD -->
        <div class="form-card">
            <div class="card-title">Đăng nhập</div>
            <div class="card-sub">Chào mừng trở lại với hệ thống KLTN</div>

            @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0)
                        && ViewData.ModelState["username"]?.Errors.Count == 0
                        && ViewData.ModelState["password"]?.Errors.Count == 0)
            {
                <div class="alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>Thông tin đăng nhập không chính xác. Vui lòng kiểm tra lại.</span>
                </div>
            }

            <form method="post" id="loginForm" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@(ViewData["ReturnUrl"] ?? "")" />

                <!-- Username -->
                <div class="field">
                    <label class="field-label" for="username">Tên đăng nhập / Email</label>
                    <div class="field-wrap">
                        <i class="fa-regular fa-envelope field-icon"></i>
                        <input type="text" id="username" name="username"
                               value="@(ViewData["username"] ?? "")"
                               placeholder="username@university.edu.vn"
                               class="@(ViewData.ModelState["username"]?.Errors.Count > 0 ? "is-error" : "")"
                               autocomplete="username" autofocus />
                    </div>
                    @if (ViewData.ModelState["username"]?.Errors.Count > 0)
                    {
                        <div class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            @ViewData.ModelState["username"]!.Errors[0].ErrorMessage
                        </div>
                    }
                </div>

                <!-- Password -->
                <div class="field">
                    <label class="field-label" for="password">Mật khẩu</label>

                    <div class="field-wrap">
                        <i class="fa-solid fa-lock field-icon"></i>

                        <input type="password" id="password" name="password"
                               placeholder="••••••••••"
                               class="@(ViewData.ModelState["password"]?.Errors.Count > 0 ? "is-error" : "")"
                               autocomplete="current-password" />

                        <button type="button" class="eye-btn" id="togglePasswordBtn" tabindex="-1">
                            <i id="eyeIcon" class="fa-regular fa-eye"></i>
                        </button>
                    </div>

                    @if (ViewData.ModelState["password"]?.Errors.Count > 0)
                    {
                        <div class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            @ViewData.ModelState["password"]!.Errors[0].ErrorMessage
                        </div>
                    }

                    <!-- Remember + Forgot -->
                    <div class="login-options">
                        <div class="remember-row">
                            <input type="checkbox" id="rememberMe" name="rememberMe" />
                            <label class="remember-label" for="rememberMe">Ghi nhớ đăng nhập</label>
                        </div>

                        <a href="#" class="forgot-link">Quên mật khẩu?</a>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-submit" id="submitBtn">
                    <div class="spinner" id="spinner"></div>
                    <span id="submitText">Đăng nhập</span>
                </button>

                <!-- Role chips -->
                <div class="role-divider">
                    <span class="role-text">Truy cập theo vai trò</span>
                </div>

                <div class="role-chips">
                    <div class="role-chip">
                        <div class="role-chip-icon"><i class="fa-solid fa-shield-halved"></i></div>
                        <span class="role-chip-label">Quản trị</span>
                    </div>
                    <div class="role-chip">
                        <div class="role-chip-icon"><i class="fa-solid fa-chalkboard-user"></i></div>
                        <span class="role-chip-label">Giảng viên</span>
                    </div>
                    <div class="role-chip">
                        <div class="role-chip-icon"><i class="fa-solid fa-graduation-cap"></i></div>
                        <span class="role-chip-label">Sinh viên</span>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- ════ FOOTER ════ -->
<footer class="site-footer">
    <div>
        <div class="footer-brand">KLTN Portal</div>
        <div class="footer-copy">
            © @DateTime.Now.Year Thesis Management System – Office of Academic Affairs.<br>
            Excellence in Research and Innovation.
        </div>
    </div>
    <div class="footer-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">University Directory</a>
        <a href="#">Technical Support</a>
    </div>
</footer>

<script src="~/js/account/login.js" asp-append-version="true"></script>

