@{
    Layout = null;
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=Sora:wght@700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/account/login.css" asp-append-version="true" />

<nav class="navbar">
    <a asp-controller="Home" asp-action="Index" class="nav-logo">KLTN Portal</a>
    <div class="nav-right">
        <a asp-controller="Account" asp-action="Login" class="btn-portal-login">Đăng nhập</a>
    </div>
</nav>

<div class="hero-wrap">
    <div class="hero-bg"></div>
    <div class="hero-glow"></div>

    <div class="hero-body forgot-body">
        <div class="hero-left">
            <div class="hero-badge">
                <div class="badge-icon"><i class="fa-solid fa-shield-halved"></i></div>
                Bảo mật tài khoản
            </div>

            <h1 class="hero-title">
                Thiết lập<br>
                mật khẩu <span class="hi">mới</span>
            </h1>

            <p class="hero-desc">
                Chọn mật khẩu mạnh, không dùng lại mật khẩu cũ và không chia sẻ với người khác.
            </p>
        </div>

        <div class="form-card">
            <div class="card-title">Đặt lại mật khẩu</div>
            <div class="card-sub">Liên kết này chỉ dùng cho tài khoản đã yêu cầu khôi phục.</div>

            @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0)
                && ViewData.ModelState["newPassword"]?.Errors.Count == 0
                && ViewData.ModelState["confirmPassword"]?.Errors.Count == 0)
            {
                <div class="alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@ViewData.ModelState.Values.SelectMany(v => v.Errors).First().ErrorMessage</span>
                </div>
            }

            <form asp-controller="Account" asp-action="ResetPassword" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@ViewData["UserId"]" />
                <input type="hidden" name="token" value="@ViewData["Token"]" />

                <div class="field">
                    <label class="field-label" for="newPassword">Mật khẩu mới</label>
                    <div class="field-wrap">
                        <i class="fa-solid fa-lock field-icon"></i>
                        <input type="password" id="newPassword" name="newPassword"
                               placeholder="Ít nhất 8 ký tự"
                               class="@(ViewData.ModelState["newPassword"]?.Errors.Count > 0 ? "is-error" : "")"
                               autocomplete="new-password" autofocus />
                    </div>
                    @if (ViewData.ModelState["newPassword"]?.Errors.Count > 0)
                    {
                        <div class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            @ViewData.ModelState["newPassword"]!.Errors[0].ErrorMessage
                        </div>
                    }
                </div>

                <div class="field">
                    <label class="field-label" for="confirmPassword">Xác nhận mật khẩu mới</label>
                    <div class="field-wrap">
                        <i class="fa-solid fa-lock field-icon"></i>
                        <input type="password" id="confirmPassword" name="confirmPassword"
                               placeholder="Nhập lại mật khẩu mới"
                               class="@(ViewData.ModelState["confirmPassword"]?.Errors.Count > 0 ? "is-error" : "")"
                               autocomplete="new-password" />
                    </div>
                    @if (ViewData.ModelState["confirmPassword"]?.Errors.Count > 0)
                    {
                        <div class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            @ViewData.ModelState["confirmPassword"]!.Errors[0].ErrorMessage
                        </div>
                    }
                </div>

                <button type="submit" class="btn-submit">
                    <i class="fa-solid fa-floppy-disk"></i>
                    <span>Lưu mật khẩu mới</span>
                </button>

                <a asp-controller="Account" asp-action="Login" class="back-login">
                    <i class="fa-solid fa-arrow-left"></i>
                    Quay lại đăng nhập
                </a>
            </form>
        </div>
    </div>
</div>
