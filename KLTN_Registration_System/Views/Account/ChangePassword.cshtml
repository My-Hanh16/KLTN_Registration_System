@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

@section Styles {
<style>
    /* ══════════════════════════════════════
       LAYOUT
    ══════════════════════════════════════ */
    .pwd-wrap {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 20px;
        max-width: 820px;
    }

    @@media (max-width: 768px) {
        .pwd-wrap { grid-template-columns: 1fr; }
        .pwd-tips  { order: -1; }
    }

    /* ══════════════════════════════════════
       FORM CARD
    ══════════════════════════════════════ */
    .pwd-card {
        background: #fff;
        border: 1px solid #e8edf4;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }

    .card-title {
        font-size: 14px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 20px;
        padding-bottom: 14px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .card-title i { color: #4f46e5; }

    /* ══════════════════════════════════════
       FORM FIELDS
    ══════════════════════════════════════ */
    .form-group { margin-bottom: 16px; }

    .form-label {
        display: block;
        font-size: 12.5px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }

    .form-label .required { color: #ef4444; margin-left: 2px; }

    /* Input wrapper for show/hide toggle */
    .input-wrap {
        position: relative;
    }

    .form-control-custom {
        width: 100%;
        border: 1.5px solid #e8edf4;
        border-radius: 10px;
        padding: 9px 42px 9px 14px;
        font-size: 13.5px;
        font-family: 'Inter', sans-serif;
        color: #1e293b;
        background: #f8fafc;
        outline: none;
        transition: border-color .15s, box-shadow .15s;
    }

    .form-control-custom:focus {
        border-color: #4f46e5;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(79,70,229,.08);
    }

    .form-control-custom.is-error { border-color: #ef4444; }
    .form-control-custom.is-error:focus { box-shadow: 0 0 0 3px rgba(239,68,68,.08); }

    .form-control-custom.is-ok { border-color: #16a34a; }
    .form-control-custom.is-ok:focus { box-shadow: 0 0 0 3px rgba(22,163,74,.08); }

    /* Show/hide password button */
    .toggle-pwd {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        font-size: 14px;
        padding: 0;
        line-height: 1;
        transition: color .15s;
    }

    .toggle-pwd:hover { color: #4f46e5; }

    /* Hint text */
    .field-hint {
        font-size: 11.5px;
        color: #94a3b8;
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .field-hint.error { color: #ef4444; }
    .field-hint.ok    { color: #16a34a; }

    /* ══════════════════════════════════════
       PASSWORD STRENGTH
    ══════════════════════════════════════ */
    .strength-wrap {
        margin-top: 8px;
    }

    .strength-bars {
        display: flex;
        gap: 4px;
        margin-bottom: 4px;
    }

    .strength-bar {
        flex: 1;
        height: 4px;
        border-radius: 99px;
        background: #e8edf4;
        transition: background .2s;
    }

    .strength-bar.weak   { background: #ef4444; }
    .strength-bar.medium { background: #f59e0b; }
    .strength-bar.strong { background: #16a34a; }

    .strength-label {
        font-size: 11px;
        font-weight: 600;
        color: #94a3b8;
    }

    .strength-label.weak   { color: #ef4444; }
    .strength-label.medium { color: #f59e0b; }
    .strength-label.strong { color: #16a34a; }

    /* ══════════════════════════════════════
       FORM ACTIONS
    ══════════════════════════════════════ */
    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 22px;
        padding-top: 18px;
        border-top: 1px solid #f1f5f9;
    }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13.5px;
        font-weight: 700;
        padding: 9px 22px;
        border-radius: 10px;
        border: none;
        background: #4f46e5;
        color: #fff;
        cursor: pointer;
        transition: background .15s;
        box-shadow: 0 4px 12px rgba(79,70,229,.22);
    }

    .btn-save:hover:not(:disabled) { background: #4338ca; }
    .btn-save:disabled { opacity: .65; cursor: not-allowed; }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13.5px;
        font-weight: 600;
        padding: 9px 18px;
        border-radius: 10px;
        border: 1.5px solid #e8edf4;
        background: #f8fafc;
        color: #64748b;
        text-decoration: none;
        transition: all .15s;
    }

    .btn-back:hover { background: #f1f5f9; color: #1e293b; }

    /* ══════════════════════════════════════
       TIPS CARD
    ══════════════════════════════════════ */
    .pwd-tips {
        background: #fff;
        border: 1px solid #e8edf4;
        border-radius: 14px;
        padding: 22px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        height: fit-content;
    }

    .tips-title {
        font-size: 13px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .tips-title i { color: #f59e0b; }

    .tip-item {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        margin-bottom: 10px;
        font-size: 12.5px;
        color: #64748b;
        line-height: 1.5;
    }

    .tip-item:last-child { margin-bottom: 0; }

    .tip-item i {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 3px;
        flex-shrink: 0;
    }

    /* Checklist realtime */
    .pwd-checklist {
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid #f1f5f9;
    }

    .check-item {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12px;
        color: #94a3b8;
        margin-bottom: 6px;
        transition: color .2s;
    }

    .check-item i {
        font-size: 11px;
        width: 14px;
        text-align: center;
        transition: color .2s;
    }

    .check-item.pass     { color: #16a34a; }
    .check-item.pass i   { color: #16a34a; }
</style>
}

<!-- PAGE TITLE -->
<div class="mb-4">
    <h2 style="font-size:20px;font-weight:800;color:#1e293b;margin-bottom:4px;">Đổi mật khẩu</h2>
    <p style="font-size:13.5px;color:#94a3b8;margin:0;">Cập nhật mật khẩu để bảo vệ tài khoản của bạn.</p>
</div>

<div class="pwd-wrap">

    <!-- FORM CARD -->
    <div class="pwd-card">

        <div class="card-title">
            <i class="fa-solid fa-lock"></i>
            Thay đổi mật khẩu
        </div>

        <form asp-action="ChangePassword" asp-controller="Account"
              method="post" id="changePwdForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- Mật khẩu hiện tại -->
            <div class="form-group">
                <label class="form-label">
                    Mật khẩu hiện tại <span class="required">*</span>
                </label>
                <div class="input-wrap">
                    <input type="password" name="currentPassword"
                           id="currentPassword"
                           class="form-control-custom"
                           required
                           placeholder="Nhập mật khẩu hiện tại" />
                    <button type="button" class="toggle-pwd"
                            onclick="togglePwd('currentPassword', this)"
                            tabindex="-1">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
            </div>

            <!-- Mật khẩu mới -->
            <div class="form-group">
                <label class="form-label">
                    Mật khẩu mới <span class="required">*</span>
                </label>
                <div class="input-wrap">
                    <input type="password" name="newPassword"
                           id="newPassword"
                           class="form-control-custom"
                           required minlength="8"
                           placeholder="Ít nhất 8 ký tự"
                           oninput="checkStrength(this.value); validateConfirm();" />
                    <button type="button" class="toggle-pwd"
                            onclick="togglePwd('newPassword', this)"
                            tabindex="-1">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>

                <!-- Strength indicator -->
                <div class="strength-wrap" id="strengthWrap" style="display:none;">
                    <div class="strength-bars">
                        <div class="strength-bar" id="bar1"></div>
                        <div class="strength-bar" id="bar2"></div>
                        <div class="strength-bar" id="bar3"></div>
                        <div class="strength-bar" id="bar4"></div>
                    </div>
                    <span class="strength-label" id="strengthLabel"></span>
                </div>
            </div>

            <!-- Xác nhận mật khẩu -->
            <div class="form-group">
                <label class="form-label">
                    Xác nhận mật khẩu mới <span class="required">*</span>
                </label>
                <div class="input-wrap">
                    <input type="password" name="confirmPassword"
                           id="confirmPassword"
                           class="form-control-custom"
                           required
                           placeholder="Nhập lại mật khẩu mới"
                           oninput="validateConfirm()" />
                    <button type="button" class="toggle-pwd"
                            onclick="togglePwd('confirmPassword', this)"
                            tabindex="-1">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
                <div class="field-hint" id="confirmHint" style="display:none;"></div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save" id="submitBtn">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Cập nhật mật khẩu
                </button>
                <a href="javascript:history.back()" class="btn-back">
                    <i class="fa-solid fa-arrow-left"></i>
                    Quay lại
                </a>
            </div>

        </form>
    </div>

    <!-- TIPS CARD -->
    <div class="pwd-tips">

        <div class="tips-title">
            <i class="fa-solid fa-shield-halved"></i>
            Lưu ý bảo mật
        </div>

        <div class="tip-item">
            <i class="fa-solid fa-circle-dot"></i>
            Không chia sẻ mật khẩu với bất kỳ ai, kể cả quản trị viên.
        </div>
        <div class="tip-item">
            <i class="fa-solid fa-circle-dot"></i>
            Sử dụng mật khẩu khác nhau cho các tài khoản khác nhau.
        </div>
        <div class="tip-item">
            <i class="fa-solid fa-circle-dot"></i>
            Đổi mật khẩu định kỳ mỗi 3–6 tháng để tăng bảo mật.
        </div>

        <!-- Checklist realtime -->
        <div class="pwd-checklist">
            <div class="check-item" id="chk-len">
                <i class="fa-regular fa-circle"></i>
                Ít nhất 8 ký tự
            </div>
            <div class="check-item" id="chk-num">
                <i class="fa-regular fa-circle"></i>
                Có chứa chữ số (0–9)
            </div>
            <div class="check-item" id="chk-upper">
                <i class="fa-regular fa-circle"></i>
                Có chữ hoa (A–Z)
            </div>
            <div class="check-item" id="chk-special">
                <i class="fa-regular fa-circle"></i>
                Có ký tự đặc biệt (!@@#$...)
            </div>
        </div>

    </div>

</div>

@section Scripts {
<script>
    // ── SHOW / HIDE PASSWORD ──
    function togglePwd(inputId, btn) {
        const input = document.getElementById(inputId);
        const icon  = btn.querySelector('i');
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        icon.className = isHidden ? 'fa-regular fa-eye-slash' : 'fa-regular fa-eye';
    }

    // ── PASSWORD STRENGTH ──
    function checkStrength(val) {
        const wrap  = document.getElementById('strengthWrap');
        const label = document.getElementById('strengthLabel');
        const bars  = [1,2,3,4].map(i => document.getElementById('bar' + i));

        if (!val) { wrap.style.display = 'none'; return; }
        wrap.style.display = 'block';

        let score = 0;
        if (val.length >= 8)             score++;
        if (val.length >= 10)            score++;
        if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val))   score++;

        const levels = [
            { cls: 'weak',   text: 'Yếu',         fill: 1 },
            { cls: 'weak',   text: 'Yếu',          fill: 1 },
            { cls: 'medium', text: 'Trung bình',   fill: 2 },
            { cls: 'medium', text: 'Khá mạnh',     fill: 3 },
            { cls: 'strong', text: 'Mạnh',         fill: 4 },
        ];

        const lv = levels[score];
        bars.forEach((b, i) => {
            b.className = 'strength-bar ' + (i < lv.fill ? lv.cls : '');
        });
        label.className = 'strength-label ' + lv.cls;
        label.textContent = lv.text;

        // Checklist
        setCheck('chk-len',     val.length >= 8);
        setCheck('chk-num',     /[0-9]/.test(val));
        setCheck('chk-upper',   /[A-Z]/.test(val));
        setCheck('chk-special', /[^A-Za-z0-9]/.test(val));
    }

    function setCheck(id, pass) {
        const el   = document.getElementById(id);
        const icon = el.querySelector('i');
        el.classList.toggle('pass', pass);
        icon.className = pass ? 'fa-solid fa-circle-check' : 'fa-regular fa-circle';
    }

    // ── CONFIRM PASSWORD VALIDATION ──
    function validateConfirm() {
        const newPwd  = document.getElementById('newPassword').value;
        const confirm = document.getElementById('confirmPassword');
        const hint    = document.getElementById('confirmHint');
        const submitBtn = document.getElementById('submitBtn');

        if (!confirm.value) {
            hint.style.display = 'none';
            confirm.className  = 'form-control-custom';
            return;
        }

        const match = newPwd === confirm.value;
        hint.style.display = 'flex';

        if (match) {
            confirm.className  = 'form-control-custom is-ok';
            hint.className     = 'field-hint ok';
            hint.innerHTML     = '<i class="fa-solid fa-circle-check"></i> Mật khẩu khớp';
        } else {
            confirm.className  = 'form-control-custom is-error';
            hint.className     = 'field-hint error';
            hint.innerHTML     = '<i class="fa-solid fa-circle-exclamation"></i> Mật khẩu không khớp';
        }

        submitBtn.disabled = !match;
    }

    // ── FORM SUBMIT: client-side guard ──
    document.getElementById('changePwdForm').addEventListener('submit', function (e) {
        const newPwd  = document.getElementById('newPassword').value;
        const confirm = document.getElementById('confirmPassword').value;

        if (newPwd !== confirm) {
            e.preventDefault();
            validateConfirm();
            return;
        }

        const btn = document.getElementById('submitBtn');
        btn.disabled  = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang cập nhật...';
    });
</script>
}
