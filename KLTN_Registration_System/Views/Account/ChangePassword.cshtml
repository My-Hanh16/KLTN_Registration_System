@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account/change-password.css" asp-append-version="true" />
}

<div class="page-heading">
    <h2>Đổi mật khẩu</h2>
    <p>Cập nhật mật khẩu để bảo vệ tài khoản của bạn.</p>
</div>

<div class="pwd-wrap">
    <div class="pwd-card">

        <div class="card-title">
            <i class="fa-solid fa-lock"></i>
            Thay đổi mật khẩu
        </div>

        <form asp-action="ChangePassword" asp-controller="Account"
              method="post" id="changePwdForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">
                    Mật khẩu hiện tại <span class="required">*</span>
                </label>
                <div class="input-wrap">
                    <input type="password" name="currentPassword"
                           id="currentPassword"
                           class="form-control-custom"
                           required
                           placeholder="Nhập mật khẩu hiện tại" />
                    <button type="button" class="toggle-pwd"
                            data-toggle-password
                            data-target="currentPassword"
                            tabindex="-1">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">
                    Mật khẩu mới <span class="required">*</span>
                </label>
                <div class="input-wrap">
                    <input type="password" name="newPassword"
                           id="newPassword"
                           class="form-control-custom"
                           required minlength="8"
                           placeholder="Ít nhất 8 ký tự" />
                    <button type="button" class="toggle-pwd"
                            data-toggle-password
                            data-target="newPassword"
                            tabindex="-1">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>

                <div class="strength-wrap" id="strengthWrap" hidden>
                    <div class="strength-bars">
                        <div class="strength-bar" id="bar1"></div>
                        <div class="strength-bar" id="bar2"></div>
                        <div class="strength-bar" id="bar3"></div>
                        <div class="strength-bar" id="bar4"></div>
                    </div>
                    <span class="strength-label" id="strengthLabel"></span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">
                    Xác nhận mật khẩu mới <span class="required">*</span>
                </label>
                <div class="input-wrap">
                    <input type="password" name="confirmPassword"
                           id="confirmPassword"
                           class="form-control-custom"
                           required
                           placeholder="Nhập lại mật khẩu mới" />
                    <button type="button" class="toggle-pwd"
                            data-toggle-password
                            data-target="confirmPassword"
                            tabindex="-1">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
                <div class="field-hint" id="confirmHint" hidden></div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save" id="submitBtn">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Cập nhật mật khẩu
                </button>
                <a href="javascript:history.back()" class="btn-back">
                    <i class="fa-solid fa-arrow-left"></i>
                    Quay lại
                </a>
            </div>

        </form>
    </div>

    <div class="pwd-tips">

        <div class="tips-title">
            <i class="fa-solid fa-shield-halved"></i>
            Lưu ý bảo mật
        </div>

        <div class="tip-item">
            <i class="fa-solid fa-circle-dot"></i>
            Không chia sẻ mật khẩu với bất kỳ ai, kể cả quản trị viên.
        </div>
        <div class="tip-item">
            <i class="fa-solid fa-circle-dot"></i>
            Sử dụng mật khẩu khác nhau cho các tài khoản khác nhau.
        </div>
        <div class="tip-item">
            <i class="fa-solid fa-circle-dot"></i>
            Đổi mật khẩu định kỳ mỗi 3–6 tháng để tăng bảo mật.
        </div>

        <div class="pwd-checklist">
            <div class="check-item" id="chk-len">
                <i class="fa-regular fa-circle"></i>
                Ít nhất 8 ký tự
            </div>
            <div class="check-item" id="chk-num">
                <i class="fa-regular fa-circle"></i>
                Có chứa chữ số (0–9)
            </div>
            <div class="check-item" id="chk-upper">
                <i class="fa-regular fa-circle"></i>
                Có chữ hoa (A–Z)
            </div>
            <div class="check-item" id="chk-special">
                <i class="fa-regular fa-circle"></i>
                Có ký tự đặc biệt (!@@#$...)
            </div>
        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/account/change-password.js" asp-append-version="true"></script>
}
