@{
    Layout = null;
    ViewData["Title"] = "Quên mật khẩu";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=Sora:wght@700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/account/login.css" asp-append-version="true" />

<nav class="navbar">
    <a asp-controller="Home" asp-action="Index" class="nav-logo">KLTN Portal</a>
    <div class="nav-right">
        <a asp-controller="Account" asp-action="Login" class="btn-portal-login">Đăng nhập</a>
    </div>
</nav>

<div class="hero-wrap">
    <div class="hero-bg"></div>
    <div class="hero-glow"></div>

    <div class="hero-body forgot-body">
        <div class="hero-left">
            <div class="hero-badge">
                <div class="badge-icon"><i class="fa-solid fa-key"></i></div>
                Khôi phục truy cập
            </div>

            <h1 class="hero-title">
                Lấy lại quyền<br>
                truy cập <span class="hi">hệ thống</span>
            </h1>

            <p class="hero-desc">
                Nhập email, tên đăng nhập hoặc mã số sinh viên/giảng viên. Hệ thống sẽ gửi mã OTP đặt lại mật khẩu về email đã đăng ký.
            </p>
        </div>

            <div class="form-card">
                <div class="card-title">Quên mật khẩu</div>
            <div class="card-sub">Kiểm tra hộp thư và nhập mã OTP trong 10 phút.</div>

            @if (TempData["Success"] != null)
            {
                <div class="alert-success">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>@TempData["Success"]</span>
                </div>
            }

            @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0)
                && ViewData.ModelState["identifier"]?.Errors.Count == 0)
            {
                <div class="alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@ViewData.ModelState.Values.SelectMany(v => v.Errors).First().ErrorMessage</span>
                </div>
            }

            <form asp-controller="Account" asp-action="ForgotPassword" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="field">
                    <label class="field-label" for="identifier">Email / tên đăng nhập / mã số</label>
                    <div class="field-wrap">
                        <i class="fa-regular fa-user field-icon"></i>
                        <input type="text" id="identifier" name="identifier"
                               value="@(ViewData["Identifier"] ?? "")"
                               placeholder="sv102@kltn.local hoặc SV102"
                               class="@(ViewData.ModelState["identifier"]?.Errors.Count > 0 ? "is-error" : "")"
                               autocomplete="username" autofocus />
                    </div>
                    @if (ViewData.ModelState["identifier"]?.Errors.Count > 0)
                    {
                        <div class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            @ViewData.ModelState["identifier"]!.Errors[0].ErrorMessage
                        </div>
                    }
                </div>

                <button type="submit" class="btn-submit">
                    <i class="fa-regular fa-paper-plane"></i>
                    <span>Gửi mã OTP</span>
                </button>

                <a asp-controller="Account" asp-action="Login" class="back-login">
                    <i class="fa-solid fa-arrow-left"></i>
                    Quay lại đăng nhập
                </a>
            </form>
        </div>
    </div>
</div>
