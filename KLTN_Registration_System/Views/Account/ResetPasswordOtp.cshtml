@{
    Layout = null;
    ViewData["Title"] = "Xác thực OTP";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=Sora:wght@700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/account/login.css" asp-append-version="true" />

<nav class="navbar">
    <a asp-controller="Home" asp-action="Index" class="nav-logo">KLTN Portal</a>
    <div class="nav-right">
        <a asp-controller="Account" asp-action="Login" class="btn-portal-login">Đăng nhập</a>
    </div>
</nav>

<div class="hero-wrap">
    <div class="hero-bg"></div>
    <div class="hero-glow"></div>

    <div class="hero-body forgot-body">
        <div class="hero-left">
            <div class="hero-badge">
                <div class="badge-icon"><i class="fa-solid fa-key"></i></div>
                Xác thực OTP
            </div>

            <h1 class="hero-title">
                Nhập mã<br>
                bảo mật <span class="hi">6 số</span>
            </h1>

            <p class="hero-desc">
                Mã OTP đã được gửi về @ViewData["MaskedEmail"]. Mã có hiệu lực trong 10 phút.
            </p>
        </div>

        <div class="form-card">
            <div class="card-title">Đặt lại mật khẩu</div>
            <div class="card-sub">Nhập OTP và mật khẩu mới cho tài khoản của bạn.</div>

            @if (TempData["Success"] != null)
            {
                <div class="alert-success">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>@TempData["Success"]</span>
                </div>
            }

            @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0)
                && ViewData.ModelState["otp"]?.Errors.Count == 0
                && ViewData.ModelState["newPassword"]?.Errors.Count == 0
                && ViewData.ModelState["confirmPassword"]?.Errors.Count == 0)
            {
                <div class="alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@ViewData.ModelState.Values.SelectMany(v => v.Errors).First().ErrorMessage</span>
                </div>
            }

            <form asp-controller="Account" asp-action="ResetPasswordOtp" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@ViewData["UserId"]" />

                <div class="field">
                    <label class="field-label" for="otp">Mã OTP</label>
                    <div class="field-wrap">
                        <i class="fa-solid fa-shield-keyhole field-icon"></i>
                        <input type="text" id="otp" name="otp"
                               inputmode="numeric" maxlength="6"
                               placeholder="Nhập 6 chữ số"
                               class="otp-input @(ViewData.ModelState["otp"]?.Errors.Count > 0 ? "is-error" : "")"
                               autocomplete="one-time-code" autofocus />
                    </div>
                    @if (ViewData.ModelState["otp"]?.Errors.Count > 0)
                    {
                        <div class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            @ViewData.ModelState["otp"]!.Errors[0].ErrorMessage
                        </div>
                    }
                </div>

                <div class="field">
                    <label class="field-label" for="newPassword">Mật khẩu mới</label>
                    <div class="field-wrap">
                        <i class="fa-solid fa-lock field-icon"></i>
                        <input type="password" id="newPassword" name="newPassword"
                               placeholder="Ít nhất 8 ký tự"
                               class="@(ViewData.ModelState["newPassword"]?.Errors.Count > 0 ? "is-error" : "")"
                               autocomplete="new-password" />
                    </div>
                    @if (ViewData.ModelState["newPassword"]?.Errors.Count > 0)
                    {
                        <div class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            @ViewData.ModelState["newPassword"]!.Errors[0].ErrorMessage
                        </div>
                    }
                </div>

                <div class="field">
                    <label class="field-label" for="confirmPassword">Xác nhận mật khẩu mới</label>
                    <div class="field-wrap">
                        <i class="fa-solid fa-lock field-icon"></i>
                        <input type="password" id="confirmPassword" name="confirmPassword"
                               placeholder="Nhập lại mật khẩu mới"
                               class="@(ViewData.ModelState["confirmPassword"]?.Errors.Count > 0 ? "is-error" : "")"
                               autocomplete="new-password" />
                    </div>
                    @if (ViewData.ModelState["confirmPassword"]?.Errors.Count > 0)
                    {
                        <div class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            @ViewData.ModelState["confirmPassword"]!.Errors[0].ErrorMessage
                        </div>
                    }
                </div>

                <button type="submit" class="btn-submit">
                    <i class="fa-solid fa-floppy-disk"></i>
                    <span>Đặt lại mật khẩu</span>
                </button>

                <a asp-controller="Account" asp-action="ForgotPassword" class="back-login">
                    <i class="fa-solid fa-rotate-left"></i>
                    Gửi lại mã OTP
                </a>
            </form>
        </div>
    </div>
</div>
