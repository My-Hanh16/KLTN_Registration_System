@model IEnumerable<KLTN_Registration_System.Models.Entities.TimelineSubmission>
@using KLTN_Registration_System.Models.Entities

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Quá hạn duyệt";
    var overdueSubmissions = Model?.ToList() ?? new List<TimelineSubmission>();
    var timelines = (ViewBag.Timelines as IEnumerable<Timeline> ?? Enumerable.Empty<Timeline>()).ToList();
    int? selectedTimelineId = ViewBag.TimelineId is int timelineIdValue ? timelineIdValue : null;

    int totalOverdue = overdueSubmissions.Count;
    int totalTimelines = overdueSubmissions
        .Select(x => x.TimelineId)
        .Distinct()
        .Count();
    int affectedStudents = overdueSubmissions
        .Where(x => !string.IsNullOrWhiteSpace(x.StudentId))
        .Select(x => x.StudentId)
        .Distinct()
        .Count();
    int affectedLecturers = ViewBag.AffectedLecturers ?? 0;
    string selectedSemester = ViewBag.Semester as string ?? Context.Request.Query["semester"].ToString();
    string selectedYear = ViewBag.Year as string ?? Context.Request.Query["year"].ToString();
    string selectedPeriodName = ViewBag.SelectedPeriodName as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/timeline/pending-after-deadline.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title">Bài chờ duyệt quá hạn</h2>
        <p class="page-sub">Các bài sinh viên đã nộp nhưng giảng viên chưa xử lý sau hạn duyệt trong đợt @selectedPeriodName.</p>
    </div>
    <a asp-action="Index"
       asp-controller="Timeline"
       asp-route-semester="@selectedSemester"
       asp-route-year="@selectedYear"
       class="btn btn-ghost">
        <i class="fa-regular fa-clock"></i> Quay lại mốc thời gian
    </a>
</div>

<div class="stats-row">
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon red"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <span class="stat-badge red">Cần xử lý</span>
        </div>
        <div class="stat-label">Bài chờ quá hạn</div>
        <div class="stat-number">@totalOverdue</div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon amber"><i class="fa-solid fa-layer-group"></i></div>
            <span class="stat-badge amber">Mốc</span>
        </div>
        <div class="stat-label">Mốc có bài quá hạn</div>
        <div class="stat-number">@totalTimelines</div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon blue"><i class="fa-solid fa-users"></i></div>
            <span class="stat-badge blue">Sinh viên</span>
        </div>
        <div class="stat-label">Sinh viên bị ảnh hưởng</div>
        <div class="stat-number">@affectedStudents</div>
        <div class="stat-meta">GV liên quan: @affectedLecturers</div>
    </div>
</div>

@if (totalOverdue > 0)
{
    <div class="warn-banner">
        <i class="fa-solid fa-circle-exclamation"></i>
        <div>
            <strong>Cảnh báo:</strong> Có <strong>@totalOverdue bài nộp</strong> của sinh viên chưa được giảng viên
            xử lý sau hạn duyệt. Các bài này sẽ không được tính vào tổng hợp kết quả nếu không có hành động kịp thời.
            Hãy liên hệ giảng viên phụ trách hoặc xử lý thủ công.
        </div>
    </div>
}

<div class="main-card">

    <div class="card-head">
        <div class="card-head-left">
            <h3 class="card-head-title">
                <i class="fa-solid fa-hourglass-end card-head-icon"></i>
                Danh sách bài quá hạn
            </h3>

            <form method="get" class="filter-form">
                <input type="hidden" name="semester" value="@selectedSemester" />
                <input type="hidden" name="year" value="@selectedYear" />
                <select name="timelineId" class="f-select js-auto-submit">
                    <option value="">Tất cả mốc quá hạn</option>
                    @foreach (var tl in timelines)
                    {
                        @if (selectedTimelineId == tl.Id)
                        {
                            <option value="@tl.Id" selected>@tl.Title</option>
                        }
                        else
                        {
                            <option value="@tl.Id">@tl.Title</option>
                        }
                    }
                </select>
            </form>
        </div>

        <span class="result-count">
            <b>@totalOverdue</b> bài chờ xử lý
        </span>
    </div>

    <div class="table-scroll">
        @if (!overdueSubmissions.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fa-solid fa-circle-check"></i></div>
                <h3>Không có bài quá hạn</h3>
                <p>Tất cả bài nộp đã được giảng viên xử lý đúng hạn.</p>
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="col-index">#</th>
                        <th>Mốc thời gian</th>
                        <th>Sinh viên</th>
                        <th>Ngày nộp</th>
                        <th>Hạn duyệt</th>
                        <th>Trễ hạn</th>
                        <th class="col-file">File</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int idx = 1;
                        @foreach (var item in overdueSubmissions)
                        {
                            string? studentName = item.Student?.FullName?.Trim();
                            string displayName = string.IsNullOrWhiteSpace(studentName)
                                ? item.Student?.UserName ?? "N/A"
                                : studentName;
                            string initial = string.IsNullOrWhiteSpace(studentName)
                                ? "SV"
                                : studentName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Last()[..1].ToUpperInvariant();

                            string lateDays = "—";
                            if (item.Timeline?.ReviewDeadline.HasValue == true)
                            {
                                var diff = DateTime.Now - item.Timeline.ReviewDeadline.Value;
                                if (diff.TotalDays > 0)
                                    lateDays = $"{(int)diff.TotalDays} ngày";
                            }

                            <tr>
                                <!-- STT -->
                                <td class="index-cell">
                                    @(idx.ToString("D2"))
                                </td>

                                <!-- Mốc thời gian -->
                                <td>
                                    <span class="tl-badge">
                                        <i class="fa-regular fa-calendar tl-badge-icon"></i>
                                        @(item.Timeline?.Title ?? "N/A")
                                    </span>
                                </td>

                                <!-- Sinh viên -->
                                <td>
                                    <div class="stu-cell">
                                        <div class="stu-avatar">@initial</div>
                                        <div>
                                            <div class="stu-name">@displayName</div>
                                            <div class="stu-email">@(item.Student?.Email ?? "—")</div>
                                        </div>
                                    </div>
                                </td>

                                <!-- Ngày nộp -->
                                <td>
                                    <div class="date-main">@item.SubmittedAt.ToString("dd/MM/yyyy")</div>
                                    <div class="date-sub">@item.SubmittedAt.ToString("HH:mm")</div>
                                </td>

                                <!-- Hạn duyệt -->
                                <td>
                                    @if (item.Timeline?.ReviewDeadline.HasValue == true)
                                    {
                                        <div class="date-main date-main--overdue">
                                            @item.Timeline.ReviewDeadline.Value.ToString("dd/MM/yyyy")
                                        </div>
                                        <div class="date-sub">@item.Timeline.ReviewDeadline.Value.ToString("HH:mm")</div>
                                    }
                                    else
                                    {
                                        <span class="muted-empty">Chưa có</span>
                                    }
                                </td>

                                <!-- Trễ hạn -->
                                <td>
                                    @if (lateDays != "—")
                                    {
                                        <span class="deadline-pill">
                                            <i class="fa-solid fa-clock deadline-pill-icon"></i>
                                            Trễ @lateDays
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="muted-empty">—</span>
                                    }
                                </td>

                                <!-- File -->
                                <td class="file-cell">
                                    @if (!string.IsNullOrWhiteSpace(item.FilePath))
                                    {
                                        <a href="@Url.Action("DownloadSubmissionFile","Timeline", new { submissionId = item.Id })"
                                           target="_blank" class="file-link">
                                            <i class="fa-solid fa-file-arrow-down file-link-icon"></i>
                                            Tải file
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="no-file">Không có</span>
                                    }
                                </td>
                            </tr>
                            idx++;
                        }
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/timeline/pending-after-deadline.js" asp-append-version="true"></script>
}
