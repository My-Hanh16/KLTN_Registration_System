@model IEnumerable<KLTN_Registration_System.Models.Entities.TimelineSubmission>

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Bai cho duyet qua han";
    var timelines = ViewBag.Timelines as IEnumerable<KLTN_Registration_System.Models.Entities.Timeline>
                    ?? Enumerable.Empty<KLTN_Registration_System.Models.Entities.Timeline>();
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold mb-1">B&#224;i ch&#7901; duy&#7879;t qu&#225; h&#7841;n</h2>
            <p class="text-muted mb-0">C&#225;c b&#224;i sinh vi&#234;n &#273;&#227; n&#7897;p nh&#432;ng gi&#7843;ng vi&#234;n ch&#432;a x&#7917; l&#253; sau h&#7841;n duy&#7879;t.</p>
        </div>
        <a asp-action="Index" asp-controller="Timeline" class="btn btn-outline-secondary">
            Quay l&#7841;i m&#7889;c th&#7901;i gian
        </a>
    </div>

    <form method="get" class="mb-3">
        <select name="timelineId" class="form-select" style="max-width:360px" onchange="this.form.submit()">
            <option value="">T&#7845;t c&#7843; m&#7889;c qu&#225; h&#7841;n</option>
            @foreach (var timeline in timelines)
            {
                <option value="@timeline.Id" selected="@(ViewBag.TimelineId == timeline.Id)">
                    @timeline.Title
                </option>
            }
        </select>
    </form>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>M&#7889;c th&#7901;i gian</th>
                        <th>Sinh vi&#234;n</th>
                        <th>Email</th>
                        <th>Ng&#224;y n&#7897;p</th>
                        <th>H&#7841;n duy&#7879;t</th>
                        <th>File</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Kh&#244;ng c&#243; b&#224;i ch&#7901; duy&#7879;t qu&#225; h&#7841;n.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@(item.Timeline?.Title ?? "N/A")</td>
                            <td>@(item.Student?.FullName ?? item.Student?.UserName ?? "N/A")</td>
                            <td>@(item.Student?.Email ?? "N/A")</td>
                            <td>@item.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(item.Timeline?.ReviewDeadline?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.FilePath))
                                {
                                    <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = item.Id })" target="_blank" rel="noopener">Xem file</a>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
