@model IEnumerable<KLTN_Registration_System.Models.Entities.TimelineSubmission>

@using KLTN_Registration_System.Models.Entities
@using KLTN_Registration_System.Models.Enums

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Tổng hợp đã duyệt";

    var approvedSubmissions = Model?.ToList() ?? new List<TimelineSubmission>();
    var timelines = ViewBag.Timelines as List<Timeline> ?? new List<Timeline>();
    var faculties = ViewBag.Faculties as List<string> ?? new List<string>();
    var majors = ViewBag.Majors as List<Major> ?? new List<Major>();
    int currentPage = ViewBag.CurrentPage ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int stt = ((currentPage - 1) * pageSize) + 1;
    int totalApproved = ViewBag.TotalApproved ?? 0;
    int todayApproved = ViewBag.TodayApproved ?? 0;
    var selectedTimeline = ViewBag.SelectedTimeline as Timeline;
    int? selectedTlId = ViewBag.TimelineId is int timelineIdValue ? timelineIdValue : null;
    string? keyword = ViewBag.Keyword as string;
    int totalPages = ViewBag.TotalPages ?? 1;
    string selectedSemester = ViewBag.Semester as string ?? Context.Request.Query["semester"].ToString();
    string selectedYear = ViewBag.Year as string ?? Context.Request.Query["year"].ToString();
    string selectedPeriodName = ViewBag.SelectedPeriodName as string ?? "";
    string? selectedFaculty = ViewBag.Faculty as string ?? Context.Request.Query["faculty"].ToString();
    int? selectedMajorId = ViewBag.MajorId is int majorIdValue ? majorIdValue : null;

    var nearestDeadline = timelines
        .Where(x => x.Date >= DateTime.Now)
        .OrderBy(x => x.Date)
        .FirstOrDefault();
}

@section Styles {
    <link rel="stylesheet" href="~/css/timeline/approved-submissions.css" asp-append-version="true" />
}
@if (TempData["Success"] != null)
{
    <div class="alert-bar success">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-bar error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="page-title">Tổng hợp bài đã duyệt</h2>
        <p class="page-sub">Danh sách bài nộp đã được giảng viên phê duyệt trong đợt @selectedPeriodName — dùng để rà soát và xuất danh sách tổng hợp khóa luận.</p>
    </div>

    @if (selectedTlId.HasValue)
    {
        <a href="@Url.Action("ExportApprovedSubmissions", "Timeline", new { keyword, timelineId = selectedTlId.Value, semester = selectedSemester, year = selectedYear, faculty = selectedFaculty, majorId = selectedMajorId })"
           class="btn btn-success export-btn">
            <i class="fa-solid fa-file-excel"></i>
            Xuất Excel theo mốc
        </a>
    }
    else
    {
        <span class="btn btn-disabled export-btn" title="Chọn mốc thời gian để xuất Excel">
            <i class="fa-solid fa-file-excel"></i>
            Xuất Excel
        </span>
    }
</div>

<div class="stats-row">

    <div class="stat-card">
        <div class="stat-icon-row">
            <div class="stat-icon blue"><i class="fa-solid fa-circle-check"></i></div>
            <span class="stat-badge blue">Tổng</span>
        </div>
        <div class="stat-label">Bài đã được duyệt</div>
        <div class="stat-number">@totalApproved</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon-row">
            <div class="stat-icon green"><i class="fa-solid fa-calendar-check"></i></div>
            <span class="stat-badge green">Hôm nay</span>
        </div>
        <div class="stat-label">Duyệt trong ngày</div>
        <div class="stat-number">@todayApproved</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon-row">
            <div class="stat-icon amber"><i class="fa-regular fa-clock"></i></div>
            <span class="stat-badge amber">Sắp tới</span>
        </div>
        <div class="stat-label">Mốc gần nhất</div>
        <div class="stat-number sm">
            @(nearestDeadline?.Title ?? "Chưa có")
        </div>
        @if (nearestDeadline != null)
        {
            <div class="stat-meta">
                @nearestDeadline.Date.ToString("dd/MM/yyyy HH:mm")
            </div>
        }
    </div>

    <div class="stat-card">
        <div class="stat-icon-row">
            <div class="stat-icon purple"><i class="fa-solid fa-filter"></i></div>
            <span class="stat-badge purple">Đang lọc</span>
        </div>
        <div class="stat-label">Mốc đang xem</div>
        <div class="stat-number sm">
            @(selectedTimeline?.Title ?? "Chưa chọn mốc")
        </div>
        @if (selectedTimeline != null)
        {
            <div class="stat-meta">
                @selectedTimeline.Date.ToString("dd/MM/yyyy")
            </div>
        }
    </div>

</div>

<div class="main-card">

    <!-- TOOLBAR -->
    <div class="toolbar">
        <form method="get" action="@Url.Action("ApprovedSubmissions", "Timeline")"
              class="toolbar-left" id="filterForm">
            <input type="hidden" name="semester" value="@selectedSemester" />
            <input type="hidden" name="year" value="@selectedYear" />

            <!-- Search -->
            <div class="search-wrap">
                <i class="fa-solid fa-magnifying-glass search-ico"></i>
                <input type="text" name="keyword" value="@keyword"
                       class="search-input"
                       placeholder="Tìm tên sinh viên, mã SV..." />
            </div>

            <!-- Timeline filter -->
            <select name="timelineId" class="f-select js-auto-submit">
                <option value="">-- Chọn mốc thời gian --</option>
                @foreach (var tl in timelines)
                {
                    if (selectedTlId == tl.Id)
                    {
                        <option value="@tl.Id" selected>@tl.Title</option>
                    }
                    else
                    {
                        <option value="@tl.Id">@tl.Title</option>
                    }
                }
            </select>

            <select name="faculty" class="f-select js-auto-submit">
                <option value="">-- Tất cả khoa --</option>
                @foreach (var faculty in faculties)
                {
                    if (selectedFaculty == faculty)
                    {
                        <option value="@faculty" selected>@faculty</option>
                    }
                    else
                    {
                        <option value="@faculty">@faculty</option>
                    }
                }
            </select>

            <select name="majorId" class="f-select js-auto-submit">
                <option value="">-- Tất cả ngành --</option>
                @foreach (var major in majors)
                {
                    if (selectedMajorId == major.Id)
                    {
                        <option value="@major.Id" selected>@major.Name</option>
                    }
                    else
                    {
                        <option value="@major.Id">@major.Name</option>
                    }
                }
            </select>

            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-magnifying-glass"></i> Tìm kiếm
            </button>

            <a href="@Url.Action("ApprovedSubmissions", "Timeline", new { semester = selectedSemester, year = selectedYear })" class="btn btn-ghost">
                <i class="fa-solid fa-rotate-left"></i> Làm mới
            </a>

        </form>

        <div class="toolbar-right">
            @if (selectedTlId.HasValue && approvedSubmissions.Any())
            {
                <span class="result-count">
                    <b>@approvedSubmissions.Count</b> / @totalApproved kết quả
                </span>
            }
        </div>
    </div>

    @if (!selectedTlId.HasValue)
    {
        <div class="hint-banner">
            <i class="fa-solid fa-circle-info"></i>
            <div>
                <strong>Chọn một mốc thời gian</strong> ở bộ lọc phía trên để xem danh sách bài nộp đã duyệt —
                ví dụ: <em>Báo cáo tiến độ lần 1</em>, <em>Nộp đề cương chi tiết</em>...
            </div>
        </div>
    }

    <div class="table-wrap">
        @if (!selectedTlId.HasValue)
        {
            <div class="empty-state empty-state--select">
                <i class="fa-regular fa-folder-open"></i>
                <p>Vui lòng chọn mốc thời gian để xem dữ liệu.</p>
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="col-stt">STT</th>
                        <th>Sinh viên</th>
                        <th>Mốc thời gian</th>
                        <th>Trạng thái</th>
                        <th>Ngày duyệt</th>
                        <th class="col-actions">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!approvedSubmissions.Any())
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <i class="fa-regular fa-inbox"></i>
                                    <p>Chưa có bài nào được duyệt ở mốc thời gian này.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in approvedSubmissions)
                        {
                            string initial = string.IsNullOrEmpty(item.Student?.FullName)
                            ? "SV"
                            : item.Student.FullName.Trim().Split(' ').Last().Substring(0, 1).ToUpper();

                            <tr>
                                <!-- STT -->
                                <td class="stt-cell">@(stt.ToString("D2"))</td>

                                <!-- Sinh viên -->
                                <td>
                                    <div class="stu-cell">
                                        <div class="stu-avatar">@initial</div>
                                        <div>
                                            <div class="stu-name">@(item.Student?.FullName ?? "Chưa có tên")</div>
                                            <span class="stu-code">@(item.Student?.UserCode ?? "N/A")</span>
                                            <div class="stu-major">
                                                @(item.Student?.Major?.FacultyName ?? item.Student?.Faculty ?? "Chưa có khoa")
                                                <span>•</span>
                                                @(item.Student?.Major?.Name ?? "Chưa có ngành")
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <!-- Timeline -->
                                <td>
                                    <span class="tl-badge">
                                        <i class="fa-regular fa-calendar tl-badge-icon"></i>
                                        @(item.Timeline?.Title ?? "—")
                                    </span>
                                </td>

                                <!-- Status -->
                                <td>
                                    <span class="status-approved">
                                        <i class="fa-solid fa-check status-approved-icon"></i>
                                        Đã duyệt
                                    </span>
                                </td>

                                <!-- Ngày duyệt -->
                                <td>
                                    @if (item.ReviewedAt.HasValue)
                                    {
                                        <div class="date-main">@item.ReviewedAt.Value.ToString("dd/MM/yyyy")</div>
                                        <div class="date-sub">@item.ReviewedAt.Value.ToString("HH:mm")</div>
                                    }
                                    else
                                    {
                                        <span class="date-empty">Chưa có</span>
                                    }
                                </td>

                                <!-- Thao tác -->
                                <td>
                                    <div class="act-group">
                                        <a href="@Url.Action("SubmissionDetail", "Timeline", new { id = item.Id, keyword, timelineId = selectedTlId.GetValueOrDefault(), semester = selectedSemester, year = selectedYear, page = currentPage })"
                                           class="act-btn view">
                                            <i class="fa-solid fa-circle-info act-btn-icon"></i>
                                            Chi tiết
                                        </a>

                                        @if (!string.IsNullOrEmpty(item.FilePath))
                                        {
                                            <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = item.Id })"
                                               target="_blank" class="act-btn dl">
                                                <i class="fa-solid fa-file-arrow-down act-btn-icon"></i>
                                                Tải file
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="no-file">Không có file</span>
                                        }
                                    </div>
                                </td>
                            </tr>

                            stt++;
                        }
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- PAGINATION -->
    @if (totalPages > 1 && selectedTlId.HasValue)
    {
        <div class="paging-wrap">
            <div class="paging-info">
                Trang <b>@currentPage</b> / <b>@totalPages</b>
                &nbsp;·&nbsp;
                <b>@approvedSubmissions.Count</b> / <b>@totalApproved</b> kết quả
            </div>

            <div class="paging-btns">
                @* Prev *@
                @if (currentPage > 1)
                {
                    <a href="@Url.Action("ApprovedSubmissions", "Timeline", new { page = currentPage - 1, keyword, timelineId = selectedTlId.GetValueOrDefault(), semester = selectedSemester, year = selectedYear, faculty = selectedFaculty, majorId = selectedMajorId })"
                       class="pg-btn">
                        <i class="fa-solid fa-chevron-left pg-icon"></i>
                    </a>
                }

                @* Pages *@
                @for (int i = 1; i <= totalPages; i++)
                {
                    if (i == 1 || i == totalPages || (i >= currentPage - 2 && i <= currentPage + 2))
                    {
                        <a href="@Url.Action("ApprovedSubmissions", "Timeline", new { page = i, keyword, timelineId = selectedTlId.GetValueOrDefault(), semester = selectedSemester, year = selectedYear, faculty = selectedFaculty, majorId = selectedMajorId })"
                           class="pg-btn @(i == currentPage ? "active" : "")">
                            @i
                        </a>
                    }
                    else if (i == currentPage - 3 || i == currentPage + 3)
                    {
                        <span class="pg-btn ellipsis">…</span>
                    }
                }

                @* Next *@
                @if (currentPage < totalPages)
                {
                    <a href="@Url.Action("ApprovedSubmissions", "Timeline", new { page = currentPage + 1, keyword, timelineId = selectedTlId.GetValueOrDefault(), semester = selectedSemester, year = selectedYear, faculty = selectedFaculty, majorId = selectedMajorId })"
                       class="pg-btn">
                        <i class="fa-solid fa-chevron-right pg-icon"></i>
                    </a>
                }
            </div>
        </div>
    }

</div>

@section Scripts {
    <script src="~/js/timeline/approved-submissions.js" asp-append-version="true"></script>
}

