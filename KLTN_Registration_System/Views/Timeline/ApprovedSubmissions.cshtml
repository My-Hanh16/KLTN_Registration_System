@model IEnumerable<KLTN_Registration_System.Models.Entities.TimelineSubmission>

@using KLTN_Registration_System.Models.Entities
@using KLTN_Registration_System.Models.Enums

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Tổng hợp đã duyệt";

    var timelines = ViewBag.Timelines as List<Timeline> ?? new List<Timeline>();

    int currentPage = ViewBag.CurrentPage ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int stt = ((currentPage - 1) * pageSize) + 1;

    int totalApproved = ViewBag.TotalApproved ?? 0;
    int todayApproved = ViewBag.TodayApproved ?? 0;
    var selectedTimeline = ViewBag.SelectedTimeline as Timeline;

    var nearestDeadline = timelines
        .Where(x => x.Date >= DateTime.Now)
        .OrderBy(x => x.Date)
        .FirstOrDefault();

    int totalPages = ViewBag.TotalPages ?? 1;
}

@section Styles {
<style>
    body {
        background: #f6f8fb;
        color: #0f172a;
        font-family: 'Inter', sans-serif;
    }

    .page-wrapper {
        max-width: 1500px;
        margin: auto;
        padding: 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 24px;
        margin-bottom: 24px;
    }

    .page-title {
        font-size: 26px;
        font-weight: 800;
        letter-spacing: -0.5px;
        margin: 0 0 8px;
        color: #0f172a;
    }

    .page-desc {
        max-width: 760px;
        font-size: 14px;
        line-height: 1.6;
        color: #64748b;
        margin: 0;
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 20px;
    }

    .summary-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, .04);
    }

    .summary-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #64748b;
        margin-bottom: 10px;
    }

    .summary-value {
        font-size: 30px;
        font-weight: 800;
        color: #0f172a;
        line-height: 1;
    }

    .summary-sub {
        margin-top: 10px;
        font-size: 12.5px;
        color: #64748b;
        font-weight: 600;
    }

    .main-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        box-shadow: 0 10px 28px rgba(15, 23, 42, .05);
        overflow: hidden;
    }

    .toolbar {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        padding: 16px 18px;
        background: #fbfdff;
        border-bottom: 1px solid #e2e8f0;
    }

    .filter-form {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        flex: 1;
    }

    .input-soft {
        height: 40px;
        border: 1px solid #cbd5e1;
        background: #fff;
        border-radius: 10px;
        padding: 0 13px;
        font-size: 13.5px;
        color: #0f172a;
        outline: none;
    }

    .input-soft:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79, 70, 229, .10);
    }

    .search-input {
        min-width: 320px;
    }

    .btn-soft {
        height: 40px;
        border-radius: 10px;
        border: 1px solid transparent;
        padding: 0 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        font-size: 13.5px;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
        transition: .15s ease;
    }

    .btn-primary {
        background: #4f46e5;
        color: #fff;
    }

    .btn-primary:hover {
        background: #4338ca;
        color: #fff;
    }

    .btn-outline {
        background: #fff;
        border-color: #cbd5e1;
        color: #475569;
    }

    .btn-outline:hover {
        background: #f8fafc;
        color: #0f172a;
    }

    .table-wrap {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    thead th {
        padding: 13px 18px;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        font-size: 11px;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: .06em;
        white-space: nowrap;
        text-align: left;
    }

    tbody td {
        padding: 15px 18px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
        font-size: 13.5px;
    }

    tbody tr:hover {
        background: #fafbff;
    }

    .student-box {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .avatar {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
    }

    .student-name {
        font-weight: 700;
        color: #0f172a;
    }

    .student-code {
        font-size: 12px;
        color: #64748b;
        margin-top: 2px;
    }

    .badge-approved {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #15803d;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .timeline-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #eef2ff;
        color: #4338ca;
        border: 1px solid #c7d2fe;
        padding: 5px 10px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
    }

    .date-main {
        font-weight: 700;
        color: #334155;
    }

    .date-sub {
        font-size: 12px;
        color: #64748b;
        margin-top: 2px;
    }

    .action-group {
        display: flex;
        justify-content: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 11px;
        border-radius: 9px;
        border: 1px solid #cbd5e1;
        color: #475569;
        background: #fff;
        font-size: 12.5px;
        font-weight: 700;
        text-decoration: none;
    }

    .action-btn:hover {
        background: #f8fafc;
        color: #0f172a;
    }

    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: #94a3b8;
        font-size: 14px;
        font-style: italic;
    }

    .pagination-wrap {
        padding: 14px 18px;
        background: #fbfdff;
        border-top: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .page-btn {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        color: #475569;
    }

    .page-btn:hover {
        background: #f1f5f9;
    }

    .page-btn.active {
        background: #4f46e5;
        color: #fff;
    }

    @@media(max-width: 1100px) {
        .summary-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(max-width: 768px) {
        .page-wrapper {
            padding: 20px;
        }

        .page-header {
            flex-direction: column;
        }

        .summary-grid {
            grid-template-columns: 1fr;
        }

        .search-input {
            min-width: 100%;
        }

        .filter-form {
            width: 100%;
        }
    }
</style>
}

<div class="page-wrapper">

    <div class="page-header">
        <div>
            <h1 class="page-title">Tổng hợp bài / đề tài đã duyệt</h1>
            <p class="page-desc">
                Danh sách các bài nộp đã được giảng viên phê duyệt. Admin dùng màn hình này để rà soát,
                lọc dữ liệu và xuất danh sách tổng hợp khóa luận tốt nghiệp.
            </p>
        </div>

        <a href="@Url.Action("ExportApprovedSubmissions", "Timeline", new {
        keyword = ViewBag.Keyword,
        timelineId = ViewBag.TimelineId
   })"
   class="btn-soft btn-primary">
    <span class="material-symbols-outlined text-[17px]">download</span>
    Xuất Excel theo mốc đang chọn
</a>
    </div>

    <div class="summary-grid">

        <div class="summary-card">
            <div class="summary-label">Tổng bài đã duyệt</div>
            <div class="summary-value">@totalApproved</div>
            <div class="summary-sub">Tất cả bài được GV phê duyệt</div>
        </div>

        <div class="summary-card">
            <div class="summary-label">Duyệt hôm nay</div>
            <div class="summary-value">@todayApproved</div>
            <div class="summary-sub">Bài mới được duyệt trong ngày</div>
        </div>

        <div class="summary-card">
            <div class="summary-label">Timeline gần nhất</div>
            <div class="summary-value" style="font-size:18px;line-height:1.35;">
                @(nearestDeadline?.Title ?? "Chưa có")
            </div>
            <div class="summary-sub">
                @(nearestDeadline != null ? nearestDeadline.Date.ToString("dd/MM/yyyy HH:mm") : "Chưa cấu hình")
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-label">Trạng thái dữ liệu</div>
            <div class="summary-value" style="font-size:18px;">
                @(selectedTimeline?.Title ?? "Chưa chọn mốc")
            </div>
            <div class="summary-sub">Mốc đang dùng để lọc và xuất Excel</div>
        </div>

    </div>

    <div class="main-card">

        <div class="toolbar">

            <form method="get" action="@Url.Action("ApprovedSubmissions", "Timeline")" class="filter-form">

    <input type="text"
           name="keyword"
           value="@ViewBag.Keyword"
           placeholder="Tìm theo tên sinh viên, mã SV..."
           class="input-soft search-input" />

    <select name="timelineId" class="input-soft" style="min-width:230px;">
        <option value="">Chọn mốc thời gian</option>

        @foreach (var tl in timelines)
{
    if (ViewBag.TimelineId != null &&
        ViewBag.TimelineId.ToString() == tl.Id.ToString())
    {
        <option value="@tl.Id" selected>
            @tl.Title
        </option>
    }
    else
    {
        <option value="@tl.Id">
            @tl.Title
        </option>
    }
}
    </select>

    <button type="submit" class="btn-soft btn-primary">
        <span class="material-symbols-outlined text-[17px]">search</span>
        Tìm kiếm
    </button>

    <a href="@Url.Action("ApprovedSubmissions", "Timeline")" class="btn-soft btn-outline">
        Làm mới
    </a>

</form>

        </div>

        <div class="table-wrap">

    @if (ViewBag.TimelineId == null)
    {
        <div class="empty-state">
            Vui lòng chọn một mốc thời gian trước, ví dụ: Báo cáo tiến độ lần 1, Báo cáo tiến độ lần 2...
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th style="width:80px;">STT</th>
                    <th>Sinh viên</th>
                    <th>Timeline</th>
                    <th>Trạng thái</th>
                    <th>Ngày duyệt</th>
                    <th style="text-align:center;width:230px;">Hành động</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                Chưa có bài nào được giảng viên duyệt ở mốc thời gian này.
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td style="font-weight:700;color:#94a3b8;">
                                @(stt.ToString("D2"))
                            </td>

                            <td>
                                <div class="student-box">
                                    <div class="avatar">
                                        @(string.IsNullOrEmpty(item.Student?.FullName)
                                            ? "SV"
                                            : item.Student.FullName.Substring(0, 1).ToUpper())
                                    </div>

                                    <div>
                                        <div class="student-name">
                                            @(item.Student?.FullName ?? "Chưa có tên")
                                        </div>
                                        <div class="student-code">
                                            @(item.Student?.UserCode ?? "Chưa có mã SV")
                                        </div>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <span class="timeline-badge">
                                    <span class="material-symbols-outlined text-[15px]">event_note</span>
                                    @(item.Timeline?.Title ?? "Chưa có timeline")
                                </span>
                            </td>

                            <td>
                                <span class="badge-approved">
                                    <span class="material-symbols-outlined text-[15px]">task_alt</span>
                                    Đã duyệt
                                </span>
                            </td>

                            <td>
                                <div class="date-main">
                                    @(item.ReviewedAt?.ToString("dd/MM/yyyy") ?? "Chưa có")
                                </div>
                                <div class="date-sub">
                                    @(item.ReviewedAt?.ToString("HH:mm") ?? "")
                                </div>
                            </td>

                            <td>
                                <div class="action-group">
                                    <a href="@Url.Action("SubmissionDetail", "Timeline", new { id = item.Id })"
                                       class="action-btn">
                                        <span class="material-symbols-outlined text-[16px]">info</span>
                                        Chi tiết
                                    </a>

                                    @if (!string.IsNullOrEmpty(item.FilePath))
                                    {
                                        <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = item.Id })" target="_blank" class="action-btn">
                                            <span class="material-symbols-outlined text-[16px]">visibility</span>
                                            Xem file
                                        </a>
                                    }
                                    else
                                    {
                                        <span style="font-size:12px;color:#94a3b8;font-style:italic;">
                                            Không có file
                                        </span>
                                    }
                                </div>
                            </td>
                        </tr>

                        stt++;
                    }
                }
            </tbody>
        </table>
    }
</div>

        @if (totalPages > 1)
        {
            <div class="pagination-wrap">

                <div style="font-size:13px;color:#64748b;">
                    Hiển thị <b>@Model.Count()</b> trong <b>@totalApproved</b> kết quả
                </div>

                <div>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <a href="@Url.Action("ApprovedSubmissions", "Timeline", new {
                                page = i,
                                keyword = ViewBag.Keyword,
                                timelineId = ViewBag.TimelineId
                           })"
                           class="page-btn @(currentPage == i ? "active" : "")">
                            @i
                        </a>
                    }
                </div>

            </div>
        }

    </div>

</div>
