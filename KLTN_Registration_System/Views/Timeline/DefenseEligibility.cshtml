@model IEnumerable<KLTN_Registration_System.Controllers.TimelineController.DefenseEligibilityVM>

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Điều kiện báo cáo";

    var rows = Model?.ToList() ?? new List<KLTN_Registration_System.Controllers.TimelineController.DefenseEligibilityVM>();
    string status              = ViewBag.SelectedStatus as string ?? "all";
    string keyword             = ViewBag.Keyword as string ?? "";
    string selectedPeriodName  = ViewBag.SelectedPeriodName as string ?? "";
    int requiredTimelineCount  = ViewBag.RequiredTimelineCount ?? 0;
    int totalAll               = ViewBag.TotalAll     ?? rows.Count;
    int totalEligible          = ViewBag.TotalEligible ?? rows.Count(x => x.IsEligible);
    int totalBlocked           = ViewBag.TotalBlocked  ?? rows.Count(x => !x.IsEligible);

    string tableTitle = status switch {
        "eligible" => "Sinh viên đủ điều kiện báo cáo",
        "blocked"  => "Sinh viên chưa đủ điều kiện báo cáo",
        _          => "Tổng hợp điều kiện báo cáo"
    };

    double eligibleRate = totalAll > 0 ? Math.Round((double)totalEligible / totalAll * 100, 1) : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/timeline/defense-eligibility.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-start mb-4 gap-3 page-header-row">
    <div>
        <h2 class="page-title">Điều kiện báo cáo khóa luận</h2>
        <p class="page-sub">
            Tổng hợp sinh viên đủ / chưa đủ điều kiện báo cáo
            @if (!string.IsNullOrEmpty(selectedPeriodName))
            {
                <span>— đợt <strong class="period-name">@selectedPeriodName</strong></span>
            }
        </p>
    </div>

    <div class="export-actions">
        <a asp-controller="Timeline" asp-action="ExportDefenseEligibility"
           asp-route-status="all" asp-route-keyword="@keyword"
           asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
           class="btn-export all">
            <i class="fa-solid fa-file-excel"></i> Xuất tất cả
        </a>
        <a asp-controller="Timeline" asp-action="ExportDefenseEligibility"
           asp-route-status="eligible" asp-route-keyword="@keyword"
           asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
           class="btn-export eligible">
            <i class="fa-solid fa-circle-check"></i> Xuất đủ điều kiện
        </a>
        <a asp-controller="Timeline" asp-action="ExportDefenseEligibility"
           asp-route-status="blocked" asp-route-keyword="@keyword"
           asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
           class="btn-export blocked">
            <i class="fa-solid fa-circle-exclamation"></i> Xuất chưa đủ
        </a>
    </div>
</div>

<div class="stats-row">
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon blue"><i class="fa-solid fa-users"></i></div>
            <span class="stat-badge blue">Tổng</span>
        </div>
        <div class="stat-label">Sinh viên có đề tài</div>
        <div class="stat-number">@totalAll</div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon green"><i class="fa-solid fa-circle-check"></i></div>
            <span class="stat-badge green">Đủ</span>
        </div>
        <div class="stat-label">Đủ điều kiện</div>
        <div class="stat-number">@totalEligible</div>
        <div class="stat-progress">
            <div class="stat-progress-fill" data-progress="@eligibleRate"></div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon red"><i class="fa-solid fa-circle-xmark"></i></div>
            <span class="stat-badge red">Chưa đủ</span>
        </div>
        <div class="stat-label">Chưa đủ điều kiện</div>
        <div class="stat-number">@totalBlocked</div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon purple"><i class="fa-solid fa-flag-checkered"></i></div>
            <span class="stat-badge purple">Bắt buộc</span>
        </div>
        <div class="stat-label">Mốc bắt buộc hoàn thành</div>
        <div class="stat-number">@requiredTimelineCount</div>
    </div>
</div>

<div class="filter-tabs">
    <a asp-controller="Timeline" asp-action="DefenseEligibility"
       asp-route-status="all" asp-route-keyword="@keyword"
       asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
       class="ftab @(status == "all" ? "active" : "")">
        Tất cả <span class="tab-count blue">@totalAll</span>
    </a>
    <a asp-controller="Timeline" asp-action="DefenseEligibility"
       asp-route-status="eligible" asp-route-keyword="@keyword"
       asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
       class="ftab green-tab @(status == "eligible" ? "active" : "")">
        Đủ điều kiện <span class="tab-count green">@totalEligible</span>
    </a>
    <a asp-controller="Timeline" asp-action="DefenseEligibility"
       asp-route-status="blocked" asp-route-keyword="@keyword"
       asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
       class="ftab red-tab @(status == "blocked" ? "active" : "")">
        Chưa đủ <span class="tab-count red">@totalBlocked</span>
    </a>
</div>

<form method="get" class="filter-card">
    <input type="hidden" name="semester" value="@ViewBag.Semester" />
    <input type="hidden" name="year"     value="@ViewBag.Year" />
    <input type="hidden" name="status"   value="@status" />

    <div class="search-wrap">
        <i class="fa-solid fa-magnifying-glass search-ico"></i>
        <input type="text" name="keyword" value="@keyword" class="search-input"
               placeholder="Tìm sinh viên, MSSV, đề tài, giảng viên..." />
    </div>

    <select name="statusFilter" class="f-select">
        @if (status == "all")
        {
            <option value="all" selected>Tất cả trạng thái</option>
        }
        else
        {
            <option value="all">Tất cả trạng thái</option>
        }

        @if (status == "eligible")
        {
            <option value="eligible" selected>Đủ điều kiện</option>
        }
        else
        {
            <option value="eligible">Đủ điều kiện</option>
        }

        @if (status == "blocked")
        {
            <option value="blocked" selected>Chưa đủ điều kiện</option>
        }
        else
        {
            <option value="blocked">Chưa đủ điều kiện</option>
        }
    </select>

    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-magnifying-glass"></i> Lọc
    </button>
</form>

<div class="main-card">
    <div class="card-head">
        <div class="card-head-title">
            <i class="fa-solid fa-table-list card-head-icon"></i>
            @tableTitle
        </div>
        <span class="row-count">Hiển thị <b>@rows.Count</b> sinh viên</span>
    </div>

    @if (!rows.Any())
    {
        <div class="empty-state">
            <i class="fa-regular fa-folder-open"></i>
            <p>Không có dữ liệu phù hợp với bộ lọc hiện tại.</p>
        </div>
    }
    else
    {
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="col-index">#</th>
                        <th>Sinh viên</th>
                        <th>Đề tài</th>
                        <th>Giảng viên HD</th>
                        <th>Tiến độ mốc</th>
                        <th class="col-status">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int idx = 1;
                        @foreach (var item in rows)
                        {
                            int progress = item.RequiredCount > 0
                                ? Math.Min(100, item.ApprovedCount * 100 / item.RequiredCount)
                                : 0;

                            string fillCls = progress >= 100 ? "" : progress > 0 ? "partial" : "zero";

                            <tr>
                                <!-- STT -->
                                <td class="index-cell">
                                    @(idx.ToString("D2"))
                                </td>

                                <!-- Sinh viên -->
                                <td>
                                    <div class="stu-name">@item.StudentName</div>
                                    <span class="stu-code">@item.StudentCode</span>
                                </td>

                                <!-- Đề tài -->
                                <td>
                                    <div class="topic-title" title="@item.TopicTitle">@item.TopicTitle</div>
                                </td>

                                <!-- Giảng viên -->
                                <td>
                                    <div class="lec-name">@item.LecturerName</div>
                                </td>

                                <!-- Tiến độ -->
                                <td>
                                    <div class="progress-wrap">
                                        <div class="progress-header">
                                            <span>@item.ApprovedCount / @item.RequiredCount mốc</span>
                                            <span class="progress-pct">@progress%</span>
                                        </div>
                                        <div class="progress-bar">
                                            <div class="progress-fill @fillCls" data-progress="@progress"></div>
                                        </div>
                                        <div class="progress-meta">
                                            @if (item.PendingCount > 0)
                                            {
                                                <span class="p-chip pending">
                                                    <i class="fa-solid fa-hourglass-half chip-icon"></i>
                                                    Chờ: @item.PendingCount
                                                </span>
                                            }
                                            @if (item.RejectedCount > 0)
                                            {
                                                <span class="p-chip rejected">
                                                    <i class="fa-solid fa-xmark chip-icon"></i>
                                                    Từ chối: @item.RejectedCount
                                                </span>
                                            }
                                            @if (item.MissingCount > 0)
                                            {
                                                <span class="p-chip missing">
                                                    <i class="fa-solid fa-minus chip-icon"></i>
                                                    Thiếu: @item.MissingCount
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <!-- Trạng thái -->
                                <td class="status-cell">
                                    <span class="s-badge @(item.IsEligible ? "eligible" : "blocked")">
                                        <i class="fa-solid @(item.IsEligible ? "fa-check" : "fa-xmark") status-icon"></i>
                                        @(item.IsEligible ? "Đủ điều kiện" : "Chưa đủ")
                                    </span>
                                </td>
                            </tr>
                            idx++;
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/timeline/defense-eligibility.js" asp-append-version="true"></script>
}
