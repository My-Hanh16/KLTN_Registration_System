@model KLTN_Registration_System.Models.Entities.TimelineSubmission
@using KLTN_Registration_System.Models.Entities

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Chi tiết bài nộp";

    var submission = Model ?? new TimelineSubmission();
    var versions = (submission.Versions ?? new List<TimelineSubmissionVersion>())
        .OrderByDescending(v => v.VersionNumber)
        .ThenByDescending(v => v.UploadedAt)
        .ToList();

    string studentName = string.IsNullOrWhiteSpace(submission.Student?.FullName)
        ? "Chưa có tên"
        : submission.Student.FullName.Trim();
    string studentCode = string.IsNullOrWhiteSpace(submission.Student?.UserCode)
        ? "Chưa có mã SV"
        : submission.Student.UserCode.Trim();
    string studentEmail = string.IsNullOrWhiteSpace(submission.Student?.Email)
        ? "Chưa có"
        : submission.Student.Email.Trim();
    string timelineTitle = string.IsNullOrWhiteSpace(submission.Timeline?.Title)
        ? "Chưa có timeline"
        : submission.Timeline.Title.Trim();
    string selectedSemester = ViewBag.Semester as string ?? Context.Request.Query["semester"].ToString();
    string selectedYear = ViewBag.Year as string ?? Context.Request.Query["year"].ToString();
    string selectedPeriodName = ViewBag.SelectedPeriodName as string ?? "";
    string keyword = ViewBag.Keyword as string ?? Context.Request.Query["keyword"].ToString();
    string timelineId = ViewBag.TimelineId as string ?? submission.TimelineId.ToString();
    int page = ViewBag.Page is int pageValue ? pageValue : 1;
    string progressDescription = string.IsNullOrWhiteSpace(submission.ProgressDescription)
        ? "Không có"
        : submission.ProgressDescription;
    string reviewerName = submission.ReviewedBy?.FullName ?? submission.ReviewedBy?.Email ?? "Chưa ghi nhận";
    string reviewComment = string.IsNullOrWhiteSpace(submission.Comment) ? "Không có" : submission.Comment;
}

@section Styles {
<style>
    body {
        background: #f6f8fb;
        color: #0f172a;
        font-family: 'Inter', sans-serif;
    }

    .page-wrapper {
        max-width: 1180px;
        margin: auto;
        padding: 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 22px;
    }

    .page-title {
        margin: 0 0 8px;
        font-size: 26px;
        font-weight: 800;
    }

    .page-desc {
        margin: 0;
        color: #64748b;
        font-size: 14px;
    }

    .btn-soft {
        min-height: 40px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        padding: 9px 14px;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        color: #475569;
        background: #fff;
        font-size: 13.5px;
        font-weight: 700;
        text-decoration: none;
    }

    .btn-soft:hover {
        background: #f8fafc;
        color: #0f172a;
    }

    .grid {
        display: grid;
        grid-template-columns: 1.1fr .9fr;
        gap: 18px;
    }

    .panel {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, .04);
        overflow: hidden;
    }

    .panel-title {
        padding: 16px 18px;
        border-bottom: 1px solid #e2e8f0;
        font-weight: 800;
        background: #fbfdff;
    }

    .info-list {
        padding: 4px 18px 18px;
    }

    .info-row {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 14px;
        padding: 13px 0;
        border-bottom: 1px solid #f1f5f9;
        font-size: 14px;
    }

    .info-row:last-child {
        border-bottom: 0;
    }

    .label {
        color: #64748b;
        font-weight: 700;
    }

    .value {
        color: #0f172a;
        font-weight: 600;
        word-break: break-word;
    }

    .badge-approved {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #15803d;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 800;
    }

    .version-list {
        padding: 10px 18px 18px;
    }

    .version-item {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 13px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .version-item:last-child {
        border-bottom: 0;
    }

    .version-name {
        font-weight: 800;
        color: #0f172a;
    }

    .version-meta {
        margin-top: 4px;
        color: #64748b;
        font-size: 12.5px;
    }

    @@media(max-width: 900px) {
        .grid {
            grid-template-columns: 1fr;
        }

        .page-header {
            flex-direction: column;
        }

        .info-row {
            grid-template-columns: 1fr;
            gap: 5px;
        }
    }
</style>
}

<div class="page-wrapper">
    <div class="page-header">
        <div>
            <h1 class="page-title">Chi tiết bài nộp</h1>
        <p class="page-desc">Thông tin bài timeline đã được giảng viên duyệt trong đợt @selectedPeriodName.</p>
        </div>

        <a href="@Url.Action("ApprovedSubmissions", "Timeline", new { keyword, timelineId, semester = selectedSemester, year = selectedYear, page })" class="btn-soft">
            <span class="material-symbols-outlined text-[17px]">arrow_back</span>
            Quay lại danh sách
        </a>
    </div>

    <div class="grid">
        <section class="panel">
            <div class="panel-title">Thông tin bài nộp</div>
            <div class="info-list">
                <div class="info-row">
                    <div class="label">Sinh viên</div>
                    <div class="value">@studentName - @studentCode</div>
                </div>
                <div class="info-row">
                    <div class="label">Email</div>
                    <div class="value">@studentEmail</div>
                </div>
                <div class="info-row">
                    <div class="label">Timeline</div>
                    <div class="value">@timelineTitle</div>
                </div>
                <div class="info-row">
                    <div class="label">Ngày mở mốc</div>
                    <div class="value">@(submission.Timeline?.Date.ToString("dd/MM/yyyy HH:mm") ?? "Chưa có")</div>
                </div>
                <div class="info-row">
                    <div class="label">Hạn sinh viên nộp</div>
                    <div class="value">@(submission.Timeline?.SubmissionDeadline?.ToString("dd/MM/yyyy HH:mm") ?? "Không cấu hình")</div>
                </div>
                <div class="info-row">
                    <div class="label">Hạn giảng viên duyệt</div>
                    <div class="value">@(submission.Timeline?.ReviewDeadline?.ToString("dd/MM/yyyy HH:mm") ?? "Không cấu hình")</div>
                </div>
                <div class="info-row">
                    <div class="label">Ngày nộp</div>
                    <div class="value">@submission.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div class="info-row">
                    <div class="label">Trạng thái</div>
                    <div class="value">
                        <span class="badge-approved">
                            <span class="material-symbols-outlined text-[15px]">task_alt</span>
                            Đã duyệt
                        </span>
                    </div>
                </div>
                <div class="info-row">
                    <div class="label">File hiện tại</div>
                    <div class="value">
                        @if (!string.IsNullOrWhiteSpace(submission.FilePath))
                        {
                            <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = submission.Id })" target="_blank" rel="noopener" class="btn-soft">
                                <span class="material-symbols-outlined text-[17px]">visibility</span>
                                @(string.IsNullOrWhiteSpace(submission.FileName) ? "Xem file" : submission.FileName)
                            </a>
                        }
                        else
                        {
                            <span>Không có file</span>
                        }
                    </div>
                </div>
                <div class="info-row">
                    <div class="label">Mô tả tiến độ</div>
                    <div class="value">@progressDescription</div>
                </div>
            </div>
        </section>

        <section class="panel">
            <div class="panel-title">Kết quả duyệt</div>
            <div class="info-list">
                <div class="info-row">
                    <div class="label">Giảng viên duyệt</div>
                    <div class="value">@reviewerName</div>
                </div>
                <div class="info-row">
                    <div class="label">Ngày duyệt</div>
                    <div class="value">@(submission.ReviewedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa có")</div>
                </div>
                <div class="info-row">
                    <div class="label">Điểm</div>
                    <div class="value">@(submission.Score?.ToString("0.##") ?? "Chưa chấm")</div>
                </div>
                <div class="info-row">
                    <div class="label">Nhận xét</div>
                    <div class="value">@reviewComment</div>
                </div>
            </div>
        </section>
    </div>

    <section class="panel" style="margin-top:18px;">
        <div class="panel-title">Lịch sử phiên bản</div>
        <div class="version-list">
            @if (!versions.Any())
            {
                <div class="version-meta">Chưa có phiên bản được lưu.</div>
            }
            else
            {
                foreach (var version in versions)
                {
                    <div class="version-item">
                        <div>
                            <div class="version-name">Phiên bản @version.VersionNumber</div>
                            <div class="version-meta">
                                @version.UploadedAt.ToString("dd/MM/yyyy HH:mm")
                                @if (!string.IsNullOrWhiteSpace(version.Note))
                                {
                                    <span> - @version.Note</span>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(version.FilePath))
                        {
                            <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = version.TimelineSubmissionId, versionId = version.Id })" target="_blank" rel="noopener" class="btn-soft">
                                <span class="material-symbols-outlined text-[17px]">download</span>
                                @(string.IsNullOrWhiteSpace(version.FileName) ? "File" : version.FileName)
                            </a>
                        }
                        else
                        {
                            <span class="version-meta">Không có file</span>
                        }
                    </div>
                }
            }
        </div>
    </section>
</div>
