@model IEnumerable<KLTN_Registration_System.Controllers.TimelineController.DefenseEligibilityVM>

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Kết quả báo cáo";

    var rows = Model?.ToList() ?? new List<KLTN_Registration_System.Controllers.TimelineController.DefenseEligibilityVM>();
    string status             = ViewBag.SelectedStatus as string ?? "waiting";
    string keyword            = ViewBag.Keyword as string ?? "";
    string selectedPeriodName = ViewBag.SelectedPeriodName as string ?? "";
    int totalReportable       = ViewBag.TotalReportable ?? rows.Count;
    int totalWaiting          = ViewBag.TotalWaiting    ?? rows.Count(x => x.IsEligible && !x.HasCompletedThesis);
    int totalCompleted        = ViewBag.TotalCompleted  ?? rows.Count(x => x.HasCompletedThesis);

    double completedRate = totalReportable > 0
        ? Math.Round((double)totalCompleted / totalReportable * 100, 1) : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/timeline/defense-results.css" asp-append-version="true" />
}

@if (TempData["Success"] != null)
{
    <div class="alert-bar success">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["Success"]</span>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-bar error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="d-flex justify-content-between align-items-start mb-4 gap-3 page-header-row">
    <div>
        <h2 class="page-title">Kết quả báo cáo khóa luận</h2>
        <p class="page-sub">
            Quản lý sinh viên đủ điều kiện, chờ và đã hoàn thành báo cáo
            @if (!string.IsNullOrEmpty(selectedPeriodName))
            {
                <span>— đợt <strong class="period-name">@selectedPeriodName</strong></span>
            }
        </p>
    </div>

    <div class="export-actions">
        <a asp-controller="Timeline" asp-action="ExportDefenseResults"
           asp-route-status="all" asp-route-keyword="@keyword"
           asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
           class="btn-export all">
            <i class="fa-solid fa-file-excel"></i> Xuất tất cả
        </a>
        <a asp-controller="Timeline" asp-action="ExportDefenseResults"
           asp-route-status="waiting" asp-route-keyword="@keyword"
           asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
           class="btn-export waiting">
            <i class="fa-solid fa-clock"></i> Xuất chờ kết quả
        </a>
        <a asp-controller="Timeline" asp-action="ExportDefenseResults"
           asp-route-status="completed" asp-route-keyword="@keyword"
           asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
           class="btn-export done">
            <i class="fa-solid fa-circle-check"></i> Xuất hoàn thành
        </a>
    </div>
</div>

<div class="stats-row">
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon blue"><i class="fa-solid fa-users"></i></div>
            <span class="stat-badge blue">Tổng</span>
        </div>
        <div class="stat-label">Được phép báo cáo</div>
        <div class="stat-number">@totalReportable</div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon amber"><i class="fa-solid fa-hourglass-half"></i></div>
            <span class="stat-badge amber">Chờ</span>
        </div>
        <div class="stat-label">Đang chờ kết quả</div>
        <div class="stat-number">@totalWaiting</div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon green"><i class="fa-solid fa-circle-check"></i></div>
            <span class="stat-badge green">@completedRate%</span>
        </div>
        <div class="stat-label">Đã hoàn thành</div>
        <div class="stat-number">@totalCompleted</div>
        <div class="stat-progress">
            <div class="stat-progress-fill" data-progress="@completedRate"></div>
        </div>
    </div>
</div>

<div class="filter-tabs">
    <a asp-controller="Timeline" asp-action="DefenseResults"
       asp-route-status="all" asp-route-keyword="@keyword"
       asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
       class="ftab @(status == "all" ? "active" : "")">
        Tất cả <span class="tab-count blue">@totalReportable</span>
    </a>
    <a asp-controller="Timeline" asp-action="DefenseResults"
       asp-route-status="waiting" asp-route-keyword="@keyword"
       asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
       class="ftab amber-tab @(status == "waiting" ? "active" : "")">
        Chờ kết quả <span class="tab-count amber">@totalWaiting</span>
    </a>
    <a asp-controller="Timeline" asp-action="DefenseResults"
       asp-route-status="completed" asp-route-keyword="@keyword"
       asp-route-semester="@ViewBag.Semester" asp-route-year="@ViewBag.Year"
       class="ftab green-tab @(status == "completed" ? "active" : "")">
        Hoàn thành <span class="tab-count green">@totalCompleted</span>
    </a>
</div>

<form method="get" class="filter-card">
    <input type="hidden" name="semester" value="@ViewBag.Semester" />
    <input type="hidden" name="year"     value="@ViewBag.Year" />

    <div class="search-wrap">
        <i class="fa-solid fa-magnifying-glass search-ico"></i>
        <input type="text" name="keyword" value="@keyword" class="search-input"
               placeholder="Tìm sinh viên, MSSV, đề tài, giảng viên..." />
    </div>

    <select name="status" class="f-select">
        @if (status == "all")
        {
            <option value="all" selected>Tất cả</option>
        }
        else
        {
            <option value="all">Tất cả</option>
        }

        @if (status == "waiting")
        {
            <option value="waiting" selected>Chờ kết quả</option>
        }
        else
        {
            <option value="waiting">Chờ kết quả</option>
        }

        @if (status == "completed")
        {
            <option value="completed" selected>Hoàn thành</option>
        }
        else
        {
            <option value="completed">Hoàn thành</option>
        }
    </select>

    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-magnifying-glass"></i> Lọc
    </button>
</form>

<div class="main-card">
    <div class="card-head">
        <div class="card-head-title">
            <i class="fa-solid fa-table-list card-head-icon"></i>
            Danh sách kết quả báo cáo
        </div>
        <span class="row-count">Hiển thị <b>@rows.Count</b> sinh viên</span>
    </div>

    @if (!rows.Any())
    {
        <div class="empty-state">
            <i class="fa-regular fa-folder-open"></i>
            <p>Không có sinh viên phù hợp với bộ lọc hiện tại.</p>
        </div>
    }
    else
    {
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="col-index">#</th>
                        <th>Sinh viên</th>
                        <th>Đề tài</th>
                        <th>Giảng viên HD</th>
                        <th>Tiến độ</th>
                        <th class="col-status">Trạng thái</th>
                        <th class="col-actions">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int idx = 1;
                        @foreach (var item in rows)
                        {
                            int prog = item.RequiredCount > 0
                                ? Math.Min(100, item.ApprovedCount * 100 / item.RequiredCount) : 0;

                            <tr>
                                <!-- STT -->
                                <td class="index-cell">
                                    @(idx.ToString("D2"))
                                </td>

                                <!-- Sinh viên -->
                                <td>
                                    <div class="stu-name">@item.StudentName</div>
                                    <span class="stu-code">@item.StudentCode</span>
                                </td>

                                <!-- Đề tài -->
                                <td>
                                    <div class="topic-title" title="@item.TopicTitle">@item.TopicTitle</div>
                                </td>

                                <!-- GV -->
                                <td>
                                    <div class="lec-name">@item.LecturerName</div>
                                </td>

                                <!-- Tiến độ -->
                                <td class="progress-cell">
                                    <div class="prog-text">@item.ApprovedCount / @item.RequiredCount mốc đã duyệt</div>
                                    <div class="progress-bar">
                                        <div class="progress-fill" data-progress="@prog"></div>
                                    </div>
                                </td>

                                <!-- Trạng thái -->
                                <td class="status-cell">
                                    @if (item.HasCompletedThesis)
                                    {
                                        <div>
                                            <span class="s-badge completed">
                                                <i class="fa-solid fa-check status-icon"></i>
                                                Hoàn thành
                                            </span>
                                            @if (item.ThesisCompletedAt.HasValue)
                                            {
                                                <div class="completed-date">
                                                    @item.ThesisCompletedAt.Value.ToString("dd/MM/yyyy")
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="s-badge waiting">
                                            <i class="fa-solid fa-hourglass-half status-icon"></i>
                                            Chờ kết quả
                                        </span>
                                    }
                                </td>

                                <!-- Thao tác -->
                                <td class="actions-cell">
                                    @if (item.HasCompletedThesis)
                                    {
                                        <form method="post" asp-controller="Timeline" asp-action="UpdateDefenseResult"
                                              class="inline-form js-confirm-form"
                                              data-confirm="Hủy trạng thái hoàn thành của sinh viên này?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="studentId" value="@item.StudentId" />
                                            <input type="hidden" name="completed"  value="false" />
                                            <input type="hidden" name="status"     value="@status" />
                                            <input type="hidden" name="keyword"    value="@keyword" />
                                            <input type="hidden" name="semester"   value="@ViewBag.Semester" />
                                            <input type="hidden" name="year"       value="@ViewBag.Year" />
                                            <button type="submit" class="act-btn reopen">
                                                <i class="fa-solid fa-rotate-left act-btn-icon"></i>
                                                Mở lại
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-controller="Timeline" asp-action="UpdateDefenseResult"
                                              class="inline-form js-confirm-form"
                                              data-confirm="Đánh dấu sinh viên này đã hoàn thành khóa luận?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="studentId" value="@item.StudentId" />
                                            <input type="hidden" name="completed"  value="true" />
                                            <input type="hidden" name="status"     value="@status" />
                                            <input type="hidden" name="keyword"    value="@keyword" />
                                            <input type="hidden" name="semester"   value="@ViewBag.Semester" />
                                            <input type="hidden" name="year"       value="@ViewBag.Year" />
                                            <button type="submit" class="act-btn complete">
                                                <i class="fa-solid fa-circle-check act-btn-icon"></i>
                                                Đánh dấu hoàn thành
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                            idx++;
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/timeline/defense-results.js" asp-append-version="true"></script>
}
