@* ============================================================
   FILE: Views/Student/Profile.cshtml
   UI VERSION: MODERN ACADEMIC DASHBOARD
   ============================================================ *@

@model KLTN_Registration_System.Models.Entities.ApplicationUser

@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Hồ sơ của tôi";

    var reg = ViewBag.CurrentRegistration as KLTN_Registration_System.Models.Entities.Registration;

    var majors = ViewBag.Majors as List<KLTN_Registration_System.Models.Entities.Major>
                 ?? new List<KLTN_Registration_System.Models.Entities.Major>();
    var selectedMajor = Model.Major
        ?? majors.FirstOrDefault(m => Model.MajorId == m.Id)
        ?? majors.FirstOrDefault();

    string initials = string.IsNullOrEmpty(Model.FullName)
        ? (Model.Email?.Substring(0, 1).ToUpper() ?? "?")
        : string.Concat(Model.FullName.Split(' ')
            .TakeLast(2)
            .Select(w => w.Substring(0, 1).ToUpper()));

    string statusLabel = reg?.Status switch
    {
        "Approved" => "Đã được duyệt",
        "Pending" => "Chờ phê duyệt",
        "Rejected" => "Bị từ chối",
        _ => "Chưa đăng ký"
    };

    string statusClass = reg?.Status switch
    {
        "Approved" => "status-success",
        "Pending" => "status-warning",
        "Rejected" => "status-danger",
        _ => "status-gray"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/student/profile.css" asp-append-version="true" />
}

<div class="profile-page">

    <!-- HEADER -->
    <div class="profile-header">
        <h2>Hồ sơ cá nhân</h2>

        <p>
            Quản lý thông tin sinh viên và bảo mật tài khoản hệ thống khóa luận tốt nghiệp.
        </p>
    </div>

    <div class="row g-4">

        <!-- LEFT -->
        <div class="col-lg-4">

            <!-- PROFILE -->
            <div class="profile-card mb-4">

                <div class="user-summary">

                    <div class="avatar-box">
                        @initials
                    </div>

                    <div class="student-name">
                        @(Model.FullName ?? "Chưa cập nhật")
                    </div>

                    <div class="student-email">
                        @Model.Email
                    </div>

                    <div class="student-code">
                        <i class="fa-regular fa-id-card"></i>
                        MSSV: @(Model.UserCode ?? "SV000")
                    </div>

                </div>

            </div>

            <!-- STATS -->
            <div class="profile-card mb-4">

                <div class="card-header">

                    <div class="card-title">
                        Hoạt động hệ thống
                    </div>

                    <div class="card-subtitle">
                        Tổng quan tài khoản sinh viên
                    </div>

                </div>

                <div class="card-body">

                    <div class="stats-list">

                        <div class="stat-item">
                            <span>Thông báo</span>
                            <strong>@(ViewBag.TotalNotifications ?? 0)</strong>
                        </div>

                        <div class="stat-item">
                            <span>Chưa đọc</span>
                            <strong class="stat-danger">
                                @(ViewBag.UnreadNotifications ?? 0)
                            </strong>
                        </div>

                        <div class="stat-item">
                            <span>Lịch sử đăng ký</span>
                            <strong>@(ViewBag.TotalRegistrations ?? 0)</strong>
                        </div>

                    </div>

                </div>

            </div>

            <!-- TOPIC -->
            <div class="profile-card">

                <div class="card-header">

                    <div class="card-title">
                        Đề tài hiện tại
                    </div>

                    <div class="card-subtitle">
                        Thông tin khóa luận đang đăng ký
                    </div>

                </div>

                <div class="card-body">

                    @if (reg != null)
                    {
                        <div class="topic-title">
                            @reg.Topic?.Title
                        </div>

                        <div class="topic-meta">
                            GVHD:
                            @(reg.Topic?.Lecturer?.FullName ?? "Chưa cập nhật")
                        </div>

                        <div class="status-badge @statusClass">
                            @statusLabel
                        </div>

                        @if (reg.Status == "Rejected" &&
                                            !string.IsNullOrEmpty(reg.Feedback))
                        {
                            <div class="custom-alert">
                                @reg.Feedback
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-topic">

                            <i class="fa-regular fa-folder-open"></i>

                            <p>
                                Bạn chưa đăng ký đề tài nào
                            </p>

                            <a href="/Topic/Index"
                               class="btn-topic">

                                <i class="fa-solid fa-book-open"></i>

                                Xem danh sách đề tài

                            </a>

                        </div>
                    }

                </div>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-8">

            <!-- PROFILE INFO -->
            <div class="profile-card mb-4">

                <div class="card-header">

                    <div class="card-title">
                        Thông tin cá nhân
                    </div>

                    <div class="card-subtitle">
                        Cập nhật dữ liệu hiển thị trên hệ thống khóa luận.
                    </div>

                </div>

                <div class="card-body">

                    <form method="post"
                          asp-action="UpdateProfile"
                          asp-controller="Student">

                        @Html.AntiForgeryToken()

                        <div class="form-grid">

                            <div class="form-group">

                                <label class="form-label">
                                    Họ và tên *
                                </label>

                                <input type="text"
                                       value="@Model.FullName"
                                       readonly
                                       class="form-control form-disabled" />

                            </div>

                            <div class="form-group">

                                <label class="form-label">
                                    Mã số sinh viên
                                </label>

                                <input type="text"
                                       value="@Model.UserCode"
                                       readonly
                                       class="form-control form-disabled" />

                            </div>

                            <div class="form-group">

                                <label class="form-label">
                                    Email
                                </label>

                                <input type="email"
                                       value="@Model.Email"
                                       disabled
                                       class="form-control form-disabled" />

                            </div>

                            <div class="form-group">

                                <label class="form-label">
                                    Số điện thoại
                                </label>

                                <input type="tel"
                                       name="phoneNumber"
                                       value="@Model.PhoneNumber"
                                       placeholder="Nhập số điện thoại"
                                       class="form-control" />

                            </div>

                            <div class="form-group full">

                                <label class="form-label">
                                    Chuyên ngành
                                </label>

                                <input type="text"
                                       value="@(selectedMajor?.Name ?? Model.Faculty ?? "Chưa được gán chuyên ngành")"
                                       readonly
                                       class="form-control form-disabled" />

                            </div>

                        </div>

                        <div class="d-flex justify-content-end mt-4">

                            <button type="submit"
                                    class="btn-primary-custom">

                                <i class="fa-regular fa-floppy-disk"></i>

                                Lưu thay đổi

                            </button>

                        </div>

                    </form>

                </div>

            </div>

            <!-- PASSWORD -->
            <!-- PASSWORD -->
            <div class="profile-card">

                <div class="card-header">

                    <div class="card-title">
                        Bảo mật tài khoản
                    </div>

                    <div class="card-subtitle">
                        Thay đổi mật khẩu đăng nhập hệ thống.
                    </div>

                </div>

                <div class="card-body">

                    <form method="post"
                          asp-action="ChangePassword"
                          asp-controller="Account">

                        @Html.AntiForgeryToken()

                        <div class="form-group mb-4">

                            <label class="form-label">
                                Mật khẩu hiện tại *
                            </label>

                            <div class="password-wrapper">

                                <input type="password"
                                       name="currentPassword"
                                       id="currentPwd"
                                       required
                                       class="form-control" />

                                <button type="button"
                                        class="toggle-password"
                                        data-toggle-password data-target="currentPwd">

                                    <i class="fa-regular fa-eye"></i>

                                </button>

                            </div>

                        </div>

                        <div class="form-grid">

                            <div class="form-group">

                                <label class="form-label">
                                    Mật khẩu mới *
                                </label>

                                <div class="password-wrapper">

                                    <input type="password"
                                           name="newPassword"
                                           id="newPwd"
                                           minlength="6"
                                           required
                                           class="form-control" />

                                    <button type="button"
                                            class="toggle-password"
                                            data-toggle-password data-target="newPwd">

                                        <i class="fa-regular fa-eye"></i>

                                    </button>

                                </div>

                            </div>

                            <div class="form-group">

                                <label class="form-label">
                                    Xác nhận mật khẩu *
                                </label>

                                <div class="password-wrapper">

                                    <input type="password"
                                           id="confirmPwd"
                                           minlength="6"
                                           required
                                           class="form-control" />

                                    <button type="button"
                                            class="toggle-password"
                                            data-toggle-password data-target="confirmPwd">

                                        <i class="fa-regular fa-eye"></i>

                                    </button>

                                </div>

                            </div>

                        </div>

                        <p id="matchMsg"
                           class="small mt-3 fw-semibold"></p>

                        <div class="d-flex justify-content-end mt-4">

                            <button type="submit"
                                    id="changePwdBtn"
                                    class="btn-primary-custom btn-dark">

                                <i class="fa-solid fa-lock"></i>

                                Đổi mật khẩu

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/student/profile.js" asp-append-version="true"></script>
}

