@using KLTN_Registration_System.Models.ViewModels.Student
@model HomeStudent
@{
    Layout = "~/Views/Shared/_LayoutStudent.cshtml";
}

<style>
    :root {
        --primary-blue: #2b4eff;
        --gradient-welcome: linear-gradient(135deg, #2b4eff 0%, #5a7bff 100%);
        --shadow-card: 0 10px 30px rgba(0, 0, 0, 0.04);
        --bg-active: #e9efff;
        --text-sub: #64748b;
    }

    body {
        background: #f6f8fc;
    }

    /* Titles */
    .section-title {
        font-size: 18px;
        font-weight: 800;
        color: #1e293b;
        letter-spacing: -0.3px;
        margin-bottom: 0;
    }

    /* Banners & Cards */
    .welcome-banner {
        background: var(--gradient-welcome);
        border-radius: 20px;
        padding: 40px;
        color: white;
        box-shadow: 0 10px 25px rgba(43, 78, 255, 0.2);
    }

    .card-custom {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: var(--shadow-card);
        height: 100%;
    }

    .status-card {
        background: white;
        border-radius: 18px;
        padding: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: var(--shadow-card);
    }

    /* Topic Cards */
    .topic-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #f1f5f9;
        transition: all 0.3s ease;
        height: 100%;
    }

        .topic-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        }

        .topic-card h6 {
            font-size: 15px;
            font-weight: 800;
            color: #2d3748;
            line-height: 1.4;
            margin-bottom: 15px;
        }

    /* Badges & Status - Gộp các class tương đồng */
    /* ===== LEVEL BADGES ===== */
    .badge-level {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 6px;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.3px;
        text-transform: uppercase;
        line-height: 1.2;
        margin-bottom: 6px;
        position: relative;
        top: -4px;
    }

    /* Nâng cao */
    .bg-level-hard {
        background: #fff5f5;
        color: #e53e3e;
    }

    /* Trung bình */
    .bg-level-medium {
        background: #fffaf0;
        color: #dd6b20;
    }

    /* Cơ bản */
    .bg-level-easy {
        background: #f0fff4;
        color: #38a169;
    }

    .badge-level {
        border: none !important;
    }

    .status-pending {
        background: #fef3c7 !important;
        color: #d97706 !important;
        border: 1px solid #fde68a;
    }

    .status-approved {
        background: #d1fae5 !important;
        color: #059669 !important;
        border: 1px solid #6ee7b7;
    }

    .status-rejected {
        background: #fee2e2 !important;
        color: #dc2626 !important;
        border: 1px solid #fca5a5;
    }

    /* Deadlines */
    .deadline-item {
        display: flex;
        gap: 18px;
        margin-bottom: 25px;
    }

    .date-box {
        background: #f4f7fe;
        border-radius: 14px;
        padding: 10px;
        text-align: center;
        min-width: 70px;
        color: var(--primary-blue);
        border: 1px solid #e0e9ff;
    }

    /* Notifications - ĐÃ FIX LỖI LỒNG NHAU */
    .notification-container {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .notification-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 8px;
        border-bottom: 1px solid #f1f5f9;
        transition: all 0.2s ease;
    }

        .notification-item:hover {
            background-color: #f8fafc;
            border-radius: 8px;
            transform: translateX(5px);
        }

        .notification-item:last-child {
            border-bottom: none;
        }

    .notif-icon {
        width: 34px;
        height: 34px;
        background: #eff6ff;
        color: var(--primary-blue);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .notif-title {
        font-size: 14px;
        font-weight: 700;
        color: #334155;
        margin-bottom: 2px;
    }

    .notif-time {
        font-size: 11px;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    /* Utilities */
    .btn-detail-outline {
        background: #f1f5ff;
        color: var(--primary-blue);
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        font-weight: 700;
        margin-top: 15px;
        transition: 0.3s;
        display: block;
        text-align: center;
        text-decoration: none;
    }

        .btn-detail-outline:hover {
            background: var(--primary-blue);
            color: white;
        }

    .library-box {
        background: linear-gradient(to right, #f0f7ff, #e0efff);
        color: #1e40af;
        border-radius: 20px;
        padding: 24px;
    }
</style>
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm mb-4">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Error"]
    </div>
}


<div class="row g-4">
    <div class="col-lg-8 d-flex flex-column gap-4">

        <div class="welcome-banner">
            <h1 class="fw-bold mb-2" style="font-size: 2rem; letter-spacing: -0.5px;">
                Chào mừng bạn, <span style="font-weight: 800;">@Model.StudentName</span>.
            </h1>

            @* --- LOGIC KIỂM TRA THỜI GIAN ĐĂNG KÝ --- *@
            @if (ViewBag.IsOpening == true)
            {
                @* TRƯỜNG HỢP 1: ĐANG MỞ *@
                <p class="mb-0 opacity-75">
                    Hệ thống đang mở cổng đăng ký! Hạn đăng ký còn
                    <span class="fw-bold text-decoration-underline @(Model.DaysLeft <= 3 ? "text-warning" : "")">
                        @Model.DaysLeft ngày
                    </span>
                    <small class="ms-1">(Kết thúc: @ViewBag.RegistrationEndDate)</small>
                </p>
            }
            else
            {
                @* TRƯỜNG HỢP 2 & 3: CHƯA MỞ HOẶC ĐÃ ĐÓNG *@
                @if (Model.DaysLeft > 0)
                {
                    @* Nếu DaysLeft dương nhưng IsOpening sai => Chưa tới ngày mở *@
                    <p class="mb-0 opacity-90">
                        <i class="fa-solid fa-calendar-clock me-1"></i>
                        Cổng đăng ký chưa mở. Vui lòng quay lại sau.
                    </p>
                }
                else
                {
                    @* Nếu DaysLeft <= 0 => Đã quá hạn *@
                    <p class="mb-0 fw-bold">
                        <i class="fa-solid fa-circle-xmark me-1"></i>
                        Đã kết thúc thời gian đăng ký đề tài trực tuyến.
                    </p>
                }
            }
        </div>

        <div>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="section-title">Trạng thái Đăng ký</h5>
                @if (Model.Status == "Pending")
                {
                    <small class="text-muted italic"><i class="fa-solid fa-clock-rotate-left me-1"></i> Đang chờ giảng viên duyệt</small>
                }
            </div>

            <div class="status-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="p-3 rounded-4" style="background: #f0f4ff;">
                        <i class="fa-solid fa-file-signature text-primary fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted fw-bold">ĐỀ TÀI HIỆN TẠI</small>
                        <div class="fw-bold">@Model.CurrentTopic</div>
                    </div>
                </div>

                @{
                    // 1. Định nghĩa tên tiếng Việt
                    string statusVietnamese = Model.Status switch
                    {
                        "Approved" => "ĐÃ DUYỆT",
                        "Pending" => "CHỜ DUYỆT",
                        "Rejected" => "TỪ CHỐI",
                        _ => Model.Status.ToUpper()
                    };

                    // 2. Định nghĩa class CSS (Đây là phần bạn đang thiếu)
                    string statusClass = Model.Status switch
                    {
                        "Approved" => "status-approved",
                        "Pending" => "status-pending",
                        "Rejected" => "status-rejected",
                        _ => ""
                    };
                }

                <span class="badge px-4 py-2 @statusClass">
                    @statusVietnamese
                </span>
            </div>
        </div>

        <div>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="col">
                    <h5 class="section-title">Đề tài đề xuất</h5>
                    <p class="text-muted small mb-0" style="font-size: 13px; color: #718096; line-height: 1.4;">
                        Dựa trên kết quả học tập và định hướng của bạn
                    </p>
                </div>
                <a asp-controller="Topic" asp-action="Index" class="text-primary text-decoration-none small fw-bold">
                    Xem tất cả <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>

            <div class="row g-4">
                @foreach (var item in Model.SuggestedTopics)
                {
                    <div class="col-md-6">
                        <div class="topic-card d-flex flex-column h-100">
                            <div>
                                @{
                                    string levelClass = item.Level.ToString() switch
                                    {
                                        "Hard" => "bg-level-hard",
                                        "Medium" => "bg-level-medium",
                                        _ => "bg-level-easy"
                                    };
                                }

                                <span class="badge-level @levelClass">
                                    @if (item.Level.ToString() == "Hard")
                                    {
                                        <span>NÂNG CAO</span>
                                    }
                                    else if (item.Level.ToString() == "Medium")
                                    {

                                        <span>TRUNG BÌNH</span>
                                    }
                                    else
                                    {

                                        <span>CƠ BẢN</span>
                                    }
                                </span>
                            </div>

                            <h6 class="fw-bold mt-2" title="@item.Title" style="flex-grow: 1;">
                                @item.Title
                            </h6>

                            <div class="d-flex align-items-center mb-3 mt-2">
                                <div class="rounded-circle bg-dark d-flex align-items-center justify-content-center text-white me-2"
                                     style="width: 35px; height: 35px; min-width: 35px;">
                                    <i class="fa-solid fa-user-tie" style="font-size: 16px;"></i>
                                </div>

                                <div class="d-flex flex-column">
                                    <div class="small mb-0" style="line-height: 1.2;">
                                        <span class="text-muted" style="font-size: 12px;"></span>
                                        <strong class="text-dark" style="font-size: 14px;">@item.Lecturer</strong>
                                    </div>
                                    <div class="text-muted" style="font-size: 11px; margin-top: 2px; opacity: 0.8;">
                                        @item.Department
                                    </div>
                                </div>
                            </div>

                            <a asp-controller="Topic" asp-action="Details" asp-route-id="@item.Id" class="btn-detail-outline">
                                XEM CHI TIẾT
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4 d-flex flex-column gap-4">

        <div class="card-custom shadow-sm p-4" style="border-radius: 16px; background: #fff;">
            <h5 class="section-title mb-4">Thời hạn quan trọng</h5>

            @foreach (var d in Model.Deadlines)
            {
                <div class="deadline-item d-flex align-items-center mb-4">
                    <div class="date-box d-flex flex-column justify-content-center align-items-center"
                         style="background: #f0f4ff; min-width: 70px; height: 75px; border-radius: 12px; border: 1px solid #e0e9ff;">

                        <span style="color: #2b4eff; font-size: 10px; font-weight: 800; text-transform: uppercase; margin-bottom: -2px;">
                            Tháng @d.Month
                        </span>

                        <span style="color: #2b4eff; font-size: 26px; font-weight: 800; line-height: 1;">
                            @d.Date
                        </span>
                    </div>

                    <div class="ms-3">
                        <div class="fw-bold" style="font-size: 15px; color: #2d3748; line-height: 1.2;">@d.Content</div>
                        <div class="text-muted" style="font-size: 12px; margin-top: 4px;">@d.SubContent</div>
                    </div>
                </div>
            }

            @if (!Model.Deadlines.Any())
            {
                <div class="text-center py-4">
                    <i class="fa-regular fa-calendar-check mb-2" style="font-size: 30px; opacity: 0.2;"></i>
                    <p class="text-muted small mb-0">Hiện tại không có thời hạn mới</p>
                </div>
            }
        </div>

        <div class="card-custom shadow-sm p-4" style="border-radius: 20px;">
            <h5 class="section-title mb-4">Tin tức & thông báo</h5>

            <div class="notification-container">
                @foreach (var n in Model.Notifications)
                {
                    <div class="notification-item">
                        <div class="notif-icon">
                            <i class="fa-solid fa-bell"></i>
                        </div>
                        <div class="notif-content">
                            <div class="notif-title">@n.Title</div>
                            <div class="notif-time">
                                <i class="fa-regular fa-clock"></i> @n.Time
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Notifications.Any())
            {
                <div class="text-center py-3 text-muted small">Không có thông báo mới</div>
            }

            <a asp-action="Notifications" class="btn btn-link btn-sm w-100 text-decoration-none mt-3 fw-bold" style="color: #2b4eff; font-size: 13px;">
                XEM TẤT CẢ
            </a>
        </div>

        <div class="library-box">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="fa-solid fa-book-bookmark fs-4"></i>
                <h6 class="fw-bold mb-0">Thư viện tài liệu</h6>
            </div>
            <p class="small mb-3">Tham khảo đề tài các khóa trước để có thêm ý tưởng và kinh nghiệm thực hiện.</p>
            <a href="#" class="btn btn-sm btn-light text-primary fw-bold px-3 rounded-3">Khám phá ngay</a>
        </div>
    </div>
</div>