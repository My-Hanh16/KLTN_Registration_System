@using KLTN_Registration_System.Models.ViewModels.Student
@model HomeStudent
@{
    Layout = "~/Views/Shared/_LayoutStudent.cshtml";
    ViewData["Title"] = "Tổng quan";
    var pageModel = Model ?? new HomeStudent();
    var suggestedTopics = pageModel.SuggestedTopics ?? new List<TopicVM>();
    var deadlines = pageModel.Deadlines ?? new List<DeadlineVM>();
    var notifications = pageModel.Notifications ?? new List<NotificationVM>();
    bool isOpening = ViewBag.IsOpening == true;
    bool isPortalOpen = ViewBag.TopicRegistrationPortalOpen == true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/student/home.css" asp-append-version="true" />
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm mb-4">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Error"]
    </div>
}


<div class="row g-4">
    <div class="col-lg-8 d-flex flex-column gap-4">

        <div class="welcome-banner">
            <h1 class="welcome-title">
                Chào mừng bạn, <span>@pageModel.StudentName</span>.
            </h1>

            @* --- LOGIC KIỂM TRA THỜI GIAN ĐĂNG KÝ --- *@
            @if (isOpening)
            {
                @* TRƯỜNG HỢP 1: ĐANG MỞ *@
                <p class="mb-0 opacity-75">
                    Hệ thống đang mở cổng đăng ký! Hạn đăng ký còn
                    <span class="fw-bold text-decoration-underline @(pageModel.DaysLeft <= 3 ? "text-warning" : "")">
                        @pageModel.DaysLeft ngày
                    </span>
                    <small class="ms-1">(Kết thúc: @ViewBag.RegistrationEndDate)</small>
                </p>
            }
            else
            {
                @if (!isPortalOpen)
                {
                    <p class="mb-0 opacity-90">
                        <i class="fa-solid fa-lock me-1"></i>
                        Cổng đăng ký đang đóng. Bạn vẫn có thể xem trước danh sách đề tài.
                    </p>
                }
                else if (pageModel.DaysLeft > 0)
                {
                    <p class="mb-0 opacity-90">
                        <i class="fa-solid fa-calendar-clock me-1"></i>
                        Cổng đăng ký chưa đến thời gian mở.
                        @if (!string.IsNullOrWhiteSpace(ViewBag.RegistrationStartDate as string))
                        {
                            <small class="ms-1">(Bắt đầu: @ViewBag.RegistrationStartDate)</small>
                        }
                    </p>
                }
                else
                {
                    @* Nếu DaysLeft <= 0 => Đã quá hạn *@
                    <p class="mb-0 fw-bold">
                        <i class="fa-solid fa-circle-xmark me-1"></i>
                        Đã kết thúc thời gian đăng ký đề tài trực tuyến.
                    </p>
                }
            }
        </div>

        <div>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="section-title">Trạng thái Đăng ký</h5>
                @if (pageModel.Status == "Pending")
                {
                    <small class="text-muted italic"><i class="fa-solid fa-clock-rotate-left me-1"></i> Đang chờ giảng viên duyệt</small>
                }
            </div>

            <div class="status-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="status-icon-box">
                        <i class="fa-solid fa-file-signature text-primary fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted fw-bold">ĐỀ TÀI HIỆN TẠI</small>
                        <div class="fw-bold">@pageModel.CurrentTopic</div>
                    </div>
                </div>

                @{
                    string statusValue = pageModel.Status ?? "Chưa có";
                    // 1. Định nghĩa tên tiếng Việt
                    string statusVietnamese = statusValue switch
                    {
                        "Approved" => "ĐÃ DUYỆT",
                        "Pending" => "CHỜ DUYỆT",
                        "Rejected" => "TỪ CHỐI",
                        _ => statusValue.ToUpper()
                    };

                    // 2. Định nghĩa class CSS (Đây là phần bạn đang thiếu)
                    string statusClass = statusValue switch
                    {
                        "Approved" => "status-approved",
                        "Pending" => "status-pending",
                        "Rejected" => "status-rejected",
                        _ => ""
                    };
                }

                <span class="badge px-4 py-2 @statusClass">
                    @statusVietnamese
                </span>
            </div>
        </div>

        <div>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="col">
                    <h5 class="section-title">Đề tài đề xuất</h5>
                    <p class="section-subtitle">
                        Dựa trên kết quả học tập và định hướng của bạn
                    </p>
                </div>
                <a asp-controller="Topic" asp-action="Index" class="text-primary text-decoration-none small fw-bold">
                    Xem tất cả <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>

            <div class="row g-4">
                @if (suggestedTopics.Any())
                {
                    @foreach (var item in suggestedTopics)
                    {
                        <div class="col-md-6">
                            <div class="topic-card d-flex flex-column h-100">
                                <div>
                                    @{
                                        string levelText = item.Level ?? "Cơ bản";
                                        string levelClass = !string.IsNullOrWhiteSpace(item.BadgeClass)
                                            ? item.BadgeClass
                                            : levelText switch
                                            {
                                                "Nâng cao" => "bg-level-hard",
                                                "Trung bình" => "bg-level-medium",
                                                _ => "bg-level-easy"
                                            };
                                    }

                                    <span class="badge-level @levelClass">
                                        @levelText.ToUpper()
                                    </span>
                                </div>

                                <h6 class="topic-title" title="@item.Title">
                                    @item.Title
                                </h6>

                                <div class="d-flex align-items-center mb-3 mt-2">
                                    <div class="lecturer-avatar">
                                        <i class="fa-solid fa-user-tie"></i>
                                    </div>

                                    <div class="d-flex flex-column">
                                        <div class="lecturer-name">
                                            <strong>@item.Lecturer</strong>
                                        </div>
                                        <div class="lecturer-department">
                                            @item.Department
                                        </div>
                                    </div>
                                </div>

                                <a asp-controller="Topic" asp-action="Details" asp-route-id="@item.Id" class="btn-detail-outline">
                                    XEM CHI TIẾT
                                </a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="empty-topic-suggestions">
                            <i class="fa-regular fa-folder-open"></i>
                            <div>
                                <h6>Chưa có đề tài phù hợp</h6>
                                <p>Hiện chưa có đề tài phù hợp theo khoa/chuyên ngành của bạn.</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4 d-flex flex-column gap-4">

        <div class="card-custom card-deadlines">
            <h5 class="section-title mb-4">Thời hạn quan trọng</h5>

            @foreach (var d in deadlines)
            {
                <div class="deadline-item d-flex align-items-center mb-4">
                    <div class="date-box">

                        <span class="date-month">
                            Tháng @d.Month
                        </span>

                        <span class="date-day">
                            @d.Date
                        </span>
                    </div>

                    <div class="ms-3">
                        <div class="deadline-title">@d.Content</div>
                        <div class="deadline-subtitle">@d.SubContent</div>
                    </div>
                </div>
            }

            @if (!deadlines.Any())
            {
                <div class="text-center py-4">
                    <i class="fa-regular fa-calendar-check mb-2 empty-calendar-icon"></i>
                    <p class="text-muted small mb-0">Hiện tại không có thời hạn mới</p>
                </div>
            }
        </div>

        <div class="card-custom card-notifications">
            <h5 class="section-title mb-4">Tin tức & thông báo</h5>

            <div class="notification-container">
                @foreach (var n in notifications)
                {
                    <div class="notification-item">
                        <div class="notif-icon">
                            <i class="fa-solid fa-bell"></i>
                        </div>
                        <div class="notif-content">
                            <div class="notif-title">@n.Title</div>
                            <div class="notif-time">
                                <i class="fa-regular fa-clock"></i> @n.Time
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!notifications.Any())
            {
                <div class="text-center py-3 text-muted small">Không có thông báo mới</div>
            }

            <a asp-action="Notifications" class="all-notifications-link">
                XEM TẤT CẢ
            </a>
        </div>

        <div class="library-box">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="fa-solid fa-book-bookmark fs-4"></i>
                <h6 class="fw-bold mb-0">Thư viện tài liệu</h6>
            </div>
            <p class="small mb-3">Tham khảo đề tài các khóa trước để có thêm ý tưởng và kinh nghiệm thực hiện.</p>
            <a href="#" class="btn btn-sm btn-light text-primary fw-bold px-3 rounded-3">Khám phá ngay</a>
        </div>
    </div>
</div>
