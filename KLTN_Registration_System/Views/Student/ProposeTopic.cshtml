@* ============================================================
   FILE: Views/Student/ProposeTopic.cshtml
   LAYOUT: _LayoutStudent
   ============================================================ *@
@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Đề xuất đề tài";

    var myProposals = ViewBag.MyProposals as List<KLTN_Registration_System.Models.Entities.Topic>
                    ?? new List<KLTN_Registration_System.Models.Entities.Topic>();
    var primaryMajor = ViewBag.PrimaryMajor as KLTN_Registration_System.Models.Entities.Major;
    var lecturers = ViewBag.Lecturers as List<KLTN_Registration_System.Models.Entities.ApplicationUser>
                    ?? new List<KLTN_Registration_System.Models.Entities.ApplicationUser>();

    int pendingCount = myProposals.Count(t => t.Status == KLTN_Registration_System.Models.Entities.TopicStatus.Pending);
    int approvedCount = myProposals.Count(t => t.IsApproved);
    int rejectedCount = myProposals.Count(t => t.Status == KLTN_Registration_System.Models.Entities.TopicStatus.Rejected);
    bool hasMajor = primaryMajor != null;
    bool hasPendingSlot = pendingCount < 3;
    bool canPropose = hasMajor && hasPendingSlot;
    string lockTitle = !hasMajor ? "Chưa được gán chuyên ngành" : "Đã đạt giới hạn đề xuất";
    string lockMessage = !hasMajor
        ? "Liên hệ Admin để cập nhật chuyên ngành trước khi gửi đề xuất."
        : "Huỷ bớt đề xuất đang chờ hoặc chờ Admin xét duyệt để gửi thêm.";
}

@section Styles {
    <link rel="stylesheet" href="~/css/student/propose-topic.css" asp-append-version="true" />
}

<!-- ════════════════════════════════
     PAGE HEADER
════════════════════════════════ -->
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="page-title">Đề xuất đề tài</h2>
        <p class="page-sub">Không tìm thấy đề tài phù hợp? Gửi ý tưởng của bạn để Admin & Giảng viên xem xét.</p>
    </div>
</div>

<!-- ALERTS -->
@if (TempData["Error"] != null)
{
    <div class="alert-bar error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["Error"]</span>
    </div>
}

@if (!hasMajor && TempData["Success"] == null && TempData["Error"] == null)
{
    <div class="alert-bar error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>Tài khoản của bạn chưa được gán chuyên ngành nên chưa thể đề xuất đề tài.</span>
    </div>
}

@if (hasMajor && !hasPendingSlot && TempData["Success"] == null && TempData["Error"] == null)
{
    <div class="alert-bar warning">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <span>Bạn đã đạt tối đa <strong>3 đề xuất đang chờ duyệt</strong>. Hãy chờ Admin xử lý hoặc huỷ bớt đề xuất cũ.</span>
    </div>
}

<!-- STATS -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fa-solid fa-lightbulb"></i></div>
        <div>
            <div class="stat-label">Tổng đề xuất</div>
            <div class="stat-number">
                @myProposals.Count
            </div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fa-solid fa-hourglass-half"></i></div>
        <div>
            <div class="stat-label">Đang chờ duyệt</div>
            <div class="stat-number">@pendingCount</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-circle-check"></i></div>
        <div>
            <div class="stat-label">Đã duyệt / Từ chối</div>
            <div class="stat-number">@approvedCount / @rejectedCount</div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════
     MAIN GRID
════════════════════════════════ -->
<div class="pt-grid">

    <!-- ══ LEFT: FORM ══ -->
    <div class="form-locked-wrap">

                @if (!canPropose)
                {
                    <div class="locked-overlay">
                        <i class="fa-solid fa-lock"></i>
                        <p>@lockTitle</p>
                        <span>@lockMessage</span>
            </div>
        }

        <div class="pt-card pt-card--flush">
            <div class="pt-head">
                <div>
                    <div class="pt-head-title">
                        <i class="fa-regular fa-pen-to-square pt-head-title-icon"></i>
                        Ý tưởng của bạn
                    </div>
                    <div class="pt-head-sub">Điền thông tin càng chi tiết, cơ hội được duyệt càng cao.</div>
                </div>
                <span class="proposal-quota-count @(pendingCount >= 3 ? "is-full" : "")">
                    @pendingCount / 3 chờ duyệt
                </span>
            </div>

            <div class="pt-body">
                <form method="post" asp-action="ProposeTopic" asp-controller="Student"
                      id="proposeForm" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Tên đề tài -->
                    <div class="f-section">
                        <label class="f-label">Tên đề tài <span class="req">*</span></label>
                        <div class="f-wrap">
                            <i class="fa-solid fa-pen f-ico"></i>
                            <input type="text" name="title" id="titleInput"
                                   required maxlength="200"
                                   class="f-input"
                                   placeholder="VD: Ứng dụng AI hỗ trợ học tiếng Anh cho sinh viên đại học"
                                   @(!canPropose ? "disabled" : "") />
                        </div>
                        <div class="char-row">
                            <span class="char-hint">Tối đa 200 ký tự</span>
                            <span class="char-ct" id="titleCt">0 / 200</span>
                        </div>
                    </div>

                    <!-- Mô tả ý tưởng -->
                    <div class="f-section">
                        <label class="f-label">Mô tả ý tưởng <span class="req">*</span></label>
                        <div class="f-wrap f-wrap-ta">
                            <i class="fa-solid fa-align-left f-ico-top"></i>
                            <textarea name="description" id="descInput"
                                      required rows="5" maxlength="1000"
                                      class="f-textarea"
                                      placeholder="Mô tả vấn đề cần giải quyết, phương hướng thực hiện, công nghệ dự kiến sử dụng..."
                                      @(!canPropose ? "disabled" : "")></textarea>
                        </div>
                        <div class="char-row">
                            <span class="char-hint">Tối đa 1000 ký tự</span>
                            <span class="char-ct" id="descCt">0 / 1000</span>
                        </div>
                    </div>

                    <!-- Chuyên ngành (hiển thị, không chỉnh) -->
                    <div class="f-section">
                        <label class="f-label">Chuyên ngành của bạn</label>
                        @if (primaryMajor != null)
                        {
                            <div class="major-box">
                                <div class="major-box-icon">
                                    <i class="fa-solid fa-book"></i>
                                </div>
                                <div>
                                    <div class="major-name">@primaryMajor.Name</div>
                                    @if (!string.IsNullOrWhiteSpace(primaryMajor.FacultyName))
                                    {
                                        <div class="major-faculty">@primaryMajor.FacultyName</div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="major-box major-box--muted">
                                <div class="major-box-icon major-box-icon--muted">
                                    <i class="fa-solid fa-question"></i>
                                </div>
                                <div>
                                    <div class="major-name major-name--muted">Chưa được gán chuyên ngành</div>
                                    <div class="major-faculty">Liên hệ Admin để cập nhật</div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Lĩnh vực — chip selector -->
                    <div class="f-section">
                        <label class="f-label">Lĩnh vực</label>
                        <input type="hidden" name="category" id="catInput" />
                        <div class="cat-grid" id="catGrid">
                            @{
                                var cats = new[]
                                {
                                                        ("web",      "fa-solid fa-globe",         "Ứng dụng Web"),
                                                        ("mobile",   "fa-solid fa-mobile-screen", "Mobile"),
                                                        ("ai",       "fa-solid fa-brain",         "Trí tuệ nhân tạo"),
                                                        ("iot",      "fa-solid fa-microchip",     "IoT & Nhúng"),
                                                        ("security", "fa-solid fa-shield-halved", "Bảo mật"),
                                                        ("data",     "fa-solid fa-chart-bar",     "Dữ liệu & Phân tích"),
                                                        ("other",    "fa-solid fa-ellipsis",      "Khác"),
                                                        };
                            }
                            @foreach (var (val, ico, lbl) in cats)
                            {
                                <div class="cat-chip @(canPropose ? "" : "disabled")" data-val="@val">
                                    <i class="@ico cat-chip-icon"></i>@lbl
                                </div>
                            }
                        </div>
                    </div>

                    <!-- GV mong muốn -->
                    <div class="f-section">
                        <label class="f-label">
                            Giảng viên mong muốn
                            <span class="opt">(tuỳ chọn)</span>
                        </label>
                        <div class="f-wrap">
                            <i class="fa-solid fa-chalkboard-user f-ico"></i>
                            <select name="preferredLecturerId" class="f-select"
                                    @(!canPropose ? "disabled" : "")>
                                <option value="">-- Để hệ thống chọn --</option>
                                @foreach (var lec in lecturers)
                                {
                                    <option value="@lec.Id">
                                        @(lec.FullName ?? lec.Email)
                                        @(!string.IsNullOrEmpty(lec.Faculty) ? $"· {lec.Faculty}" : "")
                                    </option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="f-foot">
                        <button type="reset" class="btn btn-ghost" id="resetBtn"
                                @(!canPropose ? "disabled" : "")>
                            <i class="fa-solid fa-rotate-left"></i> Đặt lại
                        </button>
                        <button type="submit" class="btn btn-primary" id="sendBtn"
                                @(!canPropose ? "disabled" : "")>
                            <div class="btn-spinner" id="btnSpinner"></div>
                            <i class="fa-solid fa-paper-plane" id="btnIco"></i>
                            <span id="btnTxt">Gửi đề xuất</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ══ RIGHT: SIDEBAR ══ -->
    <div class="sidebar-stack">

        <!-- Đề xuất của tôi -->
        <div class="pt-card">
            <div class="pt-head">
                <div>
                    <div class="pt-head-title">Đề xuất của tôi</div>
                    <div class="pt-head-sub">@pendingCount / 3 slot đang sử dụng</div>
                </div>
            </div>
            <div class="pt-body pt-body--compact">
                <!-- Quota bar -->
                <div class="quota-bar-wrap">
                    <div class="quota-bar @(pendingCount >= 3 ? "full" : "")"
                         data-quota-progress="@(myProposals.Count > 0 ? pendingCount * 100 / 3 : 0)"></div>
                </div>
                <div class="quota-text">
                    <span>@pendingCount đang chờ duyệt</span>
                    <span>@(3 - pendingCount) slot còn lại</span>
                </div>

                <div class="proposal-list-wrap">
                    @if (!myProposals.Any())
                    {
                        <div class="prop-empty">
                            <i class="fa-regular fa-lightbulb"></i>
                            <p>Bạn chưa có đề xuất nào.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var t in myProposals)
                        {
                            bool isRejected = t.Status == KLTN_Registration_System.Models.Entities.TopicStatus.Rejected;
                            string badgeCls = t.IsApproved ? "approved"
                            : (isRejected ? "rejected" : "pending");
                            string badgeTxt = t.IsApproved ? "Đã duyệt"
                            : (isRejected ? "Từ chối" : "Chờ duyệt");
                            string badgeIco = t.IsApproved ? "fa-solid fa-check"
                            : (isRejected ? "fa-solid fa-xmark" : "fa-solid fa-hourglass-half");

                            <div class="prop-item">
                                <div class="prop-main">
                                    <div class="prop-title" title="@t.Title">@t.Title</div>
                                    <div class="prop-date">
                                        <i class="fa-regular fa-calendar prop-date-icon"></i>
                                        @t.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                    <span class="prop-badge @badgeCls">
                                        <i class="@badgeIco prop-badge-icon"></i>
                                        @badgeTxt
                                    </span>
                                    @if (isRejected && !string.IsNullOrWhiteSpace(t.Note))
                                    {
                                        <div class="prop-reject-reason">
                                            <i class="fa-solid fa-comment-slash prop-reject-icon"></i>
                                            @t.Note
                                        </div>
                                    }
                                </div>

                                @if (t.Status == KLTN_Registration_System.Models.Entities.TopicStatus.Pending)
                                {
                                    <form method="post"
                                          asp-action="CancelProposal"
                                          asp-controller="Student"
                                          asp-route-id="@t.Id"
                                          class="cancel-proposal-form"
                                          data-title="@t.Title">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-cancel-prop" title="Huỷ đề xuất">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Lưu ý -->
        <div class="notes-card">
            <div class="notes-title">
                <i class="fa-solid fa-circle-info notes-title-icon"></i>
                Lưu ý quan trọng
            </div>
            <ul class="notes-list">
                <li>
                    <i class="fa-solid fa-lock"></i>
                    Tối đa <strong>3 đề xuất</strong> đang chờ duyệt cùng lúc.
                </li>
                <li>
                    <i class="fa-regular fa-clock"></i>
                    Admin xem xét trong <strong>3–5 ngày làm việc</strong>.
                </li>
                <li>
                    <i class="fa-solid fa-arrow-right"></i>
                    Sau khi duyệt, cần <strong>đăng ký chính thức</strong> qua trang danh sách đề tài.
                </li>
                <li>
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    Giảng viên mong muốn chỉ là <strong>ưu tiên</strong>, không đảm bảo phân công.
                </li>
                <li>
                    <i class="fa-solid fa-rotate-right"></i>
                    Đề xuất bị từ chối có thể chỉnh sửa và <strong>gửi lại</strong>.
                </li>
            </ul>
        </div>

    </div>
</div>

<div id="proposalConfirmModal" class="pt-modal-overlay" aria-hidden="true">
    <div class="pt-modal-box" role="dialog" aria-modal="true" aria-labelledby="proposalConfirmTitle">
        <div class="pt-modal-head">
            <div class="pt-modal-icon">
                <i class="fa-solid fa-circle-question"></i>
            </div>
            <div>
                <div class="pt-modal-title" id="proposalConfirmTitle">Xác nhận</div>
                <div class="pt-modal-sub" id="proposalConfirmMessage"></div>
            </div>
        </div>
        <div class="pt-modal-actions">
            <button type="button" class="pt-modal-cancel" data-close-proposal-confirm>Quay lại</button>
            <button type="button" class="pt-modal-confirm" id="proposalConfirmBtn">
                <i class="fa-solid fa-check"></i> Xác nhận
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/student/propose-topic.js" asp-append-version="true"></script>
}

