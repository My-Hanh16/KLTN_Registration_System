@* ============================================================
   FILE: Views/Student/ProposeTopic.cshtml  — TẠO MỚI
   MODEL: không (dùng ViewBag)
   ============================================================ *@
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Đề xuất đề tài";
    var myProposals = ViewBag.MyProposals as List<KLTN_Registration_System.Models.Entities.Topic>
                   ?? new List<KLTN_Registration_System.Models.Entities.Topic>();
    var majors = ViewBag.Majors as List<KLTN_Registration_System.Models.Entities.Major>
              ?? new List<KLTN_Registration_System.Models.Entities.Major>();
    var lecturers = ViewBag.Lecturers as List<KLTN_Registration_System.Models.Entities.ApplicationUser>
                 ?? new List<KLTN_Registration_System.Models.Entities.ApplicationUser>();
}

<div class="max-w-4xl mx-auto">
    <div class="mb-6">
        <h2 class="font-headline text-3xl font-extrabold text-on-surface tracking-tight">Đề xuất đề tài</h2>
        <p class="text-on-surface-variant mt-1">Nếu không tìm thấy đề tài phù hợp, bạn có thể đề xuất ý tưởng riêng để Admin & Giảng viên xem xét.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-5 flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 rounded-2xl px-5 py-3 text-sm font-medium">
            <span class="material-symbols-outlined text-green-600">check_circle</span>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-5 flex items-center gap-3 bg-red-50 border border-red-200 text-red-800 rounded-2xl px-5 py-3 text-sm font-medium">
            <span class="material-symbols-outlined text-red-500">error</span>@TempData["Error"]
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

        @* ── Form đề xuất ── *@
        <div class="lg:col-span-3">
            <div class="bg-surface-container-lowest rounded-3xl border border-outline-variant/10 shadow-sm overflow-hidden">
                <div class="px-8 py-5 border-b border-slate-100">
                    <h3 class="font-bold text-on-surface text-base">Ý tưởng của bạn</h3>
                    <p class="text-xs text-on-surface-variant mt-0.5">Tối đa 3 đề xuất đang chờ duyệt.</p>
                </div>
                <form method="post" asp-action="ProposeTopic" asp-controller="Student" class="p-8 space-y-5">
                    @Html.AntiForgeryToken()

                    <div>
                        <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Tên đề tài *</label>
                        <input type="text" name="title" required maxlength="300"
                               placeholder="VD: Ứng dụng AI hỗ trợ học tiếng Anh"
                               class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Mô tả ý tưởng *</label>
                        <textarea name="description" required rows="5" maxlength="1000"
                                  placeholder="Mô tả vấn đề cần giải quyết, phương hướng thực hiện, công nghệ dự kiến dùng..."
                                  class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-blue-400"></textarea>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Chuyên ngành</label>
                            <select name="majorId"
                                    class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-white">
                                <option value="">-- Chọn ngành --</option>
                                @foreach (var m in majors)
                                {
                                    <option value="@m.Id">@m.Name</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Lĩnh vực</label>
                            <select name="category"
                                    class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-white">
                                <option value="">-- Chọn lĩnh vực --</option>
                                <option>Ứng dụng web</option>
                                <option>Ứng dụng mobile</option>
                                <option>Trí tuệ nhân tạo</option>
                                <option>IoT & Nhúng</option>
                                <option>Bảo mật</option>
                                <option>Dữ liệu & Phân tích</option>
                                <option>Khác</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase">
                            Giảng viên mong muốn <span class="text-slate-400 font-normal">(tuỳ chọn)</span>
                        </label>
                        <select name="preferredLecturerId"
                                class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-white">
                            <option value="">-- Để hệ thống chọn --</option>
                            @foreach (var lec in lecturers)
                            {
                                <option value="@lec.Id">@(lec.FullName ?? lec.Email) @(!string.IsNullOrEmpty(lec.Faculty) ? $"({lec.Faculty})" : "")</option>
                            }
                        </select>
                    </div>

                    <div class="flex justify-end">
                        <button type="submit"
                                class="flex items-center gap-2 px-8 py-3 bg-primary text-white rounded-xl font-bold text-sm hover:opacity-90 active:scale-95 transition-all shadow-lg">
                            <span class="material-symbols-outlined text-base">send</span> Gửi đề xuất
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @* ── Đề xuất của tôi ── *@
        <div class="lg:col-span-2">
            <div class="bg-surface-container-lowest rounded-3xl border border-outline-variant/10 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100">
                    <h3 class="font-bold text-on-surface text-sm">Đề xuất của tôi (@myProposals.Count/3)</h3>
                </div>
                @if (!myProposals.Any())
                {
                    <div class="py-10 text-center px-6">
                        <span class="material-symbols-outlined text-4xl text-slate-300">lightbulb</span>
                        <p class="text-xs text-slate-400 mt-2">Bạn chưa có đề xuất nào.</p>
                    </div>
                }
                else
                {
                    <div class="divide-y divide-slate-100">
                        @foreach (var t in myProposals)
                        {
                            string badge = t.IsApproved ? "bg-green-100 text-green-700" : "bg-yellow-100 text-yellow-700";
                            string badgeLabel = t.IsApproved ? "Đã duyệt" : "Chờ duyệt";
                            <div class="p-5">
                                <div class="flex items-start justify-between gap-2">
                                    <div class="min-w-0">
                                        <p class="font-semibold text-sm text-on-surface leading-snug line-clamp-2">@t.Title</p>
                                        <p class="text-xs text-slate-400 mt-0.5">@t.CreatedAt.ToString("dd/MM/yyyy")</p>
                                        <span class="inline-block mt-1 text-xs font-bold px-2 py-0.5 rounded-full @badge">@badgeLabel</span>
                                    </div>
                                    @if (!t.IsApproved)
                                    {
                                        <form method="post" asp-action="CancelProposal" asp-controller="Student" asp-route-id="@t.Id"
                                              onsubmit="return confirm('Huỷ đề xuất này?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="p-1.5 rounded-lg text-red-400 hover:bg-red-50 shrink-0">
                                                <span class="material-symbols-outlined text-base">close</span>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            @* Hướng dẫn *@
            <div class="mt-4 bg-blue-50 rounded-2xl border border-blue-100 p-5">
                <h4 class="font-bold text-blue-800 text-xs uppercase tracking-wide mb-2">Lưu ý</h4>
                <ul class="text-xs text-blue-700 space-y-1 list-disc list-inside">
                    <li>Tối đa 3 đề xuất đang chờ cùng lúc.</li>
                    <li>Admin sẽ xem xét trong 3-5 ngày làm việc.</li>
                    <li>Sau khi duyệt, bạn cần đăng ký chính thức qua trang danh sách đề tài.</li>
                    <li>Giảng viên mong muốn chỉ là ưu tiên, không đảm bảo phân công.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
