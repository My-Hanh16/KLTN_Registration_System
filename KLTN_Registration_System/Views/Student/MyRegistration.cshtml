@model IEnumerable<KLTN_Registration_System.Models.Entities.Registration>
@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Đăng ký của tôi";
    var registrations = Model?.ToList() ?? new List<KLTN_Registration_System.Models.Entities.Registration>();
    var proposedTopics = ViewBag.ProposedTopics as List<KLTN_Registration_System.Models.Entities.Topic>
                         ?? new List<KLTN_Registration_System.Models.Entities.Topic>();
    bool canParticipate = ViewBag.CanParticipateInCurrentPeriod != false;
    bool hasCompletedThesis = ViewBag.StudentHasCompletedThesis == true;
    string activePeriodName = ViewBag.ActivePeriodName as string ?? "";
    int pendingRegistrationCount = registrations.Count(r => string.Equals(r.Status, "Pending", StringComparison.OrdinalIgnoreCase));
    int rejectedRegistrationCount = registrations.Count(r => string.Equals(r.Status, "Rejected", StringComparison.OrdinalIgnoreCase));
    int approvedRegistrationCount = registrations.Count(r => string.Equals(r.Status, "Approved", StringComparison.OrdinalIgnoreCase));
    int pendingProposalCount = proposedTopics.Count(t => t.Status == KLTN_Registration_System.Models.Entities.TopicStatus.Pending);
    int rejectedProposalCount = proposedTopics.Count(t => t.Status == KLTN_Registration_System.Models.Entities.TopicStatus.Rejected);
    int approvedProposalCount = proposedTopics.Count(t => t.IsApproved && t.Status != KLTN_Registration_System.Models.Entities.TopicStatus.Rejected);
    int totalTrackedCount = registrations.Count + proposedTopics.Count;
    int successCount = approvedRegistrationCount + approvedProposalCount;
    int successRate = totalTrackedCount > 0 ? Math.Min(100, successCount * 100 / totalTrackedCount) : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/student/my-registration.css" asp-append-version="true" />
}


<div class="row g-4">
    <div class="col-lg-8">
        <div class="page-heading">
            <h2>Đăng ký của tôi</h2>
            <p>
                Quản lý và theo dõi tiến độ phê duyệt đề tài của bạn
                @if (!string.IsNullOrWhiteSpace(activePeriodName))
                {
                    <span>trong đợt @activePeriodName</span>
                }.
            </p>
        </div>   

        @if (proposedTopics.Any())
        {
            <div class="section-heading">
                <i class="fa-solid fa-wand-magic-sparkles icon-primary"></i>
                Đề xuất của bạn
            </div>

            @foreach (var topic in proposedTopics)
            {
                var proposalStatus = topic.Status;
                var proposalBadgeClass = topic.IsApproved && proposalStatus == KLTN_Registration_System.Models.Entities.TopicStatus.Available
                    ? "bg-soft-blue"
                    : proposalStatus == KLTN_Registration_System.Models.Entities.TopicStatus.Rejected
                        ? "bg-soft-red"
                        : "bg-soft-orange";
                var proposalStatusText = topic.IsApproved && proposalStatus == KLTN_Registration_System.Models.Entities.TopicStatus.Available
                    ? "ĐÃ THÊM VÀO HỆ THỐNG"
                    : topic.IsApproved
                        ? "ĐÃ ĐƯỢC DUYỆT"
                    : proposalStatus == KLTN_Registration_System.Models.Entities.TopicStatus.Rejected
                        ? "ĐÃ TỪ CHỐI"
                        : "ĐANG CHỜ DUYỆT";

                <div class="reg-card-proposed">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="status-badge bg-soft-purple">TỰ ĐỀ XUẤT</span>
                            <span class="status-badge @proposalBadgeClass">● @proposalStatusText</span>
                        </div>
                        <span class="date-meta">
                            Gửi ngày: @topic.CreatedAt.ToString("dd/MM/yyyy")
                        </span>
                    </div>

                    <p class="card-topic-title">@topic.Title</p>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-box-sm"><i class="fa-solid fa-user-tie"></i></div>
                                <div>
                                    <span class="meta-label">Giảng viên mong muốn</span>
                                    <span class="meta-value">@(!string.IsNullOrEmpty(topic.Lecturer?.FullName) ? topic.Lecturer.FullName : topic.Lecturer?.Email ?? "Chờ admin phân công")</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-box-sm"><i class="fa-solid fa-microchip"></i></div>
                                <div>
                                    <span class="meta-label">Lĩnh vực</span>
                                    <span class="meta-value">@(topic.Major?.Name ?? "Nghiên cứu & Ứng dụng")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (proposalStatus == KLTN_Registration_System.Models.Entities.TopicStatus.Rejected
                         && !string.IsNullOrWhiteSpace(topic.Note))
                    {
                        <div class="reject-reason">
                            <i class="fa-solid fa-circle-info"></i>
                            <span>Lý do từ chối: @topic.Note</span>
                        </div>
                    }

                    <div class="d-flex justify-content-end align-items-center gap-3 mt-4">
                        <a asp-controller="Topic"
                           asp-action="Details"
                           asp-route-id="@topic.Id"
                           class="btn-action-link">
                            Chi tiết đề xuất
                        </a>

                        @if (proposalStatus == KLTN_Registration_System.Models.Entities.TopicStatus.Pending)
                        {
                            <form asp-action="CancelProposal"
                                  asp-route-id="@topic.Id"
                                  asp-route-returnTo="myregistration"
                                  method="post"
                                  class="cancel-registration-form"
                                  data-topic-title="@topic.Title">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-cancel">
                                    <i class="fa-solid fa-xmark"></i> Hủy đề xuất
                                </button>
                            </form>
                        }
                    </div>

                </div>
            }

            <hr class="section-divider" />
        }

        <div class="section-heading">
            <i class="fa-solid fa-clock-rotate-left icon-muted"></i>
            Lịch sử đăng ký
        </div>

        @if (!registrations.Any())
        {
            <div class="empty-state">
                <i class="fa-solid fa-folder-open"></i>
                @if (hasCompletedThesis)
                {
                    <p>Bạn đã hoàn thành KLTN. Không còn đăng ký mới ở các đợt sau.</p>
                }
                else if (!canParticipate)
                {
                    <p>Bạn chưa thuộc danh sách sinh viên đủ điều kiện của đợt hiện tại.</p>
                }
                else
                {
                    <p>Bạn chưa đăng ký đề tài nào từ danh sách chung.</p>
                    <a asp-controller="Topic" asp-action="Index"
                       class="btn-chat btn-discover">
                        Khám phá đề tài
                    </a>
                }
            </div>
        }

        @foreach (var item in registrations)
        {
            var statusLower = item.Status?.ToLower() ?? "pending";
            var borderClass = statusLower == "approved" ? "border-approved"
            : statusLower == "rejected" ? "border-rejected"
            : "border-pending";
            var badgeClass = statusLower == "approved" ? "bg-soft-blue"
            : statusLower == "rejected" ? "bg-soft-red"
            : "bg-soft-orange";
            var statusText = statusLower == "approved" ? "ĐÃ DUYỆT"
            : statusLower == "rejected" ? "TỪ CHỐI"
            : "ĐANG CHỜ DUYỆT";

            <div class="reg-card @borderClass">

                <div class="d-flex justify-content-between align-items-center">
                    <span class="status-badge @badgeClass">● @statusText</span>
                    <span class="date-meta">
                        Ngày đăng ký: @item.CreatedAt.ToString("dd/MM/yyyy")
                    </span>
                </div>

                <p class="card-topic-title">@item.Topic?.Title</p>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box-sm"><i class="fa-solid fa-user-tie"></i></div>
                            <div>
                                <span class="meta-label">Giảng viên hướng dẫn</span>
                                <span class="meta-value">@(!string.IsNullOrEmpty(item.Topic?.Lecturer?.FullName) ? item.Topic.Lecturer.FullName : item.Topic?.Lecturer?.Email)</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box-sm"><i class="fa-solid fa-layer-group"></i></div>
                            <div>
                                <span class="meta-label">Lĩnh vực</span>
                                <span class="meta-value">@(item.Topic?.Major?.Name ?? "Chuyên ngành")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end align-items-center gap-3 mt-4">

                    @if (item.Topic != null)
                    {
                        <a asp-controller="Topic"
                           asp-action="Details"
                           asp-route-id="@item.TopicId"
                           class="btn-action-link">
                            Chi tiết đề tài
                        </a>
                    }

                    @if (statusLower == "approved")
                    {
                        <a href="/Chat/Topic?topicId=@item.TopicId" class="btn-chat">
                            <i class="fa-regular fa-comments"></i> Chat với GVHD
                        </a>
                    }

                    @if (statusLower == "pending")
                    {
                        <form asp-action="CancelRegistration"
                              asp-route-id="@item.Id"
                              method="post"
                              class="cancel-registration-form"
                              data-topic-title="@(item.Topic?.Title ?? "đề tài này")">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-cancel">
                                <i class="fa-solid fa-xmark"></i> Hủy đăng ký
                            </button>
                        </form>
                    }

                </div>
            </div>
        }

    </div>

    <div class="col-lg-4">

        <div class="stats-panel shadow-sm">
            <p class="stats-panel-title">Thống kê của bạn</p>

            <div class="row g-0 text-center mb-4">
                <div class="col-6 stats-divider">
                    <div class="stats-number">@((pendingRegistrationCount + pendingProposalCount).ToString("D2"))</div>
                    <div class="stats-label">Đang chờ</div>
                </div>
                <div class="col-6">
                    <div class="stats-number">@((rejectedRegistrationCount + rejectedProposalCount).ToString("D2"))</div>
                    <div class="stats-label">Từ chối</div>
                </div>
            </div>

            <div>
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="success-rate-label">Tỷ lệ thành công</span>
                    <span class="success-rate-value">
                        @successRate%
                    </span>
                </div>
                <div class="progress-track">
                    <div class="progress-fill"
                         data-progress="@successRate">
                    </div>
                </div>
            </div>
        </div>

        <div class="note-card">
            <div class="note-card-title">
                <i class="fa-solid fa-circle-exclamation icon-primary"></i>
                Lưu ý quan trọng
            </div>
            <div class="note-item">
                <span class="note-num">01.</span>
                <p class="note-text">Mỗi sinh viên chỉ được phép có <strong>01 đề tài</strong> chính thức ở trạng thái Approved.</p>
            </div>
            <div class="note-item">
                <span class="note-num">02.</span>
                <p class="note-text">Tính năng <strong>Hủy đăng ký</strong> chỉ khả dụng khi giảng viên chưa bắt đầu quá trình phê duyệt.</p>
            </div>
            @if (hasCompletedThesis)
            {
                <div class="note-item">
                    <span class="note-num">03.</span>
                    <p class="note-text">Bạn đã <strong>hoàn thành KLTN</strong>, nên chỉ có thể xem lại lịch sử và không thể tham gia đăng ký kỳ mới.</p>
                </div>
            }
        </div>

    </div>
</div>

<div id="cancelConfirmModal" class="cancel-confirm-overlay" aria-hidden="true">
    <div class="cancel-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="cancelConfirmTitle">
        <div class="cancel-confirm-head">
            <div class="cancel-confirm-icon">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <div>
                <h3 id="cancelConfirmTitle">Xác nhận hủy đăng ký</h3>
                <p>Bạn có chắc chắn muốn hủy đăng ký đề tài này?</p>
                <div id="cancelConfirmTopic" class="cancel-confirm-topic"></div>
            </div>
        </div>
        <div class="cancel-confirm-actions">
            <button type="button" class="cancel-confirm-btn secondary" id="cancelConfirmClose">Không hủy</button>
            <button type="button" class="cancel-confirm-btn danger" id="cancelConfirmSubmit">Xác nhận hủy</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/student/my-registration.js" asp-append-version="true"></script>
}

