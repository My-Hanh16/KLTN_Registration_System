@model IEnumerable<KLTN_Registration_System.Models.Entities.Timeline>
@using KLTN_Registration_System.Models.Entities
@using KLTN_Registration_System.Models.Enums

@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Timeline";
    var submissions = ViewBag.Submissions as List<TimelineSubmission>
        ?? new List<TimelineSubmission>();
    bool hasApprovedTopic = ViewBag.HasApprovedTopic == true;
    int requiredTimelineCount = ViewBag.RequiredTimelineCount ?? 0;
    int approvedRequiredCount = ViewBag.ApprovedRequiredTimelineCount ?? 0;
    int pendingRequiredCount = ViewBag.PendingRequiredTimelineCount ?? 0;
    int rejectedRequiredCount = ViewBag.RejectedRequiredTimelineCount ?? 0;
    int missingRequiredCount = ViewBag.MissingRequiredTimelineCount ?? 0;
    bool isDefenseEligible = ViewBag.IsDefenseEligible == true;
    bool isDefenseWindowClosed = ViewBag.IsDefenseWindowClosed == true;
    bool isDefenseBlockedByDeadline = ViewBag.IsDefenseBlockedByDeadline == true;
    bool hasCompletedThesis = ViewBag.HasCompletedThesis == true;
    DateTime? thesisCompletedAt = ViewBag.ThesisCompletedAt as DateTime?;
    var blockingRequiredTimelineNames = ViewBag.BlockingRequiredTimelineNames as List<string>
        ?? new List<string>();
    int? activeTopicId = ViewBag.ActiveTopicId is int topicId ? topicId : null;
    int defenseProgress = requiredTimelineCount > 0
        ? Math.Min(100, approvedRequiredCount * 100 / requiredTimelineCount)
        : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/student/timeline.css" asp-append-version="true" />
}

<div class="timeline-page">

    <div class="timeline-header">

        <div>
            <h2>
                Timeline Đồ Án
            </h2>

            <p>
                Theo dõi lộ trình, tiến độ và hoàn thành các mốc thời gian khóa luận tốt nghiệp.
            </p>
        </div>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success timeline-alert">
            <i class="bi bi-check-circle"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger timeline-alert">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    <div class="defense-card @(hasCompletedThesis ? "is-completed" : isDefenseEligible ? "is-eligible" : isDefenseBlockedByDeadline ? "is-deadline-blocked" : "is-blocked")">
        <div class="defense-main">
            <div class="defense-icon">
                <i class="bi @(hasCompletedThesis ? "bi-award-fill" : isDefenseEligible ? "bi-patch-check-fill" : isDefenseBlockedByDeadline ? "bi-x-octagon-fill" : "bi-shield-lock-fill")"></i>
            </div>
            <div>
                <div class="defense-label">Điều kiện báo cáo khóa luận</div>
                <h3>
                    @(hasCompletedThesis
                        ? "Hoàn thành khóa luận"
                        : isDefenseEligible
                        ? "Đủ điều kiện báo cáo"
                        : isDefenseBlockedByDeadline
                            ? "Không đủ điều kiện báo cáo"
                            : "Chưa đủ điều kiện báo cáo")
                </h3>
                <p>
                    @if (hasCompletedThesis)
                    {
                        <span>
                            Bạn đã được admin ghi nhận hoàn thành khóa luận
                            @(thesisCompletedAt.HasValue ? $" vào ngày {thesisCompletedAt.Value:dd/MM/yyyy}" : "").
                            Bạn không cần đăng ký khóa luận ở các kỳ sau.
                        </span>
                    }
                    else if (!hasApprovedTopic)
                    {
                        <span>Bạn cần có đề tài được duyệt trước khi xét điều kiện báo cáo.</span>
                    }
                    else if (requiredTimelineCount == 0)
                    {
                        <span>Hiện chưa có mốc timeline bắt buộc nộp bài.</span>
                    }
                    else if (isDefenseEligible)
                    {
                        <span>Tất cả mốc bắt buộc đã được giảng viên duyệt. Bạn đã được phép tham gia bước báo cáo khóa luận và đang chờ kết quả từ admin.</span>
                    }
                    else if (isDefenseBlockedByDeadline)
                    {
                        <span>Timeline bắt buộc đã hết hạn nhưng bạn chưa hoàn tất đủ mốc được duyệt. Tài khoản vẫn hoạt động, nhưng quyền báo cáo khóa luận sẽ bị khóa.</span>
                    }
                    else
                    {
                        <span>Cần hoàn tất và được duyệt đủ các mốc timeline bắt buộc.</span>
                    }
                </p>
                @if (isDefenseBlockedByDeadline && blockingRequiredTimelineNames.Any())
                {
                    <div class="defense-missing">
                        <span>Còn vướng:</span>
                        @foreach (var name in blockingRequiredTimelineNames.Take(3))
                        {
                            <strong>@name</strong>
                        }
                        @if (blockingRequiredTimelineNames.Count > 3)
                        {
                            <em>+@(blockingRequiredTimelineNames.Count - 3) mốc khác</em>
                        }
                    </div>
                }
                @if (isDefenseEligible && !hasCompletedThesis)
                {
                    <div class="defense-next">
                        <div class="defense-next-title">Bước tiếp theo</div>
                        <div class="defense-actions">
                            <a asp-controller="Student" asp-action="Notifications" class="defense-action">
                                <i class="bi bi-bell"></i>
                                Theo dõi lịch báo cáo
                            </a>
                            @if (activeTopicId.HasValue)
                            {
                                <a asp-controller="Chat" asp-action="Topic" asp-route-topicId="@activeTopicId.Value" class="defense-action">
                                    <i class="bi bi-chat-dots"></i>
                                    Trao đổi GVHD
                                </a>
                            }
                            <a asp-controller="Student" asp-action="MyRegistration" class="defense-action">
                                <i class="bi bi-journal-check"></i>
                                Kiểm tra đề tài
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="defense-side">
            <div class="defense-count">
                <strong>@approvedRequiredCount</strong>/<span>@requiredTimelineCount</span>
            </div>
            <div class="defense-progress">
                <div style="width:@defenseProgress%"></div>
            </div>
            <div class="defense-breakdown">
                <span>Chờ duyệt: @pendingRequiredCount</span>
                <span>Từ chối: @rejectedRequiredCount</span>
                <span>Chưa nộp: @missingRequiredCount</span>
            </div>
        </div>
    </div>

    <div class="timeline-container">

        @if (Model == null || !Model.Any())
        {
            <div class="tl-card">
                <div class="expired-alert">
                    <i class="bi bi-calendar-x"></i>
                    Hiện chưa có mốc timeline nào được mở.
                </div>
            </div>
        }
        else
        {
        @foreach (var item in Model)
        {
            var allSubmissions = submissions
            .Where(x => x.TimelineId == item.Id)
            .OrderByDescending(x => x.SubmittedAt)
            .ToList();

            var latestSub = allSubmissions?.FirstOrDefault();

            var collapseId = $"tl_{item.Id}";

            var now = DateTime.Now;
            bool isExpired = item.SubmissionDeadline.HasValue && item.SubmissionDeadline.Value < now;
            bool isNotOpenYet = item.AllowSubmission && item.Date > now;
            bool latestRejected = latestSub?.Status == SubmissionStatus.Rejected;
            bool canSubmit = hasApprovedTopic && !hasCompletedThesis && !isDefenseBlockedByDeadline && item.AllowSubmission && (!isNotOpenYet || latestRejected) && (!isExpired || latestRejected);
            bool isLateResubmission = item.AllowSubmission && isExpired && latestRejected;
            var allowedTypes = string.IsNullOrWhiteSpace(item.SubmissionType)
                ? "pdf, doc, docx, ppt, pptx, zip, rar, txt"
                : item.SubmissionType;
            var acceptTypes = string.Join(",", allowedTypes
                .Split(new[] { ',', ';', '|', '/', ' ' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(x => x.Trim().TrimStart('*'))
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Select(x => x.StartsWith(".") ? x : "." + x));

            string statusClass = "status-default";
            string statusText = "Chưa nộp";

            if (latestSub != null)
            {
                if (latestSub.Status == SubmissionStatus.Approved)
                {
                    statusClass = "status-approved";
                    statusText = "Đã duyệt";
                }
                else if (latestSub.Status == SubmissionStatus.Rejected)
                {
                    statusClass = "status-rejected";
                    statusText = "Từ chối";
                }
                else
                {
                    statusClass = "status-pending";
                    statusText = "Đang chờ";
                }
            }
            else if (isExpired)
            {
                statusClass = "status-expired";
                statusText = "Quá hạn";
            }
            else if (!item.AllowSubmission)
            {
                statusClass = "status-default";
                statusText = "Không yêu cầu nộp";
            }
            else if (!hasApprovedTopic)
            {
                statusClass = "status-default";
                statusText = "Chưa có đề tài";
            }
            else if (isNotOpenYet)
            {
                statusClass = "status-default";
                statusText = "Chưa mở nộp";
            }

            <div class="tl-card">

                <!-- HEADER ROW -->
                <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">

                    <div class="d-flex align-items-center gap-3">

                        <div class="date-box">
                            <span class="month">THÁNG @item.Date.Month</span>
                            <span class="day">@item.Date.Day</span>
                        </div>

                        <div>
                            <div class="milestone-label">
                                <span class="milestone-dot"></span>
                                Mốc thời gian
                            </div>

                            <h3 class="tl-title">@item.Title</h3>

                            <p class="tl-desc">@item.Description</p>
                        </div>

                    </div>

                    <div class="d-flex align-items-center gap-2 flex-wrap">

                        <span class="status-badge @statusClass">
                            @statusText
                        </span>

                        <button type="button"
                                class="btn-toggle"
                                data-toggle-timeline data-target="@collapseId">

                            <span class="btn-text">Xem chi tiết</span>

                            <i class="bi bi-chevron-down"></i>

                        </button>

                    </div>

                </div>

                <!-- COLLAPSE -->
                <div id="@collapseId" class="tl-collapse-hidden">

                    <hr class="tl-divider" />

                    <!-- FORM -->
                    @if (item.AllowSubmission && !hasApprovedTopic)
                    {
                        <div class="expired-alert">
                            <i class="bi bi-lock"></i>
                            Bạn cần có đề tài đã được duyệt trước khi nộp timeline.
                        </div>
                    }
                    else if (item.AllowSubmission && hasCompletedThesis)
                    {
                        <div class="expired-alert success-alert">
                            <i class="bi bi-award"></i>
                            Bạn đã hoàn thành khóa luận. Timeline chỉ còn dùng để xem lại lịch sử nộp bài.
                        </div>
                    }
                    else if (item.AllowSubmission && isDefenseBlockedByDeadline)
                    {
                        <div class="expired-alert">
                            <i class="bi bi-x-octagon"></i>
                            Timeline bắt buộc đã hết hạn và bạn chưa đủ điều kiện báo cáo. Vui lòng liên hệ GVHD hoặc admin nếu cần xem xét ngoại lệ.
                        </div>
                    }
                    else if (canSubmit && (latestSub == null || latestSub.Status == SubmissionStatus.Rejected))
                    {
                        <div class="resubmit-box">

                            <div class="resubmit-title">
                                <i class="bi bi-cloud-arrow-up"></i>

                                @(latestSub == null
                                                        ? "Tải file báo cáo lần đầu"
                                                        : "Nộp lại báo cáo chỉnh sửa")
                                                                                  </div>

                            @if (isLateResubmission)
                            {
                                <div class="alert alert-warning timeline-alert mb-3">
                                    <i class="bi bi-arrow-repeat"></i>
                                    <span>Bài nộp đã bị từ chối. Bạn cần nộp bản mới để giảng viên xem xét lại.</span>
                                </div>
                            }

                            <form asp-action="SubmitTimeline"
                                  asp-controller="Student"
                                  method="post"
                                  enctype="multipart/form-data">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="timelineId"
                                       value="@item.Id" />

                                <div class="row g-2 align-items-center">

                                    <div class="col-12">
                                        <textarea name="content"
                                                  class="form-control timeline-submit-control"
                                                  rows="3"
                                                  maxlength="1000"
                                                  placeholder="Mô tả ngắn tiến độ đã thực hiện..."></textarea>
                                    </div>

                                    <div class="col-md-9">
                                        <input type="file"
                                               name="file"
                                               accept="@acceptTypes"
                                               class="form-control timeline-submit-control"
                                               required />
                                        <div class="text-muted mt-1 submit-format-note">
                                            Định dạng cho phép: @allowedTypes
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <button type="submit" class="btn-submit">
                                            @(latestSub == null
                                                                                ? "Nộp bài"
                                                                                : "Nộp bản mới")
                                </button>
                            </div>

                                </div>

                            </form>

                        </div>
                                }

                    <!-- HISTORY -->
                    @if (allSubmissions != null && allSubmissions.Any())
                    {
                        <div class="history-label">
                            Lịch sử nộp bài
                        </div>

                        <div class="d-flex flex-column gap-3">

                            @foreach (var sub in allSubmissions)
                            {
                                bool isLatest = (sub.Id == latestSub!.Id);

                                string iconClass =
                                sub.Status == SubmissionStatus.Approved ? "approved"
                                : sub.Status == SubmissionStatus.Rejected ? "rejected"
                                : "pending";

                                string subStatusClass =
                                sub.Status == SubmissionStatus.Approved ? "status-approved"
                                : sub.Status == SubmissionStatus.Rejected ? "status-rejected"
                                : "status-pending";

                                string subStatusText =
                                sub.Status == SubmissionStatus.Approved ? "Đã duyệt"
                                : sub.Status == SubmissionStatus.Rejected ? "Từ chối"
                                : "Đang chờ";

                                <div class="sub-item @(isLatest ? "is-latest" : "is-old")">

                                    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">

                                        <div class="d-flex align-items-center gap-3">

                                            <div class="sub-file-icon @iconClass">
                                                <i class="bi bi-file-earmark-text"></i>
                                            </div>

                                            <div>

                                                <div class="sub-date">

                                                    Bản nộp ngày @sub.SubmittedAt.ToString("dd/MM/yyyy")

                                                    @if (isLatest)
                                                    {
                                                        <span class="badge-latest">
                                                            Mới nhất
                                                        </span>
                                                    }

                                                </div>

                                                <div class="sub-time">
                                                    Gửi lúc @sub.SubmittedAt.ToString("HH:mm")
                                                </div>

                                            </div>

                                        </div>

                                        <div class="d-flex align-items-center gap-2 flex-wrap">

                                            <span class="status-badge @subStatusClass">
                                                @subStatusText
                                            </span>

                                            @if (!string.IsNullOrWhiteSpace(sub.FilePath))
                                            {
                                                <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = sub.Id })"
                                                   target="_blank"
                                                   class="btn-view-file">

                                                    <i class="bi bi-eye"></i>

                                                    Xem file

                                                </a>
                                            }

                                        </div>

                                    </div>

                                    @if (sub.Status != SubmissionStatus.Pending)
                                    {
                                        <div class="review-section">

                                            <div class="d-flex flex-wrap gap-4">

                                                @if (sub.Score != null)
                                                {
                                                    <div>
                                                        <div class="review-meta-label">
                                                            Điểm số
                                                        </div>

                                                        <div class="review-value review-score">

                                                            @sub.Score / 10

                                                        </div>
                                                    </div>
                                                }

                                                <div class="flex-grow-1">

                                                    <div class="review-meta-label">
                                                        Nhận xét từ giảng viên
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(sub.Comment))
                                                    {
                                                        <div class="review-value">
                                                            "@sub.Comment"
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="review-value review-empty-comment">

                                                            Giảng viên chưa để lại lời nhắn

                                                        </div>
                                                    }

                                                </div>

                                            </div>

                                            @if (sub.ReviewedAt != null)
                                            {
                                                <div class="review-reviewed-at">
                                                    Đã xem lúc:
                                                    @sub.ReviewedAt?.ToString("HH:mm dd/MM/yyyy")
                                                </div>
                                            }

                                        </div>
                                    }

                                </div>
                            }

                        </div>
                    }
                    else if (isExpired)
                    {
                        <div class="expired-alert">

                            <i class="bi bi-clock-history"></i>

                            Đã quá hạn và không có dữ liệu nộp bài.

                        </div>
                    }

                </div>

            </div>
        }
        }

    </div>

</div>

@section Scripts {
    <script src="~/js/student/timeline.js" asp-append-version="true"></script>
}

