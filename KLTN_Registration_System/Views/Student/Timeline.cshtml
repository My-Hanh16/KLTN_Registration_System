@model IEnumerable<KLTN_Registration_System.Models.Entities.Timeline>
@using KLTN_Registration_System.Models.Entities
@using KLTN_Registration_System.Models.Enums

@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Timeline";
    var submissions = ViewBag.Submissions as List<TimelineSubmission>
        ?? new List<TimelineSubmission>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/student/timeline.css" asp-append-version="true" />
}

<div class="timeline-page">

    <!-- HEADER -->
    <div class="timeline-header">

        <div>
            <h2>
                Timeline Đồ Án
            </h2>

            <p>
                Theo dõi lộ trình, tiến độ và hoàn thành các mốc thời gian khóa luận tốt nghiệp.
            </p>
        </div>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success timeline-alert">
            <i class="bi bi-check-circle"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger timeline-alert">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    <!-- TIMELINE -->
    <div class="timeline-container">

        @if (Model == null || !Model.Any())
        {
            <div class="tl-card">
                <div class="expired-alert">
                    <i class="bi bi-calendar-x"></i>
                    Hiện chưa có mốc timeline nào được mở.
                </div>
            </div>
        }
        else
        {
        @foreach (var item in Model)
        {
            var allSubmissions = submissions
            .Where(x => x.TimelineId == item.Id)
            .OrderByDescending(x => x.SubmittedAt)
            .ToList();

            var latestSub = allSubmissions?.FirstOrDefault();

            var collapseId = $"tl_{item.Id}";

            var now = DateTime.Now;
            bool isExpired = item.SubmissionDeadline.HasValue && item.SubmissionDeadline.Value < now;
            bool canSubmit = item.AllowSubmission && !isExpired;
            var allowedTypes = string.IsNullOrWhiteSpace(item.SubmissionType)
                ? "pdf, doc, docx, ppt, pptx, zip, rar, txt"
                : item.SubmissionType;
            var acceptTypes = string.Join(",", allowedTypes
                .Split(new[] { ',', ';', '|', '/', ' ' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(x => x.Trim().TrimStart('*'))
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Select(x => x.StartsWith(".") ? x : "." + x));

            string statusClass = "status-default";
            string statusText = "Chưa nộp";

            if (latestSub != null)
            {
                if (latestSub.Status == SubmissionStatus.Approved)
                {
                    statusClass = "status-approved";
                    statusText = "Đã duyệt";
                }
                else if (latestSub.Status == SubmissionStatus.Rejected)
                {
                    statusClass = "status-rejected";
                    statusText = "Từ chối";
                }
                else
                {
                    statusClass = "status-pending";
                    statusText = "Đang chờ";
                }
            }
            else if (isExpired)
            {
                statusClass = "status-expired";
                statusText = "Quá hạn";
            }
            else if (!item.AllowSubmission)
            {
                statusClass = "status-default";
                statusText = "Chưa mở nộp";
            }

            <div class="tl-card">

                <!-- HEADER ROW -->
                <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">

                    <div class="d-flex align-items-center gap-3">

                        <div class="date-box">
                            <span class="month">THÁNG @item.Date.Month</span>
                            <span class="day">@item.Date.Day</span>
                        </div>

                        <div>
                            <div class="milestone-label">
                                <span class="milestone-dot"></span>
                                Mốc thời gian
                            </div>

                            <h3 class="tl-title">@item.Title</h3>

                            <p class="tl-desc">@item.Description</p>
                        </div>

                    </div>

                    <div class="d-flex align-items-center gap-2 flex-wrap">

                        <span class="status-badge @statusClass">
                            @statusText
                        </span>

                        <button type="button"
                                class="btn-toggle"
                                data-toggle-timeline data-target="@collapseId">

                            <span class="btn-text">Xem chi tiết</span>

                            <i class="bi bi-chevron-down"></i>

                        </button>

                    </div>

                </div>

                <!-- COLLAPSE -->
                <div id="@collapseId" class="tl-collapse-hidden">

                    <hr class="tl-divider" />

                    <!-- FORM -->
                    @if (canSubmit && (latestSub == null || latestSub.Status == SubmissionStatus.Rejected))
                    {
                        <div class="resubmit-box">

                            <div class="resubmit-title">
                                <i class="bi bi-cloud-arrow-up"></i>

                                @(latestSub == null
                                                        ? "Tải file báo cáo lần đầu"
                                                        : "Nộp lại báo cáo chỉnh sửa")
                                                                                  </div>

                            <form asp-action="SubmitTimeline"
                                  asp-controller="Student"
                                  method="post"
                                  enctype="multipart/form-data">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="timelineId"
                                       value="@item.Id" />

                                <div class="row g-2 align-items-center">

                                    <div class="col-12">
                                        <textarea name="content"
                                                  class="form-control timeline-submit-control"
                                                  rows="3"
                                                  maxlength="1000"
                                                  placeholder="Mô tả ngắn tiến độ đã thực hiện..."></textarea>
                                    </div>

                                    <div class="col-md-9">
                                        <input type="file"
                                               name="file"
                                               accept="@acceptTypes"
                                               class="form-control timeline-submit-control"
                                               required />
                                        <div class="text-muted mt-1 submit-format-note">
                                            Định dạng cho phép: @allowedTypes
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <button type="submit" class="btn-submit">
                                            @(latestSub == null
                                                                                ? "Nộp bài"
                                                                                : "Nộp bản mới")
                                </button>
                            </div>

                                </div>

                            </form>

                        </div>
                                }

                    <!-- HISTORY -->
                    @if (allSubmissions != null && allSubmissions.Any())
                    {
                        <div class="history-label">
                            Lịch sử nộp bài
                        </div>

                        <div class="d-flex flex-column gap-3">

                            @foreach (var sub in allSubmissions)
                            {
                                bool isLatest = (sub.Id == latestSub!.Id);

                                string iconClass =
                                sub.Status == SubmissionStatus.Approved ? "approved"
                                : sub.Status == SubmissionStatus.Rejected ? "rejected"
                                : "pending";

                                string subStatusClass =
                                sub.Status == SubmissionStatus.Approved ? "status-approved"
                                : sub.Status == SubmissionStatus.Rejected ? "status-rejected"
                                : "status-pending";

                                string subStatusText =
                                sub.Status == SubmissionStatus.Approved ? "Đã duyệt"
                                : sub.Status == SubmissionStatus.Rejected ? "Từ chối"
                                : "Đang chờ";

                                <div class="sub-item @(isLatest ? "is-latest" : "is-old")">

                                    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">

                                        <div class="d-flex align-items-center gap-3">

                                            <div class="sub-file-icon @iconClass">
                                                <i class="bi bi-file-earmark-text"></i>
                                            </div>

                                            <div>

                                                <div class="sub-date">

                                                    Bản nộp ngày @sub.SubmittedAt.ToString("dd/MM/yyyy")

                                                    @if (isLatest)
                                                    {
                                                        <span class="badge-latest">
                                                            Mới nhất
                                                        </span>
                                                    }

                                                </div>

                                                <div class="sub-time">
                                                    Gửi lúc @sub.SubmittedAt.ToString("HH:mm")
                                                </div>

                                            </div>

                                        </div>

                                        <div class="d-flex align-items-center gap-2 flex-wrap">

                                            <span class="status-badge @subStatusClass">
                                                @subStatusText
                                            </span>

                                            @if (!string.IsNullOrWhiteSpace(sub.FilePath))
                                            {
                                                <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = sub.Id })"
                                                   target="_blank"
                                                   class="btn-view-file">

                                                    <i class="bi bi-eye"></i>

                                                    Xem file

                                                </a>
                                            }

                                        </div>

                                    </div>

                                    @if (sub.Status != SubmissionStatus.Pending)
                                    {
                                        <div class="review-section">

                                            <div class="d-flex flex-wrap gap-4">

                                                @if (sub.Score != null)
                                                {
                                                    <div>
                                                        <div class="review-meta-label">
                                                            Điểm số
                                                        </div>

                                                        <div class="review-value review-score">

                                                            @sub.Score / 10

                                                        </div>
                                                    </div>
                                                }

                                                <div class="flex-grow-1">

                                                    <div class="review-meta-label">
                                                        Nhận xét từ giảng viên
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(sub.Comment))
                                                    {
                                                        <div class="review-value">
                                                            "@sub.Comment"
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="review-value review-empty-comment">

                                                            Giảng viên chưa để lại lời nhắn

                                                        </div>
                                                    }

                                                </div>

                                            </div>

                                            @if (sub.ReviewedAt != null)
                                            {
                                                <div class="review-reviewed-at">
                                                    Đã xem lúc:
                                                    @sub.ReviewedAt?.ToString("HH:mm dd/MM/yyyy")
                                                </div>
                                            }

                                        </div>
                                    }

                                </div>
                            }

                        </div>
                    }
                    else if (isExpired)
                    {
                        <div class="expired-alert">

                            <i class="bi bi-clock-history"></i>

                            Đã quá hạn và không có dữ liệu nộp bài.

                        </div>
                    }

                </div>

            </div>
        }
        }

    </div>

</div>

@section Scripts {
    <script src="~/js/student/timeline.js" asp-append-version="true"></script>
}

