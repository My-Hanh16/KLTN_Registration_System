@model IEnumerable<KLTN_Registration_System.Models.Entities.Timeline>
@using KLTN_Registration_System.Models.Entities
@using KLTN_Registration_System.Models.Enums

@{
    Layout = "_LayoutStudent";
    var submissions = ViewBag.Submissions as List<TimelineSubmission>;
}

@section Styles {
    <style>

        body {
            background: #f5f7fb;
            font-family: "Inter", "Segoe UI", sans-serif;
        }

        .timeline-page {
            width: 100%;
            /* sửa ở đây */
            padding: 10px 24px 40px 6px;
            margin-left: -8px;
        }

        /* =========================================
                           HEADER
                ========================================= */

        .timeline-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 20px;
            margin-bottom: 26px;
            flex-wrap: wrap;
            margin-left: 0;
        }

            .timeline-header h2 {
                margin: -10px 0 0;
                font-size: 20px;
                font-weight: 800;
                color: #1e293b;
                display: flex;
                align-items: center;
                gap: 14px;
                letter-spacing: -.2px;
                line-height: 1.2;
            }

                .timeline-header h2 i {
                    width: 52px;
                    height: 52px;
                    border-radius: 18px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: linear-gradient(135deg,#4f46e5,#6366f1);
                    color: #fff;
                    font-size: 20px;
                    box-shadow: 0 12px 24px rgba(79,70,229,.18);
                }

            .timeline-header p {
                margin: 6px 0 0;
                color: #94a3b8;
                font-size: 13.5px;
                line-height: 1.7;
            }

        /* =========================================
                           CARD
                ========================================= */

        .tl-card {
            position: relative;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 28px;
            padding: 24px 26px;
            margin-bottom: 22px;
            transition: box-shadow 0.25s ease, transform 0.25s ease;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        }

            .tl-card:hover {
                box-shadow: 0 8px 24px rgba(43,78,255,0.07);
                transform: translateY(-1px);
                border-color: #dbe3f0;
            }

        /* =========================================
                           DATE BOX
                ========================================= */

        .date-box {
            width: 78px;
            height: 78px;
            min-width: 78px;
            border-radius: 22px;
            background: linear-gradient(135deg,#eef2ff,#e0e7ff);
            border: 1px solid #c7d2fe;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #4f46e5;
            flex-shrink: 0;
        }

            .date-box .month {
                font-size: 11px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: .7px;
                opacity: .85;
                line-height: 1;
                margin-bottom: 4px;
            }

            .date-box .day {
                font-size: 28px;
                font-weight: 800;
                line-height: 1;
            }

        /* =========================================
                           TITLE
                ========================================= */

        .milestone-label {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .7px;
            color: #94a3b8;
            margin-bottom: 6px;
        }

        .milestone-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #4f46e5;
        }

        .tl-title {
            font-size: 18px;
            font-weight: 800;
            color: #1e293b;
            margin: 0 0 4px;
            line-height: 1.45;
        }

        .tl-desc {
            font-size: 13.5px;
            color: #64748b;
            margin: 0;
            line-height: 1.7;
        }

        /* =========================================
                           STATUS
                ========================================= */

        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 8px 14px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .4px;
            white-space: nowrap;
        }

        .status-approved {
            background: #dcfce7;
            color: #15803d;
        }

        .status-rejected {
            background: #fee2e2;
            color: #dc2626;
        }

        .status-pending {
            background: #fef3c7;
            color: #b45309;
        }

        .status-default {
            background: #f1f5f9;
            color: #64748b;
        }

        .status-expired {
            background: #fee2e2;
            color: #dc2626;
        }

        /* =========================================
                           TOGGLE BUTTON
                ========================================= */

        .btn-toggle {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 11px 18px;
            border-radius: 14px;
            font-size: 13px;
            font-weight: 700;
            border: 1px solid #c7d2fe;
            background: #fff;
            color: #4f46e5;
            cursor: pointer;
            transition: .22s;
        }

            .btn-toggle:hover {
                background: #eef2ff;
                color: #4338ca;
            }

            .btn-toggle.active {
                background: linear-gradient(135deg,#4f46e5,#6366f1);
                border-color: transparent;
                color: #fff;
            }

            .btn-toggle i {
                font-size: 12px;
            }

        /* =========================================
                           COLLAPSE
                ========================================= */

        .tl-collapse-hidden {
            display: none !important;
        }

        .tl-collapse-visible {
            display: block !important;
            animation: fadeSlideDown .25s ease-out;
        }

        @@keyframes fadeSlideDown {

            from {
                opacity: 0;
                transform: translateY(-8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .tl-divider {
            border: none;
            border-top: 1px dashed #e2e8f0;
            margin: 22px 0;
        }

        /* =========================================
                           RESUBMIT BOX
                ========================================= */

        .resubmit-box {
            background: #fff8f8;
            border: 1px dashed #fca5a5;
            border-radius: 18px;
            padding: 18px;
            margin-bottom: 20px;
        }

        .resubmit-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .7px;
            color: #dc2626;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        /* =========================================
                           HISTORY
                ========================================= */

        .history-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: #94a3b8;
            margin-bottom: 14px;
        }

        .sub-item {
            background: #f8fafc;
            border: 1px solid #e8edf4;
            border-radius: 18px;
            padding: 18px;
            transition: .2s;
        }

            .sub-item.is-latest {
                border-color: #c7d2fe;
                background: #fafbff;
            }

            .sub-item.is-old {
                opacity: .82;
            }

        .sub-file-icon {
            width: 48px;
            height: 48px;
            min-width: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

            .sub-file-icon.approved {
                background: #dcfce7;
                color: #16a34a;
            }

            .sub-file-icon.rejected {
                background: #fee2e2;
                color: #dc2626;
            }

            .sub-file-icon.pending {
                background: #fef3c7;
                color: #b45309;
            }

        .sub-date {
            font-size: 14px;
            font-weight: 700;
            color: #1e293b;
            line-height: 1.5;
        }

        .sub-time {
            font-size: 12px;
            color: #94a3b8;
            margin-top: 2px;
        }

        .badge-latest {
            display: inline-flex;
            font-size: 10px;
            font-weight: 700;
            background: #eef2ff;
            color: #4f46e5;
            border-radius: 999px;
            padding: 3px 8px;
            margin-left: 8px;
            vertical-align: middle;
        }

        /* =========================================
                           REVIEW
                ========================================= */

        .review-section {
            border-top: 1px solid #eef2f7;
            margin-top: 16px;
            padding-top: 16px;
        }

        .review-meta-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #94a3b8;
            margin-bottom: 4px;
        }

        .review-value {
            font-size: 13.5px;
            color: #334155;
            line-height: 1.7;
        }

        .review-reviewed-at {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 10px;
            font-style: italic;
            text-align: right;
        }

        /* =========================================
                           BUTTONS
                ========================================= */

        .btn-view-file {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 700;
            color: #4338ca;
            border: 1px solid #c7d2fe;
            border-radius: 12px;
            padding: 8px 14px;
            text-decoration: none;
            background: #fff;
            transition: .2s;
        }

            .btn-view-file:hover {
                background: #eef2ff;
                color: #4338ca;
                border-color: #a5b4fc;
            }

        .btn-submit {
            width: 100%;
            padding: 11px 16px;
            font-size: 13px;
            font-weight: 700;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg,#dc2626,#ef4444);
            color: #fff;
            cursor: pointer;
            transition: .22s;
        }

            .btn-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 14px 26px rgba(220,38,38,.20);
            }

        /* =========================================
                           EXPIRED
                ========================================= */

        .expired-alert {
            background: #fff5f5;
            border: 1px solid #fecaca;
            border-radius: 16px;
            padding: 14px 16px;
            font-size: 13.5px;
            color: #dc2626;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* =========================================
                           MOBILE
                ========================================= */

        @@media(max-width:768px) {

            .timeline-header h2 {
                font-size: 18px;
            }

                .timeline-header h2 i {
                    width: 46px;
                    height: 46px;
                    font-size: 18px;
                }

            .tl-card {
                padding: 20px;
                border-radius: 24px;
            }

            .date-box {
                width: 66px;
                height: 66px;
                min-width: 66px;
            }

            .tl-title {
                font-size: 16px;
            }

            .tl-desc {
                font-size: 13px;
            }

            .btn-toggle {
                width: 100%;
                justify-content: center;
            }

            .sub-item .d-flex.justify-content-between {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 14px;
            }
        }
        /* FIX KHOẢNG TRẮNG BÊN PHẢI */

        .timeline-container {
            width: 100%;
            padding-right: 0;
            margin-right: -14px;
        }

        .tl-card {
            width: calc(100% + 14px);
        }

        /* nếu vẫn còn dư thì tăng lên */
        @@media(min - width:1200px) {
            .timeline-container

        {
            margin-right: -18px;
        }

        .tl-card {
            width: calc(100% + 18px);
        }

        }

    </style>
}

<div class="timeline-page">

    <!-- HEADER -->
    <div class="timeline-header">

        <div>
            <h2>
                Timeline Đồ Án
            </h2>

            <p>
                Theo dõi lộ trình, tiến độ và hoàn thành các mốc thời gian khóa luận tốt nghiệp.
            </p>
        </div>

    </div>

    <!-- TIMELINE -->
    <div class="timeline-container">

        @foreach (var item in Model)
        {
            var allSubmissions = submissions?
            .Where(x => x.TimelineId == item.Id)
            .OrderByDescending(x => x.SubmittedAt)
            .ToList();

            var latestSub = allSubmissions?.FirstOrDefault();

            var collapseId = "tl_" + item.Id;

            var now = DateTime.Now;
            bool isExpired = item.SubmissionDeadline.HasValue && item.SubmissionDeadline.Value < now;
            bool canSubmit = item.AllowSubmission && !isExpired;
            var allowedTypes = string.IsNullOrWhiteSpace(item.SubmissionType)
                ? "pdf, doc, docx, ppt, pptx, zip, rar, txt"
                : item.SubmissionType;
            var acceptTypes = string.Join(",", allowedTypes
                .Split(new[] { ',', ';', '|', '/', ' ' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(x => x.Trim().TrimStart('*'))
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Select(x => x.StartsWith(".") ? x : "." + x));

            string statusClass = "status-default";
            string statusText = "Chưa nộp";

            if (latestSub != null)
            {
                if (latestSub.Status == SubmissionStatus.Approved)
                {
                    statusClass = "status-approved";
                    statusText = "Đã duyệt";
                }
                else if (latestSub.Status == SubmissionStatus.Rejected)
                {
                    statusClass = "status-rejected";
                    statusText = "Từ chối";
                }
                else
                {
                    statusClass = "status-pending";
                    statusText = "Đang chờ";
                }
            }
            else if (isExpired)
            {
                statusClass = "status-expired";
                statusText = "Quá hạn";
            }
            else if (!item.AllowSubmission)
            {
                statusClass = "status-default";
                statusText = "Chưa mở nộp";
            }

            <div class="tl-card">

                <!-- HEADER ROW -->
                <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">

                    <div class="d-flex align-items-center gap-3">

                        <div class="date-box">
                            <span class="month">THÁNG @item.Date.Month</span>
                            <span class="day">@item.Date.Day</span>
                        </div>

                        <div>
                            <div class="milestone-label">
                                <span class="milestone-dot"></span>
                                Mốc thời gian
                            </div>

                            <h3 class="tl-title">@item.Title</h3>

                            <p class="tl-desc">@item.Description</p>
                        </div>

                    </div>

                    <div class="d-flex align-items-center gap-2 flex-wrap">

                        <span class="status-badge @statusClass">
                            @statusText
                        </span>

                        <button type="button"
                                class="btn-toggle"
                                onclick="toggleTimeline('@collapseId', this)">

                            <span class="btn-text">Xem chi tiết</span>

                            <i class="bi bi-chevron-down"></i>

                        </button>

                    </div>

                </div>

                <!-- COLLAPSE -->
                <div id="@collapseId" class="tl-collapse-hidden">

                    <hr class="tl-divider" />

                    <!-- FORM -->
                    @if (canSubmit && (latestSub == null || latestSub.Status == SubmissionStatus.Rejected))
                    {
                        <div class="resubmit-box">

                            <div class="resubmit-title">
                                <i class="bi bi-cloud-arrow-up"></i>

                                @(latestSub == null
                                                        ? "Tải file báo cáo lần đầu"
                                                        : "Nộp lại báo cáo chỉnh sửa")
                                                                                  </div>

                            <form asp-action="SubmitTimeline"
                                  method="post"
                                  enctype="multipart/form-data">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="timelineId"
                                       value="@item.Id" />

                                <div class="row g-2 align-items-center">

                                    <div class="col-md-9">
                                        <input type="file"
                                               name="file"
                                               accept="@acceptTypes"
                                               class="form-control"
                                               style="border-radius:12px;font-size:13px;"
                                               required />
                                        <div class="text-muted mt-1" style="font-size:12px;">
                                            Định dạng cho phép: @allowedTypes
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <button type="submit" class="btn-submit">
                                            @(latestSub == null
                                                                                ? "Nộp bài"
                                                                                : "Nộp bản mới")
                                </button>
                            </div>

                                </div>

                            </form>

                        </div>
                                }

                    <!-- HISTORY -->
                    @if (allSubmissions != null && allSubmissions.Any())
                    {
                        <div class="history-label">
                            Lịch sử nộp bài
                        </div>

                        <div class="d-flex flex-column gap-3">

                            @foreach (var sub in allSubmissions)
                            {
                                bool isLatest = (sub.Id == latestSub!.Id);

                                string iconClass =
                                sub.Status == SubmissionStatus.Approved ? "approved"
                                : sub.Status == SubmissionStatus.Rejected ? "rejected"
                                : "pending";

                                string subStatusClass =
                                sub.Status == SubmissionStatus.Approved ? "status-approved"
                                : sub.Status == SubmissionStatus.Rejected ? "status-rejected"
                                : "status-pending";

                                string subStatusText =
                                sub.Status == SubmissionStatus.Approved ? "Đã duyệt"
                                : sub.Status == SubmissionStatus.Rejected ? "Từ chối"
                                : "Đang chờ";

                                <div class="sub-item @(isLatest ? "is-latest" : "is-old")">

                                    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">

                                        <div class="d-flex align-items-center gap-3">

                                            <div class="sub-file-icon @iconClass">
                                                <i class="bi bi-file-earmark-text"></i>
                                            </div>

                                            <div>

                                                <div class="sub-date">

                                                    Bản nộp ngày @sub.SubmittedAt.ToString("dd/MM/yyyy")

                                                    @if (isLatest)
                                                    {
                                                        <span class="badge-latest">
                                                            Mới nhất
                                                        </span>
                                                    }

                                                </div>

                                                <div class="sub-time">
                                                    Gửi lúc @sub.SubmittedAt.ToString("HH:mm")
                                                </div>

                                            </div>

                                        </div>

                                        <div class="d-flex align-items-center gap-2 flex-wrap">

                                            <span class="status-badge @subStatusClass">
                                                @subStatusText
                                            </span>

                                            <a href="@Url.Action("DownloadSubmissionFile", "Timeline", new { submissionId = sub.Id })"
                                               target="_blank"
                                               class="btn-view-file">

                                                <i class="bi bi-eye"></i>

                                                Xem file

                                            </a>

                                        </div>

                                    </div>

                                    @if (sub.Status != SubmissionStatus.Pending)
                                    {
                                        <div class="review-section">

                                            <div class="d-flex flex-wrap gap-4">

                                                @if (sub.Score != null)
                                                {
                                                    <div>
                                                        <div class="review-meta-label">
                                                            Điểm số
                                                        </div>

                                                        <div class="review-value"
                                                             style="color:#4f46e5;font-weight:700;">

                                                            @sub.Score / 10

                                                        </div>
                                                    </div>
                                                }

                                                <div class="flex-grow-1">

                                                    <div class="review-meta-label">
                                                        Nhận xét từ giảng viên
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(sub.Comment))
                                                    {
                                                        <div class="review-value">
                                                            "@sub.Comment"
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="review-value"
                                                             style="color:#94a3b8;font-style:italic;">

                                                            Giảng viên chưa để lại lời nhắn

                                                        </div>
                                                    }

                                                </div>

                                            </div>

                                            @if (sub.ReviewedAt != null)
                                            {
                                                <div class="review-reviewed-at">
                                                    Đã xem lúc:
                                                    @sub.ReviewedAt?.ToString("HH:mm dd/MM/yyyy")
                                                </div>
                                            }

                                        </div>
                                    }

                                </div>
                            }

                        </div>
                    }
                    else if (isExpired)
                    {
                        <div class="expired-alert">

                            <i class="bi bi-clock-history"></i>

                            Đã quá hạn và không có dữ liệu nộp bài.

                        </div>
                    }

                </div>

            </div>
        }

    </div>

</div>

@section Scripts {

    <script>

        function toggleTimeline(id, btn) {

            const content = document.getElementById(id);

            const icon = btn.querySelector('i');

            const text = btn.querySelector('.btn-text');

            const isHidden =
                content.classList.contains('tl-collapse-hidden');

            if (isHidden) {

                content.classList.replace(
                    'tl-collapse-hidden',
                    'tl-collapse-visible'
                );

                btn.classList.add('active');

                icon.classList.replace(
                    'bi-chevron-down',
                    'bi-chevron-up'
                );

                text.textContent = 'Thu gọn';

            } else {

                content.classList.replace(
                    'tl-collapse-visible',
                    'tl-collapse-hidden'
                );

                btn.classList.remove('active');

                icon.classList.replace(
                    'bi-chevron-up',
                    'bi-chevron-down'
                );

                text.textContent = 'Xem chi tiết';
            }
        }

    </script>

}
