@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<KLTN_Registration_System.Models.Entities.Notification>

@{
    Layout = "~/Views/Shared/_LayoutStudent.cshtml";
    ViewData["Title"] = "Thông báo";

    int totalCount = Model.TotalItemCount;
    int unreadCount = ViewBag.TotalUnreadCount is int totalUnread ? totalUnread : Model.Count(n => !n.IsRead);

    int topicCount = ViewBag.TopicNotificationCount is int totalTopic ? totalTopic : Model.Count(n =>
        n.Type == "TopicApproved"
        || n.Type == "TopicRejected"
        || n.Type == "NewRegistration"
        || n.Type == "RegistrationApproved"
        || n.Type == "RegistrationRejected"
        || (n.Title != null &&
           (n.Title.Contains("duyệt")
           || n.Title.Contains("từ chối"))));

    int sysCount = totalCount - topicCount;

    string SafeNotificationUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        url = url.Trim();
        return url.StartsWith("/") && !url.StartsWith("//") && !url.Contains("\\") ? url : "";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/student/notifications.css" asp-append-version="true" />
}


<div class="notif-page">

    <!-- HEADER -->
    <div class="nh">

        <div class="nh-left">

            <h2>
                Thông báo

                @if (unreadCount > 0)
                {
                    <span class="upill">@unreadCount</span>
                }
            </h2>

            <p>
                Theo dõi trạng thái đề tài, tiến độ đăng ký và các thông báo mới nhất từ hệ thống KLTN Portal.
            </p>

        </div>

        @if (unreadCount > 0)
        {
            <form asp-controller="Student"
                  asp-action="MarkAllRead"
                  method="post">

                @Html.AntiForgeryToken()

                <button type="submit" class="mark-btn">
                    ✓ Đánh dấu tất cả đã đọc
                </button>

            </form>
        }

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="notif-alert success">
            <i class="fa-solid fa-circle-check"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="notif-alert error">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    <!-- FILTER -->
    <div class="filter-row" id="filterRow">

        <button class="ftab active"
                data-filter="all">

            Tất cả
            <span class="fcnt">@totalCount</span>

        </button>

        <button class="ftab"
                data-filter="unread">

            Chưa đọc
            <span class="fcnt">@unreadCount</span>

        </button>

        <button class="ftab"
                data-filter="topic">

            Đề tài
            <span class="fcnt">@topicCount</span>

        </button>

        <button class="ftab"
                data-filter="system">

            Hệ thống
            <span class="fcnt">@sysCount</span>

        </button>

    </div>

    <!-- LIST -->
    <div id="notifList">

        @if (!Model.Any())
        {
            <div class="notif-empty">

                <i class="fa-regular fa-bell-slash"></i>

                <h4>Chưa có thông báo</h4>

                <p>
                    Hiện tại bạn chưa có thông báo nào từ hệ thống.
                </p>

            </div>
        }
        else
        {
            <div class="notif-grid" id="notification-list">

                @foreach (var n in Model)
                {
                    string iconTag;
                    string cat;

                    switch (n.Type ?? "")
                    {
                        case "TopicApproved":
                            iconTag = "fa-circle-check";
                            cat = "topic";
                            break;

                        case "TopicRejected":
                            iconTag = "fa-circle-xmark";
                            cat = "topic";
                            break;

                        case "NewRegistration":
                            iconTag = "fa-file-signature";
                            cat = "topic";
                            break;

                        case "Deadline":
                            iconTag = "fa-clock";
                            cat = "system";
                            break;

                        default:

                            bool isTopicWord =
                            (n.Title?.Contains("duyệt") == true)
                            || (n.Title?.Contains("từ chối") == true);

                            if (isTopicWord && n.Title!.Contains("duyệt"))
                            {
                                iconTag = "fa-circle-check";
                                cat = "topic";
                            }
                            else if (isTopicWord)
                            {
                                iconTag = "fa-circle-xmark";
                                cat = "topic";
                            }
                            else
                            {
                                iconTag = "fa-bell";
                                cat = "system";
                            }

                            break;
                    }

                    string unreadCls = n.IsRead ? "" : "unread";

                    string url = SafeNotificationUrl(n.RedirectUrl);
                    string openUrl = Url.Action("OpenNotification", "Student", new { id = n.Id }) ?? url;

                    string timeStr =
                    (DateTime.Now - n.CreatedAt).TotalHours < 24
                    ? n.CreatedAt.ToString("HH:mm") + " hôm nay"
                    : n.CreatedAt.ToString("HH:mm")
                    + " • "
                    + n.CreatedAt.ToString("dd/MM/yyyy");

                    <div class="nc @unreadCls"
                         data-cat="@cat"
                         data-read="@(n.IsRead ? "1" : "0")">

                        <div class="ni">
                            <i class="fa-solid @iconTag"></i>
                        </div>

                        <div class="nc-body">

                            <div class="nc-top">

                                <div class="nc-title">

                                    @n.Title

                                    @if (!n.IsRead)
                                    {
                                        <span class="udot"></span>
                                    }

                                </div>

                                <div class="nc-time">
                                    @timeStr
                                </div>

                            </div>

                            <p class="nc-text">
                                @n.Content
                            </p>

                            @if (!string.IsNullOrWhiteSpace(url))
                            {
                                <a href="@openUrl" class="nc-link">

                                    Xem chi tiết

                                    <i class="fa-solid fa-arrow-right nc-link-icon"></i>

                                </a>
                            }

                        </div>

                    </div>
                }

            </div>
        }

    </div>

    <!-- EMPTY FILTER -->
    <div id="filteredEmpty"
         class="notif-empty"
         hidden>

        <i class="fa-regular fa-bell-slash"></i>

        <h4>Không có dữ liệu</h4>

        <p id="filteredMsg">
            Không có thông báo nào.
        </p>

    </div>

    <!-- PAGINATION -->
    <div class="pagination-wrap">

        @Html.PagedListPager(
        Model,
        page => Url.Action("Notifications", new { page }),
                new PagedListRenderOptions
                {
                    DisplayLinkToFirstPage = PagedListDisplayMode.Never,
                    DisplayLinkToLastPage = PagedListDisplayMode.Never,
                    DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                    DisplayLinkToNextPage = PagedListDisplayMode.Always,
                    MaximumPageNumbersToDisplay = 5,
                    UlElementClasses = new[] { "pagination" },
                    LiElementClasses = new[] { "page-item" },
                    PageClasses = new[] { "page-link" }
                })

    </div>

</div>

@section Scripts {
    <script src="~/js/student/notifications.js" asp-append-version="true"></script>
}

