@model IEnumerable<KLTN_Registration_System.Models.Entities.Setting>
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Cài đặt hệ thống";

    var settings = Model.ToDictionary(s => s.Name, s => s);

    string GetVal(string name, string fallback = "")
        => settings.ContainsKey(name) ? settings[name].Value : fallback;
    string GetDateVal(string name, string fallback)
        => DateTime.TryParse(GetVal(name), out var dt) ? dt.ToString("yyyy-MM-dd") : fallback;
    string GetDateTimeVal(string name)
        => DateTime.TryParse(GetVal(name), out var dt) ? dt.ToString("yyyy-MM-ddTHH:mm") : GetVal(name);

    var majors = ViewBag.Majors as IEnumerable<KLTN_Registration_System.Models.Entities.Major>
                 ?? Enumerable.Empty<KLTN_Registration_System.Models.Entities.Major>();
    var periods = ViewBag.RegistrationPeriods as IEnumerable<KLTN_Registration_System.Models.Entities.RegistrationPeriod>
                  ?? Enumerable.Empty<KLTN_Registration_System.Models.Entities.RegistrationPeriod>();
    var activePeriod = ViewBag.ActivePeriod as KLTN_Registration_System.Models.Entities.RegistrationPeriod;

    int topicTotal = ViewBag.TopicTotal ?? 0;
    int topicRegistrationOpen = ViewBag.TopicRegistrationOpen ?? 0;
    int topicRegistrationReady = ViewBag.TopicRegistrationReady ?? 0;
    int eligibleStudentCount = ViewBag.EligibleStudentCount ?? 0;
    bool topicRegOpen = GetVal("IsTopicRegistrationOpen", "false") == "true";
    string SuggestNextAcademicYear()
    {
        var parts = (activePeriod?.AcademicYear ?? "").Split('-', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 2 && int.TryParse(parts[0], out var start) && int.TryParse(parts[1], out var end))
        {
            return $"{start + 1}-{end + 1}";
        }

        return $"{DateTime.Now.Year}-{DateTime.Now.Year + 1}";
    }

    string nextAcademicYear = SuggestNextAcademicYear();
    string nextSemesterCode = activePeriod?.SemesterCode == "HK1" ? "HK2" : "HK1";
    string semesterStartValue = activePeriod?.SemesterStart.ToString("yyyy-MM-dd")
        ?? GetDateVal("Semester_Start", DateTime.Today.ToString("yyyy-MM-dd"));
    string semesterEndValue = activePeriod?.SemesterEnd.ToString("yyyy-MM-dd")
        ?? GetDateVal("Semester_End", DateTime.Today.AddMonths(4).ToString("yyyy-MM-dd"));
    string registrationStartValue = activePeriod?.RegistrationOpenAt.ToString("yyyy-MM-ddTHH:mm")
        ?? GetDateTimeVal("Registration_Start");
    string registrationEndValue = activePeriod?.RegistrationCloseAt.ToString("yyyy-MM-ddTHH:mm")
        ?? GetDateTimeVal("Registration_End");
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/settings.css" asp-append-version="true" />
}

<!-- ════════════════════════════════
     PAGE HEADER
════════════════════════════════ -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title">Cài đặt hệ thống</h2>
        <p class="page-sub">Quản lý các thông số vận hành và quy trình học thuật toàn khóa.</p>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/settings.js" asp-append-version="true"></script>
}

<div class="s-card">
    <div class="s-card-head">
        <div class="s-head-left">
            <div class="s-ico green"><i class="fa-solid fa-calendar-days"></i></div>
            <div>
                <div class="s-head-title">Đợt đăng ký khóa luận</div>
                <div class="s-head-sub">
                    Đợt hiện hành:
                    <b class="strong-text">@(activePeriod?.Name ?? "Chưa có")</b>
                </div>
            </div>
        </div>
        <span class="s-head-count">
            <b>@periods.Count()</b> đợt
        </span>
    </div>
    <div class="s-card-body">
        <form asp-action="CreateRegistrationPeriod" method="post" class="period-create-form">
            @Html.AntiForgeryToken()
            <div class="period-create-grid">
                <div class="f-field">
                    <label class="f-label">Năm học</label>
                    <input type="text" name="academicYear" class="f-input-sm" required value="@nextAcademicYear" placeholder="2026-2027" />
                </div>
                <div class="f-field">
                    <label class="f-label">Học kỳ</label>
                    <select name="semesterCode" class="f-select">
                        <option value="HK1" selected="@(nextSemesterCode == "HK1")">HK1</option>
                        <option value="HK2" selected="@(nextSemesterCode == "HK2")">HK2</option>
                        <option value="HK3">HK3</option>
                    </select>
                </div>
                <div class="form-bottom-cell">
                    <input type="hidden" name="setActive" value="true" />
                    <button type="submit" class="btn btn-primary btn-create-period">
                        <i class="fa-solid fa-plus"></i> Tạo
                    </button>
                </div>
            </div>
        </form>

        @if (periods.Any())
        {
            <div class="period-list">
                @foreach (var period in periods)
                {
                    <form asp-action="SetActiveRegistrationPeriod" method="post">
                        @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@period.Id" />
                        <button type="submit"
                                disabled="@period.IsActive"
                                data-confirm-message="Chuyển đợt hiện hành sang @period.Name? Các trang quản lý sẽ dùng dữ liệu của đợt này."
                                class="btn-sm @(period.IsActive ? "blue" : "ghost")">
                            @(period.IsActive ? "Đang dùng: " : "")@period.Name
                        </button>
                    </form>
                }
            </div>
        }
    </div>
</div>

<form asp-action="SaveSettings" method="post" id="settingsForm">
    @Html.AntiForgeryToken()

    <div class="settings-grid">

        <div class="s-card">
            <div class="s-card-head">
                <div class="s-head-left">
                    <div class="s-ico blue"><i class="fa-solid fa-door-open"></i></div>
                    <div>
                        <div class="s-head-title">Quản lý đăng ký đề tài</div>
                        <div class="s-head-sub">Kiểm soát thời gian và trạng thái mở / đóng đăng ký đề tài</div>
                    </div>
                </div>
            </div>

            <div class="s-card-body">
                <div class="info-box info-box--spaced">
                    <div class="info-box-left">
                        <div class="info-box-title">Mở đăng ký đề tài hàng loạt</div>
                        <div class="info-box-desc">Khi bật, hệ thống mở đăng ký cho các đề tài đã duyệt và chưa đủ sinh viên.</div>
                        <div class="info-chips">
                            <span class="info-chip">SV đủ điều kiện: <b>@eligibleStudentCount</b></span>
                            <span class="info-chip">Tổng đã duyệt: <b>@topicTotal</b></span>
                            <span class="info-chip">Đang mở: <b>@topicRegistrationOpen</b></span>
                            <span class="info-chip">Sẵn sàng: <b>@topicRegistrationReady</b></span>
                        </div>
                    </div>

                    <div class="toggle-wrap">
                        <span class="toggle-label @(topicRegOpen ? "on" : "off")">
                            @(topicRegOpen ? "ĐANG MỞ" : "ĐANG ĐÓNG")
                        </span>
                        <label class="toggle green">
                            <input type="hidden" name="names" value="IsTopicRegistrationOpen" />
                            <input type="hidden" name="values_IsTopicRegistrationOpen" value="false" />
                            <input type="checkbox" name="values_IsTopicRegistrationOpen" value="true"
                                   @(topicRegOpen ? "checked" : "")
                                   class="js-toggle-status" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>

                <div class="f-grid-2 form-section-spaced">
                    <div class="f-field">
                        <label class="f-label">Ngày bắt đầu học kỳ</label>
                        <input type="hidden" name="names" value="Semester_Start" />
                        <input type="date" name="values_Semester_Start" class="f-input"
                               value="@semesterStartValue" />
                    </div>
                    <div class="f-field">
                        <label class="f-label">Ngày kết thúc học kỳ</label>
                        <input type="hidden" name="names" value="Semester_End" />
                        <input type="date" name="values_Semester_End" class="f-input"
                               value="@semesterEndValue" />
                    </div>
                    <div class="f-field">
                        <label class="f-label">Mở đăng ký đề tài</label>
                        <input type="hidden" name="names" value="Registration_Start" />
                        <input type="datetime-local" name="values_Registration_Start" class="f-input"
                               value="@registrationStartValue" />
                    </div>
                    <div class="f-field">
                        <label class="f-label">Đóng đăng ký đề tài</label>
                        <input type="hidden" name="names" value="Registration_End" />
                        <input type="datetime-local" name="values_Registration_End" class="f-input"
                               value="@registrationEndValue" />
                    </div>
                </div>

                <div class="form-actions-right">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-floppy-disk"></i> Lưu tất cả thay đổi
                    </button>
                </div>
            </div>
        </div>

        <div class="settings-sidebar">
            <div class="s-card">
                <div class="s-card-head">
                    <div class="s-head-left">
                        <div class="s-ico indigo"><i class="fa-solid fa-user-gear"></i></div>
                        <div>
                            <div class="s-head-title">Quản lý tài khoản</div>
                        </div>
                    </div>
                </div>
                <div class="s-card-body quick-actions-body">
                    <a asp-action="StudentManagement" asp-controller="Admin" class="qa-btn slate">
                        <i class="fa-solid fa-users-gear"></i> Quản lý sinh viên
                    </a>
                    <a asp-action="ImportUsers" asp-controller="Admin" asp-route-role="Student" class="qa-btn slate">
                        <i class="fa-solid fa-file-arrow-up"></i> Nhập danh sách SV
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="s-card">
    <div class="s-card-head">
        <div class="s-head-left">
            <div class="s-ico purple"><i class="fa-solid fa-graduation-cap"></i></div>
            <div>
                <div class="s-head-title">Quản lý chuyên ngành</div>
                <div class="s-head-sub">Các chuyên ngành dùng để lọc đề tài, hồ sơ sinh viên và import dữ liệu.</div>
            </div>
        </div>
        <span class="s-head-count">
            <b>@majors.Count()</b> chuyên ngành
        </span>
    </div>

    <div class="s-card-body">

        <form asp-action="CreateMajor" method="post">
            @Html.AntiForgeryToken()
            <div class="add-major-row">
                <div>
                    <label class="add-major-label">Tên chuyên ngành <span class="required-mark">*</span></label>
                    <input type="text" name="name" required maxlength="150" class="f-input-sm"
                           placeholder="Công nghệ phần mềm" />
                </div>
                <div>
                    <label class="add-major-label">Mã</label>
                    <input type="text" name="majorCode" maxlength="30" class="f-input-sm text-uppercase"
                           placeholder="CNPM" />
                </div>
                <div>
                    <label class="add-major-label">Khoa</label>
                    <input type="text" name="facultyName" maxlength="150" class="f-input-sm"
                           placeholder="Công nghệ thông tin" />
                </div>
                <div>
                    <label class="add-major-label">Mô tả</label>
                    <input type="text" name="description" maxlength="300" class="f-input-sm"
                           placeholder="Ghi chú ngắn (tuỳ chọn)" />
                </div>
                <div></div>
                <div class="form-bottom-cell">
                    <button type="submit" class="btn btn-primary btn-add-major">
                        <i class="fa-solid fa-plus"></i> Thêm
                    </button>
                </div>
            </div>
        </form>

        @if (majors.Any())
        {
            <div class="major-head">
                <div>Tên chuyên ngành</div>
                <div>Mã</div>
                <div>Khoa</div>
                <div>Mô tả</div>
                <div>Trạng thái</div>
                <div class="text-right">Thao tác</div>
            </div>

            @foreach (var major in majors)
            {
                <form asp-action="UpdateMajor" method="post" class="major-row">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@major.Id" />

                    <input type="text" name="name" value="@major.Name"
                           required maxlength="150" placeholder="Tên chuyên ngành" />

                    <input type="text" name="majorCode" value="@major.MajorCode"
                           maxlength="30" placeholder="Mã" class="text-uppercase" />

                    <input type="text" name="facultyName" value="@major.FacultyName"
                           maxlength="150" placeholder="Khoa" />

                    <input type="text" name="description" value="@major.Description"
                           maxlength="300" placeholder="Mô tả" />

                    <div>
                        <label class="chk-wrap">
                            <input type="checkbox" name="isActive" value="true"
                                   @(major.IsActive ? "checked" : "") />
                            <div class="major-status">
                                <span class="status-pip @(major.IsActive ? "active" : "hidden")"></span>
                                <span class="major-status-txt @(major.IsActive ? "active" : "hidden")">
                                    @(major.IsActive ? "Dùng" : "Ẩn")
                                </span>
                            </div>
                        </label>
                    </div>

                    <div class="major-row-actions">
                        <button type="submit" class="btn-sm dark" title="Lưu thay đổi">
                            <i class="fa-solid fa-floppy-disk"></i> Lưu
                        </button>
                        <button type="submit" formaction="@Url.Action("ToggleMajor", "Admin")"
                                class="btn-sm ghost" title="@(major.IsActive ? "Ẩn" : "Bật")">
                            @(major.IsActive ? "Ẩn" : "Bật")
                        </button>
                        <button type="submit" formaction="@Url.Action("DeleteMajor", "Admin")"
                                data-confirm-message="Xóa chuyên ngành «@major.Name»? Nếu đã có dữ liệu liên quan, hệ thống sẽ chỉ ẩn."
                                class="btn-sm danger" title="Xóa">
                            <i class="fa-solid fa-trash delete-icon"></i>
                        </button>
                    </div>
                </form>
            }
        }
        else
        {
            <div class="empty-major">
                <i class="fa-regular fa-folder-open empty-major-icon"></i>
                Chưa có chuyên ngành nào. Thêm chuyên ngành đầu tiên ở trên.
            </div>
        }
    </div>
</div>

