@model IEnumerable<KLTN_Registration_System.Models.Entities.Setting>
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Cài đặt hệ thống";
    
    // Tạo Dictionary để truy xuất nhanh theo tên cài đặt
    var settings = Model.ToDictionary(s => s.Name, s => s);
    
    // Hàm Helper để lấy giá trị hoặc trả về rỗng nếu chưa có trong DB
    string GetVal(string name, string fallback = "") => settings.ContainsKey(name) ? settings[name].Value : fallback;
    string GetDateVal(string name, string fallback) => DateTime.TryParse(GetVal(name), out var dt)
        ? dt.ToString("yyyy-MM-dd")
        : fallback;
    string GetDateTimeVal(string name) => DateTime.TryParse(GetVal(name), out var dt)
        ? dt.ToString("yyyy-MM-ddTHH:mm")
        : GetVal(name);
    var majors = ViewBag.Majors as IEnumerable<KLTN_Registration_System.Models.Entities.Major>
                 ?? Enumerable.Empty<KLTN_Registration_System.Models.Entities.Major>();
}

<!-- Chèn link CSS Tailwind và Material Symbols nếu _Layout chưa có -->
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@700;800&family=Inter:wght@400;600&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@400,0..1" rel="stylesheet" />

<main class="flex-1 min-h-screen flex flex-col bg-slate-50/50">
    <div class="p-10 space-y-8">
        @if (TempData["Success"] != null)
        {
            <div class="max-w-6xl mx-auto mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-2xl flex items-center gap-3">
                <span class="material-symbols-outlined">check_circle</span>
                <span class="font-bold">@TempData["Success"]</span>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="max-w-6xl mx-auto mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-2xl flex items-center gap-3">
                <span class="material-symbols-outlined">error</span>
                <span class="font-bold">@TempData["Error"]</span>
            </div>
        }
        <form asp-action="SaveSettings" method="post">
            @Html.AntiForgeryToken()

            <div class="max-w-6xl mx-auto">
                <!-- Header -->
                <div class="flex justify-between items-end mb-8">
                    <div>
                        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-2">Cấu hình hệ thống</h2>
                        <p class="text-slate-500">Quản lý các thông số vận hành và quy trình học thuật toàn khóa.</p>
                    </div>
                    <div class="flex gap-3">
                        <button type="button" class="px-5 py-2.5 rounded-xl bg-white text-slate-700 border border-slate-200 font-semibold text-sm hover:bg-slate-50 transition-all">Sao lưu dữ liệu</button>
                        <button type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white font-bold text-sm shadow-lg shadow-blue-200 hover:bg-blue-700 active:scale-[0.98] transition-all">
                            Lưu tất cả thay đổi
                        </button>
                    </div>
                </div>

                <!-- Bento Grid -->
                <div class="grid grid-cols-12 gap-6">
                    
                    <!-- 1. Quản lý cổng đăng ký -->
                    <div class="col-span-12 md:col-span-8 bg-white rounded-2xl p-8 shadow-sm border border-slate-100">
                        <div class="flex items-center justify-between mb-8">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600">
                                    <span class="material-symbols-outlined text-3xl">door_open</span>
                                </div>
                                <div>
                                    <h3 class="text-lg font-bold">Quản lý cổng đăng ký</h3>
                                    <p class="text-xs text-slate-500">Kiểm soát trạng thái mở/đóng của cổng portal</p>
                                </div>
                            </div>

                            <label class="relative inline-flex items-center cursor-pointer">

                                <input type="hidden" name="names" value="IsPortalOpen" />

                                <!-- fallback false -->
                                <input type="hidden" name="values_IsPortalOpen" value="false" />

                                <!-- checkbox -->
                                <input type="checkbox"
                                       name="values_IsPortalOpen"
                                       value="true"
                                       class="sr-only peer"
                                       @(GetVal("IsPortalOpen") == "true" ? "checked" : "") />

                                <div class="w-14 h-7 bg-slate-200 peer-focus:outline-none rounded-full
                peer peer-checked:after:translate-x-full
                after:content-[''] after:absolute after:top-[2px]
                after:start-[2px] after:bg-white after:rounded-full
                after:h-6 after:w-6 after:transition-all
                peer-checked:bg-blue-600">
                                </div>

                                <span class="ms-3 text-sm font-bold text-blue-600">
                                    @(GetVal("IsPortalOpen") == "true"
                                                                        ? "ĐANG MỞ"
                                                                        : "ĐANG ĐÓNG")
                                </span>
                            </label>
                        </div>

                        <div class="grid grid-cols-2 gap-8">
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Ngày bắt đầu học kỳ</label>
                                <input type="hidden" name="names" value="Semester_Start" />
                                <input type="date" name="values_Semester_Start" value="@GetDateVal("Semester_Start", DateTime.Today.ToString("yyyy-MM-dd"))" class="w-full bg-slate-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500/20" />
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Ngày kết thúc học kỳ</label>
                                <input type="hidden" name="names" value="Semester_End" />
                                <input type="date" name="values_Semester_End" value="@GetDateVal("Semester_End", DateTime.Today.AddMonths(4).ToString("yyyy-MM-dd"))" class="w-full bg-slate-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500/20" />
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Mở đăng ký đề tài</label>
                                <input type="hidden" name="names" value="Registration_Start" />
                                <input type="datetime-local" name="values_Registration_Start" value="@GetDateTimeVal("Registration_Start")" class="w-full bg-slate-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500/20" />
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Đóng đăng ký đề tài</label>
                                <input type="hidden" name="names" value="Registration_End" />
                                <input type="datetime-local" name="values_Registration_End" value="@GetDateTimeVal("Registration_End")" class="w-full bg-slate-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500/20" />
                            </div>
                        </div>
                    </div>

                    <!-- 2. Quản lý tài khoản nhanh -->
                    <div class="col-span-12 md:col-span-4 bg-white rounded-2xl p-8 shadow-sm border border-slate-100 flex flex-col justify-between">
                         <div class="flex items-center gap-4 mb-6">
                            <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600">
                                <span class="material-symbols-outlined text-3xl">manage_accounts</span>
                            </div>
                            <h3 class="text-lg font-bold">Quản lý tài khoản</h3>
                        </div>
                        <div class="space-y-3">
                            <button type="button" class="w-full py-3 bg-slate-50 text-slate-700 font-semibold text-sm rounded-xl hover:bg-slate-100 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-lg">lock_reset</span> Reset mật khẩu hàng loạt
                            </button>
                            <button type="button" class="w-full py-3 bg-red-50 text-red-600 font-semibold text-sm rounded-xl hover:bg-red-100 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-lg">no_accounts</span> Khóa toàn bộ sinh viên
                            </button>
                        </div>
                    </div>

                    <!-- 3. Quy định & Ràng buộc -->
                    <div class="col-span-12 md:col-span-5 bg-white rounded-2xl p-8 shadow-sm border border-slate-100">
                        <div class="flex items-center gap-4 mb-8">
                             <div class="w-12 h-12 rounded-xl bg-orange-50 flex items-center justify-center text-orange-600">
                                <span class="material-symbols-outlined text-3xl">rule</span>
                            </div>
                            <h3 class="text-lg font-bold">Quy định & Ràng buộc</h3>
                        </div>
                        <div class="space-y-6">
                             <div class="space-y-2">
                                <div class="flex justify-between items-center">
                                    <label class="text-sm font-semibold">SV tối đa / đề tài</label>
                                    <span class="text-blue-600 font-bold text-lg">@GetVal("Max_Student_Per_Topic", "3")</span>
                                </div>
                                <input type="hidden" name="names" value="Max_Student_Per_Topic" />
                                <input type="range" name="values_Max_Student_Per_Topic" min="1" max="5" value="@GetVal("Max_Student_Per_Topic", "3")" class="w-full h-1.5 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-blue-600" />
                            </div>
                            <div class="pt-2">
                                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Điều kiện GPA tối thiểu</label>
                                <div class="flex gap-4 mt-2">
                                    <input type="hidden" name="names" value="Min_GPA" />
                                    <input type="number" name="values_Min_GPA" step="0.1" value="@GetVal("Min_GPA", "0")" class="flex-1 bg-slate-50 border-none rounded-xl px-4 py-3 text-sm font-bold" />
                                    <div class="w-12 h-12 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold shadow-blue-200 shadow-md">OK</div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </form>
        <section class="max-w-6xl mx-auto bg-white rounded-2xl p-8 shadow-sm border border-slate-100">
            <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between mb-6">
                <div>
                    <h3 class="text-xl font-extrabold text-slate-900 tracking-tight">Quản lý chuyên ngành</h3>
                    <p class="text-sm text-slate-500">Các chuyên ngành đang được dùng để lọc đề tài, hồ sơ sinh viên và import dữ liệu.</p>
                </div>
                <div class="text-sm font-semibold text-slate-500">
                    @majors.Count() chuyên ngành
                </div>
            </div>

            <form asp-action="CreateMajor" method="post" class="grid grid-cols-12 gap-3 mb-6 rounded-2xl bg-slate-50 p-4">
                @Html.AntiForgeryToken()
                <div class="col-span-12 md:col-span-3">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Tên chuyên ngành</label>
                    <input name="name" required maxlength="150" class="mt-1 w-full bg-white rounded-xl px-4 py-3 text-sm border border-slate-200 focus:ring-2 focus:ring-blue-500/20" placeholder="Công nghệ phần mềm" />
                </div>
                <div class="col-span-12 md:col-span-2">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Mã</label>
                    <input name="majorCode" maxlength="30" class="mt-1 w-full bg-white rounded-xl px-4 py-3 text-sm border border-slate-200 focus:ring-2 focus:ring-blue-500/20 uppercase" placeholder="CNPM" />
                </div>
                <div class="col-span-12 md:col-span-3">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Khoa</label>
                    <input name="facultyName" maxlength="150" class="mt-1 w-full bg-white rounded-xl px-4 py-3 text-sm border border-slate-200 focus:ring-2 focus:ring-blue-500/20" placeholder="Công nghệ thông tin" />
                </div>
                <div class="col-span-12 md:col-span-3">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Mô tả</label>
                    <input name="description" maxlength="300" class="mt-1 w-full bg-white rounded-xl px-4 py-3 text-sm border border-slate-200 focus:ring-2 focus:ring-blue-500/20" placeholder="Ghi chú ngắn" />
                </div>
                <div class="col-span-12 md:col-span-1 flex items-end">
                    <button type="submit" class="w-full px-4 py-3 rounded-xl bg-blue-600 text-white font-bold text-sm hover:bg-blue-700 transition-all">
                        Thêm
                    </button>
                </div>
            </form>

            <div class="space-y-3">
                <div class="hidden lg:grid grid-cols-12 gap-3 px-3 text-xs font-bold uppercase tracking-wider text-slate-500">
                    <div class="col-span-3">Chuyên ngành</div>
                    <div class="col-span-1">Mã</div>
                    <div class="col-span-2">Khoa</div>
                    <div class="col-span-3">Mô tả</div>
                    <div class="col-span-1">Trạng thái</div>
                    <div class="col-span-2 text-right">Thao tác</div>
                </div>

                @foreach (var major in majors)
                {
                    <div class="rounded-2xl border border-slate-100 bg-white p-3 shadow-sm">
                        <form asp-action="UpdateMajor" method="post" class="grid grid-cols-12 gap-3 items-center">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@major.Id" />
                            <div class="col-span-12 lg:col-span-3">
                                <label class="lg:hidden text-xs font-bold text-slate-500 uppercase tracking-wider">Chuyên ngành</label>
                                <input name="name" value="@major.Name" required maxlength="150" class="mt-1 lg:mt-0 w-full bg-slate-50 rounded-xl px-3 py-2 text-sm border border-slate-200" />
                            </div>
                            <div class="col-span-12 sm:col-span-4 lg:col-span-1">
                                <label class="lg:hidden text-xs font-bold text-slate-500 uppercase tracking-wider">Mã</label>
                                <input name="majorCode" value="@major.MajorCode" maxlength="30" class="mt-1 lg:mt-0 w-full bg-slate-50 rounded-xl px-3 py-2 text-sm border border-slate-200 uppercase" />
                            </div>
                            <div class="col-span-12 sm:col-span-8 lg:col-span-2">
                                <label class="lg:hidden text-xs font-bold text-slate-500 uppercase tracking-wider">Khoa</label>
                                <input name="facultyName" value="@major.FacultyName" maxlength="150" class="mt-1 lg:mt-0 w-full bg-slate-50 rounded-xl px-3 py-2 text-sm border border-slate-200" />
                            </div>
                            <div class="col-span-12 lg:col-span-3">
                                <label class="lg:hidden text-xs font-bold text-slate-500 uppercase tracking-wider">Mô tả</label>
                                <input name="description" value="@major.Description" maxlength="300" class="mt-1 lg:mt-0 w-full bg-slate-50 rounded-xl px-3 py-2 text-sm border border-slate-200" />
                            </div>
                            <div class="col-span-12 sm:col-span-4 lg:col-span-1">
                                <label class="inline-flex items-center gap-2 text-sm font-semibold text-slate-600 whitespace-nowrap">
                                    <input type="checkbox" name="isActive" value="true" @(major.IsActive ? "checked" : "") class="rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                                    @(major.IsActive ? "Đang dùng" : "Đã ẩn")
                                </label>
                            </div>
                            <div class="col-span-12 sm:col-span-8 lg:col-span-2 flex flex-wrap justify-start lg:justify-end gap-2">
                                <button type="submit" class="px-3 py-2 rounded-xl bg-slate-900 text-white text-xs font-bold hover:bg-slate-700">
                                    Lưu
                                </button>
                                <button type="submit" formaction="@Url.Action("ToggleMajor", "Admin")" class="px-3 py-2 rounded-xl bg-white border border-slate-200 text-slate-700 text-xs font-bold hover:bg-slate-50">
                                    @(major.IsActive ? "Ẩn" : "Bật")
                                </button>
                                <button type="submit" formaction="@Url.Action("DeleteMajor", "Admin")" formmethod="post" onclick="return confirm('Xóa chuyên ngành này? Nếu đã có dữ liệu liên quan, hệ thống sẽ chỉ ẩn chuyên ngành.');" class="px-3 py-2 rounded-xl bg-red-50 text-red-600 text-xs font-bold hover:bg-red-100">
                                    Xóa
                                </button>
                            </div>
                        </form>
                    </div>
                }

                @if (!majors.Any())
                {
                    <div class="rounded-2xl border border-dashed border-slate-200 py-8 text-center text-sm text-slate-500">
                        Chưa có chuyên ngành nào.
                    </div>
                }
            </div>
        </section>
        <script>
            const range = document.querySelector('input[type="range"]');
            const span = range.previousElementSibling.querySelector('span');
            range.addEventListener('input', (e) => {
                span.textContent = e.target.value;
            });
        </script>
    </div>
</main>
