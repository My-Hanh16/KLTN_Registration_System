@* ============================================================
   FILE: Views/Admin/StudentProposals.cshtml
   MODEL: IEnumerable<Topic>
   Quản lý đề xuất đề tài từ sinh viên — duyệt / từ chối
   ============================================================ *@
@using KLTN_Registration_System.Models.Entities
@model IEnumerable<Topic>
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Đề xuất từ sinh viên";
    int pendingCount = ViewBag.PendingCount ?? 0;
    int approvedCount = ViewBag.ApprovedCount ?? 0;
    string? statusFilter = ViewBag.StatusFilter;
}

<div class="px-6 py-6">

    {{!-- Header --}}
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Đề xuất đề tài từ sinh viên</h1>
            <p class="text-sm text-slate-500 mt-0.5">Duyệt hoặc từ chối đề tài do sinh viên tự đề xuất</p>
        </div>
        <div class="flex gap-2 text-sm">
            <a asp-action="StudentProposals" class="px-4 py-2 rounded-lg @(statusFilter == null ? "bg-blue-600 text-white" : "bg-slate-100 text-slate-600 hover:bg-slate-200")">
                Tất cả (@(pendingCount + approvedCount))
            </a>
            <a asp-action="StudentProposals" asp-route-status="pending"
               class="px-4 py-2 rounded-lg @(statusFilter == "pending" ? "bg-yellow-500 text-white" : "bg-slate-100 text-slate-600 hover:bg-slate-200")">
                Chờ duyệt (@pendingCount)
            </a>
            <a asp-action="StudentProposals" asp-route-status="approved"
               class="px-4 py-2 rounded-lg @(statusFilter == "approved" ? "bg-green-600 text-white" : "bg-slate-100 text-slate-600 hover:bg-slate-200")">
                Đã duyệt (@approvedCount)
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-xl text-sm">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 p-4 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm">⚠️ @TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-16 text-slate-400">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <p class="text-lg font-medium">Không có đề xuất nào</p>
        </div>
    }
    else
    {
        <div class="grid gap-4">
            @foreach (var topic in Model)
            {
                bool isPending = !topic.IsApproved;
                <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex-1">
                            <div class="flex items-center gap-2 mb-1">
                                @if (isPending)
                                {
                                    <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full font-medium">Chờ duyệt</span>
                                }
                                else
                                {
                                    <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium">Đã duyệt</span>
                                }
                                @if (!string.IsNullOrEmpty(topic.TopicCode))
                                {
                                    <span class="text-xs text-slate-400 font-mono">@topic.TopicCode</span>
                                }
                            </div>
                            <h3 class="text-base font-semibold text-slate-800 mb-1">@topic.Title</h3>
                            <p class="text-sm text-slate-500 line-clamp-2 mb-3">@topic.Description</p>

                            <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-slate-500">
                                <span>👤 SV: <strong>@(topic.Student?.FullName ?? topic.Student?.Email ?? "?")</strong></span>
                                <span>📅 @topic.CreatedAt.ToString("dd/MM/yyyy")</span>
                                @if (!string.IsNullOrEmpty(topic.Category))
                                {
                                    <span>🏷️ @topic.Category</span>
                                }
                                @if (topic.Lecturer != null)
                                {
                                    <span>👨‍🏫 GV mong muốn: <strong>@topic.Lecturer.FullName</strong></span>
                                }
                            </div>
                        </div>

                        @if (isPending)
                        {
                            <div class="flex flex-col gap-2 min-w-[180px]">
                                {{!-- Nút Duyệt --}}
                                <button onclick="openApproveModal(@topic.Id, @Json.Serialize(topic.Title ?? ""))"
                                        class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm rounded-lg font-medium transition-colors">
                                    ✓ Duyệt & Phân công
                                </button>
                                {{!-- Nút Từ chối --}}
                                <button onclick="openRejectModal(@topic.Id, @Json.Serialize(topic.Title ?? ""))"
                                        class="px-4 py-2 bg-red-50 hover:bg-red-100 text-red-600 text-sm rounded-lg font-medium border border-red-200 transition-colors">
                                    ✕ Từ chối
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

{{!-- Modal Duyệt --}}
<div id="approveModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md">
        <h3 class="text-lg font-bold text-slate-800 mb-1">Duyệt đề xuất</h3>
        <p id="approveTitle" class="text-sm text-slate-500 mb-4"></p>

        <form asp-action="ApproveStudentProposal" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="approveTopicId" name="topicId" />

            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">
                    Phân công giảng viên hướng dẫn
                </label>
                <select name="assignLecturerId"
                        class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">-- Không phân công (SV tự liên hệ) --</option>
                    @foreach (var lec in (ViewBag.Lecturers as IList<KLTN_Registration_System.Models.Entities.ApplicationUser> ?? new List<KLTN_Registration_System.Models.Entities.ApplicationUser>()))
                    {
                        <option value="@lec.Id">@lec.FullName (@lec.Email)</option>
                    }
                </select>
            </div>

            <div class="flex gap-3">
                <button type="submit"
                        class="flex-1 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm font-semibold">
                    Xác nhận duyệt
                </button>
                <button type="button" onclick="closeModals()"
                        class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg text-sm">
                    Hủy
                </button>
            </div>
        </form>
    </div>
</div>

{{!-- Modal Từ chối --}}
<div id="rejectModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md">
        <h3 class="text-lg font-bold text-slate-800 mb-1">Từ chối đề xuất</h3>
        <p id="rejectTitle" class="text-sm text-slate-500 mb-4"></p>

        <form asp-action="RejectStudentProposal" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="rejectTopicId" name="topicId" />

            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Lý do từ chối (tùy chọn)</label>
                <textarea name="reason" rows="3"
                          class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-500"
                          placeholder="Nhập lý do để sinh viên biết..."></textarea>
            </div>

            <div class="flex gap-3">
                <button type="submit"
                        class="flex-1 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-semibold">
                    Xác nhận từ chối
                </button>
                <button type="button" onclick="closeModals()"
                        class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg text-sm">
                    Hủy
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openApproveModal(id, title) {
            document.getElementById('approveTopicId').value = id;
            document.getElementById('approveTitle').textContent = title;
            document.getElementById('approveModal').classList.remove('hidden');
        }
        function openRejectModal(id, title) {
            document.getElementById('rejectTopicId').value = id;
            document.getElementById('rejectTitle').textContent = title;
            document.getElementById('rejectModal').classList.remove('hidden');
        }
        function closeModals() {
            document.getElementById('approveModal').classList.add('hidden');
            document.getElementById('rejectModal').classList.add('hidden');
        }
        // Đóng khi click ngoài modal
        ['approveModal','rejectModal'].forEach(id => {
            document.getElementById(id).addEventListener('click', function(e) {
                if (e.target === this) closeModals();
            });
        });
    </script>
}
