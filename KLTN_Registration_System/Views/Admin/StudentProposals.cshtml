@* ============================================================
   FILE: Views/Admin/StudentProposals.cshtml
   MODEL: IEnumerable<Topic>
   ============================================================ *@
@using KLTN_Registration_System.Models.Entities
@model IEnumerable<Topic>
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Đề xuất từ sinh viên";

    int pendingCount = ViewBag.PendingCount ?? 0;
    int approvedCount = ViewBag.ApprovedCount ?? 0;
    int rejectedCount = ViewBag.RejectedCount ?? 0;
    int totalCount = pendingCount + approvedCount + rejectedCount;
    string? statusFilter = ViewBag.StatusFilter;

    const string lecturerApprovedPrefix = "[LECTURER_APPROVED]";
    const string lecturerRejectedPrefix = "[LECTURER_REJECTED]";
    var lecturerOptions = ViewBag.Lecturers as IList<ApplicationUser> ?? new List<ApplicationUser>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/student-proposals.css" asp-append-version="true" />
}

<!-- ════════════════════════════════
     ALERTS
════════════════════════════════ -->
@if (TempData["Success"] != null)
{
    <div class="alert-bar success">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["Success"]</span>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-bar error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<!-- ════════════════════════════════
     PAGE HEADER
════════════════════════════════ -->
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="page-title">Đề xuất đề tài từ sinh viên</h2>
        <p class="page-sub">Duyệt hoặc từ chối đề tài do sinh viên tự đề xuất, phân công giảng viên hướng dẫn.</p>
    </div>
</div>

<!-- ════════════════════════════════
     STATS ROW
════════════════════════════════ -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fa-solid fa-lightbulb"></i></div>
        <div>
            <div class="stat-label">Tổng đề xuất</div>
            <div class="stat-number">@totalCount</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fa-solid fa-hourglass-half"></i></div>
        <div>
            <div class="stat-label">Chờ xử lý</div>
            <div class="stat-number">@pendingCount</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-circle-check"></i></div>
        <div>
            <div class="stat-label">Đã duyệt vào hệ thống</div>
            <div class="stat-number">@approvedCount</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red"><i class="fa-solid fa-ban"></i></div>
        <div>
            <div class="stat-label">Đã từ chối</div>
            <div class="stat-number">@rejectedCount</div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════
     FILTER TABS
════════════════════════════════ -->
<div class="filter-tabs">
    <a asp-action="StudentProposals"
       class="filter-tab all @(statusFilter == null ? "active" : "")">
        Tất cả
        <span class="tab-count blue">@totalCount</span>
    </a>
    <a asp-action="StudentProposals" asp-route-status="pending"
       class="filter-tab amber @(statusFilter == "pending" ? "active" : "")">
        Chờ duyệt
        @if (pendingCount > 0)
        {
            <span class="tab-count amber">@pendingCount</span>
        }
    </a>
    <a asp-action="StudentProposals" asp-route-status="approved"
       class="filter-tab green @(statusFilter == "approved" ? "active" : "")">
        Đã duyệt
        <span class="tab-count green">@approvedCount</span>
    </a>
    <a asp-action="StudentProposals" asp-route-status="rejected"
       class="filter-tab @(statusFilter == "rejected" ? "active" : "")">
        Đã từ chối
        <span class="tab-count red">@rejectedCount</span>
    </a>
</div>

<!-- ════════════════════════════════
     PROPOSAL LIST
════════════════════════════════ -->
@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon"><i class="fa-regular fa-file-lines"></i></div>
        <h3>Không có đề xuất nào</h3>
        <p>@(statusFilter == "pending" ? "Hiện tại chưa có đề xuất nào đang chờ duyệt." : "Chưa có đề xuất nào trong danh sách này.")</p>
    </div>
}
else
{
    <div>
        @foreach (var topic in Model)
        {
            bool isPending = !topic.IsApproved;
            bool lecturerApproved = !string.IsNullOrWhiteSpace(topic.Note) && topic.Note.StartsWith(lecturerApprovedPrefix);
            bool lecturerRejected = !string.IsNullOrWhiteSpace(topic.Note) && topic.Note.StartsWith(lecturerRejectedPrefix);
            bool needsLecturer = string.IsNullOrWhiteSpace(topic.LecturerId);
            bool adminRejected = topic.Status == TopicStatus.Rejected;
            string finalStateClass = adminRejected ? "final-state--rejected" : "final-state--approved";

            string badgeCls, badgeTxt, badgeIco;

            if (topic.IsApproved)
            { badgeCls = "added"; badgeTxt = "Đã thêm vào hệ thống"; badgeIco = "fa-solid fa-check"; }
            else if (adminRejected)
            { badgeCls = "admin-no"; badgeTxt = "Admin đã từ chối"; badgeIco = "fa-solid fa-ban"; }
            else if (lecturerApproved)
            { badgeCls = "lec-ok"; badgeTxt = "GV đồng ý"; badgeIco = "fa-solid fa-thumbs-up"; }
            else if (lecturerRejected)
            { badgeCls = "lec-no"; badgeTxt = "GV từ chối"; badgeIco = "fa-solid fa-thumbs-down"; }
            else if (needsLecturer)
            { badgeCls = "need-lec"; badgeTxt = "Cần phân công GV"; badgeIco = "fa-solid fa-user-clock"; }
            else
            { badgeCls = "waiting"; badgeTxt = "Đang chờ GV phản hồi"; badgeIco = "fa-solid fa-hourglass-half"; }

            string noteClean = (topic.Note ?? "")
            .Replace(lecturerApprovedPrefix, "")
            .Replace(lecturerRejectedPrefix, "")
            .Trim();

            string? topicFaculty = topic.Major?.FacultyName ?? topic.Faculty;
            var eligibleLecturers = lecturerOptions
                .Where(lec => lec.Id != topic.LecturerId)
                .Where(lec =>
                    (topic.MajorId.HasValue
                        && (lec.MajorId == topic.MajorId.Value
                            || lec.UserMajors.Any(um => um.MajorId == topic.MajorId.Value)))
                    || (!string.IsNullOrWhiteSpace(topicFaculty)
                        && (string.Equals(lec.Faculty, topicFaculty, StringComparison.OrdinalIgnoreCase)
                            || string.Equals(lec.Major?.FacultyName, topicFaculty, StringComparison.OrdinalIgnoreCase)
                            || lec.UserMajors.Any(um => string.Equals(um.Major?.FacultyName, topicFaculty, StringComparison.OrdinalIgnoreCase)))))
                .OrderBy(lec => lec.FullName)
                .ToList();

            <div class="proposal-card">
                <div class="proposal-body">

                    <!-- LEFT: Info -->
                    <div class="prop-info">
                        <div class="prop-badges">
                            <span class="s-badge @badgeCls">
                                <i class="@badgeIco badge-icon"></i>
                                @badgeTxt
                            </span>
                            @if (!string.IsNullOrEmpty(topic.TopicCode))
                            {
                                <span class="topic-code">@topic.TopicCode</span>
                            }
                            @if (!string.IsNullOrEmpty(topic.Category))
                            {
                                <span class="category-text">@topic.Category</span>
                            }
                        </div>

                        <div class="prop-title">@topic.Title</div>

                        @if (!string.IsNullOrWhiteSpace(topic.Description))
                        {
                            <div class="prop-desc">@topic.Description</div>
                        }

                        <div class="prop-meta">
                            <div class="prop-meta-item">
                                <i class="fa-solid fa-user"></i>
                                Sinh viên: <strong>@(topic.Student?.FullName ?? topic.Student?.Email ?? "?")</strong>
                            </div>
                            <div class="prop-meta-item">
                                <i class="fa-regular fa-calendar"></i>
                                @topic.CreatedAt.ToString("dd/MM/yyyy")
                            </div>
                            @if (topic.Lecturer != null)
                            {
                                <div class="prop-meta-item">
                                    <i class="fa-solid fa-chalkboard-user"></i>
                                    GV mong muốn: <strong>@topic.Lecturer.FullName</strong>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(noteClean))
                        {
                            <div class="note-box">
                                <i class="fa-solid fa-comment note-icon"></i>
                                @noteClean
                            </div>
                        }
                    </div>

                    <!-- RIGHT: Actions (chỉ khi pending) -->
                    @if (isPending && !adminRejected)
                    {
                        <div class="prop-actions">

                            <!-- Duyệt & thêm vào hệ thống -->
                            @if (lecturerApproved)
                            {
                                <div class="action-group">
                                    <div class="action-group-label">
                                        <i class="fa-solid fa-circle-check action-icon action-icon--green"></i>
                                        Duyệt & thêm vào hệ thống
                                    </div>
                                    <form asp-action="ApproveStudentProposal" asp-controller="Admin"
                                          method="post" class="action-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="topicId" value="@topic.Id" />
                                        <input type="hidden" name="status" value="@statusFilter" />
                                        <input type="hidden" name="assignLecturerId" value="@topic.LecturerId" />
                                        <button type="submit" class="act-btn green">
                                            <i class="fa-solid fa-check"></i> Thêm vào hệ thống
                                        </button>
                                    </form>
                                </div>
                            }

                            <!-- Phân công GV khác -->
                            <div class="action-group">
                                <div class="action-group-label">
                                    <i class="fa-solid fa-rotate action-icon action-icon--blue"></i>
                                    Phân công giảng viên khác
                                </div>
                                <form asp-action="ReassignStudentProposal" asp-controller="Admin"
                                      method="post" class="action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="topicId" value="@topic.Id" />
                                    <input type="hidden" name="status" value="@statusFilter" />
                                    <select name="assignLecturerId" required class="act-select">
                                        <option value="">-- Chọn giảng viên cùng khoa --</option>
                                        @foreach (var lec in eligibleLecturers)
                                        {
                                            <option value="@lec.Id">@lec.FullName</option>
                                        }
                                    </select>
                                    @if (!eligibleLecturers.Any())
                                    {
                                        <div class="empty-lecturer-note">Không có giảng viên phù hợp với khoa/chuyên ngành này.</div>
                                    }
                                    <button type="submit" class="act-btn blue" @(!eligibleLecturers.Any() ? "disabled" : "")>
                                        <i class="fa-solid fa-rotate"></i> Phân công GV
                                    </button>
                                </form>
                            </div>

                            <!-- Từ chối -->
                            <div class="action-group action-group--danger">
                                <div class="action-group-label action-group-label--danger">
                                    <i class="fa-solid fa-xmark action-icon"></i>
                                    Từ chối đề xuất
                                </div>
                                <form asp-action="RejectStudentProposal" asp-controller="Admin"
                                      method="post" class="action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="topicId" value="@topic.Id" />
                                    <input type="hidden" name="status" value="@statusFilter" />
                                    <input type="text" name="reason" class="act-input"
                                           placeholder="Nhập lý do từ chối..." required minlength="5" />
                                    <button type="submit" class="act-btn red-outline">
                                        <i class="fa-solid fa-xmark"></i> Từ chối đề xuất
                                    </button>
                                </form>
                            </div>

                        </div>
                    }
                    else
                    {
                        <div class="final-state-wrap">
                            <div class="final-state @finalStateClass">
                                <i class="fa-solid @(adminRejected ? "fa-ban" : "fa-circle-check")"></i>
                                @(adminRejected ? "Đề xuất đã bị từ chối" : "Đã thêm vào hệ thống")
                            </div>
                        </div>
                    }

                </div>
            </div>
        }
    </div>
}
