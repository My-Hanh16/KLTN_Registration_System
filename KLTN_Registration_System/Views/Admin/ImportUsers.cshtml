@{
    Layout = "_LayoutDashboard";
    string? role = ViewBag.Role as string;
    var title = role switch
    {
        "Student" => "Nhập sinh viên từ Excel",
        "Lecturer" => "Nhập giảng viên từ Excel",
        "Admin" => "Nhập quản trị viên từ Excel",
        _ => "Nhập người dùng từ Excel"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/import-users.css" asp-append-version="true" />
}

<div class="import-users-page">
    <section class="import-card">
        <header class="import-header">
            <h2>@title</h2>
            <p>
                File cần có các cột: FullName, Email, UserCode, Faculty, MajorCode, MajorName.
                Với giảng viên có thể nhập nhiều mã ngành trong cột MajorCode, ví dụ: CNPM,HTTT.
            </p>
        </header>

        <div class="template-actions">
            <a href="~/templates/import-sinh-vien-v2.xlsx" class="template-link">
                Tải mẫu sinh viên
            </a>
            <a href="~/templates/import-giang-vien-v2.xlsx" class="template-link">
                Tải mẫu giảng viên
            </a>
        </div>

        <form asp-action="ImportUsers" method="post" enctype="multipart/form-data" class="import-form">
            @Html.AntiForgeryToken()
            @if (!string.IsNullOrWhiteSpace(role))
            {
                <input type="hidden" name="role" value="@role" />
            }
            else
            {
                <div class="form-group">
                    <label for="roleSelect">Vai trò cần import</label>
                    <select id="roleSelect" name="role" class="form-select" required>
                        <option value="">-- Chọn vai trò --</option>
                        <option value="Student">Sinh viên</option>
                        <option value="Lecturer">Giảng viên</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
            }

            <div class="form-group">
                <label for="userImportFile">File Excel</label>
                <input id="userImportFile"
                       type="file"
                       name="file"
                       accept=".xlsx,.xls"
                       class="file-input"
                       required />
            </div>

            <button type="submit" class="submit-button">
                Bắt đầu nhập liệu
            </button>
        </form>
    </section>
</div>
