@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Reset mật khẩu";
    var user = ViewBag.User as KLTN_Registration_System.Models.Entities.ApplicationUser;
    var roles = ViewBag.Roles as IList<string> ?? new List<string>();
}

<div class="max-w-lg mx-auto px-4 py-8">
    <nav class="flex items-center gap-2 text-sm text-slate-400 mb-6">
        <a href="/Admin/UserManagement" class="hover:text-blue-600 no-underline">Quản lý người dùng</a>
        <span class="material-symbols-outlined text-base">chevron_right</span>
        <span class="text-slate-700">Reset mật khẩu</span>
    </nav>

    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <!-- Header người dùng -->
        <div class="bg-gradient-to-r from-slate-700 to-slate-600 px-6 py-5 flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-white/20 text-white flex items-center justify-center font-bold text-2xl shrink-0">
                @(user?.FullName?.Substring(0, 1).ToUpper() ?? "?")
            </div>
            <div>
                <p class="font-bold text-white text-lg">@(user?.FullName ?? user?.Email)</p>
                <p class="text-slate-300 text-sm">@user?.Email · @user?.UserCode</p>
                @foreach (var role in roles)
                {
                    <span class="inline-block mt-1 text-xs bg-white/20 text-white px-2 py-0.5 rounded-full font-semibold">@role</span>
                }
            </div>
        </div>

        <form method="post" asp-action="ResetPassword" asp-controller="Admin" class="p-6 space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@user?.Id" />

            <!-- Lựa chọn kiểu reset -->
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-3">Kiểu đặt mật khẩu</label>
                <div class="grid grid-cols-2 gap-3">
                    <label id="labelRandom"
                           class="flex items-center gap-3 p-4 rounded-xl border-2 border-blue-500 bg-blue-50 cursor-pointer transition-all">
                        <input type="radio" name="useRandomPassword" value="true"
                               id="radioRandom" checked onchange="togglePasswordMode(true)"
                               class="accent-blue-600" />
                        <div>
                            <p class="font-semibold text-slate-800 text-sm">Ngẫu nhiên</p>
                            <p class="text-xs text-slate-500">Hệ thống tự sinh</p>
                        </div>
                    </label>
                    <label id="labelCustom"
                           class="flex items-center gap-3 p-4 rounded-xl border-2 border-slate-200 cursor-pointer transition-all">
                        <input type="radio" name="useRandomPassword" value="false"
                               id="radioCustom" onchange="togglePasswordMode(false)"
                               class="accent-blue-600" />
                        <div>
                            <p class="font-semibold text-slate-800 text-sm">Tuỳ chỉnh</p>
                            <p class="text-xs text-slate-500">Nhập mật khẩu mới</p>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Ô nhập mật khẩu tuỳ chỉnh -->
            <div id="customPasswordField" class="hidden">
                <label class="block text-sm font-bold text-slate-700 mb-1.5">
                    Mật khẩu mới <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <input type="password" name="newPassword" id="newPasswordInput"
                           placeholder="Tối thiểu 8 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt"
                           class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm pr-12 focus:outline-none focus:ring-2 focus:ring-blue-400" />
                    <button type="button" onclick="toggleVisibility()"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                        <span id="eyeIcon" class="material-symbols-outlined text-xl">visibility</span>
                    </button>
                </div>
                <p class="text-xs text-slate-400 mt-1">Yêu cầu: ≥8 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt.</p>
            </div>

            <!-- Cảnh báo -->
            <div class="flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-xl p-4">
                <span class="material-symbols-outlined text-amber-600 shrink-0 mt-0.5">warning</span>
                <div class="text-sm text-amber-800">
                    <p class="font-semibold mb-0.5">Lưu ý trước khi thực hiện</p>
                    <p>
                        Thao tác này sẽ đăng xuất người dùng khỏi tất cả thiết bị và gửi thông báo cho họ.
                        Hãy thông báo mật khẩu mới trực tiếp cho người dùng.
                    </p>
                </div>
            </div>

            <div class="flex gap-3 pt-1">
                <a href="/Admin/UserManagement"
                   class="flex-1 flex items-center justify-center gap-2 py-3 rounded-xl border border-slate-200 text-slate-600 text-sm font-semibold hover:bg-slate-50 no-underline transition-colors">
                    Huỷ
                </a>
                <button type="submit"
                        class="flex-1 flex items-center justify-center gap-2 py-3 rounded-xl bg-red-600 text-white text-sm font-bold hover:bg-red-700 active:scale-95 transition-all">
                    <span class="material-symbols-outlined text-base">lock_reset</span>
                    Xác nhận Reset
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            togglePasswordMode(true);
        });

        function togglePasswordMode(isRandom) {

            const field = document.getElementById('customPasswordField');
            const input = document.getElementById('newPasswordInput');

            const labelR = document.getElementById('labelRandom');
            const labelC = document.getElementById('labelCustom');

            if (isRandom) {

                field.classList.add('hidden');
                input.required = false;

                labelR.classList.add(
                    'border-blue-500',
                    'bg-blue-50'
                );

                labelR.classList.remove(
                    'border-slate-200'
                );

                labelC.classList.remove(
                    'border-blue-500',
                    'bg-blue-50'
                );

                labelC.classList.add(
                    'border-slate-200'
                );

            } else {

                field.classList.remove('hidden');
                input.required = true;

                labelC.classList.add(
                    'border-blue-500',
                    'bg-blue-50'
                );

                labelC.classList.remove(
                    'border-slate-200'
                );

                labelR.classList.remove(
                    'border-blue-500',
                    'bg-blue-50'
                );

                labelR.classList.add(
                    'border-slate-200'
                );
            }
        }

        function toggleVisibility() {

            const input = document.getElementById('newPasswordInput');
            const icon = document.getElementById('eyeIcon');

            if (input.type === 'password') {

                input.type = 'text';
                icon.textContent = 'visibility_off';

            } else {

                input.type = 'password';
                icon.textContent = 'visibility';
            }
        }
    </script>
}
