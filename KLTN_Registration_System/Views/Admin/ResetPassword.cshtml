@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Reset mật khẩu";
    var user = ViewBag.User as KLTN_Registration_System.Models.Entities.ApplicationUser;
    var roles = ViewBag.Roles as IList<string> ?? new List<string>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/reset-password.css" asp-append-version="true" />
}

<div class="reset-page">
    <nav class="reset-breadcrumb">
        <a href="/Admin/UserManagement">Quản lý người dùng</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span>Reset mật khẩu</span>
    </nav>

    <div class="reset-card">
        <!-- Header người dùng -->
        <div class="user-banner">
            <div class="user-avatar">
                @(user?.FullName?.Substring(0, 1).ToUpper() ?? "?")
            </div>
            <div>
                <p class="user-name">@(user?.FullName ?? user?.Email)</p>
                <p class="user-meta">@user?.Email · @user?.UserCode</p>
                @foreach (var role in roles)
                {
                    <span class="role-chip">@role</span>
                }
            </div>
        </div>

        <form method="post" asp-action="ResetPassword" asp-controller="Admin" class="reset-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@user?.Id" />

            <!-- Lựa chọn kiểu reset -->
            <div class="form-section">
                <label class="form-label">Kiểu đặt mật khẩu</label>
                <div class="mode-grid">
                    <label id="labelRandom"
                           class="mode-card mode-card--active">
                        <input type="radio" name="useRandomPassword" value="true"
                               id="radioRandom" checked
                               class="mode-radio" />
                        <div>
                            <p class="mode-title">Ngẫu nhiên</p>
                            <p class="mode-desc">Hệ thống tự sinh</p>
                        </div>
                    </label>
                    <label id="labelCustom"
                           class="mode-card">
                        <input type="radio" name="useRandomPassword" value="false"
                               id="radioCustom"
                               class="mode-radio" />
                        <div>
                            <p class="mode-title">Tuỳ chỉnh</p>
                            <p class="mode-desc">Nhập mật khẩu mới</p>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Ô nhập mật khẩu tuỳ chỉnh -->
            <div id="customPasswordField" class="password-field is-hidden">
                <label class="form-label form-label--compact">
                    Mật khẩu mới <span class="required">*</span>
                </label>
                <div class="password-input-wrap">
                    <input type="password" name="newPassword" id="newPasswordInput"
                           placeholder="Tối thiểu 8 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt"
                           class="password-input" />
                    <button type="button" id="togglePasswordVisibility"
                            class="password-toggle">
                        <span id="eyeIcon" class="material-symbols-outlined">visibility</span>
                    </button>
                </div>
                <p class="form-hint">Yêu cầu: ≥8 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt.</p>
            </div>

            <!-- Cảnh báo -->
            <div class="warning-box">
                <span class="material-symbols-outlined">warning</span>
                <div>
                    <p class="warning-title">Lưu ý trước khi thực hiện</p>
                    <p>
                        Thao tác này sẽ đăng xuất người dùng khỏi tất cả thiết bị và gửi thông báo cho họ.
                        Hãy thông báo mật khẩu mới trực tiếp cho người dùng.
                    </p>
                </div>
            </div>

            <div class="form-actions">
                <a href="/Admin/UserManagement"
                   class="btn-cancel">
                    Huỷ
                </a>
                <button type="submit"
                        class="btn-reset">
                    <span class="material-symbols-outlined">lock_reset</span>
                    Xác nhận Reset
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/reset-password.js" asp-append-version="true"></script>
}
