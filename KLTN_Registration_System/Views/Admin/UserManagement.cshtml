@using KLTN_Registration_System.Models.Entities
@model IEnumerable<ApplicationUser>
@{
    Layout = "_LayoutDashboard";
    var roleFilter = ViewBag.RoleFilter?.ToString();
    var userRoles  = ViewBag.UserRoles as Dictionary<string, string>;
    var majors     = ViewBag.Majors as List<Major> ?? new List<Major>();
    var faculties  = ViewBag.Faculties as List<string> ?? new List<string>();
    var selectedFaculty = ViewBag.FacultyFilter?.ToString();
    int? selectedMajorId = ViewBag.MajorFilter as int?;
    var userMajorNames = ViewBag.UserMajorNames as Dictionary<string, string> ?? new Dictionary<string, string>();
    var selectedPeriodName = ViewBag.SelectedPeriodName?.ToString();

    string pageTitle = roleFilter == "Student"  ? "Quản lý Sinh viên"
                     : roleFilter == "Lecturer" ? "Quản lý Giảng viên"
                     : "Quản lý người dùng";
    string pageSub   = roleFilter == "Student"  ? $"Danh sách sinh viên đủ điều kiện của đợt {selectedPeriodName ?? "đang chọn"}."
                     : roleFilter == "Lecturer" ? "Danh sách toàn bộ giảng viên trong hệ thống."
                     : "Quản lý tài khoản, vai trò và quyền truy cập toàn hệ thống.";
    string addLabel  = roleFilter == "Student"  ? "Thêm sinh viên"
                     : roleFilter == "Lecturer" ? "Thêm giảng viên"
                     : "Thêm người dùng";

    ViewData["Title"] = pageTitle;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/user-management.css" asp-append-version="true" />
}

@if (TempData["TempPassword"] != null)
{
    <div class="toast" id="toastPwd">
        <div class="toast-body">
            <div class="toast-icon green"><i class="fa-solid fa-key"></i></div>
            <div class="toast-content">
                <div class="toast-title">Reset mật khẩu thành công</div>
                <div class="toast-msg">Mật khẩu tạm thời:</div>
                <div class="toast-pwd-box">
                    <span class="toast-pwd" id="tempPwd">@TempData["TempPassword"]</span>
                    <button class="btn-copy" data-copy-temp-password>Copy</button>
                </div>
            </div>
            <button class="toast-close" data-close-toast="toastPwd"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="toast-bar green"></div>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="toast" id="toastOk">
        <div class="toast-body">
            <div class="toast-icon green"><i class="fa-solid fa-circle-check"></i></div>
            <div class="toast-content">
                <div class="toast-title">Thành công</div>
                <div class="toast-msg">@TempData["Success"]</div>
            </div>
            <button class="toast-close" data-close-toast="toastOk"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="toast-bar green"></div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="toast" id="toastErr">
        <div class="toast-body">
            <div class="toast-icon red"><i class="fa-solid fa-circle-exclamation"></i></div>
            <div class="toast-content">
                <div class="toast-title">Có lỗi xảy ra</div>
                <div class="toast-msg">@TempData["Error"]</div>
            </div>
            <button class="toast-close" data-close-toast="toastErr"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="toast-bar red"></div>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title">@pageTitle</h2>
        <p class="page-sub">@pageSub</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-green" data-open-modal="createModal">
            <i class="fa-solid fa-plus"></i> @addLabel
        </button>
        <a href="@Url.Action("ImportUsers","Admin", new { role = roleFilter })" class="btn btn-ghost">
            <i class="fa-solid fa-file-arrow-up"></i> Nhập Excel
        </a>
        <a href="@Url.Action("ExportUsers","Admin", new { role = roleFilter })" class="btn btn-primary">
            <i class="fa-solid fa-file-arrow-down"></i> Xuất file
        </a>
    </div>
</div>

<div class="stats-row">
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon blue"><i class="fa-solid fa-users"></i></div>
            <span class="stat-badge blue">Tổng</span>
        </div>
        <div class="stat-label">@(roleFilter == "Student" ? "Sinh viên đủ điều kiện" : "Tổng người dùng")</div>
        <div class="stat-number">@(ViewBag.TotalUsers ?? 0)</div>
    </div>
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon amber"><i class="fa-solid fa-envelope-open"></i></div>
            <span class="stat-badge amber">Chưa xác thực</span>
        </div>
        <div class="stat-label">Chưa xác thực email</div>
        <div class="stat-number">@(ViewBag.NewUsers ?? 0)</div>
    </div>
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon @(roleFilter == "Student" ? "purple" : "green")">
                <i class="fa-solid @(roleFilter == "Student" ? "fa-circle-check" : "fa-user-check")"></i>
            </div>
            <span class="stat-badge @(roleFilter == "Student" ? "purple" : "green")">
                @(roleFilter == "Student" ? "Hoàn thành" : "Đã xác thực")
            </span>
        </div>
        <div class="stat-label">@(roleFilter == "Student" ? "Đã hoàn thành KLTN" : roleFilter == "Lecturer" ? "Giảng viên xác thực" : "Giảng viên xác thực")</div>
        <div class="stat-number">@(roleFilter == "Student" ? (ViewBag.CompletedStudents ?? 0) : (ViewBag.VerifiedLecturers ?? 0))</div>
    </div>
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon red"><i class="fa-solid fa-user-lock"></i></div>
            <span class="stat-badge red">Bị khóa</span>
        </div>
        <div class="stat-label">Tài khoản bị khóa</div>
        <div class="stat-number">@(ViewBag.LockedAccounts ?? 0)</div>
    </div>
</div>

<form method="get" asp-action="UserManagement">
    <div class="filter-card">
        <div class="filter-group filter-group--grow">
            <span class="filter-label">Lọc theo từ khoá</span>
            <div class="search-wrap">
                <i class="fa-solid fa-magnifying-glass search-ico"></i>
                <input type="text" name="search" value="@ViewBag.Search"
                       class="search-input"
                       placeholder="Tên, Email, Mã định danh..." />
            </div>
        </div>

        @if (string.IsNullOrEmpty(roleFilter))
        {
            <div class="filter-group">
                <span class="filter-label">Vai trò</span>
                <select name="role" class="f-select">
                    <option value="">Tất cả vai trò</option>
                    <option value="Student" selected="@(ViewBag.RoleFilter == "Student")">Sinh viên</option>

                    <option value="Lecturer" selected="@(ViewBag.RoleFilter == "Lecturer")">Giảng viên</option>

                    <option value="Admin" selected="@(ViewBag.RoleFilter == "Admin")">Admin</option>
                </select>
            </div>
        }
        else
        {
            <input type="hidden" name="role" value="@roleFilter" />
        }

        <div class="filter-group">
            <span class="filter-label">Khoa</span>
            <select name="faculty" class="f-select js-auto-submit">
                <option value="">Tất cả khoa</option>
                @foreach (var faculty in faculties)
                {
                    <option value="@faculty" selected="@(selectedFaculty == faculty)">@faculty</option>
                }
            </select>
        </div>

        <div class="filter-group">
            <span class="filter-label">Ngành / Bộ môn</span>
            <select name="majorId" class="f-select js-auto-submit">
                <option value="">Tất cả ngành</option>
                @foreach (var major in majors.Where(m => string.IsNullOrWhiteSpace(selectedFaculty)
                    || string.Equals(m.FacultyName, selectedFaculty, StringComparison.OrdinalIgnoreCase)))
                {
                    <option value="@major.Id" selected="@(selectedMajorId == major.Id)">
                        @major.Name
                    </option>
                }
            </select>
        </div>

        <div class="filter-group">
            <span class="filter-label filter-label--hidden">—</span>
            <button type="submit" class="btn btn-primary filter-button">
                <i class="fa-solid fa-magnifying-glass"></i> Tìm kiếm
            </button>
        </div>

        <div class="filter-group">
            <span class="filter-label filter-label--hidden">—</span>
            <a href="@Url.Action("UserManagement", new { role = roleFilter })" class="btn btn-ghost filter-button">
                <i class="fa-solid fa-rotate-left"></i> Làm mới
            </a>
        </div>
    </div>
</form>

<div class="main-card">
    <div class="card-head">
        <h3 class="card-head-title">
            <i class="fa-solid fa-list card-head-icon"></i>
            Danh sách @(roleFilter == "Student" ? "sinh viên" : roleFilter == "Lecturer" ? "giảng viên" : "người dùng")
        </h3>
        <span class="result-count">
            Hiển thị <b>@Model.Count()</b> / <b>@(ViewBag.TotalUsers ?? 0)</b> người dùng
        </span>
    </div>

    <div class="table-scroll">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Họ tên & Email</th>
                    <th>MSSV / MSGV</th>
                    <th>Khoa / Học vị</th>
                    <th class="text-center">Vai trò</th>
                    <th>Trạng thái</th>
                    <th class="text-right action-head">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <i class="fa-regular fa-users"></i>
                                <p>Không tìm thấy người dùng nào phù hợp.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var user in Model)
                    {
                        var role      = userRoles != null && userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : "Student";
                        var roleLbl   = role == "Admin" ? "Admin" : role == "Lecturer" ? "Giảng viên" : "Sinh viên";
                        var roleCls   = role == "Admin" ? "admin" : role == "Lecturer" ? "lecturer" : "student";
                        var roleIco   = role == "Admin"    ? "fa-solid fa-shield-halved"
                                      : role == "Lecturer" ? "fa-solid fa-chalkboard-user"
                                      : "fa-solid fa-graduation-cap";
                        bool isLocked = user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.Now;

                        string avatarUrl = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(user.FullName ?? user.UserName ?? "U")}&background=6366f1&color=fff&bold=true&size=80&rounded=true";

                        <tr>
                            <!-- Họ tên -->
                            <td>
                                <div class="user-cell">
                                    <img class="u-avatar" src="@avatarUrl" alt="@user.FullName" />
                                    <div>
                                        <div class="u-name">@(user.FullName ?? user.UserName)</div>
                                        <div class="u-email">@user.Email</div>
                                    </div>
                                </div>
                            </td>

                            <!-- Mã -->
                            <td>
                                @if (!string.IsNullOrEmpty(user.UserCode))
                                {
                                    <span class="code-badge">@user.UserCode</span>
                                }
                                else
                                {
                                    <span class="empty-code">—</span>
                                }
                            </td>

                            <!-- Khoa / Học vị -->
                            <td>
                                <div class="dept-name">@(user.Faculty ?? "Chưa rõ")</div>
                                @if (userMajorNames.TryGetValue(user.Id, out var majorNames) && !string.IsNullOrWhiteSpace(majorNames))
                                {
                                    <div class="dept-sub">@majorNames</div>
                                }
                                @if (role == "Lecturer")
                                {
                                    <div class="dept-sub">
                                        <i class="fa-solid fa-graduation-cap degree-icon"></i>
                                        @(user.Degree ?? "Giảng viên")
                                    </div>
                                }
                            </td>

                            <!-- Vai trò -->
                            <td class="text-center">
                                <span class="role-badge @roleCls">
                                    <i class="@roleIco role-badge-icon"></i>
                                    @roleLbl
                                </span>
                            </td>

                            <!-- Trạng thái -->
                            <td>
                                <div class="status-wrap">
                                    <span class="s-dot @(isLocked ? "locked" : "active")"></span>
                                    <span class="s-txt @(isLocked ? "locked" : "active")">
                                        @(isLocked ? "Đã khóa" : "Hoạt động")
                                    </span>
                                </div>
                                @if (role == "Student" && user.HasCompletedThesis)
                                {
                                    <div class="status-wrap status-wrap--spaced">
                                        <span class="s-dot done"></span>
                                        <span class="s-txt done">Đã hoàn thành KLTN</span>
                                    </div>
                                }
                            </td>

                            <!-- Thao tác -->
                            <td class="text-right">
                                <div class="act-group">
                                    <!-- Phân quyền -->
                                    <button type="button" class="act-btn role-btn" title="Phân quyền"
                                            data-role-user-id="@user.Id"
                                            data-role-user-name="@user.FullName"
                                            data-role-current="@role">
                                        <i class="fa-solid fa-user-gear"></i>
                                    </button>

                                    <!-- Khóa / Mở khóa -->
                                    <form id="lockForm-@user.Id" asp-action="ToggleLockUser" asp-controller="Admin"
                                          asp-route-role="@roleFilter" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="search" value="@ViewBag.Search" />
                                        <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
                                        <input type="hidden" name="faculty" value="@ViewBag.FacultyFilter" />
                                        <input type="hidden" name="majorId" value="@ViewBag.MajorFilter" />
                                        <button type="button" title="@(isLocked ? "Mở khóa" : "Khóa")"
                                                class="act-btn @(isLocked ? "unlock-btn" : "lock-btn")"
                                                data-lock-form-id="lockForm-@user.Id"
                                                data-lock-user-name="@user.FullName"
                                                data-is-locked="@isLocked">
                                            <i class="fa-solid @(isLocked ? "fa-lock-open" : "fa-lock")"></i>
                                        </button>
                                    </form>

                                    <!-- Reset mật khẩu -->
                                    <button type="button"
                                            class="act-btn reset-btn"
                                            title="Reset mật khẩu"
                                            data-reset-user-id="@user.Id"
                                            data-reset-user-name="@user.FullName"
                                            data-reset-user-email="@user.Email"
                                            data-reset-user-code="@user.UserCode">
                                        <i class="fa-solid fa-key"></i>
                                    </button>

                                    @if (role == "Student")
                                    {
                                        <form asp-action="ToggleThesisCompletion" asp-controller="Admin"
                                              asp-route-role="@roleFilter" method="post" class="inline-form js-confirm-submit"
                                              data-confirm-message="@(user.HasCompletedThesis ? "Mở lại quyền tham gia KLTN cho sinh viên này?" : "Đánh dấu sinh viên này đã hoàn thành KLTN và chặn tham gia đợt sau?")">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <input type="hidden" name="search" value="@ViewBag.Search" />
                                            <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
                                            <input type="hidden" name="faculty" value="@ViewBag.FacultyFilter" />
                                            <input type="hidden" name="majorId" value="@ViewBag.MajorFilter" />
                                            <button type="submit" class="act-btn done-btn"
                                                    title="@(user.HasCompletedThesis ? "Mở lại quyền KLTN" : "Đánh dấu hoàn thành KLTN")">
                                                <i class="fa-solid @(user.HasCompletedThesis ? "fa-rotate-left" : "fa-circle-check")"></i>
                                            </button>
                                        </form>
                                    }

                                    <!-- Xóa -->
                                    <form id="delForm-@user.Id" asp-action="DeleteUser" asp-controller="Admin"
                                          asp-route-role="@roleFilter" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="search" value="@ViewBag.Search" />
                                        <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
                                        <input type="hidden" name="faculty" value="@ViewBag.FacultyFilter" />
                                        <input type="hidden" name="majorId" value="@ViewBag.MajorFilter" />
                                        <button type="button" class="act-btn del-btn" title="Xóa tài khoản"
                                                data-delete-form-id="delForm-@user.Id"
                                                data-delete-user-name="@user.FullName">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- PAGINATION -->
    @if ((int)(ViewBag.TotalPages ?? 1) > 1)
    {
        <div class="paging-wrap">
            <div class="paging-info">
                Trang <b>@ViewBag.CurrentPage</b> / <b>@ViewBag.TotalPages</b>
                &nbsp;·&nbsp; <b>@ViewBag.TotalUsers</b> người dùng
            </div>
            <div class="paging-btns">
                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    <a href="@Url.Action("UserManagement", new { page = i, search = ViewBag.Search, role = ViewBag.RoleFilter, faculty = ViewBag.FacultyFilter, majorId = ViewBag.MajorFilter })"
                       class="pg-btn @((int)ViewBag.CurrentPage == i ? "active" : "")">@i</a>
                }
            </div>
        </div>
    }
</div>

<!-- ════════════════════════════════
     MODAL: PHÂN QUYỀN
════════════════════════════════ -->
<div id="roleModal" class="modal-overlay" data-dismiss-modal="roleModal">
    <div class="modal-box">
        <div class="m-head">
            <div class="m-ico blue"><i class="fa-solid fa-user-gear"></i></div>
            <div>
                <div class="m-title">Phân quyền người dùng</div>
                <div class="m-sub" id="roleModalName">—</div>
            </div>
        </div>

        <form asp-action="ChangeUserRole" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="roleModalUid" name="userId" />
            <input type="hidden" name="role" value="@roleFilter" />
            <input type="hidden" name="search" value="@ViewBag.Search" />
            <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
            <input type="hidden" name="faculty" value="@ViewBag.FacultyFilter" />
            <input type="hidden" name="majorId" value="@ViewBag.MajorFilter" />

            <div class="role-radio-wrap" id="roleRadioWrap">
                @foreach (var (rv, rl, rc, ri) in new[] {
                    ("Student",  "Sinh viên",  "student",  "fa-solid fa-graduation-cap"),
                    ("Lecturer", "Giảng viên", "lecturer", "fa-solid fa-chalkboard-user"),
                    ("Admin",    "Admin",       "admin",    "fa-solid fa-shield-halved"),
                })
                {
                    <label class="role-radio-card">
                        <input type="radio" name="newRole" value="@rv" />
                        <span class="role-badge @rc role-badge--modal">
                            <i class="@ri role-badge-icon"></i> @rl
                        </span>
                        <i class="fa-solid fa-chevron-right rrc-chevron"></i>
                    </label>
                }
            </div>

            <div class="m-foot">
                <button type="button" class="btn-m cancel" data-close-modal="roleModal">Hủy</button>
                <button type="submit" class="btn-m blue">
                    <i class="fa-solid fa-save modal-button-icon"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ════════════════════════════════
     MODAL: KHÓA / MỞ KHÓA
════════════════════════════════ -->
<div id="lockModal" class="modal-overlay" data-dismiss-modal="lockModal">
    <div class="modal-box">
        <div class="m-head">
            <div class="m-ico red" id="lockIco"><i class="fa-solid fa-lock"></i></div>
            <div>
                <div class="m-title" id="lockTitle">Khóa tài khoản</div>
                <div class="m-sub" id="lockSub">—</div>
            </div>
        </div>
        <div class="m-info" id="lockInfo"></div>
        <div class="m-foot">
            <button type="button" class="btn-m cancel" data-close-modal="lockModal">Hủy</button>
            <button type="button" class="btn-m red" id="lockConfirm">Xác nhận</button>
        </div>
    </div>
</div>

<!-- ════════════════════════════════
     MODAL: XÓA TÀI KHOẢN
════════════════════════════════ -->
<div id="deleteModal" class="modal-overlay" data-dismiss-modal="deleteModal">
    <div class="modal-box">
        <div class="m-head">
            <div class="m-ico red"><i class="fa-solid fa-trash"></i></div>
            <div>
                <div class="m-title">Xóa tài khoản</div>
                <div class="m-sub" id="deleteSub">—</div>
            </div>
        </div>
        <div class="m-info">
            Bạn có chắc muốn <strong>xóa vĩnh viễn</strong> tài khoản này?
            Toàn bộ dữ liệu liên quan sẽ bị mất và <strong>không thể hoàn tác</strong>.
        </div>
        <div class="m-foot">
            <button type="button" class="btn-m cancel" data-close-modal="deleteModal">Hủy</button>
            <button type="button" class="btn-m red" id="deleteConfirm">
                <i class="fa-solid fa-trash modal-button-icon"></i> Xóa tài khoản
            </button>
        </div>
    </div>
</div>

<!-- ════════════════════════════════
     MODAL: RESET MẬT KHẨU
════════════════════════════════ -->
<div id="resetModal" class="modal-overlay" data-dismiss-modal="resetModal">
    <div class="modal-box">
        <div class="m-head">
            <div class="m-ico red"><i class="fa-solid fa-key"></i></div>
            <div>
                <div class="m-title">Reset mật khẩu</div>
                <div class="m-sub" id="resetSub">—</div>
            </div>
        </div>

        <form id="resetPasswordForm" asp-action="ResetPassword" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="resetUserId" name="userId" />
            <input type="hidden" name="role" value="@roleFilter" />
            <input type="hidden" name="search" value="@ViewBag.Search" />
            <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
            <input type="hidden" name="faculty" value="@ViewBag.FacultyFilter" />
            <input type="hidden" name="majorId" value="@ViewBag.MajorFilter" />

            <div class="reset-mode-grid">
                <label class="reset-mode-card checked">
                    <input type="radio" name="useRandomPassword" value="true" checked />
                    <span class="reset-mode-dot"></span>
                    <span>
                        <strong>Ngẫu nhiên</strong>
                        <small>Hệ thống tự sinh</small>
                    </span>
                </label>
                <label class="reset-mode-card">
                    <input type="radio" name="useRandomPassword" value="false" />
                    <span class="reset-mode-dot"></span>
                    <span>
                        <strong>Tùy chỉnh</strong>
                        <small>Nhập mật khẩu mới</small>
                    </span>
                </label>
            </div>

            <div id="resetCustomPasswordWrap" class="m-field reset-custom-password is-hidden">
                <label class="m-label">Mật khẩu mới</label>
                <input type="password" name="newPassword" id="resetNewPassword" class="m-input"
                       placeholder="Tối thiểu 8 ký tự, có chữ hoa, số và ký tự đặc biệt" />
            </div>

            <div class="m-info reset-warning">
                Thao tác này sẽ đăng xuất người dùng khỏi tất cả thiết bị và tạo mật khẩu mới cho tài khoản.
            </div>

            <div id="resetResult" class="reset-result is-hidden">
                <div>
                    <span>Mật khẩu tạm thời</span>
                    <strong id="resetTempPassword"></strong>
                </div>
                <button type="button" class="btn-copy" data-copy-reset-password>Copy</button>
            </div>

            <div class="m-foot">
                <button type="button" class="btn-m cancel" data-close-modal="resetModal">Hủy</button>
                <button type="submit" class="btn-m red" id="resetSubmit">
                    <i class="fa-solid fa-rotate modal-button-icon"></i> Xác nhận Reset
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ════════════════════════════════
     MODAL: THÊM NGƯỜI DÙNG
════════════════════════════════ -->
<div id="createModal" class="modal-overlay" data-dismiss-modal="createModal">
    <div class="modal-box wide">
        <div class="m-head">
            <div class="m-ico green"><i class="fa-solid fa-user-plus"></i></div>
            <div>
                <div class="m-title">@addLabel</div>
                <div class="m-sub">Điền đầy đủ thông tin bên dưới</div>
            </div>
        </div>

        <form asp-action="CreateUser" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()

            <div class="m-grid2">
                <div class="m-field">
                    <label class="m-label">Họ và tên <span class="required-mark">*</span></label>
                    <input type="text" name="fullName" class="m-input" placeholder="Nguyễn Văn A" required />
                </div>
                <div class="m-field">
                    <label class="m-label">MSSV / MSGV <span class="required-mark">*</span></label>
                    <input type="text" name="userCode" class="m-input" placeholder="SV001 / GV001" required />
                </div>
            </div>

            <div class="m-field">
                <label class="m-label">Email <span class="required-mark">*</span></label>
                <input type="email" name="email" class="m-input" placeholder="example@edu.vn" required />
            </div>

            <div class="m-field">
                <label class="m-label">Chuyên ngành / Khoa</label>
                <select name="majorIds" multiple size="4" class="m-multiselect">
                    @foreach (var major in majors)
                    {
                        <option value="@major.Id">
                            @major.Name @(!string.IsNullOrWhiteSpace(major.FacultyName) ? $"· {major.FacultyName}" : "")
                        </option>
                    }
                </select>
                <div class="m-hint">Giữ Ctrl để chọn nhiều chuyên ngành. Sinh viên nên chọn 1 ngành.</div>
            </div>

            @if (!string.IsNullOrEmpty(roleFilter))
            {
                <input type="hidden" name="role" value="@roleFilter" />
            }
            else
            {
                <div class="m-field">
                    <label class="m-label">Vai trò</label>
                    <select name="role" class="m-select">
                        <option value="Student">Sinh viên</option>
                        <option value="Lecturer">Giảng viên</option>
                        <option value="Admin">Quản trị viên</option>
                    </select>
                </div>
            }

            @if (roleFilter == "Lecturer")
            {
                <div class="m-grid2">
                    <div class="m-field">
                        <label class="m-label">Trình độ</label>
                        <select name="degree" class="m-select">
                            <option value="Thạc sĩ">Thạc sĩ</option>
                            <option value="Tiến sĩ">Tiến sĩ</option>
                            <option value="PGS.TS">PGS.TS</option>
                            <option value="GS.TS">GS.TS</option>
                        </select>
                    </div>
                    <div class="m-field">
                        <label class="m-label">Chức vụ</label>
                        <input type="text" name="position" class="m-input" placeholder="Giảng viên / Trưởng bộ môn" />
                    </div>
                </div>
            }

            <div class="m-foot m-foot--spaced">
                <button type="button" class="btn-m cancel" data-close-modal="createModal">Hủy</button>
                <button type="submit" class="btn-m green">
                    <i class="fa-solid fa-user-plus modal-button-icon"></i> Tạo tài khoản
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/user-management.js" asp-append-version="true"></script>
}
