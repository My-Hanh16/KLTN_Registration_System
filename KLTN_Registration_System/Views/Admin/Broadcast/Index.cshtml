@* ============================================================
   FILE: Views/Admin/Broadcast/Index.cshtml
   LAYOUT: _LayoutDashboard  ← giữ nguyên, KHÔNG Layout = null
   ============================================================ *@
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Broadcast thông báo";
    string selectedPeriodName = ViewBag.SelectedPeriodName?.ToString() ?? ViewBag.AdminSelectedPeriodName?.ToString() ?? "đợt đang mở";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/broadcast-index.css" asp-append-version="true" />
}

<!-- ════════════════════════════════════════
     PAGE HEADER
════════════════════════════════════════ -->
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="page-title">Broadcast thông báo</h2>
        <p class="page-sub">Gửi thông báo theo đợt @selectedPeriodName. Nhóm sinh viên chỉ gồm sinh viên đủ điều kiện của đợt này.</p>
    </div>
</div>

<!-- ALERTS -->
@if (TempData["Error"] != null)
{
    <div class="alert-bar error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<!-- STATS ROW -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fa-solid fa-users"></i></div>
        <div>
            <div class="stat-label">Tổng người dùng</div>
            <div class="stat-number">@(ViewBag.TotalUsers ?? 0)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-graduation-cap"></i></div>
        <div>
            <div class="stat-label">Sinh viên đợt này</div>
            <div class="stat-number">@(ViewBag.TotalStudents ?? 0)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple"><i class="fa-solid fa-chalkboard-user"></i></div>
        <div>
            <div class="stat-label">Giảng viên</div>
            <div class="stat-number">@(ViewBag.TotalLecturers ?? 0)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fa-solid fa-paper-plane"></i></div>
        <div>
            <div class="stat-label">Đã gửi hôm nay</div>
            <div class="stat-number">@(ViewBag.SentToday ?? 0)</div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════
     MAIN GRID
════════════════════════════════════════ -->
<div class="bc-grid">

    <!-- ══ LEFT: FORM ══ -->
    <div class="bc-card">
        <div class="bc-card-head">
            <h3 class="bc-card-title">
                <i class="fa-regular fa-pen-to-square bc-card-title-icon"></i>
                Soạn thông báo
            </h3>
            <button type="button" class="btn-ghost" id="btnPreview">
                <i class="fa-regular fa-eye"></i> Xem trước
            </button>
        </div>

        <div class="bc-card-body">
            <form method="post" asp-action="Send" asp-controller="Broadcast"
                  id="bcForm" novalidate>
                @Html.AntiForgeryToken()

                <!-- 1. GỬI ĐẾN -->
                <div class="f-section">
                    <label class="f-label">Gửi đến</label>
                    <div class="tg-grid">
                        @{
                            var targets = new[]
                            {
                                                ("all",      "Tất cả",     "fa-solid fa-users",           ViewBag.TotalUsers?.ToString()     ?? "0"),
                                                ("student",  "Sinh viên",  "fa-solid fa-graduation-cap",  ViewBag.TotalStudents?.ToString()  ?? "0"),
                                                ("lecturer", "Giảng viên", "fa-solid fa-chalkboard-user", ViewBag.TotalLecturers?.ToString() ?? "0"),
                                                };
                        }
                        @foreach (var (val, lbl, ico, cnt) in targets)
                        {
                            <div class="tg-card @(val == "all" ? "sel" : "")"
                                 id="tc-@val" data-target-value="@val">
                                <input type="radio" name="target" value="@val"
                                       @(val == "all" ? "checked" : "") />
                                <div class="tg-check">
                                    <i class="fa-solid fa-check target-check-icon"></i>
                                </div>
                                <div class="tg-icon">
                                    <i class="@ico"></i>
                                </div>
                                <div class="tg-name">@lbl</div>
                                <div class="tg-count">@cnt người</div>
                            </div>
                        }
                    </div>
                </div>

                <!-- 2. LOẠI THÔNG BÁO -->
                <div class="f-section">
                    <label class="f-label">Loại thông báo</label>
                    <div class="f-wrap">
                        <i class="fa-regular fa-bell f-ico type-icon" id="typeIco"></i>
                        <select name="type" class="f-select" id="typeSelect">
                            <option value="System">🔔  Thông báo hệ thống</option>
                            <option value="SystemAlert">⚠️  Cảnh báo quan trọng</option>
                            <option value="Deadline">⏰  Nhắc nhở deadline</option>
                        </select>
                    </div>
                </div>

                <!-- 3. TIÊU ĐỀ -->
                <div class="f-section">
                    <label class="f-label">
                        Tiêu đề <span class="req">*</span>
                    </label>
                    <div class="f-wrap">
                        <i class="fa-solid fa-pen f-ico"></i>
                        <input type="text" name="title" id="titleInput"
                               required maxlength="120"
                               placeholder="VD: Thông báo gia hạn đăng ký đề tài"
                               class="f-input" />
                    </div>
                    <div class="char-row">
                        <span class="char-hint">Tối đa 120 ký tự</span>
                        <span class="char-ct" id="titleCt">0 / 120</span>
                    </div>
                </div>

                <!-- 4. NỘI DUNG -->
                <div class="f-section">
                    <label class="f-label">
                        Nội dung <span class="req">*</span>
                    </label>
                    <textarea name="content" id="contentInput"
                              required rows="5" maxlength="500"
                              placeholder="Nhập nội dung thông báo chi tiết để sinh viên / giảng viên nắm rõ..."
                              class="f-textarea"></textarea>
                    <div class="char-row">
                        <span class="char-hint">Tối đa 500 ký tự</span>
                        <span class="char-ct" id="contentCt">0 / 500</span>
                    </div>
                </div>

                <!-- 5. LINK ĐIỀU HƯỚNG -->
                <div class="f-section">
                    <label class="f-label">
                        Link điều hướng
                        <span class="opt">(tuỳ chọn — người dùng bấm vào thông báo sẽ được dẫn đến trang này)</span>
                    </label>
                    <div class="f-wrap">
                        <i class="fa-solid fa-link f-ico"></i>
                        <input type="text" name="redirectUrl"
                               placeholder="VD: /Student/MyRegistration"
                               class="f-input" />
                    </div>
                </div>

                <!-- LIVE PREVIEW (ẩn mặc định) -->
                <div class="preview-box" id="previewBox">
                    <div class="preview-lbl">Xem trước thông báo</div>
                    <div class="preview-row">
                        <div class="preview-ni preview-ni--system" id="previewIco">
                            <i class="fa-regular fa-bell"></i>
                        </div>
                        <div class="preview-content">
                            <div class="preview-title" id="previewTitle">
                                <span class="placeholder-tx">Tiêu đề sẽ hiển thị ở đây...</span>
                            </div>
                            <div class="preview-body" id="previewBody">
                                <span class="placeholder-tx">Nội dung thông báo...</span>
                            </div>
                            <div class="preview-meta">
                                <i class="fa-regular fa-clock preview-meta-icon"></i>
                                Vừa xong · Gửi bởi Admin
                            </div>
                        </div>
                    </div>
                </div>

                <!-- FORM FOOTER -->
                <div class="f-foot">
                    <span class="f-foot-hint">
                        <i class="fa-solid fa-triangle-exclamation foot-warning-icon"></i>
                        Không thể hoàn tác sau khi gửi.
                    </span>
                    <button type="submit" class="btn-send" id="sendBtn">
                        <div class="send-spinner" id="sendSpinner"></div>
                        <i class="fa-solid fa-paper-plane" id="sendIco"></i>
                        <span id="sendTxt">Gửi thông báo</span>
                    </button>
                </div>

            </form>
        </div>
    </div>

    <!-- ══ RIGHT: SIDEBAR ══ -->
    <div class="sidebar-stack">

        <!-- Thống kê người nhận -->
        <div class="bc-card">
            <div class="bc-card-head">
                <h3 class="bc-card-title">Tổng số người nhận</h3>
            </div>
            <div class="bc-card-body bc-card-body--compact">
                <div class="s-stat">
                    <span class="s-stat-lbl">
                        <span class="s-dot all"></span> Tất cả
                    </span>
                    <span class="s-stat-val">@(ViewBag.TotalUsers ?? 0)</span>
                </div>
                <div class="s-stat">
                    <span class="s-stat-lbl">
                        <span class="s-dot sv"></span> Sinh viên
                    </span>
                    <span class="s-stat-val">@(ViewBag.TotalStudents ?? 0)</span>
                </div>
                <div class="s-stat">
                    <span class="s-stat-lbl">
                        <span class="s-dot gv"></span> Giảng viên
                    </span>
                    <span class="s-stat-val">@(ViewBag.TotalLecturers ?? 0)</span>
                </div>
            </div>
        </div>

        <!-- Đã gửi gần đây -->
        <div class="bc-card">
            <div class="bc-card-head">
                <h3 class="bc-card-title">Đã gửi gần đây</h3>
            </div>
            <div class="bc-card-body bc-card-body--tight">
                @if (ViewBag.RecentBroadcasts != null &&
                                ((IEnumerable<dynamic>)ViewBag.RecentBroadcasts).Any())
                {
                    @foreach (var item in ViewBag.RecentBroadcasts)
                    {
                        string hc = item.Type == "SystemAlert" ? "warn"
                        : item.Type == "Deadline" ? "dead"
                        : "sys";
                        string hico = item.Type == "SystemAlert"
                        ? "fa-solid fa-triangle-exclamation"
                        : item.Type == "Deadline"
                        ? "fa-regular fa-clock"
                        : "fa-regular fa-bell";

                        <div class="hist-item">
                            <div class="hist-ico @hc">
                                <i class="@hico"></i>
                            </div>
                            <div class="hist-main">
                                <div class="hist-name" title="@item.Title">@item.Title</div>
                                <div class="hist-meta">
                                    @item.CreatedAt.ToString("dd/MM HH:mm") · @item.Type
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="hist-empty">
                        <i class="fa-regular fa-bell-slash"></i>
                        Chưa có lịch sử gửi
                    </div>
                }
            </div>
        </div>

        <!-- Danger zone -->
        <div class="danger-zone">
            <div class="danger-title">
                <i class="fa-solid fa-trash-can danger-title-icon"></i>
                Dọn dẹp thông báo cũ
            </div>
            <div class="danger-desc">
                Xóa vĩnh viễn thông báo đã đọc theo thời hạn chọn để giảm tải DB.
                Hành động <strong>không thể hoàn tác</strong>.
            </div>
            <form method="post" asp-action="DeleteOld" asp-controller="Broadcast" class="js-delete-old-form">
                @Html.AntiForgeryToken()
                <select name="daysOld" class="f-select-danger">
                    <option value="30">Cũ hơn 30 ngày</option>
                    <option value="60">Cũ hơn 60 ngày</option>
                    <option value="90">Cũ hơn 90 ngày</option>
                </select>
                <button type="submit" class="btn-danger-full">
                    <i class="fa-solid fa-trash-can"></i>
                    Xóa thông báo cũ
                </button>
            </form>
        </div>

    </div><!-- /sidebar -->
</div><!-- /bc-grid -->
@section Scripts {
    <script id="broadcastFlash" type="application/json">
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
{
    success = TempData["Success"]?.ToString(),
    error = TempData["Error"]?.ToString()
}))
    </script>
    <script src="~/js/admin/broadcast-index.js" asp-append-version="true"></script>
}
