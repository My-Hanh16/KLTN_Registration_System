@* ============================================================
   FILE: Views/Admin/EditTopic.cshtml
   MODEL: Topic  — Admin sửa đề tài trực tiếp (không reset IsApproved)
   ============================================================ *@
@model KLTN_Registration_System.Models.Entities.Topic
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Sửa đề tài (Admin)";
    int approvedCount = ViewBag.ApprovedCount ?? 0;
    int pendingCount = ViewBag.PendingCount ?? 0;
    int activeCount = approvedCount + pendingCount;
    int minStudents = Math.Max(1, activeCount);
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/edit-topic.css" asp-append-version="true" />
}

<div class="edit-topic-page">
    <div class="edit-topic-header">
        <a asp-action="ManageTopics" asp-controller="Admin"
           class="back-link">
            <svg class="back-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
        </a>
        <div>
            <h1 class="edit-topic-title">Sửa đề tài</h1>
            <p class="edit-topic-code">@Model.TopicCode</p>
        </div>
    </div>

    <div class="edit-topic-card">
        <form asp-action="EditTopic" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TopicCode" />
            <input type="hidden" asp-for="CreatedAt" />
            <input type="hidden" asp-for="IsStudentProposed" />
            <input type="hidden" asp-for="CreatedByStudentId" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            @if (TempData["Error"] != null)
            {
                <div class="form-alert form-alert--error">
                    @TempData["Error"]
                </div>
            }

            <div class="topic-summary-grid">
                <div class="summary-card summary-card--code">
                    <div class="summary-label">Mã đề tài</div>
                    <div class="summary-value summary-value--sm">@(Model.TopicCode ?? $"TOPIC-{Model.Id}")</div>
                </div>
                <div class="summary-card summary-card--approved">
                    <div class="summary-label">Đã duyệt</div>
                    <div class="summary-value">@approvedCount</div>
                </div>
                <div class="summary-card summary-card--pending">
                    <div class="summary-label">Chờ duyệt</div>
                    <div class="summary-value">@pendingCount</div>
                </div>
            </div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="Title" class="form-label">
                        Tên đề tài <span class="required">*</span>
                    </label>
                    <input asp-for="Title" required
                           class="form-control" />
                    <span asp-validation-for="Title" class="field-validation"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="form-label">
                        Mô tả <span class="required">*</span>
                    </label>
                    <textarea asp-for="Description" rows="5" required
                              class="form-control"></textarea>
                </div>

                <div class="form-row form-row--2">
                    <div class="form-group">
                        <label asp-for="LecturerId" class="form-label">Giảng viên hướng dẫn</label>
                        <select asp-for="LecturerId" asp-items="ViewBag.Lecturers"
                                class="form-control">
                            <option value="">-- Chưa phân công --</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="MajorId" class="form-label">Chuyên ngành</label>
                        <select asp-for="MajorId" asp-items="ViewBag.Majors"
                                class="form-control">
                            <option value="">-- Không chọn --</option>
                        </select>
                    </div>
                </div>

                <div class="form-row form-row--3">
                    <div class="form-group">
                        <label asp-for="Level" class="form-label">Mức độ</label>
                        <select asp-for="Level" class="form-control">
                            <option value="Easy">Cơ bản</option>
                            <option value="Medium">Trung bình</option>
                            <option value="Hard">Nâng cao</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="MaxStudents" class="form-label">Tối đa SV</label>
                        <input asp-for="MaxStudents" type="number" min="@minStudents" max="10"
                               class="form-control" />
                        @if (activeCount > 0)
                        {
                            <p class="form-hint">Không thể nhỏ hơn @activeCount sinh viên đã duyệt/chờ duyệt.</p>
                        }
                    </div>
                    <div class="form-group">
                        <label asp-for="Status" class="form-label">Trạng thái</label>
                        <select asp-for="Status" class="form-control">
                            <option value="Available">Còn chỗ</option>
                            <option value="Full">Đã đầy</option>
                            <option value="Closed">Đóng</option>
                            <option value="Pending">Chờ duyệt</option>
                        </select>
                    </div>
                </div>

                <div class="form-row form-row--2">
                    <div class="form-group">
                        <label class="form-label">Học kỳ</label>
                        <input value="@Model.Semester" readonly class="form-control form-control--readonly" />
                        <p class="form-hint">Admin đổi đợt hiện hành ở trang Cài đặt, không sửa text học kỳ tại đây.</p>
                    </div>
                    <div class="form-group">
                        <label asp-for="Deadline" class="form-label">Hạn đăng ký</label>
                        <input asp-for="Deadline" type="datetime-local"
                               value="@Model.Deadline.ToString("yyyy-MM-ddTHH:mm")"
                               class="form-control" />
                    </div>
                </div>

                <div class="form-row form-row--2">
                    <div class="form-group">
                        <label asp-for="Category" class="form-label">Phân loại</label>
                        <select asp-for="Category" class="form-control">
                            <option value="Ứng dụng">Ứng dụng</option>
                            <option value="Nghiên cứu">Nghiên cứu</option>
                            <option value="Phân tích">Phân tích</option>
                        </select>
                    </div>
                    <div class="checkbox-row">
                        <label class="checkbox-label">
                            <input asp-for="IsApproved" type="checkbox"
                                   class="checkbox-input" />
                            <span>Đã phê duyệt</span>
                        </label>
                        <label class="checkbox-label">
                            <input asp-for="IsRegistrationOpen" type="checkbox"
                                   class="checkbox-input" />
                            <span>Mở đăng ký</span>
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Note" class="form-label">Ghi chú</label>
                    <textarea asp-for="Note" rows="2"
                              class="form-control"></textarea>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit"
                        class="btn-save">
                    💾 Lưu thay đổi
                </button>
                <a asp-action="ManageTopics" asp-controller="Admin"
                   class="btn-cancel">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
