@* ============================================================
   FILE: Views/Admin/EditTopic.cshtml
   MODEL: Topic  — Admin sửa đề tài trực tiếp (không reset IsApproved)
   ============================================================ *@
@model KLTN_Registration_System.Models.Entities.Topic
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Sửa đề tài (Admin)";
}

<div class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="ThesisManagement" asp-controller="Admin"
           class="p-2 rounded-lg bg-slate-100 hover:bg-slate-200 text-slate-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
        </a>
        <div>
            <h1 class="text-xl font-bold text-slate-800">Sửa đề tài</h1>
            <p class="text-sm text-slate-500">@Model.TopicCode</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
        <form asp-action="EditTopic" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TopicCode" />
            <input type="hidden" asp-for="CreatedAt" />
            <input type="hidden" asp-for="IsStudentProposed" />
            <input type="hidden" asp-for="CreatedByStudentId" />

            <div class="grid grid-cols-1 gap-5">

                <div>
                    <label asp-for="Title" class="block text-sm font-medium text-slate-700 mb-1">
                        Tên đề tài <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Title" required
                           class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    <span asp-validation-for="Title" class="text-red-500 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Description" class="block text-sm font-medium text-slate-700 mb-1">
                        Mô tả <span class="text-red-500">*</span>
                    </label>
                    <textarea asp-for="Description" rows="5" required
                              class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="LecturerId" class="block text-sm font-medium text-slate-700 mb-1">Giảng viên hướng dẫn</label>
                        <select asp-for="LecturerId" asp-items="ViewBag.Lecturers"
                                class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="">-- Chưa phân công --</option>
                        </select>
                    </div>
                    <div>
                        <label asp-for="MajorId" class="block text-sm font-medium text-slate-700 mb-1">Chuyên ngành</label>
                        <select asp-for="MajorId" asp-items="ViewBag.Majors"
                                class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="">-- Không chọn --</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <label asp-for="Level" class="block text-sm font-medium text-slate-700 mb-1">Mức độ</label>
                        <select asp-for="Level" class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="Easy">Cơ bản</option>
                            <option value="Medium">Trung bình</option>
                            <option value="Hard">Nâng cao</option>
                        </select>
                    </div>
                    <div>
                        <label asp-for="MaxStudents" class="block text-sm font-medium text-slate-700 mb-1">Tối đa SV</label>
                        <input asp-for="MaxStudents" type="number" min="1" max="10"
                               class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <div>
                        <label asp-for="Status" class="block text-sm font-medium text-slate-700 mb-1">Trạng thái</label>
                        <select asp-for="Status" class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="Available">Còn chỗ</option>
                            <option value="Full">Đã đầy</option>
                            <option value="Closed">Đóng</option>
                            <option value="Pending">Chờ duyệt</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Semester" class="block text-sm font-medium text-slate-700 mb-1">Học kỳ</label>
                        <input asp-for="Semester" class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <div>
                        <label asp-for="Deadline" class="block text-sm font-medium text-slate-700 mb-1">Hạn đăng ký</label>
                        <input asp-for="Deadline" type="datetime-local"
                               value="@Model.Deadline.ToString("yyyy-MM-ddTHH:mm")"
                               class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Category" class="block text-sm font-medium text-slate-700 mb-1">Phân loại</label>
                        <select asp-for="Category" class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="Ứng dụng">Ứng dụng</option>
                            <option value="Nghiên cứu">Nghiên cứu</option>
                            <option value="Phân tích">Phân tích</option>
                        </select>
                    </div>
                    <div class="flex items-center gap-3 pt-6">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input asp-for="IsApproved" type="checkbox"
                                   class="w-4 h-4 rounded border-slate-300 text-blue-600" />
                            <span class="text-sm font-medium text-slate-700">Đã phê duyệt</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input asp-for="IsRegistrationOpen" type="checkbox"
                                   class="w-4 h-4 rounded border-slate-300 text-blue-600" />
                            <span class="text-sm font-medium text-slate-700">Mở đăng ký</span>
                        </label>
                    </div>
                </div>

                <div>
                    <label asp-for="Note" class="block text-sm font-medium text-slate-700 mb-1">Ghi chú</label>
                    <textarea asp-for="Note" rows="2"
                              class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                </div>
            </div>

            <div class="mt-8 flex gap-3">
                <button type="submit"
                        class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-sm font-semibold">
                    💾 Lưu thay đổi
                </button>
                <a asp-action="ThesisManagement" asp-controller="Admin"
                   class="px-6 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-xl text-sm font-medium">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
