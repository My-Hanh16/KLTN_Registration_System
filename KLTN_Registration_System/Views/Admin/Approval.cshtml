@model IEnumerable<KLTN_Registration_System.Models.Entities.Registration>
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Duyệt đăng ký";

    // Fix: lấy status filter từ query string, default Pending
    string currentStatus = Context.Request.Query["status"].ToString();
    if (string.IsNullOrEmpty(currentStatus)) currentStatus = "Pending";
    string selectedSemester = Context.Request.Query["semester"].ToString();
    string selectedYear = Context.Request.Query["year"].ToString();
    string selectedPeriodName = ViewBag.SelectedPeriodName as string ?? "";
    string search = ViewBag.Search as string ?? Context.Request.Query["search"].ToString();
    string selectedFaculty = ViewBag.FacultyFilter as string ?? Context.Request.Query["faculty"].ToString();
    int? selectedMajorId = ViewBag.MajorFilter as int?;
    if (!selectedMajorId.HasValue && int.TryParse(Context.Request.Query["majorId"], out var queryMajorId))
    {
        selectedMajorId = queryMajorId;
    }
    var faculties = ViewBag.Faculties as IEnumerable<string> ?? Enumerable.Empty<string>();
    var majors = ViewBag.Majors as IEnumerable<KLTN_Registration_System.Models.Entities.Major>
                 ?? Enumerable.Empty<KLTN_Registration_System.Models.Entities.Major>();

    // Filter model theo status
    var filtered = Model.Where(r =>
        string.Equals(r.Status, currentStatus, StringComparison.OrdinalIgnoreCase)
    ).ToList();

    var groupedRegistrations = filtered
        .GroupBy(r => new { r.TopicId, r.CreatedAt })
        .Select(g => new
        {
            TopicId = g.Key.TopicId,
            CreatedAt = g.Key.CreatedAt,
            Topic = g.First().Topic,
            Items = g.OrderBy(r => r.Id).ToList()
        })
        .OrderByDescending(g => g.CreatedAt)
        .ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/approval.css" asp-append-version="true" />
}

@if (TempData["Success"] != null)
{
    <div class="alert-bar success">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["Success"]</span>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-bar error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
    <div>
        <h2 class="page-title">Duyệt đăng ký đề tài</h2>
        <p class="page-sub">
            Xử lý các yêu cầu đăng ký thực hiện luận văn từ sinh viên
            @if (!string.IsNullOrWhiteSpace(selectedPeriodName))
            {
                <span> trong đợt @selectedPeriodName</span>
            }
            .
        </p>
    </div>

    <!-- Fix: filter tabs dùng href thay vì button thuần -->
    <div class="filter-tabs">
        <a href="@Url.Action("Approval", "Admin", new { status = "Pending", semester = selectedSemester, year = selectedYear, search, faculty = selectedFaculty, majorId = selectedMajorId })"
           class="filter-tab @(currentStatus == "Pending" ? "active" : "")">
            Chờ duyệt
            <span class="tab-count">@Model.Count(r => r.Status == "Pending")</span>
        </a>
        <a href="@Url.Action("Approval", "Admin", new { status = "Approved", semester = selectedSemester, year = selectedYear, search, faculty = selectedFaculty, majorId = selectedMajorId })"
           class="filter-tab @(currentStatus == "Approved" ? "active" : "")">
            Đã duyệt
            <span class="tab-count">@Model.Count(r => r.Status == "Approved")</span>
        </a>
        <a href="@Url.Action("Approval", "Admin", new { status = "Rejected", semester = selectedSemester, year = selectedYear, search, faculty = selectedFaculty, majorId = selectedMajorId })"
           class="filter-tab @(currentStatus == "Rejected" ? "active" : "")">
            Từ chối
            <span class="tab-count">@Model.Count(r => r.Status == "Rejected")</span>
        </a>
    </div>
</div>

<form method="get" asp-action="Approval" asp-controller="Admin" class="approval-filter-bar">
    <input type="hidden" name="status" value="@currentStatus" />
    <input type="hidden" name="semester" value="@selectedSemester" />
    <input type="hidden" name="year" value="@selectedYear" />

    <div class="approval-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" name="search" value="@search" placeholder="Tìm sinh viên, MSSV, đề tài..." />
    </div>

    <select name="faculty" class="approval-filter-select js-approval-auto-submit">
        <option value="">Tất cả khoa</option>
        @foreach (var faculty in faculties)
        {
            <option value="@faculty" selected="@(selectedFaculty == faculty)">@faculty</option>
        }
    </select>

    <select name="majorId" class="approval-filter-select js-approval-auto-submit">
        <option value="">Tất cả chuyên ngành</option>
        @foreach (var major in majors)
        {
            <option value="@major.Id" selected="@(selectedMajorId == major.Id)">
                @major.Name
            </option>
        }
    </select>

    <button type="submit" class="btn-filter-apply">
        <i class="fa-solid fa-filter"></i>
        Lọc
    </button>
    <a href="@Url.Action("Approval", "Admin", new { status = currentStatus, semester = selectedSemester, year = selectedYear })"
       class="btn-filter-reset">
        <i class="fa-solid fa-rotate-left"></i>
    </a>
</form>

<!-- STATS -->
<div class="stats-grid">

    <div class="stat-card">
        <div class="stat-icon blue">
            <i class="fa-solid fa-clock-rotate-left"></i>
        </div>
        <div class="stat-label">Yêu cầu chờ duyệt</div>
        <div class="stat-number">@Model.Count(r => r.Status == "Pending")</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon green">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <div class="stat-label">Đã phê duyệt</div>
        <div class="stat-number">@(ViewBag.ApprovedCount ?? Model.Count(r => r.Status == "Approved"))</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon orange">
            <i class="fa-solid fa-users"></i>
        </div>
        <div class="stat-label">Tổng số đăng ký</div>
        <div class="stat-number">@(ViewBag.TotalRegistrations ?? Model.Count())</div>
    </div>

</div>

<!-- TABLE -->
<div class="table-card">

    <div class="table-header">
        <h3 class="table-title">
            Danh sách —
            @if (currentStatus == "Pending")
            {
                <span class="table-status table-status--pending">chờ xử lý</span>
            }
            else if (currentStatus == "Approved")
            {

                <span class="table-status table-status--approved">đã duyệt</span>
            }
            else
            {

                <span class="table-status table-status--rejected">đã từ chối</span>
            }
        </h3>
        <div class="table-actions">
            @if (currentStatus == "Pending" && filtered.Any())
            {
                <form asp-controller="Admin" asp-action="ApproveAllRegistrations" method="post" class="m-0 js-approve-all-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="semester" value="@selectedSemester" />
                    <input type="hidden" name="year" value="@selectedYear" />
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="faculty" value="@selectedFaculty" />
                    <input type="hidden" name="majorId" value="@selectedMajorId" />
                    <button type="submit" class="btn-approve-all">
                        <i class="fa-solid fa-check-double"></i>
                        Duyệt tất cả
                    </button>
                </form>
            }
            <span class="table-meta">@groupedRegistrations.Count nhóm / @filtered.Count sinh viên</span>
        </div>
    </div>

    <div class="table-scroll">
        <table class="approval-table">
            <thead>
                <tr>
                    <th class="topic-col">Đề tài & Nhóm sinh viên</th>
                    <th>Thông tin sinh viên</th>
                    <th>Ngày đăng ký</th>
                    <th class="text-end action-col">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!groupedRegistrations.Any())
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <i class="fa-regular fa-folder-open"></i>
                                <p>Không có yêu cầu nào ở trạng thái này.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var group in groupedRegistrations)
                    {
                        var firstItem = group.Items.First();
                        bool isGroup = group.Items.Count > 1;

                        <tr>
                            <td>
                                <div class="topic-name">@group.Topic?.Title</div>
                                <div class="topic-meta-line">
                                    <span>@(group.Topic?.Major?.FacultyName ?? group.Topic?.Faculty ?? "Chưa có khoa")</span>
                                    <span>•</span>
                                    <span>@(group.Topic?.Major?.Name ?? group.Topic?.DepartmentName ?? "Chưa có ngành")</span>
                                </div>
                                <div class="group-summary">
                                    <span class="group-badge @(isGroup ? "group-badge--team" : "group-badge--single")">
                                        <i class="fa-solid @(isGroup ? "fa-users" : "fa-user")"></i>
                                        @(isGroup ? $"Nhóm {group.Items.Count} sinh viên" : "Đăng ký cá nhân")
                                    </span>
                                    @if (group.Topic?.MaxStudents > 1)
                                    {
                                        <span class="slot-text">@group.Items.Count / @group.Topic.MaxStudents chỗ</span>
                                    }
                                </div>
                                <div class="student-list">
                                    @foreach (var item in group.Items)
                                    {
                                        <div class="student-chip">
                                            <i class="fa-regular fa-user"></i>
                                            @(item.Student?.FullName ?? item.Student?.UserName ?? "N/A")
                                        </div>
                                    }
                                </div>
                            </td>

                            <td>
                                <div class="student-contact-list">
                                    @foreach (var item in group.Items)
                                    {
                                        <div class="student-contact">
                                            <span class="email-badge">@(item.Student?.Email ?? "—")</span>
                                            @if (!string.IsNullOrEmpty(item.Student?.UserCode))
                                            {
                                                <span class="mssv-badge">@item.Student.UserCode</span>
                                            }
                                            <span class="student-major-badge">
                                                @(item.Student?.Faculty ?? item.Student?.Major?.FacultyName ?? "Chưa có khoa")
                                                @if (!string.IsNullOrWhiteSpace(item.Student?.Major?.Name))
                                                {
                                                    <span>• @item.Student.Major.Name</span>
                                                }
                                            </span>
                                        </div>
                                    }
                                </div>
                            </td>

                            <td>
                                <span class="date-text">@group.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </td>

                            <td class="text-end row-action-cell">
                                @if (currentStatus == "Pending")
                                {
                                    <div class="d-flex justify-content-end align-items-center gap-2">
                                        <form asp-controller="Admin" asp-action="ApproveRegistration"
                                              asp-route-id="@firstItem.Id" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="semester" value="@selectedSemester" />
                                            <input type="hidden" name="year" value="@selectedYear" />
                                            <input type="hidden" name="status" value="@currentStatus" />
                                            <input type="hidden" name="search" value="@search" />
                                            <input type="hidden" name="faculty" value="@selectedFaculty" />
                                            <input type="hidden" name="majorId" value="@selectedMajorId" />
                                            <button type="submit" class="btn-approve" title="Duyệt cả nhóm">
                                                <i class="fa-solid fa-check"></i>
                                            </button>
                                        </form>
                                        <form asp-controller="Admin" asp-action="RejectRegistration"
                                              asp-route-id="@firstItem.Id" method="post" class="m-0 js-reject-registration-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="semester" value="@selectedSemester" />
                                            <input type="hidden" name="year" value="@selectedYear" />
                                            <input type="hidden" name="status" value="@currentStatus" />
                                            <input type="hidden" name="search" value="@search" />
                                            <input type="hidden" name="faculty" value="@selectedFaculty" />
                                            <input type="hidden" name="majorId" value="@selectedMajorId" />
                                            <button type="submit" class="btn-reject" title="Từ chối cả nhóm">
                                                <i class="fa-solid fa-xmark"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span class="status-badge @(currentStatus == "Approved" ? "s-approved" : "s-rejected")">
                                        @(currentStatus == "Approved" ? "Đã duyệt" : "Từ chối")
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="table-footer">
        Hiển thị @groupedRegistrations.Count nhóm / @filtered.Count sinh viên
        — Trạng thái: <strong>@currentStatus</strong>
    </div>

</div>

@section Scripts {
    <script src="~/js/admin/approval.js" asp-append-version="true"></script>
}
