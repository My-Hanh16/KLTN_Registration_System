@model IEnumerable<KLTN_Registration_System.Models.Entities.Registration>
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Duyệt đăng ký";

    // Fix: lấy status filter từ query string, default Pending
    string currentStatus = Context.Request.Query["status"].ToString();
    if (string.IsNullOrEmpty(currentStatus)) currentStatus = "Pending";

    // Filter model theo status
    var filtered = Model.Where(r =>
        string.Equals(r.Status, currentStatus, StringComparison.OrdinalIgnoreCase)
    ).ToList();
}

@section Styles {
    <style>
        /* ══════════════════════════════════════
               HEADER
            ══════════════════════════════════════ */
        .page-title {
            font-size: 20px;
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 4px;
        }

        .page-sub {
            font-size: 13.5px;
            color: #94a3b8;
            margin: 0;
        }

        /* ══════════════════════════════════════
               FILTER TABS
            ══════════════════════════════════════ */
        .filter-tabs {
            display: flex;
            gap: 4px;
            background: #f1f5f9;
            padding: 4px;
            border-radius: 12px;
        }

        .filter-tab {
            font-size: 13px;
            font-weight: 600;
            padding: 7px 18px;
            border-radius: 9px;
            border: none;
            background: transparent;
            color: #64748b;
            cursor: pointer;
            text-decoration: none;
            transition: all .15s;
            line-height: 1.5;
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .filter-tab:hover {
                background: #fff;
                color: #4f46e5;
            }

            .filter-tab.active {
                background: #4f46e5;
                color: #fff;
                box-shadow: 0 2px 8px rgba(79,70,229,.2);
            }

        .tab-count {
            font-size: 9.5px;
            font-weight: 700;
            padding: 1px 6px;
            border-radius: 99px;
            line-height: 1.6;
        }

        .filter-tab.active .tab-count {
            background: rgba(255,255,255,.25);
            color: #fff;
        }

        .filter-tab:not(.active) .tab-count {
            background: #e2e8f0;
            color: #64748b;
        }

        /* ══════════════════════════════════════
               STATS GRID
            ══════════════════════════════════════ */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
            margin-bottom: 20px;
        }

        @@media (max-width: 768px) {
            .stats-grid

        {
            grid-template-columns: 1fr;
        }

        }

        .stat-card {
            background: #fff;
            border: 1px solid #e8edf4;
            border-radius: 14px;
            padding: 18px 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        }

        .stat-icon {
            width: 40px;
            height: 40px;
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            margin-bottom: 12px;
        }

            .stat-icon.blue {
                background: #eff6ff;
                color: #2563eb;
            }

            .stat-icon.green {
                background: #f0fdf4;
                color: #16a34a;
            }

            .stat-icon.orange {
                background: #fff7ed;
                color: #ea580c;
            }

        .stat-label {
            font-size: 12px;
            color: #64748b;
            font-weight: 500;
            margin-bottom: 4px;
        }

        .stat-number {
            font-size: 26px;
            font-weight: 800;
            color: #1e293b;
            line-height: 1.1;
        }

        /* ══════════════════════════════════════
               TABLE CARD
            ══════════════════════════════════════ */
        .table-card {
            background: #fff;
            border: 1px solid #e8edf4;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        }

        .table-header {
            padding: 16px 22px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .table-title {
            font-size: 14px;
            font-weight: 700;
            color: #1e293b;
            margin: 0;
        }

        .table-meta {
            font-size: 12px;
            color: #94a3b8;
            font-weight: 500;
        }

        /* Table */
        .approval-table {
            width: 100%;
            border-collapse: collapse;
        }

            .approval-table thead tr {
                background: #f8fafc;
            }

            .approval-table th {
                padding: 11px 18px;
                font-size: 10.5px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.7px;
                color: #94a3b8;
                border-bottom: 1px solid #f1f5f9;
                white-space: nowrap;
            }

            .approval-table td {
                padding: 14px 18px;
                border-bottom: 1px solid #f8fafc;
                vertical-align: middle;
            }

            .approval-table tbody tr:last-child td {
                border-bottom: none;
            }

            .approval-table tbody tr {
                transition: background .15s;
            }

                .approval-table tbody tr:hover {
                    background: #fafbff;
                }

        /* Topic title */
        .topic-name {
            font-size: 13.5px;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 5px;
            line-height: 1.4;
        }

        .approval-table tbody tr:hover .topic-name {
            color: #4f46e5;
        }

        /* Student chip */
        .student-chip {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: #f8fafc;
            border: 1px solid #e8edf4;
            border-radius: 7px;
            padding: 3px 9px;
            font-size: 12px;
            font-weight: 500;
            color: #475569;
        }

            .student-chip i {
                font-size: 10px;
                color: #94a3b8;
            }

        /* Email / MSSV */
        .email-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            color: #475569;
            background: #f8fafc;
            border: 1px solid #e8edf4;
            border-radius: 7px;
            padding: 4px 10px;
            font-family: 'Courier New', monospace;
            font-weight: 500;
        }

        .mssv-badge {
            display: inline-flex;
            font-size: 11px;
            font-weight: 600;
            background: #eef2ff;
            color: #4f46e5;
            border: 1px solid #c7d2fe;
            border-radius: 6px;
            padding: 2px 8px;
            margin-top: 4px;
            font-family: 'Courier New', monospace;
        }

        /* Date */
        .date-text {
            font-size: 12.5px;
            color: #64748b;
            font-weight: 500;
        }

        /* Status badge for non-pending rows */
        .status-badge {
            display: inline-flex;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            padding: 4px 12px;
            border-radius: 99px;
        }

        .s-approved {
            background: #dcfce7;
            color: #15803d;
        }

        .s-rejected {
            background: #fee2e2;
            color: #dc2626;
        }

        .s-pending {
            background: #fef3c7;
            color: #b45309;
        }

        /* Action buttons */
        .btn-approve {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            border: none;
            background: #f0fdf4;
            color: #16a34a;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            cursor: pointer;
            transition: all .15s;
        }

            .btn-approve:hover {
                background: #16a34a;
                color: #fff;
                box-shadow: 0 3px 8px rgba(22,163,74,.25);
            }

        .btn-reject {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            border: none;
            background: #fff5f5;
            color: #dc2626;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            cursor: pointer;
            transition: all .15s;
        }

            .btn-reject:hover {
                background: #dc2626;
                color: #fff;
                box-shadow: 0 3px 8px rgba(220,38,38,.25);
            }

        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 48px 24px;
            color: #94a3b8;
        }

            .empty-state i {
                font-size: 32px;
                display: block;
                margin-bottom: 10px;
                opacity: 0.4;
            }

            .empty-state p {
                font-size: 13.5px;
                margin: 0;
            }

        /* Table footer */
        .table-footer {
            padding: 12px 22px;
            background: #f8fafc;
            border-top: 1px solid #f1f5f9;
            font-size: 12px;
            color: #94a3b8;
            font-weight: 500;
        }
    </style>
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
    <div>
        <h2 class="page-title">Duyệt đăng ký đề tài</h2>
        <p class="page-sub">Xử lý các yêu cầu đăng ký thực hiện luận văn từ sinh viên.</p>
    </div>

    <!-- Fix: filter tabs dùng href thay vì button thuần -->
    <div class="filter-tabs">
        <a href="?status=Pending"
           class="filter-tab @(currentStatus == "Pending" ? "active" : "")">
            Chờ duyệt
            <span class="tab-count">@Model.Count(r => r.Status == "Pending")</span>
        </a>
        <a href="?status=Approved"
           class="filter-tab @(currentStatus == "Approved" ? "active" : "")">
            Đã duyệt
            <span class="tab-count">@Model.Count(r => r.Status == "Approved")</span>
        </a>
        <a href="?status=Rejected"
           class="filter-tab @(currentStatus == "Rejected" ? "active" : "")">
            Từ chối
            <span class="tab-count">@Model.Count(r => r.Status == "Rejected")</span>
        </a>
    </div>
</div>

<!-- STATS -->
<div class="stats-grid">

    <div class="stat-card">
        <div class="stat-icon blue">
            <i class="fa-solid fa-clock-rotate-left"></i>
        </div>
        <div class="stat-label">Yêu cầu chờ duyệt</div>
        <div class="stat-number">@Model.Count(r => r.Status == "Pending")</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon green">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <div class="stat-label">Đã phê duyệt</div>
        <div class="stat-number">@(ViewBag.ApprovedCount ?? Model.Count(r => r.Status == "Approved"))</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon orange">
            <i class="fa-solid fa-users"></i>
        </div>
        <div class="stat-label">Tổng số đăng ký</div>
        <div class="stat-number">@(ViewBag.TotalRegistrations ?? Model.Count())</div>
    </div>

</div>

<!-- TABLE -->
<div class="table-card">

    <div class="table-header">
        <h3 class="table-title">
            Danh sách —
            @if (currentStatus == "Pending")
            {
                <span style="color:#b45309;font-weight:500;">chờ xử lý</span>
            }
            else if (currentStatus == "Approved")
            {

                <span style="color:#15803d;font-weight:500;">đã duyệt</span>
            }
            else
            {

                <span style="color:#dc2626;font-weight:500;">đã từ chối</span>
            }
        </h3>
        <span class="table-meta">@filtered.Count mục</span>
    </div>

    <div style="overflow-x:auto;">
        <table class="approval-table">
            <thead>
                <tr>
                    <th style="width:42%;">Đề tài & Sinh viên</th>
                    <th>Email / MSSV</th>
                    <th>Ngày đăng ký</th>
                    <th class="text-end" style="padding-right:20px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!filtered.Any())
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <i class="fa-regular fa-folder-open"></i>
                                <p>Không có yêu cầu nào ở trạng thái này.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in filtered)
                    {
                        <tr>
                            <!-- Đề tài & Sinh viên -->
                            <td>
                                <div class="topic-name">@item.Topic?.Title</div>
                                <!-- Fix: dùng FullName thay vì UserName -->
                                <div class="student-chip">
                                    <i class="fa-regular fa-user"></i>
                                    @(item.Student?.FullName ?? item.Student?.UserName ?? "N/A")
                                </div>
                            </td>

                            <!-- Email / MSSV -->
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    <span class="email-badge">@(item.Student?.Email ?? "—")</span>
                                    @if (!string.IsNullOrEmpty(item.Student?.UserCode))
                                    {
                                        <span class="mssv-badge">@item.Student.UserCode</span>
                                    }
                                </div>
                            </td>

                            <!-- Ngày -->
                            <td>
                                <span class="date-text">@item.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </td>

                            <!-- Thao tác -->
                            <td class="text-end" style="padding-right:16px;">
                                @if (currentStatus == "Pending")
                                {
                                    <div class="d-flex justify-content-end align-items-center gap-2">
                                        <!-- Fix: thêm AntiForgeryToken, sửa controller đúng Admin -->
                                        <form asp-controller="Admin" asp-action="Approve"
                                              asp-route-id="@item.Id" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-approve" title="Duyệt">
                                                <i class="fa-solid fa-check"></i>
                                            </button>
                                        </form>
                                        <form asp-controller="Admin" asp-action="Reject"
                                              asp-route-id="@item.Id" method="post" class="m-0"
                                              onsubmit="return confirm('Từ chối đăng ký này?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-reject" title="Từ chối">
                                                <i class="fa-solid fa-xmark"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span class="status-badge @(currentStatus == "Approved" ? "s-approved" : "s-rejected")">
                                        @(currentStatus == "Approved" ? "Đã duyệt" : "Từ chối")
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="table-footer">
        Hiển thị @filtered.Count / @Model.Count() yêu cầu
        — Trạng thái: <strong>@currentStatus</strong>
    </div>

</div>
