@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Nhập đề tài từ Excel";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/import-topics.css" asp-append-version="true" />
}

<section class="import-topics">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" style="margin-bottom:16px;">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" style="margin-bottom:16px;">
            @TempData["Error"]
        </div>
    }

    <header class="import-topics__header">
        <h2>Tải lên danh sách đề tài</h2>
        <p>
            File cần có tối thiểu cột <strong>Title</strong> và thông tin chuyên ngành/khoa như
            <strong>MajorCode</strong>, <strong>MajorName</strong> hoặc <strong>Faculty</strong>.
            Nên dùng đúng mẫu để đề tài được gán khoa và lên thống kê chính xác.
        </p>
        <p>
            KhÃ´ng cáº§n nháº­p ngÃ y má»Ÿ Ä‘Äƒng kÃ½ trong file. Há»‡ thá»‘ng sáº½ láº¥y thá»i gian má»Ÿ/Ä‘Ã³ng tá»« pháº§n
            <strong>CÃ i Ä‘áº·t</strong> cá»§a Admin; Ä‘á» tÃ i import xong sáº½ sáºµn sÃ ng nhÆ°ng chÆ°a má»Ÿ Ä‘Äƒng kÃ½.
        </p>
    </header>

    <a href="~/templates/mau-import-de-tai-admin.xlsx" class="template-download">
        Tải file Excel mẫu
    </a>

    <form asp-controller="Admin"
          asp-action="ImportTopics"
          method="post"
          enctype="multipart/form-data"
          id="importExcelForm"
          class="import-form">

        @Html.AntiForgeryToken()

        <input type="file"
               name="file"
               id="excelInput"
               accept=".xlsx,.xls"
               hidden />

        <p id="fileName" class="selected-file"></p>

        <div class="form-actions">
            <button type="button" id="chooseExcelBtn" class="choose-file-button">
                Chọn file Excel
            </button>

            <button type="submit" id="submitBtn" class="upload-button" hidden>
                Upload
            </button>
        </div>

        <p id="loadingText" class="loading-text" hidden>
            Đang xử lý file...
        </p>
    </form>
</section>

@section Scripts {
    <script src="~/js/admin/import-topics.js" asp-append-version="true"></script>
}
