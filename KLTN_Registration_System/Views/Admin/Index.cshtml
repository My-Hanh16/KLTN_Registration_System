@model KLTN_Registration_System.Models.ViewModels.AdminDashboard
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Bảng điều khiển Quản trị";
    var registrationLineLabels = ViewBag.RegistrationLineLabels as IEnumerable<string> ?? Enumerable.Empty<string>();
    var registrationLineCounts = ViewBag.RegistrationLineCounts as IEnumerable<int> ?? Enumerable.Empty<int>();
    var activePeriod = ViewBag.ActivePeriod as KLTN_Registration_System.Models.Entities.RegistrationPeriod;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/index.css" asp-append-version="true" />
}

<div class="admin-dashboard">
    @* --- 1. Banner chào mừng --- *@
    <section class="welcome-banner">
        <div class="welcome-content">
            <h2 class="welcome-title">Xin chào buổi sáng, Quản trị viên!</h2>
            <p class="welcome-subtitle">
                Hệ thống ghi nhận <span>@Model.PendingApprovals đề tài mới</span> đang chờ bạn phê duyệt.
            </p>
            <div class="period-pill">
                <span class="material-symbols-outlined">event</span>
                Đợt hiện tại: @(activePeriod?.Name ?? "Chưa cấu hình")
            </div>
            <div class="welcome-actions">
                <button class="btn-banner btn-banner--primary">Duyệt nhanh đề tài</button>
                <button class="btn-banner btn-banner--ghost">Xem báo cáo tháng</button>
            </div>
        </div>
        <div class="welcome-shape"></div>
    </section>

    @* --- 2. Thẻ KPI (4 cột) --- *@
    <div class="kpi-grid">
        @* Thẻ 1: Tổng số đề tài *@
        <div class="kpi-card">
            <div class="kpi-head">
                <div class="kpi-icon kpi-icon--blue"><span class="material-symbols-outlined fill-1">book</span></div>
                <span class="kpi-badge kpi-badge--green">▲ 12%</span>
            </div>
            <p class="kpi-label">Tổng số đề tài</p>
            <h3 class="kpi-value">@Model.TotalTopics.ToString("N0")</h3>
        </div>

        @* Thẻ 2: Tỉ lệ đăng ký *@
        <div class="kpi-card">
            <div class="kpi-head">
                <div class="kpi-icon kpi-icon--purple"><span class="material-symbols-outlined fill-1">groups</span></div>
                <span class="kpi-badge kpi-badge--blue">@Model.RegistrationRate%</span>
            </div>
            <p class="kpi-label">Tỉ lệ đăng ký</p>
            <h3 class="kpi-value">@Model.RegistrationRate%</h3>
        </div>

        @* Thẻ 3: Chờ phê duyệt *@
        <div class="kpi-card kpi-card--alert">
            <div class="kpi-head">
                <div class="kpi-icon kpi-icon--red"><span class="material-symbols-outlined fill-1">pending_actions</span></div>
                <span class="pulse-dot"></span>
            </div>
            <p class="kpi-label">Chờ phê duyệt</p>
            <h3 class="kpi-value kpi-value--red">@Model.PendingApprovals</h3>
        </div>

        @* Thẻ 4: Giảng viên *@
        <div class="kpi-card">
            <div class="kpi-head">
                <div class="kpi-icon kpi-icon--orange"><span class="material-symbols-outlined fill-1">school</span></div>
            </div>
            <p class="kpi-label">Giảng viên tham gia</p>
            <h3 class="kpi-value">@Model.TotalLecturers</h3>
        </div>
    </div>

    @* --- 3. Bố cục chính (Grid 12 cột) --- *@
    <div class="dashboard-grid">

        @* CỘT TRÁI (8 cột): Chuyên chứa các biểu đồ thống kê *@
        <div class="dashboard-main">
            

            @* 3b. Biểu đồ đường: Tiến độ đăng ký *@
            <div class="dashboard-panel">
                <div class="panel-head">
                    <div>
                        <h3 class="panel-title">Tiến độ đăng ký</h3>
                        <p class="panel-subtitle">7 ngày gần nhất</p>
                    </div>
                    <div class="realtime-pill">
                        <span>Thời gian thực</span>
                    </div>
                </div>
                <div class="chart-box">
                    <canvas id="registrationLineChart"></canvas>
                </div>
            </div>
            @* 3c. Đề tài mới gửi *@
            <section class="dashboard-panel dashboard-panel--flush">

                <!-- HEADER -->
                <div class="table-panel-head">
                    <div>
                        <h4 class="table-panel-title">
                            Đề tài mới gửi cần xem xét
                        </h4>

                        <p class="table-panel-subtitle">
                            Danh sách đề tài đang chờ quản trị viên duyệt
                        </p>
                    </div>

                    <button class="link-button">
                        Xem tất cả
                    </button>
                </div>

                <!-- TABLE -->
                <div>
                    <table class="topic-table">

                        <!-- THEAD -->
                        <thead>
                            <tr>

                                <!-- TÊN -->
                                <th class="topic-col-name">
                                    Tên đề tài
                                </th>

                                <!-- TRẠNG THÁI -->
                                <th class="topic-col-status">
                                    Trạng thái
                                </th>

                                <!-- THAO TÁC -->
                                <th class="topic-col-action">
                                    Thao tác
                                </th>

                            </tr>
                        </thead>

                        <!-- BODY -->
                        <tbody>

                            @foreach (var topic in Model.NewTopics.Take(3))
                            {
                                <tr>

                                    <!-- TÊN ĐỀ TÀI -->
                                    <td>

                                        <div class="topic-info">

                                            <p class="topic-name">
                                                @topic.Name
                                            </p>

                                            <p class="topic-code">
                                                Mã số: #@topic.Id
                                            </p>

                                        </div>

                                    </td>

                                    <!-- TRẠNG THÁI -->
                                    <td>

                                        <div class="status-wrap">

                                            <span class="status-chip status-chip--pending">

                                                <span class="status-dot"></span>

                                                Đang chờ duyệt

                                            </span>

                                        </div>

                                    </td>

                                    <!-- THAO TÁC -->
                                    <td>

                                        <div class="topic-actions">

                                            <!-- APPROVE -->
                                            <button class="topic-action topic-action--approve">

                                                <span class="material-symbols-outlined">
                                                    check
                                                </span>

                                            </button>

                                            <!-- REJECT -->
                                            <button class="topic-action topic-action--reject">

                                                <span class="material-symbols-outlined">
                                                    close
                                                </span>

                                            </button>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                </div>

            </section>
        </div>

        @* CỘT PHẢI (4 cột): Thao tác nhanh & Hoạt động gần đây *@
        <aside class="dashboard-side">
            @* 3c. Thao tác nhanh (Khối tối màu như Ảnh 1) *@
            <div class="quick-panel">
                <h4 class="quick-title">Thao tác nhanh</h4>
                <div class="quick-list">
                    <button class="quick-action">
                        <div class="quick-action-left">
                            <span class="material-symbols-outlined quick-icon quick-icon--blue">file_export</span>
                            <span>Xuất báo cáo PDF</span>
                        </div>
                        <span class="material-symbols-outlined quick-arrow">chevron_right</span>
                    </button>
                    <button class="quick-action">
                        <div class="quick-action-left">
                            <span class="material-symbols-outlined quick-icon quick-icon--green">table_view</span>
                            <span>Xuất dữ liệu Excel</span>
                        </div>
                        <span class="material-symbols-outlined quick-arrow">chevron_right</span>
                    </button>
                </div>
                <button class="quick-primary">
                    Duyệt tất cả (@Model.PendingApprovals)
                </button>
            </div>

            @* 3d. Hoạt động gần đây (Đúng vị trí như Ảnh 1) *@
            <div class="dashboard-panel">
                <div class="activity-head">
                    <h4 class="activity-title">Hoạt động gần đây</h4>
                    <button class="link-button link-button--sm">Tất cả</button>
                </div>
                <div class="activity-list">
                    @foreach (var activity in Model.RecentActivities.Take(3))
                    {
                        <div class="activity-item">
                            <div class="activity-icon @activity.ColorClass">
                                <span class="material-symbols-outlined">@activity.Icon</span>
                            </div>
                            <div>
                                <p class="activity-message">@activity.Message</p>
                                <span class="activity-time">@activity.TimeAgo</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </aside>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script id="registrationLineChartData" type="application/json">
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
{
    labels = registrationLineLabels,
    counts = registrationLineCounts
}))
    </script>
    <script src="~/js/admin/index.js" asp-append-version="true"></script>
}
